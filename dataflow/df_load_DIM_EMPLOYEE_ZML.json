{
	"name": "df_load_DIM_EMPLOYEE_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_emp_Employees",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_EMPLOYEE_ZML",
						"type": "DatasetReference"
					},
					"name": "targetDim",
					"description": "Export data to EDW_DIM_EMPLOYEE",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "selectColsFHI"
				},
				{
					"name": "createIDsFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "addLastUpdateTimestamp"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          FirstName as string,",
				"          LastName as string,",
				"          DOB as timestamp,",
				"          HireDate as timestamp,",
				"          Active as boolean,",
				"          UserName as string,",
				"          Password as string,",
				"          Address as string,",
				"          City as string,",
				"          State as string,",
				"          Zip as string,",
				"          HomePhone as string,",
				"          CellPhone as string,",
				"          Email as string,",
				"          Owner as boolean,",
				"          Setter as boolean,",
				"          Verifier as boolean,",
				"          Confirmer as boolean,",
				"          Promoter as boolean,",
				"          SalesRep as boolean,",
				"          Dialer as boolean,",
				"          ExclRequests as boolean,",
				"          brn_id as string,",
				"          sds_id as string,",
				"          ejt_id as integer,",
				"          secprofile as boolean,",
				"          profile_emp_id as integer,",
				"          forecolor as string,",
				"          backcolor as string,",
				"          TOSDate as timestamp,",
				"          CoCode as string,",
				"          FileNo as string,",
				"          emp_user_1 as string,",
				"          emp_user_2 as string,",
				"          emp_user_3 as string,",
				"          emp_user_4 as string,",
				"          emp_user_5 as string,",
				"          emp_user_6 as timestamp,",
				"          emp_user_7 as timestamp,",
				"          emp_user_8 as timestamp,",
				"          emp_user_9 as timestamp,",
				"          emp_user_10 as timestamp,",
				"          emp_user_11 as decimal(19,4),",
				"          emp_user_12 as decimal(19,4),",
				"          emp_user_13 as decimal(19,4),",
				"          emp_user_14 as decimal(19,4),",
				"          emp_user_15 as decimal(19,4),",
				"          hsc_id as integer,",
				"          ePwd as binary,",
				"          GoogleCalendarAccount as string,",
				"          GoogleCalendarPassword as string,",
				"          ProductList as string,",
				"          LastPwdChange as timestamp,",
				"          cvm_id as integer,",
				"          device_type as string,",
				"          push_id as string,",
				"          avatar as string,",
				"          SalesManagerName as string,",
				"          EmployeeJobType as string,",
				"          LP_CCManager as integer,",
				"          LP_CCDepartment as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select A.*,\\'NULL\\' as SalesManagerName,jt.descr as EmployeeJobType,CAST(NULL AS INT) as LP_CCManager,CAST(NULL AS INT) as LP_CCDepartment from ODS.LP_FHI_emp_employees A left join [ODS].[LP_FHI_ejt_EmpJobType] jt on A.ejt_id =jt.id',",
				"     format: 'query',",
				"     staged: true) ~> FHI",
				"FHI select(mapColumn(",
				"          LP_EmployeeID = id,",
				"          FirstName,",
				"          LastName,",
				"          DOB,",
				"          HireDate,",
				"          Active,",
				"          City,",
				"          State,",
				"          Zip,",
				"          Email,",
				"          Owner,",
				"          Setter,",
				"          Verifier,",
				"          Confirmer,",
				"          Promoter,",
				"          SalesRep,",
				"          Dialer,",
				"          Address,",
				"          HomePhone,",
				"          CellPhone,",
				"          LP_BranchID = brn_id,",
				"          LP_SalesDistrictID = sds_id,",
				"          SalesManagerName,",
				"          EmployeeJobType,",
				"          emp_user_14,",
				"          LP_Ejtid = ejt_id,",
				"          LP_CCManager,",
				"          LP_CCDepartment",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(EmployeeID = concat('FHI-',toString(LP_EmployeeID)),",
				"          BranchID = concat('FHI-',toString(LP_BranchID)),",
				"          SalesDistrictID = concat('FHI-',toString(LP_SalesDistrictID)),",
				"          Division = 'FHI',",
				"          SalesMgrID = concat('FHI-', toString(toInteger(emp_user_14))),",
				"          EjtID = concat('FHI-',toString(LP_Ejtid)),",
				"          CCManager = concat('FHI-',toString(LP_CCManager)),",
				"          CCDepartment = concat('FHI-',toString(LP_CCDepartment))) ~> createIDsFHI",
				"createIDsFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(LastUpdateTS = currentTimestamp(),",
				"          emp_user_14 = toInteger(emp_user_14)) ~> addLastUpdateTimestamp",
				"addLastUpdateTimestamp alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          EmployeeID as string,",
				"          BranchID as string,",
				"          SalesDistrictID as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          DOB as timestamp,",
				"          HireDate as timestamp,",
				"          Active as boolean,",
				"          City as string,",
				"          State as string,",
				"          Zip as string,",
				"          Email as string,",
				"          Owner as boolean,",
				"          Setter as boolean,",
				"          Verifier as boolean,",
				"          Confirmer as boolean,",
				"          Promoter as boolean,",
				"          SalesRep as boolean,",
				"          Dialer as boolean,",
				"          LP_EmployeeID as integer,",
				"          LP_BranchID as string,",
				"          LP_SalesDistrictID as string,",
				"          Division as string,",
				"          LastUpdateTS as timestamp,",
				"          SalesManagerName as string,",
				"          EmployeeJobType as string,",
				"          Address as string,",
				"          HomePhone as string,",
				"          CellPhone as string,",
				"          LP_SalesMgrID as integer,",
				"          SalesMgrID as string,",
				"          CCDepartment as string,",
				"          LP_CCDepartment as integer,",
				"          CCManager as string,",
				"          LP_CCManager as integer,",
				"          EjtID as string,",
				"          LP_EjtID as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['EmployeeID'],",
				"     format: 'table',",
				"     staged: true,",
				"     postSQLs:['-------------------To update Sales ManagerName----------------------------------------------------------------------------------------------------\\nUPDATE T1 SET SALESMANAGERNAME= COALESCE(T2.SALESMANAGERNAME,NULL)\\nFROM \\nEDW.DIM_EMPLOYEE T1 Left join\\n\\n(SELECT E.EmployeeId, E.BranchId, CONCAT(E.FirstName, \\' \\', E.LastName) as EmployeeName ,E.SalesMgrId,\\n     CONCAT(Mgr.FirstName, \\' \\', Mgr.LastName) as SalesManagerName, Mgr.EmployeeId as Mgr_EmployeeId\\nFROM EDW.DIM_EMPLOYEE E Left join EDW.DIM_EMPLOYEE Mgr \\n     On E.SalesMgrID = Mgr.EmployeeID\\n     Where E.SalesMgrId is not null \\n) T2 \\non T1.EmployeeId=T2.EmployeeId ;'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          EmployeeID,",
				"          BranchID,",
				"          SalesDistrictID,",
				"          FirstName,",
				"          LastName,",
				"          DOB,",
				"          HireDate,",
				"          Active,",
				"          City,",
				"          State,",
				"          Zip,",
				"          Email,",
				"          Owner,",
				"          Setter,",
				"          Verifier,",
				"          Confirmer,",
				"          Promoter,",
				"          SalesRep,",
				"          Dialer,",
				"          LP_EmployeeID,",
				"          LP_BranchID,",
				"          LP_SalesDistrictID,",
				"          Division,",
				"          LastUpdateTS,",
				"          SalesManagerName,",
				"          EmployeeJobType,",
				"          Address,",
				"          HomePhone,",
				"          CellPhone,",
				"          LP_SalesMgrID = emp_user_14,",
				"          SalesMgrID,",
				"          CCDepartment,",
				"          LP_CCDepartment,",
				"          CCManager,",
				"          LP_CCManager,",
				"          EjtID,",
				"          LP_EjtID = LP_Ejtid",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
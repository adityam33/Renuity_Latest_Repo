				"          Division,",
				"          LP_MilestoneDetailID,",
				"          LP_MilestoneDateTypeID,",
				"          LP_JobID,",
				"          EstimatedDate,",
				"          ActualDate,",
				"          ActualTime,",
				"          EnteredOn,",
				"          LastChangedOn,",
				"          LastUpdateTS,",
				"          MilestoneDetailID,",
				"          MilestoneDateTypeID,",
				"          JobID",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetFact"

				"     query: 'SELECT A.DIVISION \\n     ,A.SESSION_ID \\n     ,A.CALL_ID \\n     ,A.CONTACT_ID \\n     ,COALESCE(B.CallResultId,B1.CallResultId)           AS CallResultId\\n     ,COALESCE(C.MarketID      ,C1.MarketID )               AS MarketID  \\n     ,COALESCE(D.ProductID   ,D1.ProductID)                    AS ProductID \\n     ,(E.LeadSubSourceID )      AS LeadSubSourceID \\n     \\n     ,A.TIMESTAMP \\n     ,A.DATE \\n     ,A.HOUR \\n     ,A.TIME \\n     ,A.CALL_TYPE \\n     ,A.CAMPAIGN_TYPE \\n     ,A.CAMPAIGN \\n     ,A.SKILL \\n     ,A.LIST_NAME \\n     ,A.AGENT_GROUP \\n     ,A.AGENT_NAME \\n     ,A.AGENT \\n     ,A.CUSTOMER_NAME \\n     ,A.ANI_CODE \\n     ,A.ANI \\n     ,A.DNIS \\n     --DISPOSITION \\n     ,A.CALLS \\n     ,A.ABANDONED \\n     ,A.CONTACTED \\n     ,A.LIVE_CONNECT \\n     ,A.NO_PARTY_CONTACT \\n     ,A.SPEED_OF_ANSWER \\n     ,A.SERVICE_LEVEL \\n     ,A.CALLS_COMPLETED_IN_IVR \\n     ,A.COMPANY \\n     ,A.CUSTID \\n     ,A.LEAD_ID \\n     ,A.CONTACT_CREATE_DATE_TIME \\n     ,A.NUMBER1 \\n     ,A.NUMBER2 \\n     ,A.NUMBER3 \\n     ,A.ANR_LOGIT_RANK \\n     --MARKET \\n     --PRODUCT \\n     --SOURCEGROUP \\n     --SOURCE \\n     --SUBSOURCE \\n     ,A.LANGUAGE \\n     ,A.LPRECTYPE \\n     ,A.LPRECKEY \\n     ,A.DATEUPLOADED \\n     ,A.NUMBER_OF_ATTEMPTS \\n     ,A.LOCAL_ANI \\n     ,A.AB_TEST \\n     ,A.CALL_TIME \\n     ,A.DIAL_TIME \\n     ,A.RING_TIME \\n     ,A.TIME_TO_ABANDON \\n     ,A.MANUAL_TIME \\n     ,A.HANDLE_TIME \\n     ,A.CONSULT_TIME \\n     ,A.QUEUE_CALLBACK_WAIT_TIME \\n     ,A.PREVIEW_TIME \\n     ,A.AFTER_CALL_WORK_TIME \\n     ,A.TOTAL_QUEUE_TIME \\n     ,A.QUEUE_WAIT_TIME \\n     ,A.HOLD_TIME \\n     ,A.TALK_TIME \\n     ,A.PARK_TIME \\n     ,A.IVR_TIME \\n     ,A.RECORDINGS \\n     ,A.LAST_UPDATED_TS \\n     ,A.Data_Identifier \\n     ,A.DIVISION_ORIG \\n     ,A.LP_LeadID\\nFROM EDW.FACT_FIVE9_CALL_LOG_ALL A\\nLEFT JOIN [EDW].[DIM_FIVE9_CALL_RESULT_DISPOSITION] B \\n     ON COALESCE(A.DISPOSITION,\\'NULL-DEFAULT\\') = B.CallResult \\n     AND A.DIVISION = B.DIVISION\\n     \\nLEFT JOIN [EDW].[DIM_FIVE9_CALL_RESULT_DISPOSITION] B1\\n     ON COALESCE(A.LP_DISPOSITION,\\'NULL-DEFAULT\\') = B1.CallResult \\n     AND A.DIVISION = B1.DIVISION\\n     \\nLEFT JOIN EDW.DIM_FIVE9_MARKET C \\n     ON COALESCE(A.Market,\\'NULL-DEFAULT\\') = C.Market \\n     AND  A.DIVISION = C.DIVISION\\n     \\nLEFT JOIN EDW.DIM_FIVE9_MARKET C1\\n     ON COALESCE(A.LP_BranchID,\\'NULL-DEFAULT\\') = C1.Market \\n     AND  A.DIVISION = C1.DIVISION\\n     \\n     \\nLEFT JOIN EDW.DIM_FIVE9_PRODUCT D \\n     ON COALESCE(A.Product,\\'NULL-DEFAULT\\') = D.ProductName \\n     AND  A.DIVISION = D.DIVISION\\n     \\nLEFT JOIN EDW.DIM_FIVE9_PRODUCT D1 \\n     ON COALESCE(A.LP_Product,\\'NULL-DEFAULT\\') = D1.ProductName \\n     AND  A.DIVISION = D1.DIVISION\\n     \\n     \\nLEFT JOIN EDW.DIM_FIVE9_SUB_SOURCE_MAPPING E \\n     ON       COALESCE(A.SOURCE,A.LP_SourceCode,\\'NULL-DEFAULT\\')                = COALESCE(E.SOURCE,\\'NULL-DEFAULT\\')\\n     AND  COALESCE(A.SOURCEGROUP,A.LP_SourceGroup,\\'NULL-DEFAULT\\')      = COALESCE(E.SOURCEGROUP,\\'NULL-DEFAULT\\')\\n     AND  COALESCE(A.SUBSOURCE,A.LP_LeadSubSource,\\'NULL-DEFAULT\\')      = COALESCE(E.SUBSOURCE,\\'NULL-DEFAULT\\')\\n     AND A.DIVISION =E.DIVISION\\nWHERE CAST(A.DATE AS DATE) >= \\'2025-01-01\\' AND CAST(A.DATE AS DATE) <= \\'2025-03-31\\'',",

{
	"name": "df_DIM_HR_Employee_Manager_Updates",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_EMPLOYEE",
						"type": "DatasetReference"
					},
					"name": "HRemployee"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_HR_EmployeeManager",
						"type": "DatasetReference"
					},
					"name": "HRemployeeManager"
				}
			],
			"transformations": [
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Employee_PK as integer,",
				"          Location_PK as integer,",
				"          SubLocation_PK as integer,",
				"          EmployeeID as string,",
				"          ManagerID as string,",
				"          Division as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          JobTitleDescription as string,",
				"          FLSADescription as string,",
				"          WorkEmail as string,",
				"          PayClass as string,",
				"          PayClassTimeclock_RestrictionGroup as string,",
				"          BenifitsEligibility_ClassDescription as string,",
				"          HomeDepartmentDescription as string,",
				"          HireDate as date,",
				"          TerminationDate as date,",
				"          TerminationReasonDescription as string,",
				"          PositionStatus as string,",
				"          PayrollCompanyName as string,",
				"          SubDepartment as string,",
				"          Gender as string,",
				"          PayrollCompanyCode as string,",
				"          IsManagementPosition as string,",
				"          BusinessUnitDescription as string,",
				"          PositionEffectiveDate as date,",
				"          NewHireIndicatior as string,",
				"          YearsOfService as string,",
				"          Level as string,",
				"          FileNumber as string,",
				"          StateTaxDescription as string,",
				"          StateTaxCode as string,",
				"          SUI_SDI_TaxCode as string,",
				"          JobClassCode as string,",
				"          JobClassDescription as string,",
				"          EEOC_JobClassification as string,",
				"          EmployeeID_LP_REF as string,",
				"          CurrentRecordFlag as string,",
				"          RecordCreatedDate as date,",
				"          RecordUpdatedDate as date,",
				"          Data_Identifier as string,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select  E.* ,\\n--case when E.PositionEffectivedate >= Dateadd(D,-90,Getdate()) then \\'Yes\\' else \\'No\\' end as [Is New Manager],\\n-- \\'No\\' as [Is New Manager],\\nGetdate() as LastUpdatedTS\\nfrom EDW.DIM_HR_Employee E \\nLeft join EDW.DIM_HR_Employee_manager M on E.EmployeeId=M.EmployeeId \\nwhere E.CurrentRecordFlag=\\'Y\\' and E.IsManagementPosition=\\'Yes\\' and M.EmployeeId is not null ',",
				"     format: 'query',",
				"     staged: true) ~> HRemployee",
				"HRemployee alterRow(updateIf(true())) ~> alterRow1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['EmployeeID'],",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Employee_PK,",
				"          Location_PK,",
				"          SubLocation_PK,",
				"          EmployeeID,",
				"          ManagerID,",
				"          Division,",
				"          FirstName,",
				"          LastName,",
				"          JobTitleDescription,",
				"          FLSADescription,",
				"          WorkEmail,",
				"          PayClass,",
				"          PayClassTimeclock_RestrictionGroup,",
				"          BenifitsEligibility_ClassDescription,",
				"          HomeDepartmentDescription,",
				"          HireDate,",
				"          TerminationDate,",
				"          TerminationReasonDescription,",
				"          PositionStatus,",
				"          PayrollCompanyName,",
				"          SubDepartment,",
				"          Gender,",
				"          PayrollCompanyCode,",
				"          IsManagementPosition,",
				"          BusinessUnitDescription,",
				"          PositionEffectiveDate,",
				"          NewHireIndicatior,",
				"          YearsOfService,",
				"          Level,",
				"          FileNumber,",
				"          StateTaxDescription,",
				"          StateTaxCode,",
				"          SUI_SDI_TaxCode,",
				"          JobClassCode,",
				"          JobClassDescription,",
				"          EEOC_JobClassification,",
				"          EmployeeID_LP_REF,",
				"          CurrentRecordFlag,",
				"          RecordCreatedDate,",
				"          RecordUpdatedDate,",
				"          Data_Identifier,",
				"          LastUpdatedTS",
				"     )) ~> HRemployeeManager"
			]
		}
	}
}
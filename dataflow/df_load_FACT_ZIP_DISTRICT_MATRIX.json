{
	"name": "df_load_FACT_ZIP_DISTRICT_MATRIX",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {

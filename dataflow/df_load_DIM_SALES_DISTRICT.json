				"     staged: true) ~> CTA",
				"FHI select(mapColumn(",
				"          LP_SalesDistrictID = id,",
				"          ShortName,",
				"          MediumName,",
				"          LongName",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(SalesDistrictID = concat('FHI-',toString(LP_SalesDistrictID)),",
				"          Division = 'FHI') ~> createIDsFHI",
				"HSI select(mapColumn(",
				"          LP_SalesDistrictID = id,",
				"          ShortName,",
				"          MediumName,",
				"          LongName",

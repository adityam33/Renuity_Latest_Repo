				"          ShortName,",
				"          MediumName,",
				"          LongName",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectCTA",
				"selectCTA derive(SalesDistrictID = concat('CTA-',toString(LP_SalesDistrictID)),",
				"          Division = 'CTA') ~> createIDsCTA",
				"addLastUpdateTimestamp sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          SalesDistrictID as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          LP_SalesDistrictID as string,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_SalesDistrictID,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          SalesDistrictID,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",

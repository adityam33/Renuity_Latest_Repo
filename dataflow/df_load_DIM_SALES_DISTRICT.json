				"selectColsMAC derive(SalesDistrictID = concat('MAC-',toString(LP_SalesDistrictID)),",
				"          Division = 'MAC') ~> createIDsMAC",
				"selectPBC derive(SalesDistrictID = concat('PBC-',toString(LP_SalesDistrictID)),",
				"          Division = 'PBC') ~> createIDsPBC",
				"selectSWR derive(SalesDistrictID = concat('SWR-',toString(LP_SalesDistrictID)),",
				"          Division = 'SWR') ~> createIDsSWR",
				"createIDsFHI, createIDsHSI, createIDsMAC, createIDsPBC, createIDsSWR, createIDsRTW, createIDsMXH, createIDsCTA union(byName: true)~> unionAllOpCos",

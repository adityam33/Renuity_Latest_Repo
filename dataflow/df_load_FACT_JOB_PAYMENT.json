				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'select \\nid     ,\\njob_id     ,\\nPmtAmount     ,\\nPmtDate     ,\\npmt_id     ,\\npmm_id     ,\\nARBatchNo     ,\\nARBatchDate     ,\\nCAST(ARBatchFlag AS INT) AS ARBatchFlag     ,\\nIncBatchNo     ,\\nIncBatchDate     ,\\nCAST(IncBatchFlag AS INT) AS IncBatchFlag,\\nEnteredOn     ,\\nEnteredBy     ,\\nLastChangedOn     ,\\nLastChangedBy     ,\\nPmtNotes     \\n from [ODS].[LP_MXH_jbp_JobPayments]',",

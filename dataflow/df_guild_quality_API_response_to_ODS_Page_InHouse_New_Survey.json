{
	"name": "df_guild_quality_API_response_to_ODS_Page_InHouse_New_Survey",
	"properties": {
		"folder": {
			"name": "Test-Dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "TGT_GQ_Survey_Json_Pagination_New_Survey",
						"type": "DatasetReference"
					},
					"name": "sourceJSON"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "OUT_GUILD_QUALITY_CUSTOMER_SURVEY_PAGINATION_New_Survey",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "FlattenQuestion"
				},
				{
					"name": "pivotRowsIntoCols"
				},
				{
					"name": "flattenUsers"
				},
				{
					"name": "UsersFullName"
				},
				{
					"name": "joinwithCustomFilters"
				},
				{
					"name": "JoinwithUsers"
				},
				{
					"name": "joinwithQuestions"
				},
				{
					"name": "flattenCustomFilters"
				},
				{
					"name": "MapDriftedUsers",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "selectcols"
				},
				{
					"name": "selectcols2"
				},
				{
					"name": "filterInstallation"
				},
				{
					"name": "ProductLine"
				},
				{
					"name": "Questions",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "QuestionsTestimonial"
				},
				{
					"name": "customfilters"
				},
				{
					"name": "flattenDataArray"
				}
			],
			"scriptLines": [
				"source(output(",
				"          data as (id as integer, contact as (id as integer, name as string, email1 as string, email2 as string, phone1 as string, phone2 as string, createdAt as string, updatedAt as string), company as (id as integer, customCompanyId as string, name as string), project as (id as integer, address as string, city as string, state as string, zip as string, leadDate as string, startDate as string, endDate as string, createdAt as string, updatedAt as string, externalId as string, value as string, notes as string, customFilters as (Language as string[], Sold as string[], {Sales Organization} as string[], {Product Line} as string[], LeadID as string[], AccountID as string[]), users as (id as integer, firstName as string, lastName as string, roles as string[])[]), template as string, endedAt as string, createdAt as string, updatedAt as string, sendAt as string, completionMode as string, lastResponseMethod as string, lastActivityAt as string, status as string, surveyTakeUrl as string, questions as (id as integer, questionId as integer, order as integer, name as string, type as string, rating as string, ratingScale as string, comment as string, published as boolean)[])[]",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'documentPerLine') ~> sourceJSON",
				"filterInstallation foldDown(unroll(data.questions),",
				"     mapColumn(",
				"          comment = data.questions.comment,",
				"          SurveyID = data.id,",
				"          name = data.questions.name,",
				"          order = data.questions.order,",
				"          published = data.questions.published,",
				"          questionId = data.questions.questionId,",
				"          rating = data.questions.rating,",
				"          ratingScale = data.questions.ratingScale,",
				"          type = data.questions.type,",
				"          response = data.questions.response",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> FlattenQuestion",
				"FlattenQuestion pivot(groupBy(SurveyID),",
				"     pivotBy(name),",
				"     String_ = iif(max(type)=='comment',max(comment),''),",
				"          Int_ = max(rating),",
				"          Mcs_ = toString(max(response)),",
				"     columnNaming: '$N$V',",
				"     lateral: false) ~> pivotRowsIntoCols",
				"filterInstallation foldDown(unroll(data.project.users),",
				"     mapColumn(",
				"          SurveyId = data.id,",
				"          firstName = data.project.users.firstName,",
				"          lastName = data.project.users.lastName,",
				"          roles = data.project.users.roles",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenUsers",
				"MapDriftedUsers derive(UserFullName = firstName +\" \"+lastName,",
				"          roles = rtrim(ltrim(rtrim(ltrim(toString(roles),'['),']'),'\"'),'\"')) ~> UsersFullName",
				"filterInstallation, customfilters join(data.id == Surveyid,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinwithCustomFilters",
				"selectcols, UsersFullName join(selectcols@SurveyID == flattenUsers@SurveyId,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinwithUsers",
				"JoinwithUsers, QuestionsTestimonial join(selectcols@SurveyID == pivotRowsIntoCols@SurveyID,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinwithQuestions",
				"filterInstallation foldDown(unroll(data.project.customFilters.AccountID),",
				"     mapColumn(",
				"          AccountID = data.project.customFilters.AccountID,",
				"          Surveyid = data.id,",
				"          ProductLine = data.project.customFilters.{Product Line},",
				"          LeadID = data.project.customFilters.LeadID,",
				"          Sold = data.project.customFilters.Sold,",
				"          {Sales Organization} = data.project.customFilters.{Sales Organization}",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenCustomFilters",
				"flattenUsers derive(firstName = toString(byName('firstName')),",
				"          lastName = toString(byName('lastName')),",
				"          roles = array(byName('roles'))) ~> MapDriftedUsers",
				"ProductLine select(mapColumn(",
				"          SurveyID = data.id,",
				"          AccountID,",
				"          ProductLine,",
				"          customCompanyId = data.company.customCompanyId,",
				"          Companyname = data.company.name,",
				"          ContactcreatedAt = data.contact.createdAt,",
				"          Contactemail1 = data.contact.email1,",
				"          Contactemail2 = data.contact.email2,",
				"          Contactname = data.contact.name,",
				"          Contactphone1 = data.contact.phone1,",
				"          Contactphone2 = data.contact.phone2,",
				"          createdAt = data.createdAt,",
				"          endedAt = data.endedAt,",
				"          lastActivityAt = data.lastActivityAt,",
				"          lastResponseMethod = data.lastResponseMethod,",
				"          ProjectendDate = data.project.endDate,",
				"          externalId = data.project.externalId,",
				"          ProjectleadDate = data.project.leadDate,",
				"          sendAt = data.sendAt,",
				"          status = data.status,",
				"          surveyTakeUrl = data.surveyTakeUrl,",
				"          template = data.template,",
				"          UpdatedAt = data.updatedAt,",
				"          completionMode = data.completionMode,",
				"          Projectaddress = data.project.address,",
				"          ProjectCity = data.project.city,",
				"          ProjectcreatedAt = data.project.createdAt,",
				"          ProjectStartDate = data.project.startDate,",
				"          ProjectState = data.project.state,",
				"          ProjectupdatedAt = data.project.updatedAt,",
				"          value = data.project.value,",
				"          zip = data.project.zip,",
				"          customCompanyId = data.company.customCompanyId,",
				"          LeadID,",
				"          Sold,",
				"          SalesOrganization",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectcols",
				"joinwithQuestions select(mapColumn(",
				"          SurveyID = selectcols@SurveyID,",
				"          AccountID,",
				"          ProductLine,",
				"          customCompanyId,",
				"          Companyname,",
				"          ContactcreatedAt,",
				"          Contactemail1,",
				"          Contactemail2,",
				"          Contactname,",
				"          Contactphone1,",
				"          Contactphone2,",
				"          createdAt,",
				"          endedAt,",
				"          lastActivityAt,",
				"          lastResponseMethod,",
				"          ProjectendDate,",
				"          externalId,",
				"          ProjectleadDate,",
				"          sendAt,",
				"          status,",
				"          surveyTakeUrl,",
				"          template,",
				"          UpdatedAt,",
				"          completionMode,",
				"          Projectaddress,",
				"          ProjectCity,",
				"          ProjectcreatedAt,",
				"          ProjectStartDate,",
				"          ProjectState,",
				"          ProjectupdatedAt,",
				"          value,",
				"          zip,",
				"          roles,",
				"          UserFullName,",
				"          AdditionalComments,",
				"          AdditionalComments_rating,",
				"          Communication_comment,",
				"          Communication_rating,",
				"          Information_comment,",
				"          Information_rating,",
				"          Needs_comments,",
				"          Needs_rating,",
				"          Physical_Product_response,",
				"          Product_Knowledge_comments,",
				"          Product_Knowledge_rating,",
				"          Professionalism_comments,",
				"          Professionalism_rating,",
				"          Quote_response,",
				"          Satisfaction_comments,",
				"          Satisfaction_rating,",
				"          {Satisfied with Quote_comments},",
				"          {Satisfied with Quote_rating},",
				"          Service_comments,",
				"          Service_rating,",
				"          Time_comments,",
				"          Time_rating,",
				"          AreasForImprovement,",
				"          AreasOfSatisfaction,",
				"          Demonstration,",
				"          Experience,",
				"          {In-HomeSales},",
				"          InstallTeam,",
				"          Installation,",
				"          LikelyToRecommend,",
				"          Satisfaction,",
				"          Testimonial,",
				"          customCompanyId,",
				"          LeadID,",
				"          Sold,",
				"          SalesOrganization",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectcols2",
				"flattenDataArray filter(data.template=='Proposed Demo No Sale Survey Questions 1st draft') ~> filterInstallation",
				"joinwithCustomFilters derive(ProductLine = rtrim(ltrim(rtrim(ltrim(toString(ProductLine),'['),']'),'\"'),'\"'),",
				"          SalesOrganization = rtrim(ltrim(rtrim(ltrim(toString(byName('SalesOrganization')),'['),']'),'\"'),'\"')) ~> ProductLine",
				"pivotRowsIntoCols derive(AdditionalComments = toString(byName('String_Additional Comments')),",
				"          AdditionalComments_rating = toShort(byName('Int_Additional Comments')),",
				"          Communication_comment = toString(byName('String_Communication')),",
				"          Communication_rating = toShort(byName('Int_Communication')),",
				"          Information_comment = toString(byName('String_Information')),",
				"          Information_rating = toShort(byName('Int_Information')),",
				"          Needs_comments = toString(byName('String_Needs')),",
				"          Needs_rating = toShort(byName('Int_Needs')),",
				"          Physical_Product_response = ltrim(rtrim(toString(array(byName('Mcs_Physical Product'))),']]'),'[['),",
				"          Product_Knowledge_comments = toString(byName('String_Product Knowledge')),",
				"          Product_Knowledge_rating = toShort(byName('Int_Product Knowledge')),",
				"          Professionalism_comments = toString(byName('String_Professionalism')),",
				"          Professionalism_rating = toShort(byName('Int_Professionalism')),",
				"          Quote_response = ltrim(rtrim(toString(array(byName('Mcs_Quote'))),']]'),'[['),",
				"          Satisfaction_comments = toString(byName('String_Satisfaction')),",
				"          Satisfaction_rating = toShort(byName('Int_Satisfaction')),",
				"          {Satisfied with Quote_comments} = toString(byName('String_Satisfied with Quote')),",
				"          {Satisfied with Quote_rating} = toShort(byName('Int_Satisfied with Quote')),",
				"          Service_comments = toString(byName('String_Service')),",
				"          Service_rating = toShort(byName('Int_Service')),",
				"          Time_comments = toString(byName('String_Time')),",
				"          Time_rating = toShort(byName('Int_Time')),",
				"          AreasForImprovement = toString(byName('String_Areas For Improvement')),",
				"          AreasOfSatisfaction = toString(byName('String_Areas Of Satisfaction')),",
				"          String_Demonstration = toString(byName('String_Demonstration')),",
				"          Demonstration = toShort(byName('Int_Demonstration')),",
				"          Experience = toShort(byName('Int_Experience')),",
				"          {In-HomeSales} = toShort(byName('Int_In-Home Sales')),",
				"          InstallTeam = toShort(byName('Int_Install Team')),",
				"          Installation = toShort(byName('Int_Installation')),",
				"          LikelyToRecommend = toShort(byName('Int_Likely To Recommend')),",
				"          Satisfaction = toShort(byName('Int_Satisfaction')),",
				"          Testimonial = array(byName('Mcs_Testimonial'))) ~> Questions",
				"Questions derive(Testimonial = rtrim(ltrim(toString(Testimonial),'[['),']]')) ~> QuestionsTestimonial",
				"flattenCustomFilters derive(LeadID = rtrim(ltrim(rtrim(ltrim(toString(LeadID),'['),']'),'\"'),'\"'),",
				"          ProductLine = rtrim(ltrim(rtrim(ltrim(toString(ProductLine),'['),']'),'\"'),'\"'),",
				"          Sold = rtrim(ltrim(rtrim(ltrim(toString(Sold),'['),']'),'\"'),'\"')) ~> customfilters",
				"sourceJSON foldDown(unroll(data),",
				"     mapColumn(",
				"          data",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenDataArray",
				"selectcols2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Survey_ID as integer,",
				"          Response_Date as string,",
				"          Program as string,",
				"          Development_Cycle as string,",
				"          Brand as string,",
				"          BranchID as string,",
				"          Template as string,",
				"          Old_Survey_Id as string,",
				"          Contact as string,",
				"          Address as string,",
				"          City as string,",
				"          State as string,",
				"          Zip as string,",
				"          Email as string,",
				"          Phone as string,",
				"          External_Id as string,",
				"          Value as decimal(16,2),",
				"          Surveystatus as string,",
				"          ContactCreationDate as string,",
				"          ProjectStartDate as string,",
				"          ServiceDate as string,",
				"          Creationdate as string,",
				"          Channel as string,",
				"          SatisfactionScore as string,",
				"          SalesRepresentative as string,",
				"          In_Home_Sales_Rating as string,",
				"          In_Home_Sales_Comments as string,",
				"          Install_Team_Rating as string,",
				"          Install_Team_Comments as string,",
				"          Installation_Rating as string,",
				"          Installation_Comments as string,",
				"          Product_Walkthrough as string,",
				"          Experience_Rating as string,",
				"          Experience_Comments as string,",
				"          Service_NPS as string,",
				"          Likely_To_Recommend as string,",
				"          Satisfaction_Rating as string,",
				"          Satisfaction_Comments as string,",
				"          Testimonial as string,",
				"          Testimonial_Comments as string,",
				"          Additional_Comments as string,",
				"          Areas_For_Improvement_Rating as string,",
				"          Areas_For_Improvement_Comment as string,",
				"          Areas_Of_Satisfaction_Rating as string,",
				"          Areas_Of_Satisfaction_Comment as string,",
				"          SecondaryEmail as string,",
				"          SecondaryPhone as string,",
				"          NeedsAction as string,",
				"          Notes as string,",
				"          GoogleReviewBoost as string,",
				"          VIPProgramAwarenessChoice as string,",
				"          VIPProgramAwarenessComment as string,",
				"          Testimonial_Choice as string,",
				"          Testimonial_Comment as string,",
				"          ReferralProgramAwareness_Choice as string,",
				"          ReferralProgramAwareness_Comment as string,",
				"          URL as string,",
				"          AccountID as string,",
				"          LeadID as string,",
				"          UserFullName as string,",
				"          projectType as string,",
				"          surveyEnddate as string,",
				"          role as string,",
				"          LastresponseMethod as string,",
				"          updatedAt as string,",
				"          lastActivityAt as string,",
				"          Sales_Understanding as string,",
				"          Sales_Communication as string,",
				"          Sales_Punctuality as string,",
				"          Sales_Professionalism as string,",
				"          Sales_Product_Knowledge as string,",
				"          Completeness_of_Information as string,",
				"          Received_Quote as string,",
				"          Satisfaction_with_Quote as string,",
				"          Quote_Project_Start_Date as string,",
				"          Product_Demo as string,",
				"          Product_Demo_Benefits as string,",
				"          Reason_for_not_moving_forward as string,",
				"          Decided_Against_Other as string,",
				"          Final_Comment as string,",
				"          Sold as string,",
				"          SalesOrganization as string,",
				"          PRODUCTLINE as string,",
				"          Professionalism_Comments as string,",
				"          Professionalism_Rating as string,",
				"          Clarity_Helpfulness_comments as string,",
				"          Clarity_Helpfulness_Rating as string,",
				"          Future_Consideration_Comments as string,",
				"          Future_Consideration_Rating as string,",
				"          ReasonforConsideration_Comments as string,",
				"          ReasonforConsideration_Rating as string,",
				"          SalesExperience as string,",
				"          InstallationQuality as string,",
				"          OverallSatisfaction as string,",
				"          OtherReasonforConsideration as string,",
				"          AdditionalFeedback as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Survey_ID = SurveyID,",
				"          Response_Date = endedAt,",
				"          Program = template,",
				"          Brand = Companyname,",
				"          Template = template,",
				"          Contact = Contactname,",
				"          Address = Projectaddress,",
				"          City = ProjectCity,",
				"          State = ProjectState,",
				"          Zip = zip,",
				"          Email = Contactemail1,",
				"          Phone = Contactphone1,",
				"          External_Id = externalId,",
				"          Value = value,",
				"          Surveystatus = status,",
				"          ContactCreationDate = ContactcreatedAt,",
				"          ProjectStartDate,",
				"          ServiceDate = ProjectendDate,",
				"          Creationdate = createdAt,",
				"          Channel = completionMode,",
				"          In_Home_Sales_Rating = {In-HomeSales},",
				"          Install_Team_Rating = InstallTeam,",
				"          Installation_Rating = Installation,",
				"          Product_Walkthrough = Demonstration,",
				"          Experience_Rating = Experience,",
				"          Service_NPS = LikelyToRecommend,",
				"          Satisfaction_Rating = Satisfaction,",
				"          Testimonial,",
				"          Additional_Comments = AdditionalComments,",
				"          Areas_For_Improvement_Comment = AreasForImprovement,",
				"          Areas_Of_Satisfaction_Comment = AreasOfSatisfaction,",
				"          SecondaryEmail = Contactemail2,",
				"          SecondaryPhone = Contactphone2,",
				"          URL = surveyTakeUrl,",
				"          AccountID,",
				"          LeadID,",
				"          UserFullName,",
				"          surveyEnddate = endedAt,",
				"          role = roles,",
				"          LastresponseMethod = lastResponseMethod,",
				"          updatedAt = UpdatedAt,",
				"          lastActivityAt,",
				"          Sales_Communication = Communication_rating,",
				"          Sales_Punctuality = Time_rating,",
				"          Sales_Professionalism = Professionalism_rating,",
				"          Sales_Product_Knowledge = Product_Knowledge_rating,",
				"          Completeness_of_Information = Information_rating,",
				"          Received_Quote = Quote_response,",
				"          Satisfaction_with_Quote = {Satisfied with Quote_rating},",
				"          Sales_Understanding = Needs_rating,",
				"          BranchID = customCompanyId,",
				"          Sold,",
				"          SalesOrganization,",
				"          Product_Demo_Benefits = Service_rating,",
				"          PRODUCTLINE = ProductLine",
				"     )) ~> sink1"
			]
		}
	}
}
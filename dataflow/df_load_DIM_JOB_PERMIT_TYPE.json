						"type": "DatasetReference"
					},
					"name": "CTA"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_JOB_PERMIT_TYPE",
						"type": "DatasetReference"
					},
					"name": "targetDim",
					"description": "Export data to EDW_DIM_JOB_PERMIT_TYPE",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "addOpCoNameFHI"
				},
				{
					"name": "addOpCoNameHSI"
				},
				{
					"name": "addOpCoNameMAC"
				},
				{
					"name": "addOpCoNamePBC"
				},
				{
					"name": "addOpCoNameSWR"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "derivedColumns"
				},
				{
					"name": "addOpCoNameRTW"
				},
				{
					"name": "addOpCoNameMXH"
				},
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "addOpCoNameCTA"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as integer,",
				"          descr as string,",
				"          active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"source(output(",
				"          ID as integer,",
				"          descr as string,",
				"          active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> HSI",
				"source(output(",
				"          ID as integer,",
				"          descr as string,",
				"          active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MAC",
				"source(output(",
				"          ID as integer,",
				"          descr as string,",
				"          active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> PBC",
				"source(output(",
				"          ID as integer,",
				"          descr as string,",
				"          active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          ID as integer,",
				"          descr as string,",
				"          active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"source(output(",
				"          ID as integer,",
				"          descr as string,",
				"          active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MXH",
				"source(output(",
				"          ID as integer,",
				"          descr as string,",
				"          active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> CTA",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"HSI derive(Division = 'HSI') ~> addOpCoNameHSI",
				"MAC derive(Division = 'MAC') ~> addOpCoNameMAC",
				"PBC derive(Division = 'PBC') ~> addOpCoNamePBC",
				"SWR derive(Division = 'SWR') ~> addOpCoNameSWR",
				"addOpCoNameFHI, addOpCoNameHSI, addOpCoNameMAC, addOpCoNamePBC, addOpCoNameSWR, addOpCoNameRTW, addOpCoNameMXH, addOpCoNameCTA union(byName: true)~> unionAllOpCos",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          PermitTypeID = concat(Division,'-',toString(LP_PermitTypeID))) ~> derivedColumns",
				"RTW derive(Division = 'RTW') ~> addOpCoNameRTW",
				"MXH derive(Division = 'MXH') ~> addOpCoNameMXH",
				"unionAllOpCos select(mapColumn(",
				"          LP_PermitTypeID = ID,",
				"          PermitType = descr,",
				"          Active = active,",
				"          Division",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"CTA derive(Division = 'CTA') ~> addOpCoNameCTA",
				"derivedColumns alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          PermitTypeID as string,",
				"          PermitType as string,",
				"          Active as boolean,",
				"          LP_PermitTypeID as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['PermitTypeID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_PermitTypeID,",
				"          PermitType,",
				"          Active,",
				"          Division,",
				"          LastUpdateTS,",
				"          PermitTypeID",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
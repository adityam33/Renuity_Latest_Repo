{
	"name": "df_load_FACT_INBOUND_QUEUE_LOG_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/FACTS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_in1_InboundQueue1",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_InboundQueue_Log_ZML",
						"type": "DatasetReference"
					},
					"name": "targetFact",
					"description": "Export data to EDW_INBOUND_QUEUE_LOG",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "addOpCoNameFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "derivedColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as integer,",
				"          Prefix as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          Suffix as string,",
				"          Address1 as string,",
				"          Address2 as string,",
				"          City as string,",
				"          State as string,",
				"          Zip as string,",
				"          Phone as string,",
				"          PhoneType as integer,",
				"          Phone2 as string,",
				"          PhoneType2 as integer,",
				"          Phone3 as string,",
				"          PhoneType3 as integer,",
				"          ProductID as string,",
				"          ProdDescr as string,",
				"          Email as string,",
				"          Sender as string,",
				"          SentTo as string,",
				"          QNum as integer,",
				"          CallMorning as boolean,",
				"          CallAfternoon as boolean,",
				"          CallEvening as boolean,",
				"          CallWeekend as boolean,",
				"          DateReceived as timestamp,",
				"          LogNumber as string,",
				"          Source as string,",
				"          CrossStreet as string,",
				"          srs_id as integer,",
				"          brn_id as string,",
				"          rnk_id as integer,",
				"          Notes as string,",
				"          Waiver as boolean,",
				"          User1 as string,",
				"          User2 as string,",
				"          User3 as string,",
				"          User4 as string,",
				"          User5 as string,",
				"          User6 as timestamp,",
				"          User7 as timestamp,",
				"          User8 as timestamp,",
				"          User9 as timestamp,",
				"          User10 as timestamp,",
				"          User11 as decimal(19,4),",
				"          User12 as decimal(19,4),",
				"          User13 as decimal(19,4),",
				"          User14 as decimal(19,4),",
				"          User15 as decimal(19,4),",
				"          CheckOutDate as timestamp,",
				"          emp_id as integer,",
				"          Pro_ID as integer,",
				"          ApptDate as string,",
				"          ApptTime as string,",
				"          RecdDate as string,",
				"          RecdTime as string,",
				"          EmailBody as string,",
				"          Method as string,",
				"          lds_id as integer,",
				"          ikr_id as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"addOpCoNameFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos select(mapColumn(",
				"          LP_InboundQueueLogID = ID,",
				"          LP_LeadID = lds_id,",
				"          LP_InboundKillReasonID = ikr_id,",
				"          LP_LeadSubSourceID = srs_id,",
				"          LP_BranchID = brn_id,",
				"          LP_PromoterID = Pro_ID,",
				"          LP_CheckOutByEmployeeID = emp_id,",
				"          CheckOutDate,",
				"          CheckOutMethod = Method,",
				"          FirstName,",
				"          LastName,",
				"          Address1,",
				"          Address2,",
				"          City,",
				"          State,",
				"          Zip,",
				"          Phone,",
				"          Email,",
				"          ProductID,",
				"          ProductDescription = ProdDescr,",
				"          Sender,",
				"          DateReceived,",
				"          Source,",
				"          Notes,",
				"          AppointmentDate = ApptDate,",
				"          AppointmentTime = ApptTime,",
				"          Division,",
				"          User11",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(InboundQueueLogID = concat(Division,'-',toString(LP_InboundQueueLogID)),",
				"          LeadID = concat(Division,'-',toString(LP_LeadID)),",
				"          InboundKillReasonID = concat(Division,'-',toString(LP_InboundKillReasonID)),",
				"          LeadSubSourceID = concat(Division,'-',toString(LP_LeadSubSourceID)),",
				"          BranchID = concat(Division,'-',toString(LP_BranchID)),",
				"          PromoterID = concat(Division,'-',toString(LP_PromoterID)),",
				"          CheckOutByEmployeeID = concat(Division,'-',toString(LP_CheckOutByEmployeeID)),",
				"          LastUpdateTS = currentTimestamp()) ~> derivedColumns",
				"derivedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          InboundQueueLogID as string,",
				"          LeadID as string,",
				"          InboundKillReasonID as string,",
				"          LeadSubSourceID as string,",
				"          BranchID as string,",
				"          PromoterID as string,",
				"          CheckOutByEmployeeID as string,",
				"          CheckOutDate as timestamp,",
				"          CheckOutMethod as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          Address1 as string,",
				"          Address2 as string,",
				"          City as string,",
				"          State as string,",
				"          Zip as string,",
				"          Phone as string,",
				"          Email as string,",
				"          ProductID as string,",
				"          ProductDescription as string,",
				"          Sender as string,",
				"          DateReceived as timestamp,",
				"          Source as string,",
				"          Notes as string,",
				"          AppointmentDate as string,",
				"          AppointmentTime as string,",
				"          User11 as string,",
				"          LP_InboundQueueLogID as integer,",
				"          LP_LeadID as integer,",
				"          LP_InboundKillReasonID as integer,",
				"          LP_LeadSubSourceID as integer,",
				"          LP_BranchID as string,",
				"          LP_PromoterID as integer,",
				"          LP_CheckOutByEmployeeID as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          InboundQueueLogID,",
				"          LeadID,",
				"          InboundKillReasonID,",
				"          LeadSubSourceID,",
				"          BranchID,",
				"          PromoterID,",
				"          CheckOutByEmployeeID,",
				"          CheckOutDate,",
				"          CheckOutMethod,",
				"          FirstName,",
				"          LastName,",
				"          Address1,",
				"          Address2,",
				"          City,",
				"          State,",
				"          Zip,",
				"          Phone,",
				"          Email,",
				"          ProductID,",
				"          ProductDescription,",
				"          Sender,",
				"          DateReceived,",
				"          Source,",
				"          Notes,",
				"          AppointmentDate,",
				"          AppointmentTime,",
				"          User11,",
				"          LP_InboundQueueLogID,",
				"          LP_LeadID,",
				"          LP_InboundKillReasonID,",
				"          LP_LeadSubSourceID,",
				"          LP_BranchID,",
				"          LP_PromoterID,",
				"          LP_CheckOutByEmployeeID,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetFact"
			]
		}
	}
}
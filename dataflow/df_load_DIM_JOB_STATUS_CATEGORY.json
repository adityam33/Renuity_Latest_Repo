				"     staged: true) ~> PBC",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MXH",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> CTA",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"HSI derive(Division = 'HSI') ~> addOpCoNameHSI",
				"MAC derive(Division = 'MAC') ~> addOpCoNameMAC",
				"PBC derive(Division = 'PBC') ~> addOpCoNamePBC",
				"SWR derive(Division = 'SWR') ~> addOpCoNameSWR",
				"addOpCoNameFHI, addOpCoNameHSI, addOpCoNameMAC, addOpCoNamePBC, addOpCoNameSWR, addOpCoNameRTW, addOpCoNameMXH, addOpCoNameCTA union(byName: true)~> unionAllOpCos",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          JobStatusCategoryID = concat(Division,'-',toString(LP_JobStatusCategoryID))) ~> derivedColumns",
				"RTW derive(Division = 'RTW') ~> addOpCoNameRTW",
				"MXH derive(Division = 'MXH') ~> addOpCoNameMXH",
				"unionAllOpCos select(mapColumn(",
				"          LP_JobStatusCategoryID = id,",
				"          JobStatusCategory = Descr,",
				"          Active,",
				"          Division",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"CTA derive(Division = 'CTA') ~> addOpCoNameCTA",
				"derivedColumns alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          JobStatusCategoryID as string,",
				"          JobStatusCategory as string,",
				"          Active as boolean,",
				"          LP_JobStatusCategoryID as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['JobStatusCategoryID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_JobStatusCategoryID,",
				"          JobStatusCategory,",
				"          Active,",
				"          Division,",
				"          LastUpdateTS,",
				"          JobStatusCategoryID",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}

				"          TransactionDescription as string,",
				"          BatchDescription as string,",
				"          CreatedBy as string,",
				"          CreatedDateTime as timestamp,",
				"          LastModifiedDateTime as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['GL_LINE_KEY'],",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          GL_LINE_KEY,",
				"          AccountCode,",
				"          AccountClass,",
				"          AccountDescription,",
				"          BatchNumber,",
				"          ReferenceNumber,",
				"          BalanceAmount,",
				"          BranchCode = Branchcode,",
				"          CompanyID,",
				"          FinPeriodID = FinperiodID,",
				"          LedgerID,",
				"          CustomerVendor,",
				"          CustomerID,",
				"          CustomerName,",
				"          CustomerClass,",
				"          VendorID,",

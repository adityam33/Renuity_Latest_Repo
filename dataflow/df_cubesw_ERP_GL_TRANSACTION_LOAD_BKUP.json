			"scriptLines": [
				"source(output(",
				"          AccountCode as string,",
				"          AccountClass as string,",
				"          AccountDescription as string,",
				"          CompanyID as string,",
				"          Branchcode as string,",
				"          DepartmentID as string,",
				"          Department as string,",
				"          MarketingAccountID as string,",
				"          MarketingAccount as string,",
				"          ProductID as string,",
				"          Product as string,",
				"          FinperiodID as string,",
				"          LedgerID as integer,",
				"          BalanceAmount as decimal(38,4),",
				"          GL_LINE_KEY as string,",
				"          ReferenceNumber as string,",
				"          BatchNumber as string,",
				"          CustomerVendor as string,",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          CustomerClass as string,",
				"          VendorID as string,",
				"          VendorName as string,",
				"          VendorClass as string,",
				"          ProjectID as string,",
				"          TransactionDescription as string,",
				"          Createdby as string,",
				"          CreatedDatetime as timestamp,",
				"          LastModifiedDatetime as timestamp,",
				"          BatchDescription as string,",
				"          RecordFlag as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select \\n          AccountCode,AccountClass,AccountDescription,\\n          CompanyID,Branchcode,\\n          DepartmentID,Department,\\n          MarketingAccountID,MarketingAccount,\\n          ProductID,Product , \\n          FinperiodID,LedgerID,\\n          BalanceAmount,\\n          GL_LINE_KEY,\\n          ReferenceNumber,\\n          BatchNumber,\\n          CustomerVendor,\\n          CustomerID,\\n          CustomerName,\\n          CustomerClass,\\n          VendorID,\\n          VendorName,\\n          VendorClass,\\n          ProjectID,\\n          TransactionDescription,\\n          Createdby ,\\n          CreatedDatetime,\\n          LastModifiedDatetime,\\n                BatchDescription,\\n          \\'Line\\' as RecordFlag\\nfrom [OUT].[CUBESW_ERP_GL_TRANSACTION_STAGE] \\n     where AccountCode>=\\'60000\\'  \\n--and Eomonth(concat(substring(finperiodid,1,charindex(\\'-\\',finperiodid)),\\'01-\\',substring(finperiodid,charindex(\\'-\\',finperiodid)+1,len(finperiodid))))>=dateadd(M,-6,getdate())\\n\\nUNION ALL\\n\\n\\nSelect  DISTINCT AccountCode,AccountClass,AccountDescription,\\n          NULL AS CompanyID,\\n          Branchcode,\\n        NULL AS DepartmentID,\\n          NULL AS Department,\\n          NULL AS MarketingAccountID,\\n          NULL AS MarketingAccount,\\n          NULL AS ProductID,\\n          NULL AS Product,\\n        FinperiodID,LedgerID, \\n        Sum(BalanceAmount) Over (Partition by AccountCode,Branchcode,LedgerID\\n                                 order by  CalendarDate\\n                                 ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW\\n                                 ) AS EndingBalance,\\n        NULL AS GL_LINE_KEY,\\n        NULL AS ReferenceNumber,\\n        NULL AS BatchNumber,\\n        NULL AS CustomerVendor,\\n        NULL AS CustomerID,\\n        NULL AS CustomerName,\\n        NULL AS CustomerClass,\\n        NULL AS VendorID,\\n        NULL AS VendorName,\\n        NULL AS VendorClass,\\n        NULL AS ProjectID,\\n        NULL AS TransactionDescription,\\n        \\'ETLAdmin\\'  AS Createdby ,\\n        Getdate() AS CreatedDatetime,\\n        Getdate() ASLastModifiedDatetime,\\n              NULL AS BatchDescription,\\n        \\'Agg\\' AS RecordFlag\\n\\nfrom\\nOUT.CUBESW_SUMM_ERP_GL_Transaction_STAGE\\n',",
				"     format: 'query',",
				"     staged: true) ~> SrcCubeStage",
				"source(output(",
				"          GL_LINE_KEY as string,",
				"          AccountCode as string,",
				"          AccountClass as string,",
				"          AccountDescription as string,",
				"          BatchNumber as string,",
				"          ReferenceNumber as string,",
				"          BalanceAmount as decimal(38,18),",
				"          BranchCode as string,",
				"          CompanyID as string,",
				"          FinPeriodID as string,",
				"          LedgerID as integer,",
				"          CustomerVendor as string,",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          CustomerClass as string,",
				"          VendorID as string,",
				"          VendorName as string,",
				"          VendorClass as string,",
				"          DepartmentID as string,",
				"          Department as string,",
				"          MarketingAccountID as string,",
				"          MarketingAccount as string,",
				"          ProductID as string,",
				"          Product as string,",
				"          ProjectID as string,",
				"          TransactionDescription as string,",
				"          CreatedBy as string,",
				"          CreatedDateTime as timestamp,",
				"          LastModifiedDateTime as timestamp,",
				"          BatchDescription as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select * from [OUT].[CUBESW_ERP_GL_TRANSACTION] where GL_LINE_KEY is NULL',",
				"     format: 'query',",
				"     staged: true) ~> SrcCubeERPGL",
				"FilterAggData, SrcCubeERPGL lookup(LineAggData@UpsertAggdata@AccountCode == SrcCubeERPGL@AccountCode",
				"     && LineAggData@UpsertAggdata@Branchcode == SrcCubeERPGL@BranchCode",
				"     && LineAggData@UpsertAggdata@FinperiodID == SrcCubeERPGL@FinPeriodID",
				"     && LineAggData@UpsertAggdata@LedgerID == SrcCubeERPGL@LedgerID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> LkpCubeErpGL",
				"LkpCubeErpGL derive(Flag = iif((isNull(SrcCubeERPGL@AccountCode) \r",
				"&& isNull(SrcCubeERPGL@BranchCode)\r",
				"&& isNull(SrcCubeERPGL@FinPeriodID) \r",
				"&& isNull(SrcCubeERPGL@LedgerID))\r",
				", '1', '0'),",
				"          LastUpdatedTS = currentUTC(),",
				"          CreatedTS = currentUTC(),",
				"          CreatedBY = 'ETLadmin') ~> GenerateFlagAuditCol",
				"LineAggData@UpsertAggdata filter(RecordFlag=='Agg') ~> FilterAggData",
				"SelectColsToInsert alterRow(insertIf(Flag=='1')) ~> InsertNewAggdata",
				"SrcCubeStage split(isNull(GL_LINE_KEY),",
				"     disjoint: false) ~> LineAggData@(UpsertAggdata, UpsertLinedata)",
				"LineAggData@UpsertLinedata alterRow(upsertIf(true())) ~> UpsertonGLLineKey",
				"GenerateFlagAuditCol split(Flag=='1',",
				"     disjoint: false) ~> InsertUpdateAggdata@(Insert, Update)",
				"InsertUpdateAggdata@Update select(mapColumn(",
				"          AccountCode = InsertUpdateAggdata@Update@AccountCode,",
				"          AccountClass = InsertUpdateAggdata@Update@AccountClass,",
				"          AccountDescription = InsertUpdateAggdata@Update@AccountDescription,",
				"          CompanyID = InsertUpdateAggdata@Update@CompanyID,",
				"          Branchcode = InsertUpdateAggdata@Update@Branchcode,",
				"          DepartmentID = InsertUpdateAggdata@Update@DepartmentID,",
				"          Department = InsertUpdateAggdata@Update@Department,",
				"          MarketingAccountID = InsertUpdateAggdata@Update@MarketingAccountID,",
				"          MarketingAccount = InsertUpdateAggdata@Update@MarketingAccount,",
				"          ProductID = InsertUpdateAggdata@Update@ProductID,",
				"          Product = InsertUpdateAggdata@Update@Product,",
				"          FinperiodID = InsertUpdateAggdata@Update@FinperiodID,",
				"          LedgerID = InsertUpdateAggdata@Update@LedgerID,",
				"          BalanceAmount = InsertUpdateAggdata@Update@BalanceAmount,",
				"          Flag,",
				"          LastUpdatedTS",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectColsToUpdate",
				"SelectColsToUpdate alterRow(updateIf(Flag=='0')) ~> UpdateAggData",
				"InsertUpdateAggdata@Insert select(mapColumn(",
				"          AccountCode = InsertUpdateAggdata@Insert@AccountCode,",
				"          AccountClass = InsertUpdateAggdata@Insert@AccountClass,",
				"          AccountDescription = InsertUpdateAggdata@Insert@AccountDescription,",
				"          CompanyID = InsertUpdateAggdata@Insert@CompanyID,",
				"          Branchcode = InsertUpdateAggdata@Insert@Branchcode,",
				"          DepartmentID = InsertUpdateAggdata@Insert@DepartmentID,",
				"          Department = InsertUpdateAggdata@Insert@Department,",
				"          MarketingAccountID = InsertUpdateAggdata@Insert@MarketingAccountID,",
				"          MarketingAccount = InsertUpdateAggdata@Insert@MarketingAccount,",
				"          ProductID = InsertUpdateAggdata@Insert@ProductID,",
				"          Product = InsertUpdateAggdata@Insert@Product,",
				"          FinperiodID = InsertUpdateAggdata@Insert@FinperiodID,",
				"          LedgerID = InsertUpdateAggdata@Insert@LedgerID,",
				"          BalanceAmount = InsertUpdateAggdata@Insert@BalanceAmount,",
				"          GL_LINE_KEY = InsertUpdateAggdata@Insert@GL_LINE_KEY,",
				"          ReferenceNumber = InsertUpdateAggdata@Insert@ReferenceNumber,",
				"          BatchNumber = InsertUpdateAggdata@Insert@BatchNumber,",
				"          CustomerVendor = InsertUpdateAggdata@Insert@CustomerVendor,",
				"          CustomerID = InsertUpdateAggdata@Insert@CustomerID,",
				"          CustomerName = InsertUpdateAggdata@Insert@CustomerName,",
				"          CustomerClass = InsertUpdateAggdata@Insert@CustomerClass,",
				"          VendorID = InsertUpdateAggdata@Insert@VendorID,",
				"          VendorName = InsertUpdateAggdata@Insert@VendorName,",
				"          VendorClass = InsertUpdateAggdata@Insert@VendorClass,",
				"          ProjectID = InsertUpdateAggdata@Insert@ProjectID,",
				"          TransactionDescription = InsertUpdateAggdata@Insert@TransactionDescription,",
				"          Flag,",
				"          LastUpdatedTS,",
				"          CreatedTS,",
				"          CreatedBY = InsertUpdateAggdata@Insert@CreatedBY,",
				"          BatchDescription = InsertUpdateAggdata@Insert@BatchDescription",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectColsToInsert",
				"InsertNewAggdata sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          AccountCode as string,",
				"          AccountClass as string,",
				"          AccountDescription as string,",
				"          GL_LINE_KEY as string,",
				"          ReferenceNumber as string,",
				"          BatchNumber as string,",
				"          BalanceAmount as decimal(38,18),",
				"          BranchCode as string,",
				"          CompanyID as string,",
				"          FinPeriodID as string,",
				"          LedgerID as integer,",
				"          DepartmentID as string,",
				"          Department as string,",
				"          MarketingAccountID as string,",
				"          MarketingAccount as string,",
				"          ProductID as string,",
				"          Product as string,",
				"          CustomerVendor as string,",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          CustomerClass as string,",
				"          VendorID as string,",
				"          VendorName as string,",
				"          VendorClass as string,",
				"          ProjectID as string,",
				"          TransactionDescription as string,",
				"          BatchDescription as string,",
				"          CreatedBy as string,",
				"          CreatedDateTime as timestamp,",
				"          LastModifiedDateTime as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          GL_LINE_KEY,",
				"          AccountCode,",
				"          AccountClass,",
				"          AccountDescription,",
				"          BatchNumber,",
				"          ReferenceNumber,",
				"          BalanceAmount,",
				"          BranchCode = Branchcode,",
				"          CompanyID,",
				"          FinPeriodID = FinperiodID,",
				"          LedgerID,",
				"          CustomerVendor,",
				"          CustomerID,",
				"          CustomerName,",
				"          CustomerClass,",
				"          VendorID,",
				"          VendorName,",
				"          VendorClass,",
				"          DepartmentID,",
				"          Department,",
				"          MarketingAccountID,",
				"          MarketingAccount,",
				"          ProductID,",
				"          Product,",
				"          ProjectID,",
				"          TransactionDescription,",
				"          CreatedBy = CreatedBY,",
				"          CreatedDateTime = CreatedTS,",
				"          LastModifiedDateTime = LastUpdatedTS,",
				"          BatchDescription",
				"     )) ~> TgtCubeERPGLInsertAgg",
				"UpsertonGLLineKey sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          AccountCode as string,",
				"          AccountClass as string,",
				"          AccountDescription as string,",
				"          GL_LINE_KEY as string,",
				"          ReferenceNumber as string,",
				"          BatchNumber as string,",

				"          MarketingAccount,",
				"          ProductID,",
				"          Product,",
				"          ProjectID,",
				"          TransactionDescription,",
				"          CreatedBy = Createdby,",
				"          CreatedDateTime = CreatedDatetime,",
				"          LastModifiedDateTime = LastModifiedDatetime,",
				"          BatchDescription",
				"     )) ~> TgtCubeERPGLUpsertLine",
				"UpdateAggData sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          AccountCode as string,",
				"          AccountClass as string,",
				"          AccountDescription as string,",
				"          GL_LINE_KEY as string,",
				"          ReferenceNumber as string,",
				"          BatchNumber as string,",
				"          BalanceAmount as decimal(38,18),",
				"          BranchCode as string,",
				"          CompanyID as string,",
				"          FinPeriodID as string,",
				"          LedgerID as integer,",
				"          DepartmentID as string,",

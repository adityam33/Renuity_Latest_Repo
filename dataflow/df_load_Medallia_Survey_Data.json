				"          ReportingMarketTypeID as string,",
				"          Product_Line_InHomeConsultationExperience as string,",
				"          Social_Unit_ID as string,",
				"          On_Site_Quote_Satisfaction_Team_Score as string,",
				"          Reason_for_Score as string,",
				"          Sales_Understanding as string,",
				"          Sales_Communication as string,",
				"          Sales_Punctuality as string,",
				"          Sales_Professionalism as string,",
				"          Sales_Product_Knowledge as string,",
				"          Completeness_Of_Information as string,",
				"          Received_Quote as string,",
				"          Satisfaction_With_Quote as string,",
				"          Quote_Project_Start_Date as string,",
				"          Product_Demo as string,",
				"          Product_Demo_Benefits as string,",
				"          Reason_For_Not_Moving_Forward as string,",
				"          Decided_Against_Other as string,",
				"          Final_Comment as string,",
				"          Service_NPS as string,",
				"          Reasons_For_Your_Score as string,",
				"          Give_More_Feedback as string,",
				"          In_Home_Sales as string,",
				"          Install_Team as string,",
				"          Installation as string,",
				"          Product_Walkthrough as string,",
				"          Experience as string,",
				"          Satisfaction as string,",
				"          Area_For_Improvement as string,",
				"          Area_Of_Satisfaction as string,",
				"          Testimonial as string,",
				"          Additional_Comments as string,",
				"          LP_CustomerID as integer,",
				"          LP_LeadID as integer,",
				"          LP_SalesRepEmployeeID_1 as integer,",
				"          LP_SalesRepEmployeeID_2 as integer,",
				"          LP_BranchID as string,",
				"          LP_InstallerID_1 as integer,",
				"          LP_InstallerID_2 as integer,",
				"          LP_InstallerID_3 as integer,",
				"          LP_InstallerID_4 as integer,",
				"          LP_ReportingMarketID as integer,",
				"          LP_ReportingMarketTypeID as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select * from (Select A.Survey_ID,A.Response_Date,A.Program,Case when A.Lead_ID is not null then L.CustomerID ELSE J.CustomerID END as CustomerID,\\r\\nCase when A.Lead_ID is not NUll then L.LeadID ELSE J.LeadID END as LeadID,L.SalesRep1_EmployeeID,L.SalesRep2_EmployeeID,L.BranchID,\\r\\nL.ApptDate,J.ContractID,\\r\\ncase when Brand_name=\\'Mad City Windows & Baths\\' then \\'MAC\\'\\r\\nWHEN Brand_name=\\'Pacific Bath\\' then \\'PBC\\'\\r\\nWHEN Brand_name=\\'Statewide Remodeling\\' then \\'SWR\\'\\r\\nWHEN Brand_name=\\'FHIA Remodeling\\' then \\'FHI\\'\\r\\nWHEN Brand_name=\\'Max Home\\' then \\'MXH\\'\\r\\nWHEN Brand_name=\\'Rite Window & Door\\' then \\'RTW\\'\\r\\nWHEN Brand_name=\\'Paradise Home Improvement\\' then \\'PHI\\'\\r\\nWhen Brand_name=\\'Home Smart\\' then \\'HSI\\'\\r\\nWHEN Brand_name=\\'Renuity\\' then \\'REN\\' END as Division,J.InstallerID_1,J.InstallerID_2,J.InstallerID_3,J.InstallerID_4,\\r\\nA.Product_Line_InstallationExperience,A.Date_To_Survey,A.Country,A.[Language],A.Unit,\\r\\nCase when A.Sold=\\'Not Sold\\' then \\'0\\' Else \\'1\\' END as Sold,A.Development_Cycle as DevelopmentCycle,A.Sales_Organization as SalesOrganization,\\r\\nA.Record_Type_Medallia_Conversations,A.Main_Metric,A.Service_Datetime,A.Channel,\\r\\nB.ReportingMarketID,B.ReportingMarketTypeID,A.Product_Line_InHomeConsultationExperience,A.Social_Unit_ID,A.On_Site_Quote_Satisfaction_Team_Score,\\r\\nA.Reason_for_Score,A.Sales_Understanding,a.Sales_Communication,A.Sales_Punctuality,A.Sales_Professionalism,A.Sales_Product_Knowledge,\\r\\nA.Completeness_Of_Information,A.Received_Quote,A.Satisfaction_With_Quote,A.Quote_Project_Start_Date,A.Product_Demo,A.Product_Demo_Benefits,\\r\\nA.Reason_For_Not_Moving_Forward,A.Decided_Against_Other,A.Final_Comment,A.Service_NPS,A.Reasons_For_Your_Score,A.Give_More_Feedback,\\r\\nA.In_Home_Sales,A.Install_Team,A.Installation,a.Product_Walkthrough,A.Experience,A.Satisfaction,A.Area_For_Improvement,A.Area_Of_Satisfaction,\\r\\nA.Testimonial,A.Additional_Comments,\\r\\nCase when A.Lead_ID is not null then L.LP_CustomerID ELSE J.LP_CustomerID END as LP_CustomerID,\\r\\nCase when A.Lead_ID is not NUll then L.LP_LeadID ELSE J.LP_LeadID END as LP_LeadID,L.LP_SalesRep1_EmployeeID as LP_SalesRepEmployeeID_1,\\r\\nL.LP_SalesRep2_EmployeeID as LP_SalesRepEmployeeID_2,L.LP_BranchID,J.LP_InstallerID_1,J.LP_InstallerID_2,\\r\\nJ.LP_InstallerID_3,J.LP_InstallerID_4,B.LP_ReportingMarketID,B.LP_ReportingMarketTypeID\\r\\n from EDW.FACT_LEAD L left join EDW.FACT_JOB J on L.LeadID=J.LeadID\\r\\n left join ODS.MEDALLIA_CUSTOMER_SURVEY A on A.Lead_ID=L.LP_LeadID\\r\\n and L.Division=(case when A.Brand_name=\\'Mad City Windows & Baths\\' then \\'MAC\\'\\r\\nWHEN A.Brand_name=\\'Pacific Bath\\' then \\'PBC\\'\\r\\nWHEN A.Brand_name=\\'Statewide Remodeling\\' then \\'SWR\\'\\r\\nWHEN A.Brand_name=\\'FHIA Remodeling\\' then \\'FHI\\'\\r\\nWHEN A.Brand_name=\\'Max Home\\' then \\'MXH\\'\\r\\nWHEN A.Brand_name=\\'Rite Window & Door\\' then \\'RTW\\'\\r\\nWHEN Brand_name=\\'Paradise Home Improvement\\' then \\'PHI\\'\\r\\nWhen Brand_name=\\'Home Smart\\' then \\'HSI\\'\\r\\nWHEN A.Brand_name=\\'Renuity\\' then \\'REN\\' END) or A.Contract_ID=J.ContractID\\r\\nleft join EDW.DIM_BRANCH B on A.Production_branch_name=B.LongName\\r\\nand B.Division=(case when A.Brand_name=\\'Mad City Windows & Baths\\' then \\'MAC\\'\\r\\nWHEN A.Brand_name=\\'Pacific Bath\\' then \\'PBC\\'\\r\\nWHEN A.Brand_name=\\'Statewide Remodeling\\' then \\'SWR\\'\\r\\nWHEN A.Brand_name=\\'FHIA Remodeling\\' then \\'FHI\\'\\r\\nWHEN A.Brand_name=\\'Max Home\\' then \\'MXH\\'\\r\\nWHEN A.Brand_name=\\'Rite Window & Door\\' then \\'RTW\\'\\r\\nWHEN Brand_name=\\'Paradise Home Improvement\\' then \\'PHI\\'\\r\\nWhen Brand_name=\\'Home Smart\\' then \\'HSI\\'\\r\\nWHEN A.Brand_name=\\'Renuity\\' then \\'REN\\' END)) M\\r\\nwhere M.Survey_ID is not null\\r\\n',",
				"     format: 'query',",
				"     staged: true) ~> MedalliaData",
				"MedalliaData derive(LastUpdateTS = currentTimestamp()) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     input(",
				"          Survey_ID as integer,",
				"          Response_Date as timestamp,",

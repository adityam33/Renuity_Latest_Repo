			"scriptLines": [
				"source(output(",
				"          Survey_ID as integer,",
				"          Response_Date as timestamp,",
				"          Program as string,",
				"          CustomerID as string,",
				"          LeadID as string,",
				"          SalesRep1_EmployeeID as string,",
				"          SalesRep2_EmployeeID as string,",
				"          BranchID as string,",
				"          ApptDate as timestamp,",
				"          ContractID as string,",
				"          Division as string,",
				"          InstallerID_1 as string,",
				"          InstallerID_2 as string,",
				"          InstallerID_3 as string,",
				"          InstallerID_4 as string,",
				"          Product_Line_InstallationExperience as string,",
				"          Date_To_Survey as timestamp,",
				"          Country as string,",
				"          Language as string,",
				"          Unit as string,",
				"          Sold as string,",
				"          DevelopmentCycle as string,",
				"          SalesOrganization as string,",
				"          Record_Type_Medallia_Conversations as string,",
				"          Main_Metric as string,",
				"          Service_Datetime as timestamp,",

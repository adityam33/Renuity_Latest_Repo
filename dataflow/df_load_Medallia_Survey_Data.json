				"          SurveyFlag as string,",
				"          ActiveInd as string,",
				"          updatedAt as timestamp,",
				"          LastActivityAt as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     preSQLs:['Delete from EDW.FACT_MEDALLIA_CUSTOMER_SURVEY where CAST(Response_Date as Date)>=CAST(DATEADD(dd,-1,CAST(SYSDATETIME() as DATE)) AS DATE)'],",
				"     dateFormat:'MM-dd-yyyy',",
				"     timestampFormat:'yyyy-MM-dd\\'T\\'HH:mm:ss.SSS\\'Z\\'',",
				"     booleanFormat: ['1', '0'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Survey_ID,",
				"          Response_Date,",
				"          Program,",
				"          CustomerID,",
				"          LeadID,",
				"          SalesRep1_EmployeeID,",
				"          SalesRep2_EmployeeID,",
				"          BranchID,",
				"          ApptDate,",

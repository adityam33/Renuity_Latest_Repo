				"          Experience as integer,",
				"          Satisfaction as integer,",
				"          Areas_For_Improvement as string,",
				"          Areas_Of_Satisfaction as string,",
				"          Testimonial as string,",
				"          Additional_Comments as string,",
				"          LP_CustomerID as string,",
				"          LP_LeadID as string,",
				"          LP_SalesRep1_EmployeeID as string,",
				"          LP_SalesRep2_EmployeeID as string,",
				"          LP_BranchID as string,",
				"          LP_ProductID as string,",
				"          LP_InstallerID_1 as string,",
				"          LP_InstallerID_2 as string,",
				"          LP_InstallerID_3 as string,",
				"          LP_InstallerID_4 as string,",
				"          LastUpdateTS as timestamp,",
				"          ReportingMarket_ID as string,",
				"          LP_ReportingMarket_ID as string,",
				"          LP_ReportingMarketTypeID as string,",
				"          ReportingMarketTypeID as string,",
				"          Medallia_AccountID as string,",
				"          Medallia_SalesRepID1 as string,",
				"          Medallia_ServiceTechID1 as string,",
				"          SalesRepActiveFlag as string,",
				"          Testimonial_Additional_Comments as string,",
				"          Demonstration_Additional_Comments as string,",
				"          Experience_Additional_Comments as string,",
				"          Likely_To_Recommend_Additional_Comments as string,",
				"          Satisfaction_Additional_Comments as string,",
				"          In_Home_Sales_Additional_Comments as string,",
				"          Install_Team_Additional_Comments as string,",
				"          Installation_Additional_Comments as string,",
				"          Area_For_Improvement_Additional_Comments as string,",
				"          Area_Of_Satisfaction_Additional_Comments as string,",
				"          Area_For_Improvement_Rating as string,",
				"          Area_Of_Satisfaction_Rating as string,",
				"          Template as string,",
				"          GuildQuality_Survey_Id as string,",
				"          Amount as decimal(19,4),",
				"          Survey_status as string,",
				"          Customer_Creation_Date as timestamp,",
				"          Project_Start_Date as timestamp,",
				"          Creationdate as timestamp,",
				"          Satisfaction_Score_in_Percentage as string,",
				"          Needs_Action as string,",
				"          Notes as string,",
				"          Google_Review_Boost as string,",
				"          VIP_Program_Awareness_Choice as string,",

				"          Channel,",
				"          ProductLine_InHomeConsultationExperience = Product_Line_InHomeConsultationExperience,",
				"          Social_Unit_ID,",
				"          On_Site_Quote_Satisfaction_Team_Score,",
				"          Reason_for_Score,",
				"          Sales_Understanding,",
				"          Sales_Communication,",
				"          Sales_Punctuality,",
				"          Sales_Professionalism,",
				"          Sales_Product_Knowledge,",
				"          Completeness_Of_Information,",
				"          Received_Quote,",
				"          Satisfaction_With_Quote,",
				"          Quote_Project_Start_Date,",
				"          Product_Demo,",
				"          Product_Demo_Benefits,",
				"          Reason_For_Not_Moving_Forward,",
				"          Decided_Against_Other,",
				"          Final_Comment,",
				"          Service_NPS,",
				"          Reasons_For_Your_Score,",
				"          Give_More_Feedback,",
				"          In_Home_Sales,",
				"          Install_Team,",
				"          Installation,",
				"          Product_Walkthrough,",
				"          Experience,",
				"          Satisfaction,",
				"          Area_For_Improvement,",
				"          Area_Of_Satisfaction,",
				"          Testimonial,",
				"          Additional_Comments,",
				"          LP_CustomerID,",
				"          LP_LeadID,",
				"          LP_SalesRep1_EmployeeID = LP_SalesRepEmployeeID_1,",
				"          LP_SalesRep2_EmployeeID = LP_SalesRepEmployeeID_2,",
				"          LP_BranchID,",
				"          LP_InstallerID_1,",
				"          LP_InstallerID_2,",
				"          LP_InstallerID_3,",
				"          LP_InstallerID_4,",
				"          LastUpdateTS,",
				"          ReportingMarket_ID = ReportingMarketID,",
				"          LP_ReportingMarket_ID = LP_ReportingMarketID,",
				"          LP_ReportingMarketTypeID,",
				"          ReportingMarketTypeID",
				"     )) ~> TargetFactMedallia"
			]
		}

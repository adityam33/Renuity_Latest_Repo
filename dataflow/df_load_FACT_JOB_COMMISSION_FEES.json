				"source(output(",
				"          ID as integer,",
				"          inq_id as integer,",
				"          lds_id as integer,",
				"          GCLID as string,",
				"          UTMAccount as string,",
				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",
				"          PropertyType as string,",
				"          UTMCampaignID as string,",
				"          UTMAdID as string,",
				"          UTMAdSetID as string,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string,",
				"          UnitCPL as string",

				"          inq_id as integer,",
				"          lds_id as integer,",
				"          GCLID as string,",
				"          UTMAccount as string,",
				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",

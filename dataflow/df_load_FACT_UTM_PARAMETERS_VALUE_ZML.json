				"          LeadID = concat(Division,'-',toString(LP_LeadID)),",
				"          GCLID = concat(Division,'-',toString(LP_GCLID)),",
				"          UTMCampaignID = concat(Division,'-',toString(LP_UTMCampaignID)),",
				"          UTMAdID = concat(Division,'-',toString(LP_UTMAdID)),",
				"          UTMAdsetID = concat(Division,'-',toString(LP_UTMAdSetID)),",
				"          LastUpdateTS = currentTimestamp(),",
				"          UnitCPL = toDecimal(replace(ltrim(rtrim(UnitCPL)),'$',''),16,4)) ~> derivedColumns",
				"MXH derive(Division = 'MXH') ~> addOpCoNameMXH",
				"CTA derive(Division = 'CTA') ~> addOpCoNameCTA",
				"derivedColumns, FactInboundQueueLog lookup(InboundQueueID == InboundQueueLogID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> LookupForDateReceived",

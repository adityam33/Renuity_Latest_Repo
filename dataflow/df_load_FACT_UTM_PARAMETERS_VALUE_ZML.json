				"          UTMCampaign,",
				"          UTMContent,",
				"          UTMTerm,",
				"          PropertyType,",
				"          LP_UTMCampaignID = UTMCampaignID,",
				"          LP_UTMAdID = UTMAdID,",
				"          LP_UTMAdSetID = UTMAdSetID,",
				"          Division,",
				"          MarketingID,",
				"          MarketingCustomerID,",
				"          GbraID,",
				"          UnitCPL,",

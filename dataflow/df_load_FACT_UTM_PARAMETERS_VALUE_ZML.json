				"          LP_UTMID,",
				"          LP_InboundQueueID,",
				"          LP_LeadID = selectRenameColumns@LP_LeadID,",
				"          LP_GCLID,",
				"          UTMAccount,",
				"          UTMMedium,",
				"          UTMSource,",
				"          UTMCampaign,",
				"          UTMContent,",
				"          UTMTerm,",
				"          PropertyType,",
				"          LP_UTMCampaignID,",
				"          LP_UTMAdID,",
				"          LP_UTMAdSetID,",
				"          Division = selectRenameColumns@Division,",
				"          MarketingID,",
				"          MarketingCustomerID,",
				"          GbraID,",
				"          UnitCPL,",
				"          UTMID,",
				"          InboundQueueID,",
				"          LeadID = derivedColumns@LeadID,",
				"          GCLID,",
				"          UTMCampaignID,",
				"          UTMAdID,",
				"          UTMAdsetID,",
				"          LastUpdateTS = derivedColumns@LastUpdateTS,",
				"          DateReceived,",
				"          ProductSubCategory1,",
				"          ProductSubCategory2,",
				"          TrustedFormURL,",
				"          InternalMarketingId",

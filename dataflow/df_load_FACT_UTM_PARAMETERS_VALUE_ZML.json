				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",
				"          PropertyType as string,",
				"          UTMCampaignID as string,",
				"          UTMAdID as string,",
				"          UTMAdSetID as string,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string,",
				"          UnitCPL as decimal(16,4),",
				"          LP_UTMID as integer,",
				"          LP_InboundQueueID as integer,",
				"          LP_LeadID as integer,",
				"          LP_GCLID as string,",
				"          LP_UTMCampaignID as string,",
				"          LP_UTMAdID as string,",
				"          LP_UTMAdSetID as string,",
				"          Division as string,",
				"          LastUpdateTS as timestamp,",
				"          DateReceived as timestamp,",

				"          InboundQueueID,",
				"          LeadID,",
				"          GCLID,",
				"          UTMAccount,",
				"          UTMMedium,",
				"          UTMSource,",
				"          UTMCampaign,",
				"          UTMContent,",
				"          UTMTerm,",
				"          PropertyType,",
				"          UTMCampaignID,",
				"          UTMAdID,",
				"          UTMAdSetID = UTMAdsetID,",
				"          MarketingID,",
				"          MarketingCustomerID,",
				"          GbraID,",
				"          UnitCPL,",
				"          LP_UTMID,",
				"          LP_InboundQueueID,",
				"          LP_LeadID,",
				"          LP_GCLID,",
				"          LP_UTMCampaignID,",

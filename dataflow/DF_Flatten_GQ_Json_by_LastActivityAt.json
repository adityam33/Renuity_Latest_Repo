{
	"name": "DF_Flatten_GQ_Json_by_LastActivityAt",
	"properties": {
		"folder": {
			"name": "Test-Dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "GQ_survey_By_LastActivityAt",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "test_GUILD_QUALITY_CUSTOMER_SURVEy_1",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "flattenDataArray"
				},
				{
					"name": "FlattenQuestion"
				},
				{
					"name": "pivot1"
				},
				{
					"name": "FlattenQuestions"
				},
				{
					"name": "pivot2"
				},
				{
					"name": "MapDrifted1",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "MapDrifted2",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "join1"
				},
				{
					"name": "flattenDealers"
				},
				{
					"name": "MapDrifted3",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "flattenInstaller"
				},
				{
					"name": "flattenProjectType"
				},
				{
					"name": "flattenUsers"
				},
				{
					"name": "DCUsersName"
				},
				{
					"name": "MapDrifted4",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "join2"
				},
				{
					"name": "join3"
				},
				{
					"name": "join4"
				},
				{
					"name": "join5"
				},
				{
					"name": "join6"
				},
				{
					"name": "AlterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          data as (company as (customCompanyId as string, id as integer, name as string), completionMode as string, contact as (createdAt as string, email1 as string, email2 as string, id as integer, name as string, phone1 as string, phone2 as string, updatedAt as string), createdAt as string, endedAt as string, id as integer, lastActivityAt as string, lastResponseMethod as string, project as (address as string, city as string, createdAt as string, customFilters as ({Dealer Name} as string[], {Installer 1} as string[], {Product ID} as string[], {Project Type} as string[]), endDate as date, externalId as string, id as integer, leadDate as date, notes as string, startDate as date, state as string, updatedAt as string, users as (firstName as string, id as integer, lastName as string, roles as string[])[], value as double, zip as integer), questions as (comment as string, id as integer, name as string, order as short, published as boolean, questionId as short, rating as short, ratingScale as string, response as boolean[], type as string)[], sendAt as string, status as string, surveyTakeUrl as string, template as string, updatedAt as string)[]",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'documentPerLine') ~> source1",
				"source1 foldDown(unroll(data, data),",
				"     mapColumn(",
				"          data",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenDataArray",
				"source1 foldDown(unroll(data.questions, data),",
				"     mapColumn(",
				"          comment = data.questions.comment,",
				"          SurveyID = data.id,",
				"          name = data.questions.name,",
				"          order = data.questions.order,",
				"          published = data.questions.published,",
				"          questionId = data.questions.questionId,",
				"          rating = data.questions.rating,",
				"          ratingScale = data.questions.ratingScale,",
				"          response = data.questions.response,",
				"          type = data.questions.type",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> FlattenQuestion",
				"FlattenQuestion pivot(groupBy(SurveyID),",
				"     pivotBy(name),",
				"     Pivot = sum(toInteger(rating)),",
				"     columnNaming: '$N$V',",
				"     lateral: true) ~> pivot1",
				"source1 foldDown(unroll(data.questions, data),",
				"     mapColumn(",
				"          SurveyId = data.id,",
				"          name = data.questions.name,",
				"          comment = data.questions.comment,",
				"          rating = data.questions.rating",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> FlattenQuestions",
				"FlattenQuestions pivot(groupBy(SurveyId),",
				"     pivotBy(name),",
				"     pivot = max(toString(comment)),",
				"     columnNaming: '$N$V',",
				"     lateral: true) ~> pivot2",
				"pivot2 derive({pivotAdditional Comments} = toString(byName('pivotAdditional Comments')),",
				"          {pivotArea For Improvement} = toString(byName('pivotArea For Improvement')),",
				"          {pivotArea of Satisfaction} = toString(byName('Areas_Of_Satisfaction_Comment')),",
				"          {pivotArea(s) For Improvement} = toString(byName('pivotArea(s) For Improvement')),",
				"          {pivotArea(s) Of Satisfaction} = toString(byName('pivotArea(s) Of Satisfaction')),",
				"          {pivotAreas For Improvement} = toString(byName('pivotAreas For Improvement')),",
				"          {pivotAreas Of Satisfaction} = toString(byName('pivotAreas Of Satisfaction')),",
				"          pivotDemo = toString(byName('pivotDemo')),",
				"          pivotDemonstration = toString(byName('pivotDemonstration')),",
				"          pivotExperience = toString(byName('pivotExperience')),",
				"          {pivotIn Home Sales} = toString(byName('pivotIn Home Sales')),",
				"          {pivotIn-Home Sales} = toString(byName('pivotIn-Home Sales')),",
				"          {pivotInstall Team} = toString(byName('pivotInstall Team')),",
				"          pivotInstallation = toString(byName('pivotInstallation')),",
				"          {pivotInstallation Quality} = toString(byName('pivotInstallation Quality')),",
				"          {pivotLikely To Recommend} = toString(byName('pivotLikely To Recommend')),",
				"          {pivotLikely to Recommend} = toString(byName('pivotLikely to Recommend')),",
				"          {pivotProduct Walkthrough} = toString(byName('pivotProduct Walkthrough')),",
				"          pivotReason = toString(byName('pivotReason')),",
				"          pivotRecommendation = toString(byName('pivotRecommendation')),",
				"          pivotSatisfaction = toString(byName('pivotSatisfaction')),",
				"          pivotTestimonial = toString(byName('pivotTestimonial')),",
				"          {pivotVIP Program Awareness} = toString(byName('pivotVIP Program Awareness'))) ~> MapDrifted1",
				"pivot1 derive({PivotAdditional Comments} = toLong(byName('PivotAdditional Comments')),",
				"          {PivotArea For Improvement} = toLong(byName('PivotArea For Improvement')),",
				"          {PivotArea of Satisfaction} = toLong(byName('PivotArea of Satisfaction')),",
				"          {PivotArea(s) For Improvement} = toLong(byName('PivotArea(s) For Improvement')),",
				"          {PivotArea(s) Of Satisfaction} = toLong(byName('PivotArea(s) Of Satisfaction')),",
				"          {PivotAreas For Improvement} = toLong(byName('PivotAreas For Improvement')),",
				"          {PivotAreas Of Satisfaction} = toLong(byName('PivotAreas Of Satisfaction')),",
				"          PivotDemo = toLong(byName('PivotDemo')),",
				"          PivotDemonstration = toLong(byName('PivotDemonstration')),",
				"          PivotExperience = toLong(byName('PivotExperience')),",
				"          {PivotIn Home Sales} = toLong(byName('PivotIn Home Sales')),",
				"          {PivotIn-Home Sales} = toLong(byName('PivotIn-Home Sales')),",
				"          {PivotInstall Team} = toLong(byName('PivotInstall Team')),",
				"          PivotInstallation = toLong(byName('PivotInstallation')),",
				"          {PivotInstallation Quality} = toLong(byName('PivotInstallation Quality')),",
				"          {PivotLikely To Recommend} = toLong(byName('PivotLikely To Recommend')),",
				"          {PivotLikely to Recommend} = toLong(byName('PivotLikely to Recommend')),",
				"          {PivotProduct Walkthrough} = toLong(byName('PivotProduct Walkthrough')),",
				"          PivotReason = toLong(byName('PivotReason')),",
				"          PivotRecommendation = toLong(byName('PivotRecommendation')),",
				"          PivotSatisfaction = toLong(byName('PivotSatisfaction')),",
				"          PivotTestimonial = toLong(byName('PivotTestimonial')),",
				"          {PivotVIP Program Awareness} = toLong(byName('PivotVIP Program Awareness'))) ~> MapDrifted2",
				"MapDrifted1, MapDrifted2 join(pivot2@SurveyId == pivot1@SurveyID,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"source1 foldDown(unroll(data.project.customFilters.{Dealer Name}, data),",
				"     mapColumn(",
				"          {Dealer Name} = data.project.customFilters.{Dealer Name},",
				"          SurveyId = data.id",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenDealers",
				"flattenDealers derive({Dealer Name} = toString(byName('Dealer Name'))) ~> MapDrifted3",
				"source1 foldDown(unroll(data.project.customFilters.{Installer 1}, data),",
				"     mapColumn(",
				"          Installer1 = data.project.customFilters.{Installer 1},",
				"          SurveyId = data.id",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenInstaller",
				"source1 foldDown(unroll(data.project.customFilters.{Project Type}),",
				"     mapColumn(",
				"          ProjectType = data.project.customFilters.{Project Type},",
				"          SurveyId = data.id",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenProjectType",
				"source1 foldDown(unroll(data.project.users, data),",
				"     mapColumn(",
				"          SurveyId = data.id,",
				"          firstName = data.project.users.firstName,",
				"          lastName = data.project.users.lastName",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenUsers",
				"MapDrifted4 derive(UserFullName = firstName +\" \"+lastName) ~> DCUsersName",
				"flattenUsers derive(SurveyId = toInteger(byName('SurveyId')),",
				"          firstName = toString(byName('firstName')),",
				"          lastName = toString(byName('lastName'))) ~> MapDrifted4",
				"flattenDataArray, MapDrifted3 join(data.id == SurveyId,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2, DCUsersName join(data.id == MapDrifted4@SurveyId,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3, flattenInstaller join(data.id == flattenInstaller@SurveyId,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join4",
				"join4, flattenProjectType join(data.id == flattenProjectType@SurveyId,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join5",
				"join5, join1 join(data.id == pivot2@SurveyId,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join6",
				"join6 alterRow(upsertIf(!isNull(data.id)),",
				"     insertIf(isNull(data.id))) ~> AlterRow1",
				"AlterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Survey_ID as integer,",
				"          Response_Date as string,",
				"          Program as string,",
				"          Development_Cycle as string,",
				"          Brand as string,",
				"          Template as string,",
				"          Old_Survey_Id as string,",
				"          Contact as string,",
				"          Address as string,",
				"          City as string,",
				"          State as string,",
				"          Zip as string,",
				"          Email as string,",
				"          Phone as string,",
				"          External_Id as string,",
				"          Value as decimal(16,2),",
				"          Surveystatus as string,",
				"          ContactCreationDate as string,",
				"          ProjectStartDate as string,",
				"          ServiceDate as string,",
				"          Creationdate as string,",
				"          Channel as string,",
				"          SatisfactionScore as string,",
				"          SalesRepresentative as string,",
				"          In_Home_Sales_Rating as string,",
				"          In_Home_Sales_Comments as string,",
				"          Install_Team_Rating as string,",
				"          Install_Team_Comments as string,",
				"          Installation_Rating as string,",
				"          Installation_Comments as string,",
				"          Product_Walkthrough as string,",
				"          Demonstration as string,",
				"          Experience_Rating as string,",
				"          Experience_Comments as string,",
				"          Service_NPS as string,",
				"          Likely_To_Recommend as string,",
				"          Satisfaction_Rating as string,",
				"          Satisfaction_Comments as string,",
				"          Area_for_Improvement as string,",
				"          Area_of_Satisfaction as string,",
				"          Testimonial as string,",
				"          Testimonial_Comments as string,",
				"          Additional_Comments as string,",
				"          Areas_For_Improvement_Rating as string,",
				"          Areas_For_Improvement_Comment as string,",
				"          Areas_Of_Satisfaction_Rating as string,",
				"          Areas_Of_Satisfaction_Comment as string,",
				"          SecondaryEmail as string,",
				"          SecondaryPhone as string,",
				"          NeedsAction as string,",
				"          Notes as string,",
				"          GoogleReviewBoost as string,",
				"          VIPProgramAwarenessChoice as string,",
				"          VIPProgramAwarenessComment as string,",
				"          Testimonial_Choice as string,",
				"          Testimonial_Comment as string,",
				"          ReferralProgramAwareness_Choice as string,",
				"          ReferralProgramAwareness_Comment as string,",
				"          Technician1 as string,",
				"          URL as string,",
				"          Dealer_Name as string,",
				"          UserFullName as string,",
				"          projectType as string,",
				"          surveyEnddate as string,",
				"          role as string,",
				"          completionMode as string,",
				"          LastresponseMethod as string,",
				"          updatedAt as string,",
				"          lastActivityAt as string",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['Survey_ID'],",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Survey_ID = data.id,",
				"          updatedAt = data.updatedAt,",
				"          lastActivityAt = data.lastActivityAt,",
				"          Response_Date = data.sendAt,",
				"          ServiceDate = data.project.endDate,",
				"          Brand = data.company.name,",
				"          Template = data.template,",
				"          Contact = data.contact.name,",
				"          Address = data.project.address,",
				"          City = data.project.city,",
				"          State = data.project.state,",
				"          Zip = data.project.zip,",
				"          Email = data.contact.email1,",
				"          Phone = data.contact.phone1,",
				"          External_Id = data.project.externalId,",
				"          Value = data.project.value,",
				"          Surveystatus = data.status,",
				"          ContactCreationDate = data.contact.createdAt,",
				"          ProjectStartDate = data.project.leadDate,",
				"          Creationdate = data.createdAt,",
				"          SalesRepresentative = data.project.users[1].firstName,",
				"          SecondaryEmail = data.contact.email2,",
				"          SecondaryPhone = data.contact.phone2,",
				"          Notes = data.project.notes,",
				"          Technician1 = Installer1,",
				"          URL = data.surveyTakeUrl,",
				"          Dealer_Name = {Dealer Name},",
				"          UserFullName,",
				"          projectType = ProjectType,",
				"          Additional_Comments = MapDrifted1@{pivotAdditional Comments},",
				"          Area_for_Improvement = MapDrifted1@{pivotAreas For Improvement},",
				"          Area_of_Satisfaction = MapDrifted1@{pivotAreas Of Satisfaction},",
				"          Experience_Comments = MapDrifted1@pivotExperience,",
				"          In_Home_Sales_Comments = MapDrifted1@{pivotIn-Home Sales},",
				"          Install_Team_Comments = MapDrifted1@{pivotInstall Team},",
				"          Installation_Comments = MapDrifted1@pivotInstallation,",
				"          Testimonial_Comment = MapDrifted1@pivotTestimonial,",
				"          VIPProgramAwarenessComment = MapDrifted1@{pivotVIP Program Awareness},",
				"          Areas_Of_Satisfaction_Rating = MapDrifted2@{PivotAreas Of Satisfaction},",
				"          Demonstration = MapDrifted1@pivotDemonstration,",
				"          Experience_Rating = MapDrifted2@PivotExperience,",
				"          In_Home_Sales_Rating = MapDrifted2@{PivotIn-Home Sales},",
				"          Install_Team_Rating = MapDrifted2@{PivotInstall Team},",
				"          Installation_Rating = MapDrifted2@PivotInstallation,",
				"          Likely_To_Recommend = MapDrifted1@{pivotLikely To Recommend},",
				"          Product_Walkthrough = MapDrifted2@PivotDemonstration,",
				"          SatisfactionScore = MapDrifted2@PivotSatisfaction,",
				"          Testimonial_Choice = MapDrifted2@PivotTestimonial,",
				"          surveyEnddate = data.endedAt,",
				"          role = data.project.users[1].roles,",
				"          LastresponseMethod = data.lastResponseMethod,",
				"          completionMode = data.completionMode,",
				"          Areas_For_Improvement_Comment = MapDrifted1@{pivotAreas For Improvement},",
				"          Areas_For_Improvement_Rating = MapDrifted2@{PivotAreas For Improvement},",
				"          Satisfaction_Comments = MapDrifted1@pivotSatisfaction,",
				"          Satisfaction_Rating = MapDrifted2@PivotSatisfaction,",
				"          VIPProgramAwarenessChoice = MapDrifted2@{PivotVIP Program Awareness},",
				"          Areas_Of_Satisfaction_Comment = MapDrifted1@{pivotAreas Of Satisfaction},",
				"          Service_NPS = MapDrifted2@{PivotLikely To Recommend},",
				"          Channel = data.completionMode,",
				"          Program = data.template",
				"     )) ~> sink1"
			]
		}
	}
}
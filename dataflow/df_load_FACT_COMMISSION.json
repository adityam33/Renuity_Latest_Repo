				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          CommissionID = concat(Division,'-',toString(LP_CommissionID)),",
				"          JobID = concat(Division,'-',toString(LP_JobID)),",
				"          CommissionPaymentTypeID = concat(Division,'-',toString(LP_CommissionPaymentTypeID)),",
				"          SalesRepID = concat(Division,'-',toString(LP_SalesRepID))) ~> derivedColumns",
				"MXH derive(Division = 'MXH') ~> addOpCoNameMXH",
				"CTA derive(Division = 'CTA') ~> addOpCoNameCTA",
				"derivedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CommissionID as string,",
				"          JobID as string,",
				"          CommissionPaymentTypeID as string,",
				"          SalesRepID as string,",
				"          PaymentAmount as decimal(38,18),",
				"          BatchFlag as boolean,",
				"          BatchNumber as integer,",
				"          BatchDate as timestamp,",
				"          CoCode as string,",
				"          FileNumber as string,",
				"          Comments as string,",
				"          EnteredOn as timestamp,",
				"          EnteredBy as integer,",
				"          UpdatedOn as timestamp,",
				"          UpdatedBy as integer,",
				"          LP_CommissionID as integer,",
				"          LP_JobID as integer,",
				"          LP_CommissionPaymentTypeID as integer,",

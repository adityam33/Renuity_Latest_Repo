{
	"name": "df_load_DIM_DISPOSITION_CATEGORY_Regular_Instance",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SRC_ODS_LP_FHI_dct_DispositionCategories_Regular_Instance",
						"type": "DatasetReference"
					},
					"name": "FHI"
				},
				{
					"dataset": {
						"referenceName": "SRC_ODS_LP_MAC_dct_DispositionCategories_Regular_Instance",
						"type": "DatasetReference"
					},
					"name": "MAC"
				},
				{
					"dataset": {
						"referenceName": "SRC_ODS_LP_SWR_dct_DispositionCategories_Regular_Instance",
						"type": "DatasetReference"
					},
					"name": "SWR"
				},
				{
					"dataset": {
						"referenceName": "SRC_ODS_LP_RTW_dct_DispositionCategories_Regular_Instance",
						"type": "DatasetReference"
					},
					"name": "RTW"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_DISPOSITION_CATEGORY_Regular_Instance",
						"type": "DatasetReference"
					},
					"name": "targetDim",
					"description": "Export data to EDW_DIM_DISPOSITION_CATEGORY",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "selectColsFHI"
				},
				{
					"name": "createIDsFHI"
				},
				{
					"name": "selectColsMAC"
				},
				{
					"name": "selectSWR"
				},
				{
					"name": "createIDsMAC"
				},
				{
					"name": "createIDsSWR"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "addLastUpdateTimestamp"
				},
				{
					"name": "selectRTW"
				},
				{
					"name": "createIDsRTW"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as integer,",
				"          Descr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"source(output(",
				"          ID as integer,",
				"          Descr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MAC",
				"source(output(",
				"          ID as integer,",
				"          Descr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          ID as integer,",
				"          Descr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"FHI select(mapColumn(",
				"          LP_DispositionCategoryID = ID,",
				"          DispositionCategory = Descr",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(DispositionCategoryID = concat('FHI-',toString(LP_DispositionCategoryID)),",
				"          Division = 'FHI') ~> createIDsFHI",
				"MAC select(mapColumn(",
				"          LP_DispositionCategoryID = ID,",
				"          DispositionCategory = Descr",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsMAC",
				"SWR select(mapColumn(",
				"          LP_DispositionCategoryID = ID,",
				"          DispositionCategory = Descr",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectSWR",
				"selectColsMAC derive(DispositionCategoryID = concat('MAC-',toString(LP_DispositionCategoryID)),",
				"          Division = 'MAC') ~> createIDsMAC",
				"selectSWR derive(DispositionCategoryID = concat('SWR-',toString(LP_DispositionCategoryID)),",
				"          Division = 'SWR') ~> createIDsSWR",
				"createIDsFHI, createIDsMAC, createIDsSWR, createIDsRTW union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(LastUpdateTS = currentTimestamp()) ~> addLastUpdateTimestamp",
				"RTW select(mapColumn(",
				"          LP_DispositionCategoryID = ID,",
				"          DispositionCategory = Descr",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRTW",
				"selectRTW derive(DispositionCategoryID = concat('RTW-',toString(LP_DispositionCategoryID)),",
				"          Division = 'RTW') ~> createIDsRTW",
				"addLastUpdateTimestamp alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          DispositionCategoryID as string,",
				"          DispositionCategory as string,",
				"          LP_DispositionCategoryID as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['DispositionCategoryID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_DispositionCategoryID,",
				"          DispositionCategory,",
				"          DispositionCategoryID,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
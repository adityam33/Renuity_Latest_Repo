{
	"name": "DF_Prod_Flatten_GQ_Json_Table",
	"properties": {
		"folder": {
			"name": "Test-Dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Prod_GQ_Survey_Json_Source",
						"type": "DatasetReference"
					},
					"name": "sourceJSON"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "AD_API_linkedservice",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "flattenDataArray"
				},
				{
					"name": "FlattenQuestion"
				},
				{
					"name": "pivotRowsIntoCols"
				},
				{
					"name": "flattenUsers"
				},
				{
					"name": "UsersFullName"
				},
				{
					"name": "joinwithCustomFilters"
				},
				{
					"name": "JoinwithUsers"
				},
				{
					"name": "joinwithQuestions"
				},
				{
					"name": "flattenCustomFilters"
				},
				{
					"name": "MapDriftedUsers",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "Questions",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "selectcols"
				},
				{
					"name": "selectcols2"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          data as (company as (customCompanyId as string, id as integer, name as string), completionMode as string, contact as (createdAt as string, email1 as string, email2 as string, id as integer, name as string, phone1 as string, phone2 as string, updatedAt as string), createdAt as string, endedAt as string, id as integer, lastActivityAt as string, lastResponseMethod as string, project as (address as string, city as string, createdAt as string, customFilters as (AccountID as integer[], Language as string[], LeadID as integer[], {Product Line} as string[], {Sales Organization} as string[], Sold as boolean[]), endDate as string, externalId as string, id as integer, leadDate as date, notes as string, startDate as string, state as string, updatedAt as string, users as (firstName as string, id as integer, lastName as string, roles as string[])[], value as double, zip as string), questions as (comment as string, id as integer, name as string, order as short, published as boolean, questionId as short, rating as string, ratingScale as string, response as string[], type as string)[], sendAt as string, status as string, surveyTakeUrl as string, template as string, updatedAt as string)[]",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> sourceJSON",
				"sourceJSON foldDown(unroll(data, data),",
				"     mapColumn(",
				"          data",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenDataArray",
				"sourceJSON foldDown(unroll(data.questions, data),",
				"     mapColumn(",
				"          comment = data.questions.comment,",
				"          SurveyID = data.id,",
				"          name = data.questions.name,",
				"          order = data.questions.order,",
				"          published = data.questions.published,",
				"          questionId = data.questions.questionId,",
				"          rating = data.questions.rating,",
				"          ratingScale = data.questions.ratingScale,",
				"          type = data.questions.type",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> FlattenQuestion",
				"FlattenQuestion pivot(groupBy(SurveyID),",
				"     pivotBy(name),",
				"     {} = toInteger(max(rating)),",
				"     columnNaming: 'Cal_$N$V',",
				"     lateral: false) ~> pivotRowsIntoCols",
				"sourceJSON foldDown(unroll(data.project.users, data),",
				"     mapColumn(",
				"          SurveyId = data.id,",
				"          firstName = data.project.users.firstName,",
				"          lastName = data.project.users.lastName,",
				"          roles = data.project.users.roles",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenUsers",
				"MapDriftedUsers derive(UserFullName = firstName +\" \"+lastName) ~> UsersFullName",
				"flattenDataArray, flattenCustomFilters join(data.id == Surveyid,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinwithCustomFilters",
				"selectcols, UsersFullName join(selectcols@SurveyID == flattenUsers@SurveyId,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinwithUsers",
				"JoinwithUsers, Questions join(selectcols@SurveyID == pivotRowsIntoCols@SurveyID,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinwithQuestions",
				"sourceJSON foldDown(unroll(data.project.customFilters.AccountID, data),",
				"     mapColumn(",
				"          AccountID = data.project.customFilters.AccountID,",
				"          Surveyid = data.id,",
				"          Language = data.project.customFilters.Language,",
				"          Sold = data.project.customFilters.Sold,",
				"          LeadID = data.project.customFilters.LeadID,",
				"          ProductLine = data.project.customFilters.{Product Line},",
				"          SalesOrganization = data.project.customFilters.{Sales Organization}",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flattenCustomFilters",
				"flattenUsers derive(firstName = toString(byName('firstName')),",
				"          lastName = toString(byName('lastName')),",
				"          roles = array(byName('roles'))) ~> MapDriftedUsers",
				"pivotRowsIntoCols derive({Additional Comments} = toInteger(byName('Cal_Additional Comments')),",
				"          Communication = toInteger(byName('Cal_Communication')),",
				"          Information = toInteger(byName('Cal_Information')),",
				"          Needs = toInteger(byName('Cal_Needs')),",
				"          {Physical Product} = toInteger(byName('Cal_Physical Product')),",
				"          {Product Knowledge} = toInteger(byName('Cal_Product Knowledge')),",
				"          Professionalism = toInteger(byName('Cal_Professionalism')),",
				"          Quote = toInteger(byName('Cal_Quote')),",
				"          Satisfaction = toInteger(byName('Cal_Satisfaction')),",
				"          {Satisfied with Quote} = toInteger(byName('Cal_Satisfied with Quote')),",
				"          Service = toInteger(byName('Cal_Service')),",
				"          Cal_Time = toInteger(byName('Cal_Time'))) ~> Questions",
				"joinwithCustomFilters select(mapColumn(",
				"          SurveyID = data.id,",
				"          AccountID,",
				"          Language,",
				"          Sold,",
				"          LeadID,",
				"          ProductLine,",
				"          SalesOrganization,",
				"          customCompanyId = data.company.customCompanyId,",
				"          Companyname = data.company.name,",
				"          ContactcreatedAt = data.contact.createdAt,",
				"          Contactemail1 = data.contact.email1,",
				"          Contactemail2 = data.contact.email2,",
				"          Contactname = data.contact.name,",
				"          Contactphone1 = data.contact.phone1,",
				"          Contactphone2 = data.contact.phone2,",
				"          createdAt = data.createdAt,",
				"          endedAt = data.endedAt,",
				"          lastActivityAt = data.lastActivityAt,",
				"          lastResponseMethod = data.lastResponseMethod,",
				"          ProjectendDate = data.project.endDate,",
				"          externalId = data.project.externalId,",
				"          ProjectleadDate = data.project.leadDate,",
				"          sendAt = data.sendAt,",
				"          status = data.status,",
				"          surveyTakeUrl = data.surveyTakeUrl,",
				"          template = data.template,",
				"          contact = data.updatedAt,",
				"          completionMode = data.completionMode,",
				"          Projectaddress = data.project.address,",
				"          ProjectCity = data.project.city,",
				"          ProjectcreatedAt = data.project.createdAt,",
				"          ProjectStartDate = data.project.startDate,",
				"          ProjectState = data.project.state,",
				"          ProjectupdatedAt = data.project.updatedAt",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectcols",
				"derivedColumn1 select(mapColumn(",
				"          SurveyID = selectcols@SurveyID,",
				"          AccountID,",
				"          Language,",
				"          Sold,",
				"          LeadID,",
				"          ProductLine,",
				"          SalesOrganization,",
				"          customCompanyId,",
				"          Companyname,",
				"          ContactcreatedAt,",
				"          Contactemail1,",
				"          Contactemail2,",
				"          Contactname,",
				"          Contactphone1,",
				"          Contactphone2,",
				"          createdAt,",
				"          endedAt,",
				"          lastActivityAt,",
				"          lastResponseMethod,",
				"          ProjectendDate,",
				"          externalId,",
				"          ProjectleadDate,",
				"          sendAt,",
				"          status,",
				"          surveyTakeUrl,",
				"          template,",
				"          contact,",
				"          completionMode,",
				"          Projectaddress,",
				"          ProjectCity,",
				"          ProjectcreatedAt,",
				"          ProjectStartDate,",
				"          ProjectState,",
				"          ProjectupdatedAt,",
				"          firstName,",
				"          lastName,",
				"          roles,",
				"          UserFullName,",
				"          Communication,",
				"          Information,",
				"          Needs,",
				"          Professionalism,",
				"          Quote,",
				"          Satisfaction,",
				"          Service,",
				"          Cal_Time,",
				"          AdditionalComments,",
				"          PhysicalProduct,",
				"          ProductKnowledge,",
				"          SatisfiedwithQuote",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectcols2",
				"joinwithQuestions derive(Language = toString(Language),",
				"          Sold = toString(Sold),",
				"          LeadID = toString(LeadID),",
				"          ProductLine = toString(ProductLine),",
				"          SalesOrganization = toString(SalesOrganization),",
				"          roles = toString(roles),",
				"          AdditionalComments = {Additional Comments},",
				"          PhysicalProduct = {Physical Product},",
				"          ProductKnowledge = {Product Knowledge},",
				"          SatisfiedwithQuote = {Satisfied with Quote}) ~> derivedColumn1",
				"sourceJSON sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:false,",
				"     timeout: 30,",
				"     requestInterval: 0,",
				"     truncate: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table') ~> sink1"
			]
		}
	}
}
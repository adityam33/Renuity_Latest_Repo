				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> PBC",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MAC",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> HSI",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MXH",
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> CTA",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"PBC derive(Division = 'PBC') ~> addOpCoNamePBC",
				"RTW derive(Division = 'RTW') ~> addOpCoNameRTW",
				"MAC derive(Division = 'MAC') ~> addOpCoNameMAC",
				"SWR derive(Division = 'SWR') ~> addOpCoNameSWR",
				"HSI derive(Division = 'HSI') ~> addOpCoNameHSI",
				"addOpCoNameFHI, addOpCoNamePBC, addOpCoNameRTW, addOpCoNameMAC, addOpCoNameSWR, addOpCoNameHSI, addOpCoNameMXH, addOpCoNameCTA union(byName: true)~> unionAllOpCos",
				"unionAllOpCos select(mapColumn(",
				"          LP_MarketingCostCategoryId = id,",
				"          Description = Descr,",
				"          Active,",
				"          SortOrder,",
				"          Division",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          MarketingCostCategoryID = concat(Division,'-',toString(LP_MarketingCostCategoryId))) ~> derivedColumns",
				"MXH derive(Division = 'MXH') ~> addOpCoNameMXH",
				"CTA derive(Division = 'CTA') ~> addOpCoNameCTA",
				"derivedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          MarketingCostCategoryId as string,",
				"          Description as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          LP_MarketingCostCategoryId as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          MarketingCostCategoryId = MarketingCostCategoryID,",
				"          Description,",
				"          Active,",
				"          SortOrder,",
				"          LP_MarketingCostCategoryId,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetFact"
			]
		}

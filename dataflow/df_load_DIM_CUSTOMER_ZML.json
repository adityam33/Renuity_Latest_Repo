{
	"name": "df_load_DIM_CUSTOMER_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_cst_Customers",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_CUSTOMER_ZML",
						"type": "DatasetReference"
					},
					"name": "targetDim",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "selectColsFHI"
				},
				{
					"name": "createIDsFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "addLastUpdateTimestamp"
				},
				{
					"name": "cleanColumns"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          CustNumber as string,",
				"          nmp_Descr as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          nms_Descr as string,",
				"          Address1 as string,",
				"          Address2 as string,",
				"          City as string,",
				"          State as string,",
				"          Zip as string,",
				"          Zip4 as string,",
				"          Phone as string,",
				"          Email as string,",
				"          DateAdded as timestamp,",
				"          AddedBy as integer,",
				"          LastChanged as timestamp,",
				"          LastChangedBy as integer,",
				"          Directions as string,",
				"          CallMorning as boolean,",
				"          CalLAfternoon as boolean,",
				"          CallEvening as boolean,",
				"          CallWeekend as boolean,",
				"          dnc_id as string,",
				"          intdnc as string,",
				"          Rev as integer,",
				"          QBRefID as string,",
				"          QBDate as timestamp,",
				"          QBBalance as decimal(19,4),",
				"          MailingAddress1 as string,",
				"          MailingAddress2 as string,",
				"          MailingCity as string,",
				"          MailingState as string,",
				"          MailingZip as string,",
				"          MailingZip4 as string,",
				"          Email2 as string,",
				"          cst_user_1 as string,",
				"          cst_user_2 as string,",
				"          cst_user_3 as string,",
				"          cst_user_4 as string,",
				"          cst_user_5 as string,",
				"          cst_user_6 as timestamp,",
				"          cst_user_7 as timestamp,",
				"          cst_user_8 as timestamp,",
				"          cst_user_9 as timestamp,",
				"          cst_user_10 as timestamp,",
				"          cst_user_11 as decimal(19,4),",
				"          cst_user_12 as decimal(19,4),",
				"          cst_user_13 as decimal(19,4),",
				"          cst_user_14 as decimal(19,4),",
				"          cst_user_15 as decimal(19,4),",
				"          cst_user_16 as integer,",
				"          cst_user_17 as integer,",
				"          cst_user_18 as integer,",
				"          cst_user_19 as integer,",
				"          cst_user_20 as integer,",
				"          bld_id as integer,",
				"          Latitude as double,",
				"          Longitude as double,",
				"          LLSource as string,",
				"          LLDate as timestamp,",
				"          mpnt_id as integer,",
				"          QBXML as string,",
				"          anr_matchscore as decimal(19,4),",
				"          cst_user_2_CAL as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT *,\\nCASE WHEN cst_user_2 IN (\\'A\\',\\'B\\',\\'C\\',\\'D\\',\\'U\\') THEN cst_user_2 ELSE NULL END AS cst_user_2_CAL\\nFROM [ODS].[LP_FHI_cst_Customers]',",
				"     format: 'query',",
				"     staged: true) ~> FHI",
				"FHI select(mapColumn(",
				"          LP_CustomerID = id,",
				"          LP_LeadID = CustNumber,",
				"          FirstName,",
				"          LastName,",
				"          City,",
				"          State,",
				"          Zip,",
				"          Zip4,",
				"          Phone,",
				"          Email,",
				"          LP_DateAdded = DateAdded,",
				"          LP_LastChanged = LastChanged,",
				"          CallMorning,",
				"          CalLAfternoon,",
				"          CallEvening,",
				"          CallWeekend,",
				"          Address1,",
				"          Address2,",
				"          Directions,",
				"          CreditRating = cst_user_2_CAL",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(CustomerID = concat('FHI-',toString(LP_CustomerID)),",
				"          Division = 'FHI',",
				"          LeadID = concat('FHI-',toString(LP_LeadID))) ~> createIDsFHI",
				"createIDsFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(LastUpdateTS = currentTimestamp()) ~> addLastUpdateTimestamp",
				"addLastUpdateTimestamp derive(Phone = left(rtrim(ltrim(replace(replace(replace(replace(replace(Phone, '-', ''), ')', ''), '(', ''), ' ', ''), '.', ''))),10),",
				"          Zip = left(rtrim(ltrim(Zip)),5),",
				"          EXP_LP_leadID = 'NULL',",
				"          EXP_LeadID = 'NULL') ~> cleanColumns",
				"cleanColumns alterRow(upsertIf(true())) ~> alterRow1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerID as string,",
				"          LeadID as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          Address1 as string,",
				"          Address2 as string,",
				"          City as string,",
				"          State as string,",
				"          Zip as string,",
				"          Zip4 as string,",
				"          Phone as string,",
				"          Email as string,",
				"          CallMorning as boolean,",
				"          CallAfternoon as boolean,",
				"          CallEvening as boolean,",
				"          CallWeekend as boolean,",
				"          CreditRating as string,",
				"          LP_DateAdded as timestamp,",
				"          LP_LastChanged as timestamp,",
				"          LP_CustomerID as integer,",
				"          LP_LeadID as string,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['CustomerID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID,",
				"          LeadID = EXP_LeadID,",
				"          FirstName,",
				"          LastName,",
				"          Address1,",
				"          Address2,",
				"          City,",
				"          State,",
				"          Zip,",
				"          Zip4,",
				"          Phone,",
				"          Email,",
				"          CallMorning,",
				"          CallAfternoon = CalLAfternoon,",
				"          CallEvening,",
				"          CallWeekend,",
				"          CreditRating,",
				"          LP_DateAdded,",
				"          LP_LastChanged,",
				"          LP_CustomerID,",
				"          LP_LeadID = EXP_LP_leadID,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
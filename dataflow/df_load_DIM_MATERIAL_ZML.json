{
	"name": "df_load_DIM_MATERIAL_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_mat_Materials",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_MATERIAL_ZML",
						"type": "DatasetReference"
					},
					"name": "targetDim",
					"description": "Export data to EDW_DIM_MATERIAL",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "addOpCoNameFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "derivedColumns"
				},
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Id as integer,",
				"          Descr as string,",
				"          UOM as string,",
				"          CommFlag as boolean,",
				"          DiscFlag as boolean,",
				"          Cost as decimal(19,4),",
				"          ListPrice as decimal(19,4),",
				"          jcc_id as integer,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"addOpCoNameFHI union(byName: true)~> unionAllOpCos",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          MaterialID = concat(Division,'-',toString(LP_MaterialID)),",
				"          JobCostCategoryID = concat(Division,'-',toString(LP_JobCostCategoryID))) ~> derivedColumns",
				"unionAllOpCos select(mapColumn(",
				"          LP_MaterialID = Id,",
				"          Material = Descr,",
				"          UnitOfMeasure = UOM,",
				"          Cost,",
				"          ListPrice,",
				"          LP_JobCostCategoryID = jcc_id,",
				"          Active,",
				"          Division",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"derivedColumns alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          MaterialID as string,",
				"          JobCostCategoryID as string,",
				"          Material as string,",
				"          UnitOfMeasure as string,",
				"          Cost as decimal(19,4),",
				"          ListPrice as decimal(19,4),",
				"          Active as boolean,",
				"          LP_MaterialID as integer,",
				"          LP_JobCostCategoryID as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['MaterialID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_MaterialID,",
				"          Material,",
				"          UnitOfMeasure,",
				"          Cost,",
				"          ListPrice,",
				"          LP_JobCostCategoryID,",
				"          Active,",
				"          Division,",
				"          LastUpdateTS,",
				"          MaterialID,",
				"          JobCostCategoryID",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
{
	"name": "df_load_FACT_AD_PERFORMANCE_DETAILS_Incremental_bkup",
	"properties": {
		"folder": {
			"name": "Test-Dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ODS_FUNNEL_AD_PERFORMANCE_METRICS",
						"type": "DatasetReference"
					},
					"name": "ODS"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_AD_PERFORMANCE_METRICS_DETAIL",
						"type": "DatasetReference"
					},
					"name": "FACT"
				}
			],
			"transformations": [
				{
					"name": "createRZIDSRSID"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PerformanceDate as timestamp,",
				"          DataSourcetype as string,",
				"          Currency as string,",
				"          Cost as double,",
				"          Clicks as long,",
				"          Impressions as long,",
				"          AccountID as string,",
				"          AdName as string,",
				"          AdGroupName as string,",
				"          CampaignName as string,",
				"          Mediatype as string,",
				"          PaidOrganic as string,",
				"          Trafficsource as string,",
				"          DataSourcename as string,",
				"          DataSource as string,",
				"          DataSourcetypename as string,",
				"          Dayofweek as string,",
				"          Month as string,",
				"          Week as string,",
				"          Year as long,",
				"          Week_number as long,",
				"          Conversions as double,",
				"          AdGroupID as string,",
				"          ADID as string,",
				"          CampaignID as string,",
				"          Market as string,",
				"          LinkClicks as long,",
				"          Leads as long,",
				"          AdCreatedTime as timestamp,",
				"          AdEndTime as timestamp,",
				"          AdsetEndTime as timestamp,",
				"          AdsetStartTime as timestamp,",
				"          AdStartTime as timestamp,",
				"          CampaignEndTime as timestamp,",
				"          CampaignStartTime as timestamp,",
				"          AdsetEffectiveStatus as string,",
				"          CampaignEffectiveStatus as string,",
				"          AdEffectiveStatus as string,",
				"          AdCreativeAssetLinks as string,",
				"          AdCreativeLink as string,",
				"          AttributionSetting as string,",
				"          BuyingType as string,",
				"          CampaignObjective as string,",
				"          RZID as string,",
				"          SRSID as string,",
				"          OptimizationGoal as string,",
				"          CreativeObjectType as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select \\n[Date]                              as [PerformanceDate]          ,\\n[Data_Source_type]                  as [DataSourcetype]         ,\\n[Currency]                          as [Currency]               ,\\n[Cost]                              as [Cost]                   ,\\n[Clicks]                            as [Clicks]                 ,\\n[Impressions]                       as [Impressions]            ,\\n[Account]                           as [AccountID]            ,\\n[Ad]                                as [AdName]                 ,\\n[Ad_Group]                          as [AdGroupName]            ,\\n[Campaign]                          as [CampaignName]           ,\\n[Media_type]                        as [Mediatype]              ,\\n[Paid__Organic]                     as [PaidOrganic]            ,\\n[Traffic_source]                    as [Trafficsource]          ,\\n[Data_Source_name]                  as [DataSourcename]         ,\\n[Data_Source]                       as [DataSource]             ,\\nNULL                                    as [DataSourcetypename]     ,\\n[Day_of_week]                       as [Dayofweek]              ,\\n[Month]                             as [Month]                  ,\\n[Week]                              as [Week]                   ,\\n[Year]                              as [Year]                   ,\\n[Week_number]                       as [Week_number]            ,\\n[Conversions]                       as [Conversions]            ,\\n[Ad_Group_ID]                       as [AdGroupID]              ,\\n[AD_ID]                             as [ADID]                   ,\\n[Campaign_ID]                       as [CampaignID]             ,\\nNULL                                      as [Market]                 ,\\nNULL                                      as [LinkClicks]                 ,\\nNULL                                      as [Leads]                  ,\\nNULL                                      as [AdCreatedTime]          ,\\nNULL                                      as [AdEndTime]              ,\\nNULL                                      as [AdsetEndTime]           ,\\nNULL                                      as [AdsetStartTime]         ,\\nNULL                                      as [AdStartTime]            ,\\nNULL                                      as [CampaignEndTime]        ,\\nNULL                                      as [CampaignStartTime]      ,\\nNULL                                      as [AdsetEffectiveStatus]   ,\\nNULL                                      as [CampaignEffectiveStatus],\\nNULL                                      as [AdEffectiveStatus]      ,\\nNULL                                      as [AdCreativeAssetLinks]   ,\\nNULL                                      as [AdCreativeLink]         ,\\nNULL                                      as [AttributionSetting]     ,\\nNULL                                      as [BuyingType]             ,\\nNULL                                      as [CampaignObjective]      ,\\n[RZID]                              as [RZID]                 ,\\n[SRSID]                             as [SRSID]                 ,\\nNULL                                       as [OptimizationGoal]       ,\\nNULL                                       as [CreativeObjectType]\\n\\n\\nfrom \\n\\n[ODS].[FUNNEL_AD_PERFORMANCE_METRICS_DETAILS_1]\\n',",
				"     format: 'query',",
				"     staged: true) ~> ODS",
				"ODS derive(RZID_Updated = iif(Trafficsource=='Google',\r",
				"     rtrim(ltrim(RZID,'{rzid}=')),\r",
				"     ltrim(substring(RZID,\r",
				"                  instr(RZID,'rzid='),\r",
				"                  instr(RZID,'&srs_id=')-instr(RZID,'rzid=')\r",
				"                  )\r",
				"            ,'rzid=')\r",
				"     ),",
				"          SRSID = iif(instr(SRSID,'srs')==0,\r",
				"               '',\r",
				"               iif(Trafficsource=='Google',\r",
				"                    ltrim(substring(SRSID, instr(SRSID,'\"srsid\":\"'), instr(SRSID,'\"}')-instr(SRSID,'\"srsid\":\"')),'\"srsid\":\"'),\r",
				"                    ltrim(substring(SRSID,\r",
				"                                    instr(SRSID,'&srs_id=')+1,\r",
				"                                    iif(instr(SRSID,'&campaign_id')-instr(SRSID,'&srs_id=')-1 <=0 \r",
				"                                                                                                            , length(SRSID)-instr(SRSID,'&srs_id=')\r",
				"                                                                                                           , instr(SRSID,'&campaign_id')-instr(SRSID,'&srs_id=')-1 )\r",
				"                                     )\r",
				"                          ,'srs_id=' )\r",
				"                    )\r",
				"     ),",
				"          CreatedTS = fromUTC(currentUTC(),'EST'),",
				"          LastUpdatedTS = fromUTC(currentUTC(),'EST')) ~> createRZIDSRSID",
				"createRZIDSRSID sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          PerformanceDate as timestamp,",
				"          DataSourcetype as string,",
				"          Currency as string,",
				"          Cost as double,",
				"          Clicks as long,",
				"          Impressions as long,",
				"          AccountID as string,",
				"          AdName as string,",
				"          AdGroupName as string,",
				"          CampaignName as string,",
				"          Mediatype as string,",
				"          PaidOrganic as string,",
				"          Trafficsource as string,",
				"          DataSourcename as string,",
				"          DataSource as string,",
				"          DataSourcetypename as string,",
				"          Dayofweek as string,",
				"          Month as string,",
				"          Week as string,",
				"          Year as long,",
				"          Week_number as long,",
				"          Conversions as double,",
				"          AdGroupID as string,",
				"          ADID as string,",
				"          CampaignID as string,",
				"          Market as string,",
				"          LinkClicks as long,",
				"          Leads as long,",
				"          AdCreatedTime as timestamp,",
				"          AdEndTime as timestamp,",
				"          AdsetEndTime as timestamp,",
				"          AdsetStartTime as timestamp,",
				"          AdStartTime as timestamp,",
				"          CampaignEndTime as timestamp,",
				"          CampaignStartTime as timestamp,",
				"          AdsetEffectiveStatus as string,",
				"          CampaignEffectiveStatus as string,",
				"          AdEffectiveStatus as string,",
				"          AdCreativeAssetLinks as string,",
				"          AdCreativeLink as string,",
				"          AttributionSetting as string,",
				"          BuyingType as string,",
				"          CampaignObjective as string,",
				"          AdLink as string,",
				"          OptimizationGoal as string,",
				"          CreativeObjectType as string,",
				"          RZID as string,",
				"          SRSID as string,",
				"          CreatedTS as timestamp,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     preSQLs:['DELETE FROM EDW.FACT_AD_PERFORMANCE_METRICS_DETAIL WHERE EOMONTH(PERFORMANCEDATE) IN \\n( SELECT Distinct EOMONTH(DATE) FROM ODS.FUNNEL_AD_PERFORMANCE_METRICS_DETAILS )'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          PerformanceDate,",
				"          DataSourcetype,",
				"          Currency,",
				"          Cost,",
				"          Clicks,",
				"          Impressions,",
				"          AccountID,",
				"          AdName,",
				"          AdGroupName,",
				"          CampaignName,",
				"          Mediatype,",
				"          PaidOrganic,",
				"          Trafficsource,",
				"          DataSourcename,",
				"          DataSource,",
				"          DataSourcetypename,",
				"          Dayofweek,",
				"          Month,",
				"          Week,",
				"          Year,",
				"          Week_number,",
				"          Conversions,",
				"          AdGroupID,",
				"          ADID,",
				"          CampaignID,",
				"          Market,",
				"          LinkClicks,",
				"          Leads,",
				"          AdCreatedTime,",
				"          AdEndTime,",
				"          AdsetEndTime,",
				"          AdsetStartTime,",
				"          AdStartTime,",
				"          CampaignEndTime,",
				"          CampaignStartTime,",
				"          AdsetEffectiveStatus,",
				"          CampaignEffectiveStatus,",
				"          AdEffectiveStatus,",
				"          AdCreativeAssetLinks,",
				"          AdCreativeLink,",
				"          AttributionSetting,",
				"          BuyingType,",
				"          CampaignObjective,",
				"          AdLink = RZID,",
				"          OptimizationGoal,",
				"          CreativeObjectType,",
				"          RZID = RZID_Updated,",
				"          SRSID,",
				"          CreatedTS,",
				"          LastUpdatedTS",
				"     )) ~> FACT"
			]
		}
	}
}
{
	"name": "df_load_DIM_BRANCH_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_brn_Branches",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_BRANCH_ZML",
						"type": "DatasetReference"
					},
					"name": "targetDim",
					"description": "Export data to EDW_DIM_BRANCH",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "selectColsFHI"
				},
				{
					"name": "createIDsFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "addLastUpdateTimestamp"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          ManagerID as integer,",
				"          AdminID as integer,",
				"          Phone as string,",
				"          Fax as string,",
				"          Active as boolean,",
				"          tms_id1 as integer,",
				"          tms_id2 as integer,",
				"          tms_id3 as integer,",
				"          tms_id4 as integer,",
				"          tms_id5 as integer,",
				"          tms_id6 as integer,",
				"          canset as boolean,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          idpkey as integer,",
				"          RptRollupOrg as string,",
				"          acctbranch as string,",
				"          tof_id as integer,",
				"          rpm_id as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI select(mapColumn(",
				"          LP_BranchID = id,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active,",
				"          CanSet = canset,",
				"          LP_ReportingMarket_ID = rpm_id,",
				"          LP_ReportingMarketType_ID = tof_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(BranchID = concat('FHI-',toString(LP_BranchID)),",
				"          Division = 'FHI') ~> createIDsFHI",
				"createIDsFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(LastUpdateTS = currentTimestamp(),",
				"          ReportingMarketID = concat(Division,'-',toString(LP_ReportingMarket_ID)),",
				"          ReportingMarketTypeID = concat(Division,'-',toString(LP_ReportingMarketType_ID))) ~> addLastUpdateTimestamp",
				"addLastUpdateTimestamp alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          BranchID as string,",
				"          ReportingMarketID as string,",
				"          ReportingMarketTypeID as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean,",
				"          CanSet as boolean,",
				"          LP_BranchID as string,",
				"          LP_ReportingMarketID as integer,",
				"          LP_ReportingMarketTypeID as integer,",
				"          Division as string,",
				"          UNI_Market as string,",
				"          UNI_MarketGroup as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['BranchID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          BranchID,",
				"          ReportingMarketID,",
				"          ReportingMarketTypeID,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active,",
				"          CanSet,",
				"          LP_BranchID,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
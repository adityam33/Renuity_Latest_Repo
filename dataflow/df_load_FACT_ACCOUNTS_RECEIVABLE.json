{
	"name": "df_load_FACT_ACCOUNTS_RECEIVABLE",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/FACTS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ODS_ERP_AR_REGISTER",
						"type": "DatasetReference"
					},
					"name": "ARRegister"
				},
				{
					"dataset": {
						"referenceName": "ODS_ERP_BRANCH_MASTER",
						"type": "DatasetReference"
					},
					"name": "ODSERPBranchMaster"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_FACT_ACCOUNTS_RECEIVABLE",
						"type": "DatasetReference"
					},
					"name": "targetFact"
				}
			],
			"transformations": [
				{
					"name": "selectAndRenameColumns"
				},
				{
					"name": "lkpCompany"
				},
				{
					"name": "CreatecurrencyBatchNbr"
				}
			],
			"scriptLines": [
				"source(output(",
				"          type as string,",
				"          referencenbr as string,",
				"          ARAccount as string,",
				"          customer as string,",
				"          branch as string,",
				"          customerordernbr as string,",
				"          date as timestamp,",
				"          closeddate as timestamp,",
				"          duedate as timestamp,",
				"          paymentdate as timestamp,",
				"          postperiod as string,",
				"          InvoiceDate as timestamp,",
				"          arregister_tranperiodid as string,",
				"          paymentperiod as string,",
				"          arregister_approved as boolean,",
				"          arregister_rejected as boolean,",
				"          arregister_released as boolean,",
				"          status as string,",
				"          arregister_voided as boolean,",
				"          arregister_docbal as decimal(38,18),",
				"          arregister_origDocamt as decimal(38,18),",
				"          paymentmethod as string,",
				"          reasonforcredit as string,",
				"          description as string,",
				"          description_2 as string,",
				"          payment_currency as string,",
				"          Invoice_currency as string,",
				"          origrefnbr as string,",
				"          Invoice_ProjectID as string,",
				"          Payment_projectID as string,",
				"          Invoice_batchNbr as string,",
				"          Payment_BatchNbr as string,",
				"          cashdiscount as decimal(16,2),",
				"          taxtotal as decimal(16,2),",
				"          retainageDocument as string,",
				"          paymentref as string,",
				"          cashaccount as string,",
				"          selected as string,",
				"          lpjob as string,",
				"          lppmttype as string,",
				"          ARPayment_origDocAmt as decimal(38,18),",
				"          Balance as decimal(38,18),",
				"          AdjAmount as decimal(16,2),",
				"          Application_ReferenceNumber as string,",
				"          Application_Type as string,",
				"          Invoice_createdby as string,",
				"          Invoice_Createdon as timestamp,",
				"          Invoice_lastModifiedby as string,",
				"          Invoice_lastmodfiedOn as timestamp,",
				"          Payment_createdby as string,",
				"          Payment_createdon as timestamp,",
				"          Payment_Lastmodifiedby as string,",
				"          Payment_lastModifiedon as timestamp,",
				"          Source as string,",
				"          ARInvoice_released as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'select \\nr.type,r.referencenbr,r.ARAccount,r.customer,r.branch,i.customerordernbr,r.date,r.closeddate,r.duedate,p.paymentdate,\\nr.postperiod,i.date  as InvoiceDate,r.arregister_tranperiodid,p.paymentperiod,r.arregister_approved,r.arregister_rejected,r.arregister_released,r.status,r.arregister_voided,\\nr.arregister_docbal,r.arregister_origDocamt,p.paymentmethod,i.reasonforcredit,i.description, p.description_2,\\np.currency as payment_currency,i.currency as Invoice_currency,i.origrefnbr,i.projectid as Invoice_ProjectID,p.project as Payment_projectID,i.batchnbr as Invoice_batchNbr,p.batchnbr as Payment_BatchNbr,\\ni.cashdiscount,i.taxtotal,i.retainageDocument,p.paymentref,p.cashaccount,p.selected,p.lpjob,p.lppmttype,\\np.ARPayment_origDocAmt, p.Balance,a.AdjAmount,\\na.Payment_SOAdjust_ReferenceNbr as Application_ReferenceNumber,a.Payment_SOAdjust_type as Application_Type,\\ni.createdby as Invoice_createdby,i.createdon as Invoice_Createdon,i.lastmodifiedby as Invoice_lastModifiedby,i.lastmodifiedon as Invoice_lastmodfiedOn,\\np.createdby as Payment_createdby,p.createdon as Payment_createdon,p.lastmodifiedby as Payment_Lastmodifiedby,p.lastmodifiedon as Payment_lastModifiedon,\\ni.Source,i.ARInvoice_released\\nfrom ods.erp_ar_register r \\n join ods.erp_ar_adjust a on  r.referencenbr=a.Invoice_Tran_ReferenceNbr and r.type=a.Invoice_Tran_type\\n left join ods.erp_ar_invoice i on i.referencenbr=r.referencenbr and i.type=r.Type\\nleft join ods.erp_Ar_payment p on p.referencenbr=a.Payment_SOAdjust_ReferenceNbr and p.type=a.Payment_SOAdjust_type\\n\\n\\n\\nUnion all\\n\\nselect \\nr.type,r.referencenbr,r.ARAccount,r.customer,r.branch,i.customerordernbr,r.date,r.closeddate,r.duedate,p.paymentdate,\\nr.postperiod,i.date as InvoiceDate,r.arregister_tranperiodid,p.paymentperiod,r.arregister_approved,r.arregister_rejected,r.arregister_released,r.status,r.arregister_voided,\\nr.arregister_docbal,r.arregister_origDocamt,p.paymentmethod,i.reasonforcredit,i.description, \\np.description_2,p.currency as payment_currency,\\ni.currency as Invoice_currency,i.origrefnbr,\\ni.projectid as Invoice_ProjectID,p.project as Payment_projectID,i.batchnbr as Invoice_batchNbr,p.batchnbr as Payment_BatchNbr,\\ni.cashdiscount,i.taxtotal,i.retainageDocument,p.paymentref,p.cashaccount,p.selected,p.lpjob,p.lppmttype,\\ni.ARInvoice_origDocamt,i.ARInvoice_Docbal,a1.AdjAmount,\\na1.Invoice_Tran_ReferenceNbr as Application_ReferenceNumber,a1.Invoice_Tran_type as Application_Type,\\ni.createdby as Invoice_createdby,i.createdon as Invoice_Createdon,i.lastmodifiedby as Invoice_lastModifiedby,i.lastmodifiedon as Invoice_lastmodfiedOn,\\np.createdby as Payment_createdby,p.createdon as Payment_createdon,p.lastmodifiedby as Payment_Lastmodifiedby,p.lastmodifiedon as Payment_lastModifiedon,\\ni.Source,i.ARInvoice_released\\nfrom ods.erp_ar_register r \\njoin ods.erp_ar_adjust a1 on  r.referencenbr = a1.Payment_SOAdjust_ReferenceNbr and r.type = a1.Payment_SOAdjust_type \\nleft join ods.erp_Ar_payment p on r.referencenbr=p.referencenbr and r.type=p.type\\nleft join ods.erp_ar_invoice i on i.referencenbr=a1.Invoice_Tran_ReferenceNbr and i.type=a1.Invoice_Tran_Type\\n\\nUnion all\\n\\nselect r.type,r.referencenbr,r.ARAccount,r.customer,r.branch,i.customerordernbr,r.date,r.closeddate,r.duedate,p.paymentdate,\\nr.postperiod,i.date as InvoiceDate,r.arregister_tranperiodid,p.paymentperiod,r.arregister_approved,r.arregister_rejected,r.arregister_released,r.status,r.arregister_voided,\\nr.arregister_docbal,r.arregister_origDocamt,p.paymentmethod,i.reasonforcredit,i.description, \\np.description_2,p.currency as payment_currency,\\ni.currency as Invoice_currency,i.origrefnbr,\\ni.projectid as Invoice_ProjectID,p.project as Payment_projectID,i.batchnbr as Invoice_batchNbr,p.batchnbr as Payment_BatchNbr,\\ni.cashdiscount,i.taxtotal,i.retainageDocument,p.paymentref,p.cashaccount,p.selected,p.lpjob,p.lppmttype,\\nNULL as ARInvoice_origDocamt,NULL as ARInvoice_Docbal,Null as AdjAmount,\\nNULL as Application_ReferenceNumber,NULL as Application_Type,\\ni.createdby as Invoice_createdby,i.createdon as Invoice_Createdon,i.lastmodifiedby as Invoice_lastModifiedby,i.lastmodifiedon as Invoice_lastmodfiedOn,\\np.createdby as Payment_createdby,p.createdon as Payment_createdon,p.lastmodifiedby as Payment_Lastmodifiedby,p.lastmodifiedon as Payment_lastModifiedon,\\ni.Source,i.ARInvoice_released\\nfrom ods.erp_ar_register r \\nleft join ods.erp_ar_adjust a on  r.referencenbr=a.Invoice_Tran_ReferenceNbr and r.type=a.Invoice_Tran_type\\nleft join ods.erp_ar_adjust a1 on  r.referencenbr = a1.Payment_SOAdjust_ReferenceNbr and r.type = a1.Payment_SOAdjust_type \\nleft join ods.erp_ar_invoice i on r.referencenbr=i.referencenbr and r.type=i.type\\nleft join ods.erp_ar_payment p on r.referencenbr=p.referencenbr and r.type=p.type\\nwhere   a.Invoice_Tran_ReferenceNbr is  null and  a1.Payment_SOAdjust_ReferenceNbr is  null',",
				"     format: 'query',",
				"     staged: true) ~> ARRegister",
				"source(output(",
				"          BranchCode as string,",
				"          BranchID as integer,",
				"          Active as boolean,",
				"          BranchAccountID as integer,",
				"          BranchName as string,",
				"          CompanyID as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: false) ~> ODSERPBranchMaster",
				"ARRegister select(mapColumn(",
				"          DocumentType = type,",
				"          ReferenceNumber = referencenbr,",
				"          AccountID = ARAccount,",
				"          CustomerID = customer,",
				"          BranchCode = branch,",
				"          CustomerOrderNumber = customerordernbr,",
				"          DocumentDate = date,",
				"          ClosedDate = closeddate,",
				"          DueDate = duedate,",
				"          PaymentDate = paymentdate,",
				"          PostPeriod = postperiod,",
				"          InvoiceDate,",
				"          RegisterTranPeriodID = arregister_tranperiodid,",
				"          PaymentPeriod = paymentperiod,",
				"          Register_Approved = arregister_approved,",
				"          Register_Rejected = arregister_rejected,",
				"          Register_Released = arregister_released,",
				"          Status = status,",
				"          Register_Voided = arregister_voided,",
				"          Register_DocumentBalance = arregister_docbal,",
				"          Register_OriginalDocumentAmount = arregister_origDocamt,",
				"          PaymentMethod = paymentmethod,",
				"          ReasonForCredit = reasonforcredit,",
				"          Invoice_Description = description,",
				"          Payment_Description = description_2,",
				"          Payment_Currency = payment_currency,",
				"          Invoice_Currency = Invoice_currency,",
				"          OriginalReferenceNumber = origrefnbr,",
				"          Invoice_ProjectID,",
				"          Payment_ProjectID = Payment_projectID,",
				"          Invoice_BatchNumber = Invoice_batchNbr,",
				"          Payment_BatchNumber = Payment_BatchNbr,",
				"          CashDiscount = cashdiscount,",
				"          TaxTotal = taxtotal,",
				"          RetainageDocument = retainageDocument,",
				"          PaymentReference = paymentref,",
				"          CashAccount = cashaccount,",
				"          selected,",
				"          LpJob = lpjob,",
				"          LpPmtType = lppmttype,",
				"          ARPayment_OrigDocAmt = ARPayment_origDocAmt,",
				"          Balance,",
				"          AdjAmount,",
				"          Application_ReferenceNumber,",
				"          Application_Type,",
				"          Invoice_CreatedBy = Invoice_createdby,",
				"          Invoice_Createdon,",
				"          Invoice_LastModifiedBy = Invoice_lastModifiedby,",
				"          Invoice_lastmodifiedOn = Invoice_lastmodfiedOn,",
				"          Payment_Createdby = Payment_createdby,",
				"          Payment_Createdon = Payment_createdon,",
				"          Payment_Lastmodifiedby,",
				"          Payment_lastModifiedon,",
				"          Source,",
				"          ARInvoice_released",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectAndRenameColumns",
				"CreatecurrencyBatchNbr, ODSERPBranchMaster lookup(selectAndRenameColumns@BranchCode == ODSERPBranchMaster@BranchCode,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lkpCompany",
				"selectAndRenameColumns derive(Currency = iif(isNull(Payment_Currency),Invoice_Currency,Payment_Currency),",
				"          BatchNumber = iif(isNull(Payment_BatchNumber), Invoice_BatchNumber, Payment_BatchNumber)) ~> CreatecurrencyBatchNbr",
				"lkpCompany sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          DocumentType as string,",
				"          ReferenceNumber as string,",
				"          AccountCode as string,",
				"          CustomerID as string,",
				"          BranchCode as string,",
				"          CompanyID as string,",
				"          CustomerOrderNumber as string,",
				"          DocumentDate as timestamp,",
				"          ClosedDate as timestamp,",
				"          DueDate as timestamp,",
				"          PaymentDate as timestamp,",
				"          InvoiceDate as timestamp,",
				"          PostPeriod as string,",
				"          TransactionPeriodID as string,",
				"          PaymentPeriod as string,",
				"          Approved as boolean,",
				"          Rejected as boolean,",
				"          Released as boolean,",
				"          Status as string,",
				"          Voided as boolean,",
				"          DocumentBalance as decimal(38,18),",
				"          OriginalDocumentAmount as decimal(38,18),",
				"          PaymentMethod as string,",
				"          DocumentDescription as string,",
				"          InvoiceDescription as string,",
				"          Currency as string,",
				"          BatchNumber as string,",
				"          OriginalReferenceNumber as string,",
				"          PaymentProjectID as string,",
				"          InvoiceProjectID as string,",
				"          CashDiscount as decimal(38,18),",
				"          TaxTotal as decimal(38,18),",
				"          IsRetainageDocument as string,",
				"          ReasonForCredit as string,",
				"          PaymentReference as string,",
				"          PaymentCashAccount as string,",
				"          Payment_Selected as string,",
				"          Lp_JobNumber as string,",
				"          LP_PaymentType as string,",
				"          Invoice_CreatedBy as string,",
				"          Invoice_CreatedOn as timestamp,",
				"          Invoice_LastModifiedBy as string,",
				"          Invoice_LastModifiedOn as timestamp,",
				"          Payment_CreatedBy as string,",
				"          Payment_CreatedOn as timestamp,",
				"          Payment_LastModifiedBy as string,",
				"          Payment_LastModifiedOn as timestamp,",
				"          Invoice_Source as string,",
				"          Invoice_Released as boolean,",
				"          Payment_Amount as decimal(38,18),",
				"          Payment_Balance as decimal(38,18),",
				"          AmountPaid as decimal(16,2),",
				"          Application_ReferenceNumber as string,",
				"          Application_Type as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     preSQLs:['TRUNCATE TABLE [EDW].[FACT_ACCOUNTS_RECEIVABLE]'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          DocumentType,",
				"          ReferenceNumber,",
				"          AccountCode = AccountID,",
				"          CustomerID,",
				"          BranchCode = selectAndRenameColumns@BranchCode,",
				"          CompanyID,",
				"          CustomerOrderNumber,",
				"          DocumentDate,",
				"          ClosedDate,",
				"          DueDate,",
				"          PaymentDate,",
				"          InvoiceDate,",
				"          PostPeriod,",
				"          TransactionPeriodID = RegisterTranPeriodID,",
				"          PaymentPeriod,",
				"          Approved = Register_Approved,",
				"          Rejected = Register_Rejected,",
				"          Released = Register_Released,",
				"          Status,",
				"          Voided = Register_Voided,",
				"          DocumentBalance = Register_DocumentBalance,",
				"          OriginalDocumentAmount = Register_OriginalDocumentAmount,",
				"          PaymentMethod,",
				"          DocumentDescription = Payment_Description,",
				"          InvoiceDescription = Invoice_Description,",
				"          Currency,",
				"          BatchNumber,",
				"          OriginalReferenceNumber,",
				"          PaymentProjectID = Payment_ProjectID,",
				"          InvoiceProjectID = Invoice_ProjectID,",
				"          CashDiscount,",
				"          TaxTotal,",
				"          IsRetainageDocument = RetainageDocument,",
				"          ReasonForCredit,",
				"          PaymentReference,",
				"          PaymentCashAccount = CashAccount,",
				"          Payment_Selected = selected,",
				"          Lp_JobNumber = LpJob,",
				"          LP_PaymentType = LpPmtType,",
				"          Invoice_CreatedBy,",
				"          Invoice_CreatedOn = Invoice_Createdon,",
				"          Invoice_LastModifiedBy,",
				"          Invoice_LastModifiedOn = Invoice_lastmodifiedOn,",
				"          Payment_CreatedBy = Payment_Createdby,",
				"          Payment_CreatedOn = Payment_Createdon,",
				"          Payment_LastModifiedBy = Payment_Lastmodifiedby,",
				"          Payment_LastModifiedOn = Payment_lastModifiedon,",
				"          Invoice_Source = Source,",
				"          Invoice_Released = ARInvoice_released,",
				"          Payment_Amount = ARPayment_OrigDocAmt,",
				"          Payment_Balance = Balance,",
				"          AmountPaid = AdjAmount,",
				"          Application_ReferenceNumber,",
				"          Application_Type",
				"     )) ~> targetFact"
			]
		}
	}
}
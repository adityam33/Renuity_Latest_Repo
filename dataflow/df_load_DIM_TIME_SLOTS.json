				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"source(output(",
				"          id as integer,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> HSI",
				"source(output(",
				"          id as integer,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MAC",

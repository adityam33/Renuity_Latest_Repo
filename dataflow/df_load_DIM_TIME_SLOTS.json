				"          id as integer,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> PBC",
				"source(output(",
				"          id as integer,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          id as integer,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"source(output(",
				"          id as integer,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MXH",
				"source(output(",
				"          id as integer,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> CTA",
				"FHI select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(Division = 'FHI') ~> createDivFHI",
				"createDivFHI, createDivHSI, createDivMAC, createDivPBC, createDivSWR, createDivRTW, createDivMXH, createDivCTA union(byName: true)~> unionAllOpCos",
				"HSI select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsHSI",
				"selectColsHSI derive(Division = 'HSI') ~> createDivHSI",
				"MAC select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsMAC",
				"selectColsMAC derive(Division = 'MAC') ~> createDivMAC",
				"selectColsPBC derive(Division = 'PBC') ~> createDivPBC",
				"PBC select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsPBC",
				"SWR select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsSWR",
				"selectColsSWR derive(Division = 'SWR') ~> createDivSWR",
				"unionAllOpCos derive(TimeSlotID = concatWS('-',Division,toString(LP_TimeSlotID)),",
				"          LastUpdateTS = currentTimestamp()) ~> createIDsfinal",
				"RTW select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsRTW",
				"selectColsRTW derive(Division = 'RTW') ~> createDivRTW",
				"MXH select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsMXH",
				"selectColsMXH derive(Division = 'MXH') ~> createDivMXH",
				"CTA select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectCTA",
				"selectCTA derive(Division = 'CTA') ~> createDivCTA",
				"createIDsfinal alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          TimeSlotID as string,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean,",
				"          LP_TimeSlotID as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['TimeSlotID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_TimeSlotID,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active,",
				"          Division,",
				"          TimeSlotID,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]

{
	"name": "df_load_DIM_HOA_STATUS",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SRC_ODS_LP_FHI_HOA_Status",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_HOA_STATUS",
						"type": "DatasetReference"
					},
					"name": "targetDim"
				}
			],
			"transformations": [
				{
					"name": "addOpCoNameFHI"
				},
				{
					"name": "derivedColumns"
				},
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "AlterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          HOAStatusID = concat(Division,'-',toString(LP_HOAStatusID))) ~> derivedColumns",
				"addOpCoNameFHI select(mapColumn(",
				"          LP_HOAStatusID = id,",
				"          HOStatus = Descr,",
				"          Active,",
				"          Division",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"derivedColumns alterRow(upsertIf(true())) ~> AlterRow1",
				"AlterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          HOAStatusID as string,",
				"          HOStatus as string,",
				"          Active as boolean,",
				"          LP_HOAStatusID as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['HOAStatusID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_HOAStatusID,",
				"          HOStatus,",
				"          Active,",
				"          Division,",
				"          LastUpdateTS,",
				"          HOAStatusID",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
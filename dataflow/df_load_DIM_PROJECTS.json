				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Project_ID as string,",
				"          Parent_id as string,",
				"          Name as string,",
				"          Description as string,",
				"          Color as string,",
				"          Expanded as boolean,",
				"          brp_id as string,",
				"          ins_id as string,",
				"          Sortorder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"source(output(",
				"          Project_ID as string,",
				"          Parent_id as string,",
				"          Name as string,",
				"          Description as string,",
				"          Color as string,",
				"          Expanded as boolean,",
				"          brp_id as string,",
				"          ins_id as string,",
				"          Sortorder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MAC",
				"source(output(",
				"          Project_ID as string,",
				"          Parent_id as string,",
				"          Name as string,",
				"          Description as string,",
				"          Color as string,",
				"          Expanded as boolean,",
				"          brp_id as string,",
				"          ins_id as string,",
				"          Sortorder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> PBC",
				"source(output(",
				"          Project_ID as string,",
				"          Parent_id as string,",
				"          Name as string,",
				"          Description as string,",
				"          Color as string,",
				"          Expanded as boolean,",
				"          brp_id as string,",
				"          ins_id as string,",
				"          Sortorder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          Project_ID as string,",
				"          Parent_id as string,",
				"          Name as string,",
				"          Description as string,",
				"          Color as string,",
				"          Expanded as boolean,",
				"          brp_id as string,",
				"          ins_id as string,",
				"          Sortorder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"source(output(",
				"          Project_ID as string,",
				"          Parent_id as string,",
				"          Name as string,",
				"          Description as string,",
				"          Color as string,",
				"          Expanded as boolean,",
				"          brp_id as string,",
				"          ins_id as string,",
				"          Sortorder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MXH",
				"source(output(",
				"          Project_ID as string,",
				"          Parent_id as string,",
				"          Name as string,",
				"          Description as string,",
				"          Color as string,",
				"          Expanded as boolean,",
				"          brp_id as string,",
				"          ins_id as string,",
				"          Sortorder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> CTA",
				"FHI select(mapColumn(",
				"          LP_ProjectId = Project_ID,",
				"          Parent_id,",
				"          Name,",
				"          Description,",
				"          Color,",
				"          Expanded,",
				"          LP_ProductionBranchId = brp_id,",
				"          LP_InstallerId = ins_id,",
				"          Sortorder",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(Division = 'FHI') ~> createIDsFHI",
				"MAC select(mapColumn(",
				"          LP_ProjectId = Project_ID,",
				"          Parent_id,",
				"          Name,",
				"          Description,",
				"          Color,",
				"          Expanded,",
				"          LP_ProductionBranchId = brp_id,",
				"          LP_InstallerId = ins_id,",
				"          Sortorder",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsMAC",
				"PBC select(mapColumn(",
				"          LP_ProjectId = Project_ID,",
				"          Parent_id,",
				"          Name,",
				"          Description,",
				"          Color,",
				"          Expanded,",
				"          LP_ProductionBranchId = brp_id,",
				"          LP_InstallerId = ins_id,",
				"          Sortorder",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectPBC",
				"SWR select(mapColumn(",
				"          LP_ProjectId = Project_ID,",
				"          Parent_id,",
				"          Name,",
				"          Description,",
				"          Color,",
				"          Expanded,",
				"          LP_ProductionBranchId = brp_id,",
				"          LP_InstallerId = ins_id,",
				"          Sortorder",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectSWR",
				"selectColsMAC derive(Division = 'MAC') ~> createIDsMAC",
				"selectPBC derive(Division = 'PBC') ~> createIDsPBC",
				"selectSWR derive(Division = 'SWR') ~> createIDsSWR",
				"createIDsFHI, createIDsMAC, createIDsPBC, createIDsSWR, createIDsRTW, createIDsMXH, createIDsCTA union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(LastUpdateTS = currentTimestamp(),",
				"          ProjectId = concat(Division,'-',toString(LP_ProjectId)),",
				"          ProductionBranchId = concat(Division,'-',toString(LP_ProductionBranchId)),",
				"          InstallerId = concat(Division,'-',toString(LP_InstallerId))) ~> addLastUpdateTimestamp",
				"RTW select(mapColumn(",
				"          LP_ProjectId = Project_ID,",
				"          Parent_id,",
				"          Name,",
				"          Description,",
				"          Color,",
				"          Expanded,",
				"          LP_ProductionBranchId = brp_id,",
				"          LP_InstallerId = ins_id,",
				"          Sortorder",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRTW",
				"selectRTW derive(Division = 'RTW') ~> createIDsRTW",
				"MXH select(mapColumn(",
				"          LP_ProjectId = Project_ID,",
				"          Parent_id,",
				"          Name,",
				"          Description,",
				"          Color,",
				"          Expanded,",
				"          LP_ProductionBranchId = brp_id,",
				"          LP_InstallerId = ins_id,",
				"          Sortorder",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectMXH",
				"selectMXH derive(Division = 'MXH') ~> createIDsMXH",
				"CTA select(mapColumn(",
				"          LP_ProjectId = Project_ID,",
				"          Parent_id,",
				"          Name,",
				"          Description,",
				"          Color,",
				"          Expanded,",
				"          LP_ProductionBranchId = brp_id,",
				"          LP_InstallerId = ins_id,",
				"          Sortorder",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectCTA",
				"selectCTA derive(Division = 'CTA') ~> createIDsCTA",
				"addLastUpdateTimestamp alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ProjectId as string,",
				"          ParentID as string,",
				"          ProjectName as string,",
				"          ProjectDescription as string,",
				"          Color as string,",
				"          Expanded as boolean,",
				"          ProductionBranchId as string,",
				"          InstallerId as string,",
				"          SortOrder as integer,",
				"          Division as string,",
				"          LP_ProjectId as integer,",
				"          LP_ProductionBranchId as string,",
				"          LP_InstallerId as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['ProjectId'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ProjectId,",
				"          ParentID = Parent_id,",
				"          ProjectName = Name,",
				"          ProjectDescription = Description,",
				"          Color,",
				"          Expanded,",
				"          ProductionBranchId,",
				"          InstallerId,",
				"          SortOrder = Sortorder,",
				"          Division,",
				"          LP_ProjectId,",
				"          LP_ProductionBranchId,",
				"          LP_InstallerId",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}

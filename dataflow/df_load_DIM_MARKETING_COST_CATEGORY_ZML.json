{
	"name": "df_load_DIM_MARKETING_COST_CATEGORY_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_mcc_MarketingCostCategories",
						"type": "DatasetReference"
					},
					"name": "FHI",
					"description": "Import data from SRC_ODS_LP_FHI_mcd_MarketingCostDetail"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_MARKETING_COST_CATEGORY_ZML",
						"type": "DatasetReference"
					},
					"name": "targetFact",
					"description": "Export data to FACT_MARKETING_COST_DETAIL",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "addOpCoNameFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "derivedColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          Descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"addOpCoNameFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos select(mapColumn(",
				"          LP_MarketingCostCategoryId = id,",
				"          Description = Descr,",
				"          Active,",
				"          SortOrder,",
				"          Division",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          MarketingCostCategoryID = concat(Division,'-',toString(LP_MarketingCostCategoryId))) ~> derivedColumns",
				"derivedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          MarketingCostCategoryId as string,",
				"          Description as string,",
				"          Active as boolean,",
				"          SortOrder as integer,",
				"          LP_MarketingCostCategoryId as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          MarketingCostCategoryId = MarketingCostCategoryID,",
				"          Description,",
				"          Active,",
				"          SortOrder,",
				"          LP_MarketingCostCategoryId,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetFact"
			]
		}
	}
}
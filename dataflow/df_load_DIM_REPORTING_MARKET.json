{
	"name": "df_load_DIM_REPORTING_MARKET",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SRC_ODS_LP_FHI_rpm_ReportingMarket",
						"type": "DatasetReference"

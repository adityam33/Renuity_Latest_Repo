				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {_data} as (id as integer, name as string, notes as string, type as string, status as string, createdOn as integer, labels as string[], percentTraffic as integer, createdBy as (id as integer, name as string, imageUrl as string), urls as (type as string, value as string)[], excludedUrls as string[], primaryUrl as string, thresholds as (winningPercent as double, losingPercent as double, visitors as integer), device as string, variations as (id as integer, name as string, isControl as boolean, isDisabled as boolean, heatmapThumbUrl as string, screenshots as (quick as string), percentSplit as integer, urls as (type as string, value as string)[], isBase as boolean)[], goals as (id as integer, isPrimary as boolean, name as string, type as string, mode as string, code as string, urls as (type as string, value as string)[], pUrls as string[], pExcludedUrls as string[], excludedUrls as string[], description as string, createdAt as integer, metricId as integer, isArchived as boolean, attributionTime as string, waitForMaturity as boolean, outliers as string, outliersOverriden as boolean, calcLogic as (logic as string), events as (props as string[], id as string, eventDefinitionType as string, apiName as string, name as string, queryElementType as string)[], rope as (value as integer, disabled as boolean), decisionStats as (minimumDetectableEffect as integer, falsePositiveRate as integer, statisticalPower as integer), identifier as (text as string, color as string), isInverse as boolean, testingObjective as string, isGuardrail as boolean, guardrailStats as (minimumDetectableEffect as integer, falsePositiveRate as integer, statisticalPower as integer), guardrailBreachAction as string, guardrailCheckFrequency as integer, roiInfo as string, isContextual as boolean, isRetrospective as string, averageData as (visitorCount as integer, conversionCount as integer, conversionRate as double, standardError as double), aggregatedData as ({1} as (visitorCount as integer, conversionCount as integer), {2} as (visitorCount as integer, conversionCount as integer)), isInObservatoryMode as boolean, notifications as (type as string)[])[], dataIntervalRange as (intervalSize as integer, startTime as integer, endTime as integer, limitingStartTime as integer, limitingEndTime as integer), variationGoalData as (goal as integer, variation as integer, aggregated as (visitorCount as integer, conversionCount as integer, isGoalDurationComplete as boolean, standardDeviation as double, conversionRate as (median as double, credibleInterval1pct as double[]), improvementRate as string, relativeImprovementRate as string, conversionExpectedImprovementRate as string, decisionGraphData as (betterPercentage as integer, notBetterPercentage as integer, practicalEquivalancePercentage as integer, notWorsePercentage as integer, worsePercentage as integer), decision as string, isDecisionMade as boolean), isWinner as boolean, isSmartDecision as boolean, possibleWinner as boolean, intervalWise as (interval as integer, visitorCount as integer, conversionCount as integer, totalSessions as integer, totalConversionCount as integer, totalSessionsSumSquared as integer, totalConversionCountSumSquared as integer, crossProduct as integer, logTotalRevenue as integer, logTotalSumSquaredRevenue as integer, productCount as integer, totalProducts as integer)[], isInObservatoryMode as boolean)[], schedules as string[], isCrossDomainEnabled as boolean, stats as (expectedRevenuePerVisitor as string, reportingVersion as integer, reportingView as integer, peekingCorrection as boolean, multipleCorrection as boolean, typeMCorrection as boolean, sidakCorrection as boolean, delayDecision as boolean, testingApproach as string, statisticalModel as string, pauseCampaignAfterFinalDay as boolean, observatoryMinVisitors as integer, observatoryMinConversions as integer, observatoryMinRuntime as integer, conversionRate as string, liftInConversionRate as string, certaintyMode as string, expectedMonthlyVisitors as integer), isDeleted as boolean, isGlobalSegmentEnabled as boolean, globalSegment as (type as string, id as string, name as string, partialSegments as string[], segmentSettings as string[], event as string), isMAB as boolean, isHeatmapEnabled as boolean, triggerType as string, integrations as string[])",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments',",
				"     wildcardPaths:['Anuj_Test/VWO/All_Campaign/By_Campaign_Response_JSON/VWO_ByCampaign_Response_*.json']) ~> source1",
				"FlattenVariations select(mapColumn(",
				"          Variations_ID,",
				"          Variations_Name,",
				"          Variations_isControl,",
				"          Variations_isDisabled,",
				"          Variations_percentSplit,",
				"          CampaignID,",
				"          CampaignName,",
				"          CampaignType,",
				"          CampaignStatus,",
				"          CampaignCreatedBy,",
				"          CampaignPrimaryURL,",
				"          CampaignCreatedOn",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectvarMain",
				"source1 foldDown(unroll({_data}.variations),",
				"     mapColumn(",
				"          Variations_ID = {_data}.variations.id,",
				"          Variations_Name = {_data}.variations.name,",
				"          Variations_isControl = {_data}.variations.isControl,",
				"          Variations_isDisabled = {_data}.variations.isDisabled,",
				"          Variations_percentSplit = {_data}.variations.percentSplit,",
				"          CampaignID = {_data}.id,",
				"          CampaignName = {_data}.name,",
				"          CampaignType = {_data}.type,",
				"          CampaignStatus = {_data}.status,",
				"          CampaignCreatedBy = {_data}.createdBy.name,",
				"          CampaignPrimaryURL = {_data}.primaryUrl,",
				"          CampaignCreatedOn = {_data}.createdOn",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> FlattenVariations",
				"source1 foldDown(unroll({_data}.variations.urls),",
				"     mapColumn(",
				"          Variations_URL = {_data}.variations.urls.value,",
				"          CampaignID = {_data}.id,",
				"          Variation_ID = {_data}.variations.id",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> FlattenVariationsURL",
				"FlattenVariationsURL select(mapColumn(",
				"          Variations_URL,",
				"          CampaignID,",
				"          Variations_ID = Variation_ID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectVarURL",
				"source1 foldDown(unroll({_data}.goals),",
				"     mapColumn(",
				"          Goals_Description = {_data}.goals.description,",
				"          Goals_ID = {_data}.goals.id,",
				"          Goals_Name = {_data}.goals.name,",
				"          Goals_Type = {_data}.goals.type,",
				"          CampaignID = {_data}.id,",
				"          TotalconversionCount = {_data}.goals.averageData.conversionCount,",
				"          TotalconversionRate = {_data}.goals.averageData.conversionRate,",
				"          TotalvisitorCount = {_data}.goals.averageData.visitorCount",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> FlattenGoals",
				"source1 foldDown(unroll({_data}.variationGoalData),",
				"     mapColumn(",
				"          CampaignID = {_data}.id,",
				"          Goal_ID = {_data}.variationGoalData.goal,",
				"          isWinner = {_data}.variationGoalData.isWinner,",
				"          possibleWinner = {_data}.variationGoalData.possibleWinner,",
				"          Variation_ID = {_data}.variationGoalData.variation,",
				"          Variation_ConversionCount = {_data}.variationGoalData.aggregated.conversionCount,",
				"          Variation_visitorCount = {_data}.variationGoalData.aggregated.visitorCount,",
				"          Variation_isGoalDurationComplete = {_data}.variationGoalData.aggregated.isGoalDurationComplete",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> FlattenVariationGoalsData",
				"FlattenGoals select(mapColumn(",
				"          Goals_Description,",
				"          Goals_ID,",
				"          Goals_Name,",
				"          Goals_Type,",
				"          CampaignID,",
				"          TotalconversionCount,",
				"          TotalconversionRate,",
				"          TotalvisitorCount",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectGoals",
				"derivedColumn1, selectGoals join(selectvarMain@CampaignID == selectGoals@CampaignID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, selectVarURL join(selectvarMain@CampaignID == selectVarURL@CampaignID",
				"     && selectvarMain@Variations_ID == selectVarURL@Variations_ID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"FlattenVariationGoalsData select(mapColumn(",
				"          CampaignID,",
				"          Goal_ID,",
				"          isWinner,",
				"          possibleWinner,",
				"          Variation_ID,",
				"          Variation_ConversionCount,",
				"          Variation_visitorCount,",
				"          Variation_isGoalDurationComplete",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectvariationGoalsData",
				"join2, selectvariationGoalsData join(selectvarMain@CampaignID == selectvariationGoalsData@CampaignID",
				"     && selectvarMain@Variations_ID == Variation_ID",
				"     && Goals_ID == Goal_ID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"selectvarMain derive(CampaignCreatedOn = toDate(toTimestamp(toLong(CampaignCreatedOn) * 1000l))) ~> derivedColumn1",
				"join3 select(mapColumn(",
				"          Variations_ID = selectvarMain@Variations_ID,",
				"          Variations_Name,",
				"          Variations_isControl,",
				"          Variations_isDisabled,",
				"          Variations_percentSplit,",
				"          CampaignID = selectvarMain@CampaignID,",
				"          CampaignName,",
				"          CampaignType,",
				"          CampaignStatus,",
				"          CampaignCreatedBy,",
				"          CampaignPrimaryURL,",
				"          CampaignCreatedOn,",
				"          Goals_Name,",
				"          Goals_Type,",
				"          CampaignID = selectGoals@CampaignID,",
				"          TotalconversionCount,",
				"          TotalconversionRate,",
				"          TotalvisitorCount,",
				"          Variations_URL,",
				"          CampaignID = selectVarURL@CampaignID,",
				"          Variations_ID = selectVarURL@Variations_ID,",
				"          CampaignID = selectvariationGoalsData@CampaignID,",
				"          isWinner,",
				"          possibleWinner,",
				"          Variation_ConversionCount,",
				"          Variation_visitorCount,",
				"          Variation_isGoalDurationComplete",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Division as string,",
				"          CampaignID as integer,",
				"          CampaignName as string,",
				"          CampaignType as string,",
				"          CampaignStatus as string,",
				"          CampaignCreatedBy as string,",
				"          CampaignPrimaryURL as string,",
				"          CampaignCreatedOn as date,",
				"          Variations_ID as integer,",
				"          Variations_Name as string,",
				"          Variations_isControl as string,",
				"          Variations_isDisabled as string,",
				"          Variations_percentSplit as decimal(16,4),",
				"          Goals_Name as string,",
				"          Goals_Type as string,",
				"          TotalconversionCount as integer,",
				"          TotalconversionRate as decimal(16,6),",
				"          TotalvisitorCount as integer,",
				"          Variations_URL as string,",
				"          isWinner as string,",
				"          possibleWinner as string,",
				"          Variation_ConversionCount as integer,",
				"          Variation_visitorCount as integer,",
				"          Variation_isGoalDurationComplete as string,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     quoteAll: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CampaignID,",
				"          CampaignName,",
				"          CampaignType,",
				"          CampaignStatus,",
				"          CampaignCreatedBy,",
				"          CampaignPrimaryURL,",
				"          CampaignCreatedOn,",
				"          Variations_ID,",
				"          Variations_Name,",
				"          Variations_isControl,",
				"          Variations_isDisabled,",
				"          Variations_percentSplit,",
				"          Goals_Name,",
				"          Goals_Type,",
				"          TotalconversionCount,",
				"          TotalconversionRate,",
				"          TotalvisitorCount,",
				"          Variations_URL,",
				"          isWinner,",
				"          possibleWinner,",
				"          Variation_ConversionCount,",
				"          Variation_visitorCount,",
				"          Variation_isGoalDurationComplete",
				"     ),",
				"     partitionBy('hash', 1),",
				"     preCommands: [],",
				"     postCommands: []) ~> sink1"
			]
		}
	}
}
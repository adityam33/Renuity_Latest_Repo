{
	"name": "df_dim_slt_Saletype_ZML",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "LP_ODS_FHI_slt_SalesTypes_ZML",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_slt_SalesType_ZML",
						"type": "DatasetReference"
					},
					"name": "sink1",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "selectColFHI"
				},
				{
					"name": "createDsFHI"
				},
				{
					"name": "union1"
				},
				{
					"name": "select1"
				},
				{
					"name": "AlterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          descr as string,",
				"          Active as boolean,",
				"          SortOrder as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI select(mapColumn(",
				"          LP_SaleTypeID = id,",
				"          descr,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColFHI",
				"selectColFHI derive(SaleTypeID = concat('FHI-', toString(LP_SaleTypeID)),",
				"          Division = 'FHI',",
				"          LastUpdateTS = currentTimestamp()) ~> createDsFHI",
				"createDsFHI union(byName: true)~> union1",
				"union1 select(mapColumn(",
				"          SaleTypeID,",
				"          descr,",
				"          Active,",
				"          LP_SaleTypeID,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 alterRow(upsertIf(true())) ~> AlterRow1",
				"AlterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['SaleTypeID'],",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          SaleTypeID,",
				"          Division,",
				"          LastUpdateTS",
				"     )) ~> sink1"
			]
		}
	}
}
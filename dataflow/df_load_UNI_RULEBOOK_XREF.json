{
	"name": "df_load_UNI_RULEBOOK_XREF",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "TGT_UNI_RULEBOOK",
						"type": "DatasetReference"
					},
					"name": "RuleBookTbl"
				},
				{
					"dataset": {
						"referenceName": "SRC_UNI_RULEBOOK",
						"type": "DatasetReference"
					},
					"name": "RuleBookExcel"
				},
				{
					"dataset": {
						"referenceName": "TGT_UNI_RULEBOOK",
						"type": "DatasetReference"
					},
					"name": "LKPRuleBook"
				},
				{
					"dataset": {
						"referenceName": "EDW_DUN_METADATA",
						"type": "DatasetReference"
					},
					"name": "EDWMetadata"
				}
			],
			"sinks": [
				{
					"name": "MaxRuleID"
				},
				{
					"dataset": {
						"referenceName": "TGT_UNI_RULEBOOK",
						"type": "DatasetReference"
					},
					"name": "RulebookInsert"
				},
				{
					"dataset": {
						"referenceName": "TGT_UNI_RULEBOOK",
						"type": "DatasetReference"
					},
					"name": "RuleBookUpdate"
				},
				{
					"dataset": {
						"referenceName": "TGT_UNI_RULEBOOK",
						"type": "DatasetReference"
					},
					"name": "IsActivePriorityUpdates"
				}
			],
			"transformations": [
				{
					"name": "CreateFlag"
				},
				{
					"name": "InsertNewUpdatedRec"
				},
				{
					"name": "lkpDBRulebook"
				},
				{
					"name": "surrogateKey"
				},
				{
					"name": "selectCols2"
				},
				{
					"name": "GenerateRuleID"
				},
				{
					"name": "lkpMetaData"
				},
				{
					"name": "CreateLKPMetakey"
				},
				{
					"name": "createMetakey"
				},
				{
					"name": "SelectCols"
				},
				{
					"name": "createLKPRuleKey"
				},
				{
					"name": "createRuleKey"
				},
				{
					"name": "split1"
				},
				{
					"name": "UpdateExistingRec"
				},
				{
					"name": "CreateAuditcols"
				},
				{
					"name": "UpdateIsactivePriority"
				},
				{
					"name": "AuditCol"
				},
				{
					"name": "sortbyMetaID"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     PipelineName as string ('test')",
				"}",
				"source(output(",
				"          Max_RuleID as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select max(CAST(UNI_RuleID as Integer)) as Max_RuleID from EDW_DUN.UNI_Rulebook_Xref ',",
				"     format: 'query',",
				"     staged: true) ~> RuleBookTbl",
				"source(output(",
				"          SourceSystem as string,",
				"          TableName as string,",
				"          TableColumnName as string,",
				"          Division as string,",
				"          MatchType as string,",
				"          RulePriority as string,",
				"          RuleValue as string,",
				"          RuleValueDesc as string,",
				"          UnifiedValue as string,",
				"          UnifiedValueDesc as string,",
				"          UnifiedValue_Group as string,",
				"          UnifiedValue_Category as string,",
				"          IsActive as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> RuleBookExcel",
				"source(output(",
				"          UNI_RuleID as string,",
				"          UNI_MetaID as string,",
				"          SourceSystem as string,",
				"          Division as string,",
				"          TableName as string,",
				"          TableColumnName as string,",
				"          MatchType as string,",
				"          RulePriority as integer,",
				"          RuleValue as string,",
				"          RuleValueDesc as string,",
				"          UnifiedValue as string,",
				"          UnifiedValueDesc as string,",
				"          UnifiedValue_Group as string,",
				"          UnifiedValue_Category as string,",
				"          RuleStartDate as timestamp,",
				"          RuleEndDate as timestamp,",
				"          CurrentRecordFlag as string,",
				"          IsActive as integer,",
				"          CreatedByProcess as string,",
				"          CreatedTS as timestamp,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select  * from EDW_DUN.UNI_RuleBook_xref where CurrentRecordFLag=\\'Y\\'',",
				"     format: 'query',",
				"     staged: true) ~> LKPRuleBook",
				"source(output(",
				"          UNI_MetaID as string,",
				"          SourceSystem as string,",
				"          TableName as string,",
				"          TablePKColumn_SRC as string,",
				"          TablePKColumn_EDW as string,",
				"          TableColumnName as string,",
				"          DescriptionColumn as string,",
				"          DataFilter as string,",
				"          DataOwner as string,",
				"          IsActive as integer,",
				"          CreatedByProcess as string,",
				"          CreatedTS as timestamp,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> EDWMetadata",
				"lkpDBRulebook derive(RecordIdentifier = iif(isNull(Lkp_RuleKey), 1, \r",
				"                           iif( Src_UnifiedKey!=Lkp_UnifiedKey , 2, \r",
				"                                                 iif(Src_Priority_ActiveKey!=LKp_PriorityActiveKey,3,0) \r",
				"                              )\r",
				"    ),",
				"          CreatedTS = currentUTC(),",
				"          LastUpdatedTS = currentUTC(),",
				"          CreatedByProcess = $PipelineName,",
				"          RuleCreatedBy = 'MANUAL',",
				"          RuleApprovedBy = 'MANUAL',",
				"          RuleCreatedDate = currentUTC(),",
				"          RuleApprovedDate = currentUTC()) ~> CreateFlag",
				"split1@Insert alterRow(insertIf(RecordIdentifier>=1)) ~> InsertNewUpdatedRec",
				"createRuleKey, createLKPRuleKey lookup(Src_RuleKey == Lkp_RuleKey,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lkpDBRulebook",
				"InsertNewUpdatedRec keyGenerate(output(RuleID as long),",
				"     startAt: 1L,",
				"     stepValue: 1L) ~> surrogateKey",
				"CreateFlag select(mapColumn(",
				"          SourceSystem = SelectCols@SourceSystem,",
				"          TableName = SelectCols@TableName,",
				"          TableColumnName = SelectCols@TableColumnName,",
				"          Division = SelectCols@Division,",
				"          MatchType = SelectCols@MatchType,",
				"          RulePriority = SelectCols@RulePriority,",
				"          RuleValue = SelectCols@RuleValue,",
				"          RuleValueDesc = SelectCols@RuleValueDesc,",
				"          UnifiedValue = SelectCols@UnifiedValue,",
				"          UnifiedValueDesc = SelectCols@UnifiedValueDesc,",
				"          UnifiedValue_Group = SelectCols@UnifiedValue_Group,",
				"          UnifiedValue_Category = SelectCols@UnifiedValue_Category,",
				"          IsActive = SelectCols@IsActive,",
				"          Src_MetaKey,",
				"          UNI_MetaID = SelectCols@UNI_MetaID,",
				"          UNI_RuleID,",
				"          RecordIdentifier,",
				"          CreatedTS,",
				"          LastUpdatedTS,",
				"          CreatedByProcess,",
				"          RuleCreatedBy,",
				"          RuleApprovedBy,",
				"          RuleCreatedDate,",
				"          RuleApprovedDate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectCols2",
				"surrogateKey derive(RuleID = RuleID + toInteger(iif(isNull(MaxRuleID#outputs()[1].Max_RuleID),0,MaxRuleID#outputs()[1].Max_RuleID)),",
				"          CurrentRecordFlag = 'Y',",
				"          RuleStartDate = currentUTC(),",
				"          RuleEndDate = toTimestamp(toString('NULL'))) ~> GenerateRuleID",
				"createMetakey, CreateLKPMetakey lookup(Src_MetaKey == Lkp_MetaKey,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lkpMetaData",
				"EDWMetadata derive(Lkp_MetaKey = md5(concat(upper(SourceSystem),upper(TableName),upper(TableColumnName)))) ~> CreateLKPMetakey",
				"RuleBookExcel derive(Src_MetaKey = md5(concat(upper(SourceSystem),upper(TableName),upper(TableColumnName)))) ~> createMetakey",
				"lkpMetaData select(mapColumn(",
				"          SourceSystem = RuleBookExcel@SourceSystem,",
				"          TableName = RuleBookExcel@TableName,",
				"          TableColumnName = RuleBookExcel@TableColumnName,",
				"          Division,",
				"          MatchType,",
				"          RulePriority,",
				"          RuleValue,",
				"          RuleValueDesc,",
				"          UnifiedValue,",
				"          UnifiedValueDesc,",
				"          UnifiedValue_Group,",
				"          UnifiedValue_Category,",
				"          IsActive = RuleBookExcel@IsActive,",
				"          Src_MetaKey,",
				"          UNI_MetaID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectCols",
				"LKPRuleBook derive(Lkp_RuleKey = md5(concat(UNI_MetaID,MatchType,Division,RuleValue)),",
				"          Lkp_UnifiedKey = md5(concat(UnifiedValue,\r",
				"iif(isNull(UnifiedValue_Group),'xx',UnifiedValue_Group),\r",
				"iif(isNull(UnifiedValue_Category),'xx',UnifiedValue_Category)\r",
				")),",
				"          LKp_PriorityActiveKey = md5(concat(toString(RulePriority),toString(IsActive)))) ~> createLKPRuleKey",
				"SelectCols derive(Src_RuleKey = md5(concat(UNI_MetaID,MatchType,Division,RuleValue)),",
				"          Src_UnifiedKey = md5(concat(UnifiedValue,\r",
				"iif(isNull(UnifiedValue_Group),'xx',UnifiedValue_Group),\r",
				"iif(isNull(UnifiedValue_Category),'xx',UnifiedValue_Category)\r",
				")),",
				"          Src_Priority_ActiveKey = md5(concat(RulePriority,IsActive))) ~> createRuleKey",
				"sortbyMetaID split(RecordIdentifier>=1 && RecordIdentifier<=2,",
				"     RecordIdentifier==2,",
				"     RecordIdentifier==3,",
				"     disjoint: true) ~> split1@(Insert, UpdateExistRecs, UpdateIsActivePriority)",
				"split1@UpdateExistRecs alterRow(updateIf(RecordIdentifier==2)) ~> UpdateExistingRec",
				"UpdateExistingRec derive(CurrentRecordFlag = 'N',",
				"          IsActive = '0',",
				"          RuleEndDate = currentUTC()) ~> CreateAuditcols",
				"split1@UpdateIsActivePriority alterRow(updateIf(RecordIdentifier==3)) ~> UpdateIsactivePriority",
				"UpdateIsactivePriority derive(LastUpdatedTS = currentUTC()) ~> AuditCol",
				"derivedColumn1 sort(asc(uni_meta_id_int, true)) ~> sortbyMetaID",
				"selectCols2 derive(uni_meta_id_int = toInteger(UNI_MetaID)) ~> derivedColumn1",
				"RuleBookTbl sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     store: 'cache',",
				"     format: 'inline',",
				"     output: false,",
				"     saveOrder: 0,",
				"     mapColumn(",
				"          Max_RuleID",
				"     )) ~> MaxRuleID",
				"GenerateRuleID sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          UNI_RuleID as long,",
				"          UNI_MetaID as long,",
				"          SourceSystem as string,",
				"          Division as string,",
				"          TableName as string,",
				"          TableColumnName as string,",
				"          MatchType as string,",
				"          RulePriority as integer,",
				"          RuleValue as string,",
				"          RuleValueDesc as string,",
				"          UnifiedValue as string,",
				"          UnifiedValueDesc as string,",
				"          UnifiedValue_Group as string,",
				"          UnifiedValue_Category as string,",
				"          RuleStartDate as timestamp,",
				"          RuleEndDate as timestamp,",
				"          CurrentRecordFlag as string,",
				"          IsActive as integer,",
				"          CreatedByProcess as string,",
				"          RuleCreatedBy as string,",
				"          RuleApprovedBy as string,",
				"          RuleCreatedDate as timestamp,",
				"          RuleApprovedDate as timestamp,",
				"          CreatedTS as timestamp,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          UNI_RuleID = RuleID,",
				"          UNI_MetaID,",
				"          SourceSystem,",
				"          Division,",
				"          TableName,",
				"          TableColumnName,",
				"          MatchType,",
				"          RulePriority,",
				"          RuleValue,",
				"          RuleValueDesc,",
				"          UnifiedValue,",
				"          UnifiedValueDesc,",
				"          UnifiedValue_Group,",
				"          UnifiedValue_Category,",
				"          RuleStartDate,",
				"          RuleEndDate,",
				"          CurrentRecordFlag,",
				"          IsActive,",
				"          CreatedByProcess,",
				"          CreatedTS,",
				"          LastUpdatedTS,",
				"          RuleCreatedBy,",
				"          RuleApprovedBy,",
				"          RuleCreatedDate,",
				"          RuleApprovedDate",
				"     )) ~> RulebookInsert",
				"CreateAuditcols sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          UNI_RuleID as long,",
				"          UNI_MetaID as long,",
				"          SourceSystem as string,",
				"          Division as string,",
				"          TableName as string,",
				"          TableColumnName as string,",
				"          MatchType as string,",
				"          RulePriority as integer,",
				"          RuleValue as string,",
				"          RuleValueDesc as string,",
				"          UnifiedValue as string,",
				"          UnifiedValueDesc as string,",
				"          UnifiedValue_Group as string,",
				"          UnifiedValue_Category as string,",
				"          RuleStartDate as timestamp,",
				"          RuleEndDate as timestamp,",
				"          CurrentRecordFlag as string,",
				"          IsActive as integer,",
				"          CreatedByProcess as string,",
				"          RuleCreatedBy as string,",
				"          RuleApprovedBy as string,",
				"          RuleCreatedDate as timestamp,",
				"          RuleApprovedDate as timestamp,",
				"          CreatedTS as timestamp,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['UNI_RuleID','UNI_MetaID'],",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          UNI_RuleID,",
				"          UNI_MetaID,",
				"          RuleEndDate,",
				"          CurrentRecordFlag,",
				"          IsActive,",
				"          LastUpdatedTS",
				"     )) ~> RuleBookUpdate",
				"AuditCol sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          UNI_RuleID as long,",
				"          UNI_MetaID as long,",
				"          SourceSystem as string,",
				"          Division as string,",
				"          TableName as string,",
				"          TableColumnName as string,",
				"          MatchType as string,",
				"          RulePriority as integer,",
				"          RuleValue as string,",
				"          RuleValueDesc as string,",
				"          UnifiedValue as string,",
				"          UnifiedValueDesc as string,",
				"          UnifiedValue_Group as string,",
				"          UnifiedValue_Category as string,",
				"          RuleStartDate as timestamp,",
				"          RuleEndDate as timestamp,",
				"          CurrentRecordFlag as string,",
				"          IsActive as integer,",
				"          CreatedByProcess as string,",
				"          RuleCreatedBy as string,",
				"          RuleApprovedBy as string,",
				"          RuleCreatedDate as timestamp,",
				"          RuleApprovedDate as timestamp,",
				"          CreatedTS as timestamp,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['UNI_MetaID','UNI_RuleID'],",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          UNI_RuleID,",
				"          UNI_MetaID,",
				"          RulePriority,",
				"          IsActive,",
				"          LastUpdatedTS",
				"     )) ~> IsActivePriorityUpdates"
			]
		}
	}
}
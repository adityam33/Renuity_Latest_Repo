{
	"name": "New_DSTimeCard",
	"properties": {
		"folder": {
			"name": "Test-Dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText3",
						"type": "DatasetReference"
					},
					"name": "source1",
					"description": "Import data from in file from blob storage"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ODS_ADP_Employee_TimeCard",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {First Name} as string,",
				"          {Last Name} as string,",
				"          {Associate ID} as string,",
				"          {Job Title Description} as string,",
				"          {Work Contact: Work Email} as string,",
				"          {FLSA Description} as string,",
				"          {Pay Class} as string,",
				"          {(Pay Class) Timeclock Restriction Group} as string,",
				"          Division as string,",
				"          {Pay Date} as date,",
				"          {Time In} as string,",
				"          {Time Out} as string,",
				"          Hours as double,",
				"          {Earnings Code} as string,",
				"          {Worked Department} as short,",
				"          {Timecard Work Location} as string,",
				"          {Timecard Work Carpenters Job Number} as string,",
				"          {Timecard Worked Carpenters Job Number Description} as string,",
				"          {Timecard Work FHIA BJ's Locations} as string,",
				"          {Timecard Work Go Southern Location} as string,",
				"          {Timecard Work MADCITY LOCATION} as string,",
				"          {Timecard Work MAXHOME LOCATION} as string,",
				"          {Timecard Work SERVICE ID} as string,",
				"          {Timecard Worked SERVICE ID Description} as string,",
				"          Approve as boolean,",
				"          {Approve Supervisor Name} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(InsertedDate = currentTimestamp()) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          ASSOCIATE_ID as string,",
				"          JOB_TITLE_DESCRIPTION as string,",
				"          WORK_CONTACT_WORK_EMAIL as string,",
				"          FLSA_DESCRIPTION as string,",
				"          PAY_CLASS as string,",
				"          PAY_CLASS_TIMECLOCK_RESTRICTION_GROUP as string,",
				"          DIVISION as string,",
				"          PAY_DATE as string,",
				"          TIME_IN as string,",
				"          TIME_OUT as string,",
				"          HOURS as string,",
				"          EARNINGS_CODE as string,",
				"          WORKED_DEPARTMENT as string,",
				"          TIMECARD_WORK_LOCATION as string,",
				"          TIMECARD_WORK_CARPENTERS_JOB_NUMBER as string,",
				"          TIMECARD_WORKED_CARPENTERS_JOB_NUMBER_DESCRIPTION as string,",
				"          TIMECARD_WORK_FHIA_BJS_LOCATIONS as string,",
				"          TIMECARD_WORK_GO_SOUTHERN_LOCATION as string,",
				"          TIMECARD_WORK_MADCITY_LOCATION as string,",
				"          TIMECARD_WORK_MAXHOME_LOCATION as string,",
				"          TIMECARD_WORK_SERVICE_ID as string,",
				"          TIMECARD_WORKED_SERVICE_ID_DESCRIPTION as string,",
				"          APPROVE as string,",
				"          APPROVE_SUPERVISOR_NAME as string,",
				"          InsertedDate as timestamp,",
				"          ref_file as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          FIRST_NAME = {First Name},",
				"          LAST_NAME = {Last Name},",
				"          ASSOCIATE_ID = {Associate ID},",
				"          JOB_TITLE_DESCRIPTION = {Job Title Description},",
				"          WORK_CONTACT_WORK_EMAIL = {Work Contact: Work Email},",
				"          FLSA_DESCRIPTION = {FLSA Description},",
				"          PAY_CLASS = {Pay Class},",
				"          PAY_CLASS_TIMECLOCK_RESTRICTION_GROUP = {(Pay Class) Timeclock Restriction Group},",
				"          DIVISION = Division,",
				"          PAY_DATE = {Pay Date},",
				"          TIME_IN = {Time In},",
				"          TIME_OUT = {Time Out},",
				"          HOURS = Hours,",
				"          EARNINGS_CODE = {Earnings Code},",
				"          WORKED_DEPARTMENT = {Worked Department},",
				"          TIMECARD_WORK_LOCATION = {Timecard Work Location},",
				"          TIMECARD_WORK_CARPENTERS_JOB_NUMBER = {Timecard Work Carpenters Job Number},",
				"          TIMECARD_WORKED_CARPENTERS_JOB_NUMBER_DESCRIPTION = {Timecard Worked Carpenters Job Number Description},",
				"          TIMECARD_WORK_FHIA_BJS_LOCATIONS = {Timecard Work FHIA BJ's Locations},",
				"          TIMECARD_WORK_GO_SOUTHERN_LOCATION = {Timecard Work Go Southern Location},",
				"          TIMECARD_WORK_MADCITY_LOCATION = {Timecard Work MADCITY LOCATION},",
				"          TIMECARD_WORK_MAXHOME_LOCATION = {Timecard Work MAXHOME LOCATION},",
				"          TIMECARD_WORK_SERVICE_ID = {Timecard Work SERVICE ID},",
				"          TIMECARD_WORKED_SERVICE_ID_DESCRIPTION = {Timecard Worked SERVICE ID Description},",
				"          APPROVE = Approve,",
				"          APPROVE_SUPERVISOR_NAME = {Approve Supervisor Name},",
				"          InsertedDate",
				"     )) ~> sink1"
			]
		}
	}
}
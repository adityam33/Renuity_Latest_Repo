{
	"name": "df_load_erp_bills_and_adjustments",
	"properties": {
		"folder": {
			"name": "Test-Dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SRC_ERP_BILLS_AND_ADJUSTMENTS",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ODS_ERP_AP_BILLS_ADJUSTMENTS_DF",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          Status as string,",
				"          Branch as string,",
				"          Date as date,",
				"          {Post Period} as string,",
				"          Vendor as string,",
				"          {Vendor Name} as string,",
				"          {Vendor Ref.} as string,",
				"          Amount as float,",
				"          {Last Modified By} as string,",
				"          Type as string,",
				"          {Reference Nbr.} as string,",
				"          Description as string,",
				"          Balance as float,",
				"          {Batch Nbr.} as string,",
				"          {Branch Name} as string,",
				"          {Cash Discount} as float,",
				"          {Created By} as string,",
				"          {Created On} as timestamp 'yyyy-MM-dd\\'T\\'HH:mm:ss.SSS\\'Z\\'',",
				"          Currency as string,",
				"          Description1 as string,",
				"          {Due Date} as date,",
				"          {Orig. Ref. Nbr.} as string,",
				"          Project as string,",
				"          {Tax Amount} as float,",
				"          Selected as boolean,",
				"          {Last Modified On} as timestamp 'yyyy-MM-dd\\'T\\'HH:mm:ss.SSS\\'Z\\''",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     wildcardPaths:['erp_acumatica/Inbound_Reports_AP/Bills and Adjustments 20230613.xlsx']) ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Status as string,",
				"          Branch as string,",
				"          Date as date,",
				"          PostPeriod as string,",
				"          VendorId as string,",
				"          VendorName as string,",
				"          VendorReferenceNumber as string,",
				"          Amount as decimal(16,2),",
				"          LastModifiedBy as string,",
				"          Type as string,",
				"          ReferenceNumber as string,",
				"          Description as string,",
				"          Balance as decimal(16,2),",
				"          BatchNumber as string,",
				"          BranchName as string,",
				"          CashDiscount as decimal(16,2),",
				"          CreatedBy as string,",
				"          Createdon as timestamp,",
				"          Currency as string,",
				"          Description1 as string,",
				"          DueDate as date,",
				"          OriginalReferenceNumber as string,",
				"          Project as string,",
				"          TaxAmount as decimal(16,2),",
				"          Selected as boolean,",
				"          LastModifiedOn as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Status,",
				"          Branch,",
				"          Date,",
				"          PostPeriod = {Post Period},",
				"          VendorId = Vendor,",
				"          VendorName = {Vendor Name},",
				"          VendorReferenceNumber = {Vendor Ref.},",
				"          Amount,",
				"          LastModifiedBy = {Last Modified By},",
				"          Type,",
				"          ReferenceNumber = {Reference Nbr.},",
				"          Description,",
				"          Balance,",
				"          BatchNumber = {Batch Nbr.},",
				"          BranchName = {Branch Name},",
				"          CashDiscount = {Cash Discount},",
				"          CreatedBy = {Created By},",
				"          Createdon = {Created On},",
				"          Currency,",
				"          Description1,",
				"          DueDate = {Due Date},",
				"          OriginalReferenceNumber = {Orig. Ref. Nbr.},",
				"          Project,",
				"          TaxAmount = {Tax Amount},",
				"          Selected,",
				"          LastModifiedOn = {Last Modified On}",
				"     )) ~> sink1"
			]
		}
	}
}
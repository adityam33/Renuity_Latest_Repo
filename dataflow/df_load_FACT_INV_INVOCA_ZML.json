{
	"name": "df_load_FACT_INV_INVOCA_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/FACTS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_inv_InvocaData",
						"type": "DatasetReference"
					},
					"name": "FHI",
					"description": "Import data from SRC_ODS_LP_FHI_inv_InvocaData"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_FACT_INV_INVOCA_DATA_ZML",
						"type": "DatasetReference"
					},
					"name": "TargetFact",
					"description": "Export data to EDW_FACT_INV_INVOCA",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "addOpCoNameFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "derivedColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          CallStartTime as timestamp,",
				"          CallRecordID as string,",
				"          Source as string,",
				"          MediaType as string,",
				"          PromoNumberDescription as string,",
				"          FinalCampaign as string,",
				"          FinalCampaignID as integer,",
				"          DestinationPhoneNumber as string,",
				"          Transactions as string,",
				"          City as string,",
				"          Region as string,",
				"          RepeatCaller as string,",
				"          CallerID as string,",
				"          PhoneType as string,",
				"          CallStartTimeUTC as string,",
				"          InvocaUniqueID as integer,",
				"          DetectedDestination as string,",
				"          GoogleClickID as string,",
				"          GoogleAnalyticsClientID as string,",
				"          MicrosoftAdsClickID as string,",
				"          GooglePropertyID as string,",
				"          UserID as string,",
				"          FullLandingPageURL as string,",
				"          MarketingMedium as string,",
				"          MarketingSource as string,",
				"          MarketingCampaign as string,",
				"          MarketingContent as string,",
				"          CallingPage as string,",
				"          Brand as string,",
				"          AppointmentsSetPhrases as integer,",
				"          CustomerServicePhrase as integer,",
				"          QualifiedCalls as integer,",
				"          LPSource as string,",
				"          LPSubSource as string,",
				"          SRS_Id as string,",
				"          CallSegmentPath as string,",
				"          TotalDuration as integer,",
				"          TotalConnectedDuration as integer,",
				"          TotalIVRDuration as integer,",
				"          CallResult as string,",
				"          SignalNames as string,",
				"          EndofCallReason as string,",
				"          Recording as string,",
				"          DateReceived as timestamp,",
				"          DateUpdated as timestamp,",
				"          cst_id as integer,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI derive(Brand = 'FHI') ~> addOpCoNameFHI",
				"addOpCoNameFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos select(mapColumn(",
				"          LP_INVCallID = id,",
				"          CallStartTime,",
				"          CallRecordID,",
				"          Source,",
				"          MediaType,",
				"          PromoNumberDescription,",
				"          FinalCampaign,",
				"          FinalCampaignID,",
				"          DestinationPhoneNumber,",
				"          Transactions,",
				"          City,",
				"          Region,",
				"          RepeatCaller,",
				"          CallerID,",
				"          PhoneType,",
				"          CallStartTimeUTC,",
				"          InvocaUniqueID,",
				"          DetectedDestination,",
				"          GoogleClickID,",
				"          GoogleAnalyticsClientID,",
				"          MicrosoftAdsClickID,",
				"          GooglePropertyID,",
				"          UserID,",
				"          FullLandingPageURL,",
				"          MarketingMedium,",
				"          MarketingSource,",
				"          MarketingCampaign,",
				"          MarketingContent,",
				"          CallingPage,",
				"          Division = Brand,",
				"          AppointmentsSetPhrases,",
				"          CustomerServicePhrase,",
				"          QualifiedCalls,",
				"          LP_LeadSubSource = LPSource,",
				"          LPSubSource,",
				"          LP_SRS_Id = SRS_Id,",
				"          CallSegmentPath,",
				"          TotalDuration,",
				"          TotalConnectedDuration,",
				"          TotalIVRDuration,",
				"          CallResult,",
				"          SignalNames,",
				"          EndofCallReason,",
				"          Recording,",
				"          DateReceived,",
				"          DateUpdated,",
				"          LP_CustomerID = cst_id,",
				"          MarketingID,",
				"          MarketingCustomerID,",
				"          GbraID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(INVCallID = concat(Division,'-',iifNull(toString(LP_INVCallID),'')),",
				"          LeadSubSourceID = concat(Division,'-',iifNull(toString(LP_LeadSubSource),'')),",
				"          CustomerID = concat(Division,'-',iifNull(toString(LP_CustomerID),'')),",
				"          createdTS = currentTimestamp(),",
				"          LastUpdatedTS = currentTimestamp(),",
				"          SrsID = concat(Division,'-',iifNull(toString(LP_SRS_Id),''))) ~> derivedColumns",
				"derivedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          INVCallID as string,",
				"          CallStartTime as timestamp,",
				"          CallRecordID as string,",
				"          Source as string,",
				"          MediaType as string,",
				"          PromoNumberDescription as string,",
				"          FinalCampaign as string,",
				"          FinalCampaignID as integer,",
				"          DestinationPhoneNumber as string,",
				"          Transactions as string,",
				"          City as string,",
				"          Region as string,",
				"          RepeatCaller as string,",
				"          CallerID as string,",
				"          PhoneType as string,",
				"          CallStartTimeUTC as string,",
				"          InvocaUniqueID as integer,",
				"          DetectedDestination as string,",
				"          GoogleClickID as string,",
				"          GoogleAnalyticsClientID as string,",
				"          MicrosoftAdsClickID as string,",
				"          GooglePropertyID as string,",
				"          UserID as string,",
				"          FullLandingPageURL as string,",
				"          MarketingMedium as string,",
				"          MarketingSource as string,",
				"          MarketingCampaign as string,",
				"          MarketingContent as string,",
				"          CallingPage as string,",
				"          Division as string,",
				"          AppointmentsSetPhrases as integer,",
				"          CustomerServicePhrase as integer,",
				"          QualifiedCalls as integer,",
				"          LeadSubSourceID as string,",
				"          SrsID as string,",
				"          CallSegmentPath as string,",
				"          TotalDuration as integer,",
				"          TotalConnectedDuration as integer,",
				"          TotalIVRDuration as integer,",
				"          CallResult as string,",
				"          SignalNames as string,",
				"          EndofCallReason as string,",
				"          Recording as string,",
				"          DateReceived as timestamp,",
				"          DateUpdated as timestamp,",
				"          CustomerID as string,",
				"          LP_INVCallID as string,",
				"          LP_LeadSubSourceID as string,",
				"          LP_SrsID as string,",
				"          LP_CustomerID as string,",
				"          CreatedTS as timestamp,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          INVCallID,",
				"          CallStartTime,",
				"          CallRecordID,",
				"          Source,",
				"          MediaType,",
				"          PromoNumberDescription,",
				"          FinalCampaign,",
				"          FinalCampaignID,",
				"          DestinationPhoneNumber,",
				"          Transactions,",
				"          City,",
				"          Region,",
				"          RepeatCaller,",
				"          CallerID,",
				"          PhoneType,",
				"          CallStartTimeUTC,",
				"          InvocaUniqueID,",
				"          DetectedDestination,",
				"          GoogleClickID,",
				"          GoogleAnalyticsClientID,",
				"          MicrosoftAdsClickID,",
				"          GooglePropertyID,",
				"          UserID,",
				"          FullLandingPageURL,",
				"          MarketingMedium,",
				"          MarketingSource,",
				"          MarketingCampaign,",
				"          MarketingContent,",
				"          CallingPage,",
				"          Division,",
				"          AppointmentsSetPhrases,",
				"          CustomerServicePhrase,",
				"          QualifiedCalls,",
				"          LeadSubSourceID,",
				"          SrsID,",
				"          CallSegmentPath,",
				"          TotalDuration,",
				"          TotalConnectedDuration,",
				"          TotalIVRDuration,",
				"          CallResult,",
				"          SignalNames,",
				"          EndofCallReason,",
				"          Recording,",
				"          DateReceived,",
				"          DateUpdated,",
				"          CustomerID,",
				"          LP_INVCallID,",
				"          LP_LeadSubSourceID = LP_LeadSubSource,",
				"          LP_SrsID = LP_SRS_Id,",
				"          LP_CustomerID,",
				"          CreatedTS = createdTS,",
				"          LastUpdatedTS,",
				"          MarketingID,",
				"          MarketingCustomerID,",
				"          GbraID",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> TargetFact"
			]
		}
	}
}
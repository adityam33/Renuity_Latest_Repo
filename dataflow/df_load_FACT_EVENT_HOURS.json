			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          Sdate as timestamp,",
				"          srs_id as integer,",
				"          emp_id as integer,",
				"          hours as decimal(19,4),",
				"          exhours as decimal(19,4),",
				"          enteredby as integer,",
				"          enteredon as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"source(output(",
				"          ID as integer,",
				"          inq_id as integer,",
				"          lds_id as integer,",
				"          GCLID as string,",
				"          UTMAccount as string,",
				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",
				"          PropertyType as string,",
				"          UTMCampaignID as string,",
				"          UTMAdID as string,",
				"          UTMAdSetID as string,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string,",
				"          UnitCPL as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> PBC",
				"source(output(",
				"          ID as integer,",
				"          inq_id as integer,",
				"          lds_id as integer,",
				"          GCLID as string,",
				"          UTMAccount as string,",
				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",
				"          PropertyType as string,",
				"          UTMCampaignID as string,",
				"          UTMAdID as string,",
				"          UTMAdSetID as string,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string,",
				"          UnitCPL as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"source(output(",
				"          ID as integer,",
				"          inq_id as integer,",
				"          lds_id as integer,",
				"          GCLID as string,",
				"          UTMAccount as string,",
				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",
				"          PropertyType as string,",
				"          UTMCampaignID as string,",
				"          UTMAdID as string,",
				"          UTMAdSetID as string,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string,",
				"          UnitCPL as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MAC",
				"source(output(",
				"          ID as integer,",
				"          inq_id as integer,",
				"          lds_id as integer,",
				"          GCLID as string,",
				"          UTMAccount as string,",
				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",
				"          PropertyType as string,",
				"          UTMCampaignID as string,",
				"          UTMAdID as string,",
				"          UTMAdSetID as string,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string,",
				"          UnitCPL as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          ID as integer,",
				"          inq_id as integer,",
				"          lds_id as integer,",
				"          GCLID as string,",
				"          UTMAccount as string,",
				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",
				"          PropertyType as string,",
				"          UTMCampaignID as string,",
				"          UTMAdID as string,",
				"          UTMAdSetID as string,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string,",
				"          UnitCPL as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MXH",
				"source(output(",
				"          ID as integer,",
				"          inq_id as integer,",
				"          lds_id as integer,",
				"          GCLID as string,",
				"          UTMAccount as string,",
				"          UTMMedium as string,",
				"          UTMSource as string,",
				"          UTMCampaign as string,",
				"          UTMContent as string,",
				"          UTMTerm as string,",
				"          PropertyType as string,",
				"          UTMCampaignID as string,",
				"          UTMAdID as string,",
				"          UTMAdSetID as string,",
				"          MarketingID as string,",
				"          MarketingCustomerID as string,",
				"          GbraID as string,",
				"          UnitCPL as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> CTA",
				"FHI derive(Division = 'FHI') ~> addDivNameFHI",
				"PBC derive(Division = 'PBC') ~> addDivNamePBC",
				"RTW derive(Division = 'RTW') ~> addDivNameRTW",
				"MAC derive(Division = 'MAC') ~> addDivNameMAC",
				"SWR derive(Division = 'SWR') ~> addDivNameSWR",
				"addDivNameFHI, addDivNamePBC, addDivNameRTW, addDivNameMAC, addDivNameSWR, addDivNameMXH, addDivNameCTA union(byName: true)~> unionAllOpCos",
				"unionAllOpCos select(mapColumn(",
				"          LP_EventId = unionAllOpCos@id,",
				"          Startdate = Sdate,",
				"          LP_LeadSubsourceId = srs_id,",
				"          LP_EmployeeId = emp_id,",
				"          RegularHours = hours,",
				"          ExcludedHours = exhours,",
				"          LP_Enteredby = enteredby,",
				"          Enteredon = enteredon,",
				"          Division",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          EventId = concat(Division,'-',toString(LP_EventId)),",
				"          LeadSubSourceID = concat(Division,'-',toString(LP_LeadSubsourceId)),",
				"          EmployeeID = concat(Division,'-',toString(LP_EmployeeId)),",
				"          EnteredBy = concat(Division,'-',toString(LP_Enteredby))) ~> derivedColumns",
				"MXH derive(Division = 'MXH') ~> addDivNameMXH",
				"CTA derive(Division = 'CTA') ~> addDivNameCTA",
				"derivedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          EventId as string,",
				"          StartDate as timestamp,",
				"          LeadSubSourceId as string,",
				"          EmployeeId as string,",
				"          RegularHours as decimal(38,18),",
				"          ExcludedHours as decimal(38,18),",
				"          EnteredBy as string,",
				"          EnteredOn as timestamp,",
				"          LP_EventId as string,",
				"          LP_LeadSubSourceId as string,",
				"          LP_EmployeeId as string,",
				"          LP_EnteredBy as string,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          EventId,",
				"          StartDate = Startdate,",
				"          LeadSubSourceId = LeadSubSourceID,",
				"          EmployeeId = EmployeeID,",
				"          RegularHours,",
				"          ExcludedHours,",
				"          EnteredBy,",
				"          EnteredOn = Enteredon,",
				"          LP_EventId,",
				"          LP_LeadSubSourceId = LP_LeadSubsourceId,",
				"          LP_EmployeeId,",
				"          LP_EnteredBy = LP_Enteredby,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetFact"
			]
		}

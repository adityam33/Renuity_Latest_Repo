{
	"name": "df_managed_instance_FACT_APPOINTMENT_test",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/FACTS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "LP_FHI_ManagedInstance_Appointment",
						"type": "DatasetReference"
					},
					"name": "FHI"
				},
				{
					"dataset": {
						"referenceName": "LP_RTW_ManagedInstance_Appointment",
						"type": "DatasetReference"
					},
					"name": "RTW"
				},
				{
					"dataset": {
						"referenceName": "LP_MAC_ManagedInstance_Appointment",
						"type": "DatasetReference"
					},
					"name": "MAC"
				},
				{
					"dataset": {
						"referenceName": "LP_SWR_ManagedInstance_Appointment",
						"type": "DatasetReference"
					},
					"name": "SWR"
				},
				{
					"dataset": {
						"referenceName": "ODS_vw_lkp_LP_Dispositions",
						"type": "DatasetReference"
					},
					"name": "Srcvwlkpdisposition"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_FACT_APPOINTMENT_ManagedInstance_Test",
						"type": "DatasetReference"
					},
					"name": "targetFact",
					"description": "Export data to EDW_FACT_APPOINTMENT",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "addOpCoNameFHI"
				},
				{
					"name": "addOpCoNameRTW"
				},
				{
					"name": "addOpCoNameMAC"
				},
				{
					"name": "addOpCoNameSWR"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "derivedColumns"
				},
				{
					"name": "lookuponDisposition"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          cst_id as integer,",
				"          Lds_ID as integer,",
				"          ApptDate as timestamp,",
				"          SetBy as integer,",
				"          VerifiedBy as integer,",
				"          ConfirmedBy as integer,",
				"          Dsp_ID as string,",
				"          ApptSet as boolean,",
				"          Verified as boolean,",
				"          Confirmed as boolean,",
				"          Issued as boolean,",
				"          NetIssued as boolean,",
				"          Sat as boolean,",
				"          Sold as boolean,",
				"          rnk_id as integer,",
				"          SetDate as timestamp,",
				"          VerifiedDate as timestamp,",
				"          ConfirmedDate as timestamp,",
				"          LastChangedDate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> FHI",
				"source(output(",
				"          id as integer,",
				"          cst_id as integer,",
				"          Lds_ID as integer,",
				"          ApptDate as timestamp,",
				"          SetBy as integer,",
				"          VerifiedBy as integer,",
				"          ConfirmedBy as integer,",
				"          Dsp_ID as string,",
				"          ApptSet as boolean,",
				"          Verified as boolean,",
				"          Confirmed as boolean,",
				"          Issued as boolean,",
				"          NetIssued as boolean,",
				"          Sat as boolean,",
				"          Sold as boolean,",
				"          rnk_id as integer,",
				"          SetDate as timestamp,",
				"          VerifiedDate as timestamp,",
				"          ConfirmedDate as timestamp,",
				"          LastChangedDate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> RTW",
				"source(output(",
				"          id as integer,",
				"          cst_id as integer,",
				"          Lds_ID as integer,",
				"          ApptDate as timestamp,",
				"          SetBy as integer,",
				"          VerifiedBy as integer,",
				"          ConfirmedBy as integer,",
				"          Dsp_ID as string,",
				"          ApptSet as boolean,",
				"          Verified as boolean,",
				"          Confirmed as boolean,",
				"          Issued as boolean,",
				"          NetIssued as boolean,",
				"          Sat as boolean,",
				"          Sold as boolean,",
				"          rnk_id as integer,",
				"          SetDate as timestamp,",
				"          VerifiedDate as timestamp,",
				"          ConfirmedDate as timestamp,",
				"          LastChangedDate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> MAC",
				"source(output(",
				"          id as integer,",
				"          cst_id as integer,",
				"          Lds_ID as integer,",
				"          ApptDate as timestamp,",
				"          SetBy as integer,",
				"          VerifiedBy as integer,",
				"          ConfirmedBy as integer,",
				"          Dsp_ID as string,",
				"          ApptSet as boolean,",
				"          Verified as boolean,",
				"          Confirmed as boolean,",
				"          Issued as boolean,",
				"          NetIssued as boolean,",
				"          Sat as boolean,",
				"          Sold as boolean,",
				"          rnk_id as integer,",
				"          SetDate as timestamp,",
				"          VerifiedDate as timestamp,",
				"          ConfirmedDate as timestamp,",
				"          LastChangedDate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SWR",
				"source(output(",
				"          descr as string,",
				"          id as integer,",
				"          Division as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> Srcvwlkpdisposition",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"RTW derive(Division = 'RTW') ~> addOpCoNameRTW",
				"MAC derive(Division = 'MAC') ~> addOpCoNameMAC",
				"SWR derive(Division = 'SWR') ~> addOpCoNameSWR",
				"addOpCoNameFHI, addOpCoNameRTW, addOpCoNameMAC, addOpCoNameSWR union(byName: true)~> unionAllOpCos",
				"lookuponDisposition select(mapColumn(",
				"          Division = unionAllOpCos@Division,",
				"          LP_AppointmentID = unionAllOpCos@id,",
				"          LP_CustomerID = cst_id,",
				"          LP_LeadID = Lds_ID,",
				"          LP_DispositionID = Srcvwlkpdisposition@id,",
				"          LP_RankID = rnk_id,",
				"          ApptDate,",
				"          SetDate,",
				"          VerifiedDate,",
				"          ConfirmedDate,",
				"          LastChangedDate,",
				"          LP_SetBy = SetBy,",
				"          LP_VerifiedBy = VerifiedBy,",
				"          LP_ConfirmedBy = ConfirmedBy,",
				"          ApptSet,",
				"          Verified,",
				"          Confirmed,",
				"          Issued,",
				"          NetIssued,",
				"          Sat,",
				"          Sold",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          AppointmentID = concat(Division,'-',toString(LP_AppointmentID)),",
				"          CustomerID = concat(Division,'-',toString(LP_CustomerID)),",
				"          LeadID = concat(Division,'-',toString(LP_LeadID)),",
				"          DispositionID = concat(Division,'-',toString(LP_DispositionID)),",
				"          RankID = concat(Division,'-',toString(LP_RankID)),",
				"          SetBy = concat(Division,'-',toString(LP_SetBy)),",
				"          VerifiedBy = concat(Division,'-',toString(LP_VerifiedBy)),",
				"          ConfirmedBy = concat(Division,'-',toString(LP_ConfirmedBy))) ~> derivedColumns",
				"unionAllOpCos, Srcvwlkpdisposition lookup(unionAllOpCos@Division == Srcvwlkpdisposition@Division",
				"     && Dsp_ID == descr,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookuponDisposition",
				"derivedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          AppointmentID as string,",
				"          CustomerID as string,",
				"          LeadID as string,",
				"          DispositionID as string,",
				"          RankID as string,",
				"          SetBy as string,",
				"          VerifiedBy as string,",
				"          ConfirmedBy as string,",
				"          ApptDate as timestamp,",
				"          SetDate as timestamp,",
				"          VerifiedDate as timestamp,",
				"          ConfirmedDate as timestamp,",
				"          LastChangedDate as timestamp,",
				"          ApptSet as boolean,",
				"          Verified as boolean,",
				"          Confirmed as boolean,",
				"          Issued as boolean,",
				"          NetIssued as boolean,",
				"          Sat as boolean,",
				"          Sold as boolean,",
				"          LP_AppointmentID as integer,",
				"          LP_CustomerID as integer,",
				"          LP_LeadID as integer,",
				"          LP_RankID as integer,",
				"          LP_DispositionID as string,",
				"          LP_SetBy as integer,",
				"          LP_VerifiedBy as integer,",
				"          LP_ConfirmedBy as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Division,",
				"          LP_AppointmentID,",
				"          LP_CustomerID,",
				"          LP_LeadID,",
				"          LP_DispositionID,",
				"          LP_RankID,",
				"          ApptDate,",
				"          SetDate,",
				"          VerifiedDate,",
				"          ConfirmedDate,",
				"          LastChangedDate,",
				"          LP_SetBy,",
				"          LP_VerifiedBy,",
				"          LP_ConfirmedBy,",
				"          ApptSet,",
				"          Verified,",
				"          Confirmed,",
				"          Issued,",
				"          NetIssued,",
				"          Sat,",
				"          Sold,",
				"          LastUpdateTS,",
				"          AppointmentID,",
				"          CustomerID,",
				"          LeadID,",
				"          DispositionID,",
				"          RankID,",
				"          SetBy,",
				"          VerifiedBy,",
				"          ConfirmedBy",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetFact"
			]
		}
	}
}
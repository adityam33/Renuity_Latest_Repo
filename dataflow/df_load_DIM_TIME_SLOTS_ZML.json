{
	"name": "df_load_DIM_TIME_SLOTS_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_tms_TimeSlots",
						"type": "DatasetReference"
					},
					"name": "FHI",
					"description": "Import data from SRC_ODS_LP_FHI_tms_TimeSlots"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_TIME_SLOTS_ZML",
						"type": "DatasetReference"
					},
					"name": "targetDim",
					"description": "Export data to EDW_DIM_TIME_SLOTS"
				}
			],
			"transformations": [
				{
					"name": "selectColsFHI"
				},
				{
					"name": "createDivFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "createIDsfinal"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI select(mapColumn(",
				"          LP_TimeSlotID = id,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(Division = 'FHI') ~> createDivFHI",
				"createDivFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(TimeSlotID = concatWS('-',Division,toString(LP_TimeSlotID)),",
				"          LastUpdateTS = currentTimestamp()) ~> createIDsfinal",
				"createIDsfinal alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          TimeSlotID as string,",
				"          SlotTime as string,",
				"          SlotTimeAP as string,",
				"          ShortName as string,",
				"          MediumName as string,",
				"          LongName as string,",
				"          Active as boolean,",
				"          LP_TimeSlotID as integer,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['TimeSlotID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_TimeSlotID,",
				"          SlotTime,",
				"          SlotTimeAP,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active,",
				"          Division,",
				"          TimeSlotID,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
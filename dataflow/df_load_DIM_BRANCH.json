				"          Division as string,",
				"          UNI_Market as string,",
				"          UNI_MarketGroup as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['BranchID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_BranchID,",
				"          ShortName,",
				"          MediumName,",
				"          LongName,",
				"          Active,",
				"          CanSet = unionAllOpCos@CanSet,",
				"          LP_ReportingMarketID = LP_ReportingMarket_ID,",
				"          LP_ReportingMarketTypeID = LP_ReportingMarketType_ID,",

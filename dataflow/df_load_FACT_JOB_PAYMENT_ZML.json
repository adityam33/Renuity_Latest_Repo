{
	"name": "df_load_FACT_JOB_PAYMENT_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/FACTS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_jbp_JobPayments",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_FACT_JOB_PAYMENT_ZML",
						"type": "DatasetReference"
					},
					"name": "targetFact",
					"description": "Export data to EDW_FACT_JOB_PAYMENT",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "addOpCoNameFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "derivedColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          job_id as integer,",
				"          PmtAmount as decimal(19,4),",
				"          PmtDate as timestamp,",
				"          pmt_id as string,",
				"          pmm_id as string,",
				"          ARBatchNo as integer,",
				"          ARBatchDate as timestamp,",
				"          ARBatchFlag as integer,",
				"          IncBatchNo as integer,",
				"          IncBatchDate as timestamp,",
				"          IncBatchFlag as integer,",
				"          EnteredOn as timestamp,",
				"          EnteredBy as integer,",
				"          LastChangedOn as timestamp,",
				"          LastChangedBy as integer,",
				"          PmtNotes as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'select \\nid     ,\\njob_id     ,\\nPmtAmount     ,\\nPmtDate     ,\\npmt_id     ,\\npmm_id     ,\\nARBatchNo     ,\\nARBatchDate     ,\\nCAST(ARBatchFlag AS INT) AS ARBatchFlag     ,\\nIncBatchNo     ,\\nIncBatchDate     ,\\nCAST(IncBatchFlag AS INT) AS IncBatchFlag,\\nEnteredOn     ,\\nEnteredBy     ,\\nLastChangedOn     ,\\nLastChangedBy     ,\\nPmtNotes     \\n from [ODS].[LP_FHI_jbp_JobPayments]',",
				"     format: 'query',",
				"     staged: true) ~> FHI",
				"FHI derive(Division = 'FHI') ~> addOpCoNameFHI",
				"addOpCoNameFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos select(mapColumn(",
				"          Division,",
				"          LP_JobPaymentID = id,",
				"          LP_JobID = job_id,",
				"          LP_PaymentTypeID = pmt_id,",
				"          LP_PaymentMethodID = pmm_id,",
				"          PaymentDate = PmtDate,",
				"          ARBatchDate,",
				"          IncBatchDate,",
				"          ARBatchNo,",
				"          IncBatchNo,",
				"          PaymentAmount = PmtAmount,",
				"          ARBatchFlag,",
				"          IncBatchFlag,",
				"          PaymentNotes = PmtNotes",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(LastUpdateTS = currentTimestamp(),",
				"          JobPaymentID = concat(Division,'-',toString(LP_JobPaymentID)),",
				"          JobID = concat(Division,'-',toString(LP_JobID)),",
				"          PaymentTypeID = concat(Division,'-',toString(LP_PaymentTypeID)),",
				"          PaymentMethodID = concat(Division,'-',toString(LP_PaymentMethodID))) ~> derivedColumns",
				"derivedColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          JobPaymentID as string,",
				"          JobID as string,",
				"          PaymentTypeID as string,",
				"          PaymentMethodID as string,",
				"          PaymentDate as timestamp,",
				"          ARBatchDate as timestamp,",
				"          IncBatchDate as timestamp,",
				"          ARBatchNo as integer,",
				"          IncBatchNo as integer,",
				"          PaymentAmount as decimal(19,4),",
				"          LP_JobPaymentID as integer,",
				"          LP_JobID as integer,",
				"          LP_PaymentTypeID as string,",
				"          LP_PaymentMethodID as string,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Division,",
				"          LP_JobPaymentID,",
				"          LP_JobID,",
				"          LP_PaymentTypeID,",
				"          LP_PaymentMethodID,",
				"          PaymentDate,",
				"          ARBatchDate,",
				"          IncBatchDate,",
				"          ARBatchNo,",
				"          IncBatchNo,",
				"          PaymentAmount,",
				"          ARBatchFlag,",
				"          IncBatchFlag,",
				"          PaymentNotes,",
				"          LastUpdateTS,",
				"          JobPaymentID,",
				"          JobID,",
				"          PaymentTypeID,",
				"          PaymentMethodID",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetFact"
			]
		}
	}
}
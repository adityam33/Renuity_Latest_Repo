				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          MarketingCostDetailId,",
				"          LeadSubSourceID,",
				"          SDate,",
				"          MarketingCostCategoryID,",
				"          Description,",
				"          Amount,",
				"          ValidFromDate,",
				"          ValidToDate,",
				"          Recordsource,",
				"          ProductID,",
				"          BranchID,",
				"          LP_LeadSubSourceID,",
				"          LP_MarketingCostCategoryID,",
				"          LP_ProductID,",
				"          LP_BranchID,",
				"          Division,",

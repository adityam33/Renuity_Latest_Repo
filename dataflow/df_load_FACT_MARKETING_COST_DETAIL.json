				"          MarketingCostDetailId as integer,",
				"          LeadSubSourceID as string,",
				"          SDate as timestamp,",
				"          MarketingCostCategoryID as string,",
				"          Description as string,",
				"          Amount as decimal(16,2),",
				"          ValidFromDate as timestamp,",
				"          ValidToDate as timestamp,",
				"          Recordsource as string,",
				"          ProductID as string,",
				"          BranchID as string,",
				"          LP_LeadSubSourceID as integer,",
				"          LP_MarketingCostCategoryID as integer,",
				"          LP_ProductID as string,",
				"          LP_BranchID as string,",

{
	"name": "df_load_Medallia_Response_Rate",
	"properties": {
		"folder": {
			"name": "Test-Dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "OUT_MEDALLIA_INSTALL_EXP_INVITE_1",
						"type": "DatasetReference"
					},
					"name": "srcmedalliadata"
				},
				{
					"dataset": {
						"referenceName": "OUT_MEDALLIA_INSTALL_EXP_INVITE_HIST",
						"type": "DatasetReference"
					},
					"name": "srcmedalliahistdata"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "OUT_MEDALLIA_INSTALL_EXP_INVITE_HIST",
						"type": "DatasetReference"
					},
					"name": "TgtMedalliaHistData",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "lkpmedalliahistdata"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "InsertUpdateMedalliaData"
				},
				{
					"name": "selectColsToInsert"
				},
				{
					"name": "InsertNewMedalliaData"
				}
			],
			"scriptLines": [
				"source(output(",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          EMAIL_ADDRESS as string,",
				"          PHONE_NUMBER as string,",
				"          CONTRACT_ID as string,",
				"          ACCOUNT_ID as integer,",
				"          SERVICE_DATETIME as timestamp,",
				"          PRODUCT_LINE as string,",
				"          PRODUCTION_BRANCH_NAME as string,",
				"          SERVICE_TECHNICIAN_1_ID as integer,",
				"          SERVICE_TECHNICIAN_2_ID as integer,",
				"          SERVICE_TECHNICIAN_3_ID as integer,",
				"          SERVICE_TECHNICIAN_4_ID as integer,",
				"          BRAND_NAME as string,",
				"          LANGUAGE as string,",
				"          COUNTRY as string,",
				"          CHANNEL as string,",
				"          REPORTING_MARKET as string,",
				"          REPORTING_MARKET_TYPE as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> srcmedalliadata",
				"source(output(",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          EMAIL_ADDRESS as string,",
				"          PHONE_NUMBER as string,",
				"          CONTRACT_ID as string,",
				"          ACCOUNT_ID as integer,",
				"          SERVICE_DATETIME as timestamp,",
				"          PRODUCT_LINE as string,",
				"          PRODUCTION_BRANCH_NAME as string,",
				"          SERVICE_TECHNICIAN_1_ID as integer,",
				"          SERVICE_TECHNICIAN_2_ID as integer,",
				"          SERVICE_TECHNICIAN_3_ID as integer,",
				"          SERVICE_TECHNICIAN_4_ID as integer,",
				"          BRAND_NAME as string,",
				"          LANGUAGE as string,",
				"          COUNTRY as string,",
				"          CHANNEL as string,",
				"          REPORTING_MARKET as string,",
				"          REPORTING_MARKET_TYPE as string,",
				"          SUrvey_Sent_Date as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'select * from OUT.MEDALLIA_INSTALL_EXP_INVITE_TEST\\r\\nwhere SUrvey_Sent_Date>=(Select DATEADD(dd,-31,max(SUrvey_Sent_Date)) from OUT.MEDALLIA_INSTALL_EXP_INVITE_TEST)\\r\\n',",
				"     format: 'query',",
				"     staged: true) ~> srcmedalliahistdata",
				"srcmedalliadata, srcmedalliahistdata lookup(srcmedalliadata@CONTRACT_ID == srcmedalliahistdata@CONTRACT_ID",
				"     && srcmedalliadata@ACCOUNT_ID == srcmedalliahistdata@ACCOUNT_ID",
				"     && srcmedalliadata@BRAND_NAME == srcmedalliahistdata@BRAND_NAME,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lkpmedalliahistdata",
				"lkpmedalliahistdata derive(Flag = iif((isNull(srcmedalliahistdata@CONTRACT_ID) \r",
				"&& isNull(srcmedalliahistdata@ACCOUNT_ID)\r",
				"&& isNull(srcmedalliahistdata@BRAND_NAME)), '1', '0'),",
				"          LastUpdatedTS = currentUTC(),",
				"          CreatedTS = currentUTC(),",
				"          CreatedBY = 'ETLadmin',",
				"          Survey_sent_date = toDate('2024-04-08')) ~> derivedColumn1",
				"derivedColumn1 split(Flag=='1',",
				"     disjoint: false) ~> InsertUpdateMedalliaData@(Insert, Update)",
				"InsertUpdateMedalliaData@Insert select(mapColumn(",
				"          FIRST_NAME = InsertUpdateMedalliaData@Insert@FIRST_NAME,",
				"          LAST_NAME = InsertUpdateMedalliaData@Insert@LAST_NAME,",
				"          EMAIL_ADDRESS = InsertUpdateMedalliaData@Insert@EMAIL_ADDRESS,",
				"          PHONE_NUMBER = InsertUpdateMedalliaData@Insert@PHONE_NUMBER,",
				"          CONTRACT_ID = InsertUpdateMedalliaData@Insert@CONTRACT_ID,",
				"          ACCOUNT_ID = InsertUpdateMedalliaData@Insert@ACCOUNT_ID,",
				"          SERVICE_DATETIME = InsertUpdateMedalliaData@Insert@SERVICE_DATETIME,",
				"          PRODUCT_LINE = InsertUpdateMedalliaData@Insert@PRODUCT_LINE,",
				"          PRODUCTION_BRANCH_NAME = InsertUpdateMedalliaData@Insert@PRODUCTION_BRANCH_NAME,",
				"          SERVICE_TECHNICIAN_1_ID = InsertUpdateMedalliaData@Insert@SERVICE_TECHNICIAN_1_ID,",
				"          SERVICE_TECHNICIAN_2_ID = InsertUpdateMedalliaData@Insert@SERVICE_TECHNICIAN_2_ID,",
				"          SERVICE_TECHNICIAN_3_ID = InsertUpdateMedalliaData@Insert@SERVICE_TECHNICIAN_3_ID,",
				"          SERVICE_TECHNICIAN_4_ID = InsertUpdateMedalliaData@Insert@SERVICE_TECHNICIAN_4_ID,",
				"          BRAND_NAME = InsertUpdateMedalliaData@Insert@BRAND_NAME,",
				"          LANGUAGE = InsertUpdateMedalliaData@Insert@LANGUAGE,",
				"          COUNTRY = InsertUpdateMedalliaData@Insert@COUNTRY,",
				"          CHANNEL = InsertUpdateMedalliaData@Insert@CHANNEL,",
				"          REPORTING_MARKET = InsertUpdateMedalliaData@Insert@REPORTING_MARKET,",
				"          REPORTING_MARKET_TYPE = InsertUpdateMedalliaData@Insert@REPORTING_MARKET_TYPE,",
				"          SUrvey_Sent_Date = InsertUpdateMedalliaData@Insert@Survey_sent_date,",
				"          Flag,",
				"          LastUpdatedTS,",
				"          CreatedTS,",
				"          CreatedBY,",
				"          Survey_sent_date = InsertUpdateMedalliaData@Insert@Survey_sent_date",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsToInsert",
				"selectColsToInsert alterRow(insertIf(Flag=='1')) ~> InsertNewMedalliaData",
				"InsertNewMedalliaData sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          FIRST_NAME as string,",
				"          LAST_NAME as string,",
				"          EMAIL_ADDRESS as string,",
				"          PHONE_NUMBER as string,",
				"          CONTRACT_ID as string,",
				"          ACCOUNT_ID as integer,",
				"          SERVICE_DATETIME as timestamp,",
				"          PRODUCT_LINE as string,",
				"          PRODUCTION_BRANCH_NAME as string,",
				"          SERVICE_TECHNICIAN_1_ID as integer,",
				"          SERVICE_TECHNICIAN_2_ID as integer,",
				"          SERVICE_TECHNICIAN_3_ID as integer,",
				"          SERVICE_TECHNICIAN_4_ID as integer,",
				"          BRAND_NAME as string,",
				"          LANGUAGE as string,",
				"          COUNTRY as string,",
				"          CHANNEL as string,",
				"          REPORTING_MARKET as string,",
				"          REPORTING_MARKET_TYPE as string,",
				"          SUrvey_Sent_Date as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          FIRST_NAME,",
				"          LAST_NAME,",
				"          EMAIL_ADDRESS,",
				"          PHONE_NUMBER,",
				"          CONTRACT_ID,",
				"          ACCOUNT_ID,",
				"          SERVICE_DATETIME,",
				"          PRODUCT_LINE,",
				"          PRODUCTION_BRANCH_NAME,",
				"          SERVICE_TECHNICIAN_1_ID,",
				"          SERVICE_TECHNICIAN_2_ID,",
				"          SERVICE_TECHNICIAN_3_ID,",
				"          SERVICE_TECHNICIAN_4_ID,",
				"          BRAND_NAME,",
				"          LANGUAGE,",
				"          COUNTRY,",
				"          CHANNEL,",
				"          REPORTING_MARKET,",
				"          REPORTING_MARKET_TYPE,",
				"          SUrvey_Sent_Date",
				"     )) ~> TgtMedalliaHistData"
			]
		}
	}
}
					"description": "Creating/updating the columns DivisionID"
				},
				{
					"name": "derivedDivisionMAC",
					"description": "Creating/updating the columns DivisionID"
				},
				{
					"name": "derivedDivisionMXH",
					"description": "Creating/updating the columns DivisionID"
				},
				{
					"name": "derivedDivisionPBC",
					"description": "Creating/updating the columns DivisionID"
				},
				{
					"name": "unionAllOpCos",
					"description": "Combining rows from transformation 'createIDsFHI, createIDsHSI, createIDsMAC, createIDsPBC, createIDsPHI, createIDsSWR, createIDsRTW, createIDsMXH'"
				},
				{
					"name": "addLastUpdatedTimestamp"
				},
				{
					"name": "selectColsRTW",
					"description": "Renaming RTW to selectColsPHI with columns 'LP_AlternatePhoneId, LP_CustomerID, Phone, LP_PhoneTypeID, CallMorning, CallAfternoon, CallEvening, CallWeekend, dnc_id, intdnc'"
				},
				{
					"name": "derivedDivisionRTW",

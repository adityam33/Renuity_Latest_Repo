				},
				{
					"name": "selectColsSWR",
					"description": "Renaming SWR to selectColsPHI with columns 'LP_AlternatePhoneId, LP_CustomerID, Phone, LP_PhoneTypeID, CallMorning, CallAfternoon, CallEvening, CallWeekend, dnc_id, intdnc'"
				},
				{
					"name": "derivedDivisionSWR",
					"description": "Creating/updating the columns DivisionID"
				},
				{
					"name": "selectColsCTA"
				},
				{
					"name": "derivedDivisionCTA"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Id as long,",
				"          Phone as string,",
				"          Descr as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          srs_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"source(output(",
				"          Id as long,",
				"          Phone as string,",
				"          Descr as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          srs_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> HSI",
				"source(output(",
				"          Id as long,",
				"          Phone as string,",
				"          Descr as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          srs_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MAC",
				"source(output(",
				"          Id as long,",
				"          Phone as string,",
				"          Descr as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          srs_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MXH",
				"source(output(",
				"          Id as long,",
				"          Phone as string,",
				"          Descr as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          srs_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> PBC",
				"source(output(",
				"          Id as long,",
				"          Phone as string,",
				"          Descr as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          srs_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"source(output(",
				"          Id as long,",
				"          Phone as string,",
				"          Descr as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          srs_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          Id as long,",
				"          Phone as string,",
				"          Descr as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          srs_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> CTA",
				"FHI select(mapColumn(",
				"          LP_PhoneId = Id,",
				"          Phone,",
				"          PhoneDescription = Descr,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID = srs_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"HSI select(mapColumn(",
				"          LP_PhoneId = Id,",
				"          Phone,",
				"          PhoneDescription = Descr,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID = srs_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsHSI",
				"MAC select(mapColumn(",
				"          LP_PhoneId = Id,",
				"          Phone,",
				"          PhoneDescription = Descr,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID = srs_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsMAC",
				"MXH select(mapColumn(",
				"          LP_PhoneId = Id,",
				"          Phone,",
				"          PhoneDescription = Descr,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID = srs_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsMXH",
				"PBC select(mapColumn(",
				"          LP_PhoneId = Id,",
				"          Phone,",
				"          PhoneDescription = Descr,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID = srs_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsPBC",
				"selectColsFHI derive(Division = 'FHI') ~> derivedDivisionFHI",
				"selectColsHSI derive(Division = 'HSI') ~> derivedDivisionHSI",
				"selectColsMAC derive(Division = 'MAC') ~> derivedDivisionMAC",
				"selectColsMXH derive(Division = 'MXH') ~> derivedDivisionMXH",
				"selectColsPBC derive(Division = 'PBC') ~> derivedDivisionPBC",
				"derivedDivisionFHI, derivedDivisionHSI, derivedDivisionMAC, derivedDivisionMXH, derivedDivisionPBC, derivedDivisionRTW, derivedDivisionSWR, derivedDivisionCTA union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(LastUpdatedTS = currentTimestamp(),",
				"          SubSourceID = concat(Division,'-',toString(LP_SubSourceID)),",
				"          PhoneID = concat(Division,'-',toString(LP_PhoneId))) ~> addLastUpdatedTimestamp",
				"RTW select(mapColumn(",
				"          LP_PhoneId = Id,",
				"          Phone,",
				"          PhoneDescription = Descr,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID = srs_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsRTW",
				"selectColsRTW derive(Division = 'RTW') ~> derivedDivisionRTW",
				"SWR select(mapColumn(",
				"          LP_PhoneId = Id,",
				"          Phone,",
				"          PhoneDescription = Descr,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID = srs_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsSWR",
				"selectColsSWR derive(Division = 'SWR') ~> derivedDivisionSWR",
				"CTA select(mapColumn(",
				"          LP_PhoneId = Id,",
				"          Phone,",
				"          PhoneDescription = Descr,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID = srs_id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsCTA",
				"selectColsCTA derive(Division = 'CTA') ~> derivedDivisionCTA",
				"addLastUpdatedTimestamp alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          PhoneId as string,",
				"          Phone as string,",
				"          PhoneDescription as string,",
				"          Active as integer,",
				"          SortOrder as integer,",
				"          SubSourceID as string,",
				"          LP_SubSourceID as integer,",
				"          LP_PhoneId as integer,",
				"          Division as string,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['PhoneId'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_PhoneId,",
				"          Phone,",
				"          PhoneDescription,",
				"          Active,",
				"          SortOrder,",
				"          LP_SubSourceID,",
				"          Division,",
				"          LastUpdatedTS,",
				"          SubSourceID,",
				"          PhoneId = PhoneID",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDIM"
			]
		}
	}

				},
				{
					"name": "createIDsCTA"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ProductID as string,",
				"          prg_id as string,",
				"          ShortDescr as string,",
				"          MediumDescr as string,",
				"          LongDescr as string,",
				"          Aff_ProductID as string,",
				"          SCI_ProductID as string,",
				"          AvgDuration as integer,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          active as boolean,",
				"          SortOrder as integer,",
				"          hdvendorid as string,",
				"          hdprogramgroup as string,",
				"          id as integer,",
				"          GLAcct as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"source(output(",
				"          ProductID as string,",
				"          prg_id as string,",
				"          ShortDescr as string,",
				"          MediumDescr as string,",
				"          LongDescr as string,",
				"          Aff_ProductID as string,",
				"          SCI_ProductID as string,",
				"          AvgDuration as integer,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          active as boolean,",
				"          SortOrder as integer,",
				"          hdvendorid as string,",
				"          hdprogramgroup as string,",
				"          id as integer,",
				"          GLAcct as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> HSI",
				"source(output(",
				"          ProductID as string,",
				"          prg_id as string,",
				"          ShortDescr as string,",
				"          MediumDescr as string,",
				"          LongDescr as string,",
				"          Aff_ProductID as string,",
				"          SCI_ProductID as string,",
				"          AvgDuration as integer,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          active as boolean,",
				"          SortOrder as integer,",
				"          hdvendorid as string,",
				"          hdprogramgroup as string,",
				"          id as integer,",
				"          GLAcct as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MAC",
				"source(output(",
				"          ProductID as string,",
				"          prg_id as string,",
				"          ShortDescr as string,",
				"          MediumDescr as string,",
				"          LongDescr as string,",
				"          Aff_ProductID as string,",
				"          SCI_ProductID as string,",
				"          AvgDuration as integer,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          active as boolean,",
				"          SortOrder as integer,",
				"          hdvendorid as string,",
				"          hdprogramgroup as string,",
				"          id as integer,",
				"          GLAcct as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> PBC",
				"source(output(",
				"          ProductID as string,",
				"          prg_id as string,",
				"          ShortDescr as string,",
				"          MediumDescr as string,",
				"          LongDescr as string,",
				"          Aff_ProductID as string,",
				"          SCI_ProductID as string,",
				"          AvgDuration as integer,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          active as boolean,",
				"          SortOrder as integer,",
				"          hdvendorid as string,",
				"          hdprogramgroup as string,",
				"          id as integer,",
				"          GLAcct as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> SWR",
				"source(output(",
				"          ProductID as string,",
				"          prg_id as string,",
				"          ShortDescr as string,",
				"          MediumDescr as string,",
				"          LongDescr as string,",
				"          Aff_ProductID as string,",
				"          SCI_ProductID as string,",
				"          AvgDuration as integer,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          active as boolean,",
				"          SortOrder as integer,",
				"          hdvendorid as string,",
				"          hdprogramgroup as string,",
				"          id as integer,",
				"          GLAcct as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> RTW",
				"source(output(",
				"          ProductID as string,",
				"          prg_id as string,",
				"          ShortDescr as string,",
				"          MediumDescr as string,",
				"          LongDescr as string,",
				"          Aff_ProductID as string,",
				"          SCI_ProductID as string,",
				"          AvgDuration as integer,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          active as boolean,",
				"          SortOrder as integer,",
				"          hdvendorid as string,",
				"          hdprogramgroup as string,",
				"          id as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> MXH",
				"source(output(",
				"          ProductID as string,",
				"          prg_id as string,",
				"          ShortDescr as string,",
				"          MediumDescr as string,",
				"          LongDescr as string,",
				"          Aff_ProductID as string,",
				"          SCI_ProductID as string,",
				"          AvgDuration as integer,",
				"          ForeColor as string,",
				"          BackColor as string,",
				"          active as boolean,",
				"          SortOrder as integer,",
				"          hdvendorid as string,",
				"          hdprogramgroup as string,",
				"          id as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> CTA",
				"FHI select(mapColumn(",
				"          ProductName = ProductID,",
				"          LP_ProductGroupID = prg_id,",
				"          ShortDescription = ShortDescr,",
				"          MediumDescription = MediumDescr,",
				"          LongDescription = LongDescr,",
				"          Active = active,",
				"          LP_ProductID = id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(ProductID = concat('FHI-',toString(LP_ProductID)),",
				"          Division = 'FHI',",
				"          ProductGroupID = concat('FHI-',toString(LP_ProductGroupID))) ~> createIDsFHI",
				"HSI select(mapColumn(",
				"          ProductName = ProductID,",
				"          LP_ProductGroupID = prg_id,",
				"          ShortDescription = ShortDescr,",
				"          MediumDescription = MediumDescr,",
				"          LongDescription = LongDescr,",
				"          Active = active,",
				"          LP_ProductID = id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsHSI",
				"MAC select(mapColumn(",
				"          ProductName = ProductID,",
				"          LP_ProductGroupID = prg_id,",
				"          ShortDescription = ShortDescr,",
				"          MediumDescription = MediumDescr,",
				"          LongDescription = LongDescr,",
				"          Active = active,",
				"          LP_ProductID = id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsMAC",
				"PBC select(mapColumn(",
				"          ProductName = ProductID,",
				"          LP_ProductGroupID = prg_id,",
				"          ShortDescription = ShortDescr,",
				"          MediumDescription = MediumDescr,",
				"          LongDescription = LongDescr,",
				"          Active = active,",
				"          LP_ProductID = id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectPBC",
				"SWR select(mapColumn(",
				"          ProductName = ProductID,",
				"          LP_ProductGroupID = prg_id,",
				"          ShortDescription = ShortDescr,",
				"          MediumDescription = MediumDescr,",
				"          LongDescription = LongDescr,",
				"          Active = active,",
				"          LP_ProductID = id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectSWR",
				"selectColsHSI derive(ProductID = concat('HSI-',toString(LP_ProductID)),",
				"          Division = 'HSI',",
				"          ProductGroupID = concat('HSI-',toString(LP_ProductGroupID))) ~> createIDsHSI",
				"selectColsMAC derive(ProductID = concat('MAC-',toString(LP_ProductID)),",
				"          Division = 'MAC',",
				"          ProductGroupID = concat('MAC-',toString(LP_ProductGroupID))) ~> createIDsMAC",
				"selectPBC derive(ProductID = concat('PBC-',toString(LP_ProductID)),",
				"          Division = 'PBC',",
				"          ProductGroupID = concat('PBC-',toString(LP_ProductGroupID))) ~> createIDsPBC",
				"selectSWR derive(ProductID = concat('SWR-',toString(LP_ProductID)),",
				"          Division = 'SWR',",
				"          ProductGroupID = concat('SWR-',toString(LP_ProductGroupID))) ~> createIDsSWR",
				"createIDsFHI, createIDsHSI, createIDsMAC, createIDsPBC, createIDsSWR, createIDsRTW, createIDsMXH, createIDsCTA union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(LastUpdateTS = currentTimestamp()) ~> addLastUpdateTimestamp",
				"RTW select(mapColumn(",
				"          ProductName = ProductID,",
				"          LP_ProductGroupID = prg_id,",
				"          ShortDescription = ShortDescr,",
				"          MediumDescription = MediumDescr,",
				"          LongDescription = LongDescr,",
				"          Active = active,",
				"          LP_ProductID = id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRTW",
				"selectRTW derive(ProductID = concat('RTW-',toString(LP_ProductID)),",
				"          Division = 'RTW',",
				"          ProductGroupID = concat('RTW-',toString(LP_ProductGroupID))) ~> createIDsRTW",
				"MXH select(mapColumn(",
				"          ProductName = ProductID,",
				"          LP_ProductGroupID = prg_id,",
				"          ShortDescription = ShortDescr,",
				"          MediumDescription = MediumDescr,",
				"          LongDescription = LongDescr,",
				"          Active = active,",
				"          LP_ProductID = id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectMXH",
				"selectMXH derive(ProductID = concat('MXH-',toString(LP_ProductID)),",
				"          ProductGroupID = concat('MXH-',toString(LP_ProductGroupID)),",
				"          Division = 'MXH') ~> createIDsMXH",
				"CTA select(mapColumn(",
				"          ProductName = ProductID,",
				"          LP_ProductGroupID = prg_id,",
				"          ShortDescription = ShortDescr,",
				"          MediumDescription = MediumDescr,",
				"          LongDescription = LongDescr,",
				"          active,",
				"          LP_ProductID = id",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectCTA",
				"selectCTA derive(ProductID = concat('CTA-',toString(LP_ProductID)),",
				"          ProductGroupID = concat('CTA-',toString(LP_ProductGroupID)),",
				"          Division = 'CTA') ~> createIDsCTA",
				"addLastUpdateTimestamp alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ProductID as string,",
				"          ProductGroupID as string,",
				"          ProductName as string,",
				"          ShortDescription as string,",
				"          MediumDescription as string,",
				"          LongDescription as string,",
				"          Active as boolean,",
				"          LP_ProductID as integer,",
				"          LP_ProductGroupID as string,",
				"          Division as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['ProductID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ProductName,",
				"          LP_ProductGroupID,",
				"          ShortDescription,",
				"          MediumDescription,",
				"          LongDescription,",
				"          Active = unionAllOpCos@Active,",
				"          LP_ProductID,",
				"          ProductID,",
				"          Division,",
				"          ProductGroupID,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
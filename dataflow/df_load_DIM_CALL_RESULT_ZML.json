{
	"name": "df_load_DIM_CALL_RESULT_ZML",
	"properties": {
		"folder": {
			"name": "ZML_ODS_to_EDW/DIMENSIONS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ZML_ODS_FHI_clr_CallResults",
						"type": "DatasetReference"
					},
					"name": "FHI"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_DIM_CALL_RESULT_ZML",
						"type": "DatasetReference"
					},
					"name": "targetDim",
					"description": "Export data to EDW_DIM_CALL_RESULT",
					"rejectedDataLinkedService": {
						"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "selectColsFHI"
				},
				{
					"name": "createIDsFHI"
				},
				{
					"name": "unionAllOpCos"
				},
				{
					"name": "addLastUpdateTimestamp"
				},
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as string,",
				"          Descr as string,",
				"          Deferral as integer,",
				"          Connected as boolean,",
				"          Pitched as boolean,",
				"          Positive as boolean,",
				"          DialNextNumber as boolean,",
				"          Active as boolean,",
				"          SortOrder as integer,",
				"          idpkey as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> FHI",
				"FHI select(mapColumn(",
				"          LP_CallResultID = ID,",
				"          CallResult = Descr,",
				"          Deferral,",
				"          Connected,",
				"          Pitched,",
				"          Positive,",
				"          DialNextNumber,",
				"          Active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColsFHI",
				"selectColsFHI derive(CallResultID = concat('FHI-',toString(LP_CallResultID)),",
				"          Division = 'FHI') ~> createIDsFHI",
				"createIDsFHI union(byName: true)~> unionAllOpCos",
				"unionAllOpCos derive(LastUpdateTS = currentTimestamp()) ~> addLastUpdateTimestamp",
				"addLastUpdateTimestamp alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CallResultID as string,",
				"          CallResult as string,",
				"          Deferral as integer,",
				"          Connected as boolean,",
				"          Pitched as boolean,",
				"          Positive as boolean,",
				"          DialNextNumber as boolean,",
				"          Active as boolean,",
				"          LP_CallResultID as string,",
				"          Division as string,",
				"          UNI_CallResult as string,",
				"          LastUpdateTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['CallResultID'],",
				"     format: 'table',",
				"     staged: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          LP_CallResultID,",
				"          CallResult,",
				"          Deferral,",
				"          Connected,",
				"          Pitched,",
				"          Positive,",
				"          DialNextNumber,",
				"          Active,",
				"          CallResultID,",
				"          Division,",
				"          LastUpdateTS",
				"     ),",
				"     preCommands: [],",
				"     postCommands: []) ~> targetDim"
			]
		}
	}
}
{
	"name": "df_deltaload_FACT_ERP_GL_TRANSACTION",
	"properties": {
		"folder": {
			"name": "ODS_to_EDW/FACTS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SRC_ODS_ERP_GL_TRANSACTIONS_GL_DELTA",
						"type": "DatasetReference"
					},
					"name": "ERPGLTransactionsGLDelta"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_FACT_ERP_GL_TRANSACTION",
						"type": "DatasetReference"
					},
					"name": "FactERPGlTransaction"
				}
			],
			"transformations": [
				{
					"name": "extractSubAccountSegments"
				},
				{
					"name": "GLHistChangeDatatypes"
				},
				{
					"name": "upsertRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Module as string,",
				"          BatchNumber as string,",
				"          LineNbr as integer,",
				"          Account as string,",
				"          Branch as string,",
				"          CreatedBy as string,",
				"          GLTran_createdDateTime as timestamp,",
				"          GLTran_creditAmt as decimal(38,18),",
				"          GLTran_debitAmt as decimal(38,18),",
				"          PeriodID as string,",
				"          GLTran_lastModifiedDateTime as timestamp,",
				"          GLTran_ledgerID as integer,",
				"          OrigBatchNbr as string,",
				"          OrigLineNbr as integer,",
				"          OrigModule as string,",
				"          ProjectTranID as long,",
				"          GLTran_posted as string,",
				"          GLTran_postYear as string,",
				"          Project as string,",
				"          CustomerVendor as string,",
				"          RefNumber as string,",
				"          GLTran_released as string,",
				"          Selected as string,",
				"          Subaccount as string,",
				"          GLTran_summPost as string,",
				"          ProjectTask as string,",
				"          TaxCategory as string,",
				"          TaxID as string,",
				"          GLTran_tranClass as string,",
				"          TransactionDate as timestamp,",
				"          TransactionDescription as string,",
				"          GLTran_tranID as integer,",
				"          GLTran_tranLineNbr as integer,",
				"          MasterPeriodID as string,",
				"          GLTran_tranType as string,",
				"          GLTran_tranYear as string,",
				"          CreateTS as timestamp,",
				"          UpdateTS as timestamp,",
				"          ServicePeriod as string,",
				"          InventoryID as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table',",
				"     staged: true) ~> ERPGLTransactionsGLDelta",
				"GLHistChangeDatatypes derive(GL_LINE_KEY = Module + '|' + BatchNumber + '|' + toString((LineNbr)),",
				"          ProductID = substring(Subaccount, 1, 3),",
				"          SourceID = substring(Subaccount, 4, 3),",
				"          SourceVendorID = substring(Subaccount, 7, 3),",
				"          DepartmentID = substring(Subaccount, 10, 4),",
				"          MarketingAccountID = substring(Subaccount, 14, 4),",
				"          AcquisitionID = substring(Subaccount, 18, 3),",
				"          BalanceAmount = GLTran_debitAmt - GLTran_creditAmt,",
				"          FinPeriodID = substring(PeriodID,1,2)+'-'+substring(PeriodID,3,4),",
				"          TransactionPeriodID = substring(MasterPeriodID,1,2)+'-'+substring(MasterPeriodID,3,4)) ~> extractSubAccountSegments",
				"ERPGLTransactionsGLDelta derive(GLTran_posted = toBoolean(GLTran_posted),",
				"          GLTran_released = toBoolean(GLTran_posted),",
				"          Selected = toBoolean(Selected),",
				"          GLTran_summPost = toBoolean(GLTran_summPost)) ~> GLHistChangeDatatypes",
				"extractSubAccountSegments alterRow(upsertIf(true())) ~> upsertRow",
				"upsertRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          GL_LINE_KEY as string,",
				"          Module as string,",
				"          BatchNumber as string,",
				"          LineNbr as integer,",
				"          TransactionID as integer,",
				"          AccountCode as string,",
				"          SubAccount as string,",
				"          BranchCode as string,",
				"          FinPeriodID as string,",
				"          LedgerID as integer,",
				"          ProjectID as string,",
				"          ProductID as string,",
				"          SourceID as string,",
				"          SourceVendorID as string,",
				"          DepartmentID as string,",
				"          MarketingAccountID as string,",
				"          AcquisitionID as string,",
				"          ProjectTransactionID as long,",
				"          CustomerVendor as string,",
				"          ReferenceNumber as string,",
				"          ProjectTask as string,",
				"          CreditAmount as decimal(38,18),",
				"          DebitAmount as decimal(38,18),",
				"          BalanceAmount as decimal(38,18),",
				"          PostYear as string,",
				"          TransactionPeriodID as string,",
				"          Posted as boolean,",
				"          Released as boolean,",
				"          Selected as boolean,",
				"          SummaryPost as boolean,",
				"          TaxID as string,",
				"          TaxCategory as string,",
				"          TransactionClass as string,",
				"          TransactionDate as timestamp,",
				"          TransactionDescription as string,",
				"          TransactionLineNbr as integer,",
				"          TransactionType as string,",
				"          TransactionYear as string,",
				"          OriginalBatchNumber as string,",
				"          OriginalLineNumber as integer,",
				"          OriginalModule as string,",
				"          CreatedBy as string,",
				"          CreatedDateTime as timestamp,",
				"          LastModifiedDateTime as timestamp,",
				"          ServicePeriod as string,",
				"          InventoryID as string",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['GL_LINE_KEY'],",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          GL_LINE_KEY,",
				"          Module,",
				"          BatchNumber,",
				"          LineNbr,",
				"          TransactionID = GLTran_tranID,",
				"          AccountCode = Account,",
				"          SubAccount = Subaccount,",
				"          BranchCode = Branch,",
				"          FinPeriodID,",
				"          LedgerID = GLTran_ledgerID,",
				"          ProjectID = Project,",
				"          ProductID,",
				"          SourceID,",
				"          SourceVendorID,",
				"          DepartmentID,",
				"          MarketingAccountID,",
				"          AcquisitionID,",
				"          ProjectTransactionID = ProjectTranID,",
				"          CustomerVendor,",
				"          ReferenceNumber = RefNumber,",
				"          ProjectTask,",
				"          CreditAmount = GLTran_creditAmt,",
				"          DebitAmount = GLTran_debitAmt,",
				"          BalanceAmount,",
				"          PostYear = GLTran_postYear,",
				"          TransactionPeriodID,",
				"          Posted = GLTran_posted,",
				"          Released = GLTran_released,",
				"          Selected,",
				"          SummaryPost = GLTran_summPost,",
				"          TaxID,",
				"          TaxCategory,",
				"          TransactionClass = GLTran_tranClass,",
				"          TransactionDate,",
				"          TransactionDescription,",
				"          TransactionLineNbr = GLTran_tranLineNbr,",
				"          TransactionType = GLTran_tranType,",
				"          TransactionYear = GLTran_tranYear,",
				"          OriginalBatchNumber = OrigBatchNbr,",
				"          OriginalLineNumber = OrigLineNbr,",
				"          OriginalModule = OrigModule,",
				"          CreatedBy,",
				"          CreatedDateTime = GLTran_createdDateTime,",
				"          LastModifiedDateTime = GLTran_lastModifiedDateTime,",
				"          ServicePeriod,",
				"          InventoryID",
				"     )) ~> FactERPGlTransaction"
			]
		}
	}
}
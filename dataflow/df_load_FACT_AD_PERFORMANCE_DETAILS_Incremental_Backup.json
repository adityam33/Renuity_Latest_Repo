{
	"name": "df_load_FACT_AD_PERFORMANCE_DETAILS_Incremental_Backup",
	"properties": {
		"folder": {
			"name": "Test-Dataflows"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ODS_FUNNEL_AD_PERFORMANCE_METRICS",
						"type": "DatasetReference"
					},
					"name": "ODS"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "EDW_FACT_AD_PERFORMANCE_METRICS_DETAIL",
						"type": "DatasetReference"
					},
					"name": "FACT"
				}
			],
			"transformations": [
				{
					"name": "createRZIDSRSID"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PerformanceDate as timestamp,",
				"          DataSourcetype as string,",
				"          DataSource as string,",
				"          DataSourcename as string,",
				"          Trafficsource as string,",
				"          AccountID as string,",
				"          CampaignName as string,",
				"          AdGroupName as string,",
				"          AdName as string,",
				"          CampaignID as string,",
				"          AdGroupID as string,",
				"          ADID as string,",
				"          Mediatype as string,",
				"          PaidOrganic as string,",
				"          Currency as string,",
				"          Cost as double,",
				"          Clicks as long,",
				"          Impressions as long,",
				"          Conversions as double,",
				"          LinkClicks as long,",
				"          Dayofweek as string,",
				"          Month as string,",
				"          Week as string,",
				"          Year as long,",
				"          Week_number as long,",
				"          RZID as string,",
				"          SRSID as string,",
				"          Adlink as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'Select \\n[Date]                              as [PerformanceDate]          ,\\n[Data_Source_type]                  as [DataSourcetype]         ,\\n[Data_Source]                       as [DataSource]             ,\\n[Data_Source_name]                  as [DataSourcename]         ,\\n[Traffic_source]                    as [Trafficsource]          ,\\n[Account]                           as [AccountID]            ,\\n[Campaign]                          as [CampaignName]           ,\\n[Ad_Group]                          as [AdGroupName]            ,\\n[Ad]                                as [AdName]                 ,\\n[Campaign_ID]                       as [CampaignID]             ,\\n[Ad_Group_ID]                       as [AdGroupID]              ,\\n[AD_ID]                             as [ADID]                   ,\\n[Media_type]                        as [Mediatype]              ,\\n[Paid__Organic]                     as [PaidOrganic]            ,\\n[Currency]                          as [Currency]               ,\\n[Cost]                              as [Cost]                   ,\\n[Clicks]                            as [Clicks]                 ,\\n[Impressions]                       as [Impressions]            ,\\n[Conversions]                       as [Conversions]            ,\\n[LinkClicks]                        as [LinkClicks]                    ,\\n[Day_of_week]                       as [Dayofweek]              ,\\n[Month]                             as [Month]                  ,\\n[Week]                              as [Week]                   ,\\n[Year]                              as [Year]                   ,\\n[Week_number]                       as [Week_number]            ,\\n[RZID]                              as [RZID]                 ,\\n[SRSID]                             as [SRSID]                 ,\\n[Adlink]                            as [Adlink]\\n\\n\\nfrom \\n\\n[ODS].[FUNNEL_AD_PERFORMANCE_METRICS_DETAILS]\\n\\n',",
				"     format: 'query',",
				"     staged: true) ~> ODS",
				"ODS derive(RZID_Updated = iif(Trafficsource=='Google',\r",
				"     rtrim(ltrim(RZID,'{rzid}=')),\r",
				"     ltrim(substring(RZID,\r",
				"                  instr(RZID,'rzid='),\r",
				"                  instr(RZID,'&srs_id=')-instr(RZID,'rzid=')\r",
				"                  )\r",
				"            ,'rzid=')\r",
				"     ),",
				"          SRSID_Updated = iif(instr(SRSID,'srs')==0,\r",
				"               '',\r",
				"               iif(Trafficsource=='Google',\r",
				"                    ltrim(substring(SRSID, instr(SRSID,'\"srsid\":\"'), instr(SRSID,'\"}')-instr(SRSID,'\"srsid\":\"')),'\"srsid\":\"'),\r",
				"                    ltrim(substring(SRSID,\r",
				"                                    instr(SRSID,'&srs_id=')+1,\r",
				"                                    iif(instr(SRSID,'&campaign_id')-instr(SRSID,'&srs_id=')-1 <=0 \r",
				"                                                                                                            , length(SRSID)-instr(SRSID,'&srs_id=')\r",
				"                                                                                                           , instr(SRSID,'&campaign_id')-instr(SRSID,'&srs_id=')-1 )\r",
				"                                     )\r",
				"                          ,'srs_id=' )\r",
				"                    )\r",
				"     ),",
				"          CreatedTS = fromUTC(currentUTC(),'EST'),",
				"          LastUpdatedTS = fromUTC(currentUTC(),'EST')) ~> createRZIDSRSID",
				"createRZIDSRSID sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          PerformanceDate as timestamp,",
				"          DataSourcetype as string,",
				"          Trafficsource as string,",
				"          DataSourcename as string,",
				"          AccountID as string,",
				"          CampaignName as string,",
				"          CampaignType as string,",
				"          AdGroupName as string,",
				"          AdGroupType as string,",
				"          AdName as string,",
				"          AdType as string,",
				"          CampaignID as string,",
				"          AdGroupID as string,",
				"          ADID as string,",
				"          Breakdown_Attribute as string,",
				"          Attribute_1 as string,",
				"          Attribute_2 as string,",
				"          PaidOrganic as string,",
				"          Mediatype as string,",
				"          Currency as string,",
				"          Cost as double,",
				"          Clicks as long,",
				"          Impressions as long,",
				"          Conversions as double,",
				"          All_Conversions as double,",
				"          LinkClicks as long,",
				"          All_Conversion_Value as double,",
				"          Dayofweek as string,",
				"          Month as string,",
				"          Week as string,",
				"          Year as long,",
				"          Week_number as long,",
				"          ADCustomParameter as string,",
				"          RZID as string,",
				"          SRSID as string,",
				"          AdLink as string,",
				"          CreatedTS as timestamp,",
				"          LastUpdatedTS as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     staged: true,",
				"     allowCopyCommand: true,",
				"     preSQLs:['DELETE FROM EDW.FACT_AD_PERFORMANCE_METRICS_DETAIL WHERE EOMONTH(PERFORMANCEDATE) IN \\n( SELECT Distinct EOMONTH(DATE) FROM ODS.FUNNEL_AD_PERFORMANCE_METRICS_DETAILS )'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          PerformanceDate,",
				"          DataSourcetype,",
				"          DataSource,",
				"          DataSourcename,",
				"          Trafficsource,",
				"          AccountID,",
				"          CampaignName,",
				"          AdGroupName,",
				"          AdName,",
				"          CampaignID,",
				"          AdGroupID,",
				"          ADID,",
				"          PaidOrganic,",
				"          Mediatype,",
				"          Currency,",
				"          Cost,",
				"          Clicks,",
				"          Impressions,",
				"          Conversions,",
				"          LinkClicks,",
				"          Dayofweek,",
				"          Month,",
				"          Week,",
				"          Year,",
				"          Week_number,",
				"          ADCustomParameter = RZID,",
				"          RZID = RZID_Updated,",
				"          SRSID = SRSID_Updated,",
				"          AdLink = Adlink,",
				"          CreatedTS,",
				"          LastUpdatedTS",
				"     )) ~> FACT"
			]
		}
	}
}
{
	"name": "BinaryDataDestination",
	"properties": {
		"description": "It describes the destination store.",
		"linkedServiceName": {
			"referenceName": "renuitydatacore-WorkspaceDefaultStorage",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"Container": {
				"type": "String"
			},
			"Directory": {
				"type": "String"
			},
			"filename": {
				"type": "string"
			}
		},
		"folder": {
			"name": "Standard_Func_Dataset"
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@replace(dataset().filename,'.',concat(formatDateTime(convertFromUtc(utcnow(), 'Eastern Standard Time'),'_yyyyMMdd_HHmmss.')))",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@{dataset().Directory}",
					"type": "Expression"
				},
				"fileSystem": {
					"value": "@{dataset().Container}",
					"type": "Expression"
				}
			}
		}
	},
	"type": "Microsoft.Synapse/workspaces/datasets"
}
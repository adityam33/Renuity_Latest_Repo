{
	"name": "cpy_load_SUMM_FACT_CONTACT_CENTER_PERFORMANCE",
	"properties": {
		"activities": [
			{
				"name": "Load Contact Center Level Performance into Summary Fact",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.06:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,

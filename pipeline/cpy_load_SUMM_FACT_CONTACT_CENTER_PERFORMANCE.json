				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT \n[Division]\n,SetBy as Agent_EmployeeID\n,count([AppointmentID]) as AppointmentCount\n,min([ApptDate]) EarliestAppointmentDate\n,min([SetDate]) as EarliestDateAppointmentSet\n,min([VerifiedDate]) as EarliestVerifiedDate\n,min([ConfirmedDate]) as EarliestConfirmedDate\n,sum(case when [ApptSet] = 'True' then 1 else 0 end) as ApptSetCount\n,sum(case when [Verified] = 'True' then 1 else 0 end) as VerifiedCount\n,sum(case when [Confirmed] = 'True' then 1 else 0 end) as ConfirmedCount\n,sum(case when [Issued] = 'True' then 1 else 0 end) as IssuedCount\n,sum(case when [NetIssued] = 'True' then 1 else 0 end) as NetIssuedCount\n,sum(case when [Sat] = 'True' then 1 else 0 end) as SatCount\n,sum(case when [Sold] = 'True' then 1 else 0 end) as SoldCount\n FROM [EDW].[FACT_APPOINTMENT]\ngroup BY\n[Division]\n,SetBy",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",
						"preCopyScript": "IF OBJECT_ID('EDW.SUMM_FACT_CONTACT_CENTER_PERFORMANCE')  IS NOT NULL TRUNCATE TABLE EDW.SUMM_FACT_CONTACT_CENTER_PERFORMANCE",

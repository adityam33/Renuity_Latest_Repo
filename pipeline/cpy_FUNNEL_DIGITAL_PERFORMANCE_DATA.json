				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "Update  ODS.FUNNEL_AD_Performance_metrics   Set Data_source_Name='IHM | Renuity | Bath' where Traffic_Source='Facebook' and Data_source_Name='IHM | PCB | Pacific Bath';\r\n\r\n\r\nUpdate  ODS.FUNNEL_AD_Performance_Metrics  Set  data_source_name = Case When account='446062704832816' then 'Closet America - Guru'\r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tWhen account='1383520679433146' then 'FHIA Remodeling - Guru' \r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tWhen account='1162359722291918' then 'MAD CITY - Guru' \r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tWhen account='1117945462471184' then 'Pacific Bath - Guru' \r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tWhen account='727724543532061' then 'Statewide Remodeling - Guru' \r\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\tend\r\nwhere Traffic_Source='Facebook' and Account in (\r\n'1117945462471184',\r\n'1162359722291918',\r\n'1383520679433146',\r\n'446062704832816',\r\n'727724543532061'\r\n);\r\n\r\n\r\nUpdate ODS.Funnel_ad_performance_metrics \r\nSet Account= case when Account ='ClosetAmerica/4021/Classic/Closets/ClosetAmerica/MD&VA' then 'ClosetAmerica/4021/Platinum/Closets/ClosetAmerica/MD&VA'\r\n\t\t\t\t  when Account='ClosetAmerica/5063/Classic/Closets/ClosetAmerica/SC,NC&GA' then 'ClosetAmerica/5063/Platinum/Closets/ClosetAmerica/SC,NC&GA'  end \r\nwhere Traffic_source='Google' and Account like '%Classic%';"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			},

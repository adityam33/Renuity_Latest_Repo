			{
				"name": "UpdateProductGroupIdNameActive",
				"description": "Update ProductGroupId Name Active flag for History from LP",
				"type": "Script",
				"dependsOn": [
					{
						"activity": "cpy_dim_mktng_productMapping",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.06:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "Update EDW.DIM_MKTNG_PRODUCT_MAPPING set \r\n\t\tProductgroupId=t1.ProductGroupID\r\n\t\t,ProductGroup=t1.ProductGroup\r\n\t\t,Active=t1.Active\r\n\t\t,productName=t1.ProductName\r\n\tfrom EDW.DIM_MKTNG_PRODUCT_MAPPING T \r\n\tjoin \r\n\t(\r\n\t\tselect  p.Division,\r\n\t\tp.productID as ProductID,\r\n\t\tp.productName as ProductName,\r\n\t\tP.LongDescription as ProductDescription,\r\n\t\tp.productGroupID as ProductGroupID,\r\n\t\tpg.productgroup as ProductGroup,\r\n\t\tp.Active,\r\n\t\tNULL as TX_ProductGroup,\r\n\t\tNULL AS TX_ProductGroup_Reporting,\r\n\t\t'LP' as MappingInd,\r\n\t\tGetdate() as CreatedTS,\r\n\t\tGetdate() as LastupdatedTS\r\n\t\t\tfrom edw.dim_product P \r\n\t\t\tleft join edw.dim_product_group pg on p.productgroupID=pg.productgroupid\r\n\t) t1 \r\n\ton T.Division=t1.division and t1.productID=t.ProductId\r\nwhere 1=1 ;\r\n\r\n\r\nupdate \r\nEDW.DIM_MKTNG_PRODUCT_MAPPING \r\nset productgroupId = null , productgroup = null, active = null ,ProductName =NULL\r\nwhere productgroupid='ProductReference.xlsx' ;"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			}

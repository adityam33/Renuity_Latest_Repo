					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "Update ODS.ERP_AR_ADJUST set PAYMENT_SOADJUST_TYPE=\ncase when PAYMENT_SOADJUST_TYPE ='INV' then 'Invoice'\n\t when PAYMENT_SOADJUST_TYPE ='DRM' then 'Debit Memo'\n\t when PAYMENT_SOADJUST_TYPE ='FCH' then 'Financial Charge'\n\t when PAYMENT_SOADJUST_TYPE ='CSL' then 'Cash Sales'\n\t when PAYMENT_SOADJUST_TYPE ='RCS' then 'Cash Sales Returns'\n\t when PAYMENT_SOADJUST_TYPE ='SMC' then 'Credit WO'\n\t when PAYMENT_SOADJUST_TYPE ='CRM' then 'Credit Memo'\n\t when PAYMENT_SOADJUST_TYPE ='PMT' then 'Payment'\n\t when PAYMENT_SOADJUST_TYPE ='RPM' then 'Voided Payment'\n\t when PAYMENT_SOADJUST_TYPE ='REF' then 'Customer Refund'\n\t when PAYMENT_SOADJUST_TYPE ='PPM' then 'Prepayment'\n\t when PAYMENT_SOADJUST_TYPE ='SMB' then 'Balance WO'\n\t when PAYMENT_SOADJUST_TYPE ='VRF' then 'Voided Refund'\n\t else PAYMENT_SOADJUST_TYPE\nend\nwhere 1=1\n\n\nUpdate ODS.ERP_AR_ADJUST set Invoice_tran_type=\ncase when Invoice_tran_type ='INV' then 'Invoice'\n\t when Invoice_tran_type ='DRM' then 'Debit Memo'\n\t when Invoice_tran_type ='FCH' then 'Financial Charge'\n\t when Invoice_tran_type ='CSL' then 'Cash Sales'\n\t when Invoice_tran_type ='RCS' then 'Cash Sales Returns'\n\t when Invoice_tran_type ='SMC' then 'Credit WO'\n\t when Invoice_tran_type ='CRM' then 'Credit Memo'\n\t when Invoice_tran_type ='PMT' then 'Payment'\n\t when Invoice_tran_type ='RPM' then 'Voided Payment'\n\t when Invoice_tran_type ='REF' then 'Customer Refund'\n\t when Invoice_tran_type ='PPM' then 'Prepayment'\n\t when Invoice_tran_type ='SMB' then 'Balance WO'\n\t when Invoice_tran_type ='VRF' then 'Voided Refund'\n\t else Invoice_tran_type\nend\nwhere 1=1\n"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}

{
	"name": "cpy_load_SUMM_FACT_PROMOTER_PERFORMANCE_ZML",
	"properties": {
		"activities": [
			{
				"name": "Load Sales Rep Level Performance into Summary Fact",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.06:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT\n[Division]\n,[PromoterID]\n,count([LeadID]) as LeadCount\n,min([EntryDate]) as EarliestLeadEntryDate\n FROM [ZML].[FACT_LEAD]\n where \n LP_PromoterID is not null\n group by \n[Division]\n,[PromoterID]",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",
						"preCopyScript": "IF OBJECT_ID('ZML.SUMM_FACT_PROMOTER_PERFORMANCE')  IS NOT NULL TRUNCATE TABLE ZML.SUMM_FACT_PROMOTER_PERFORMANCE",
						"writeBehavior": "Insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "Division",
									"type": "String",
									"physicalType": "nvarchar"
								},
								"sink": {
									"name": "Division",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "PromoterID",
									"type": "String",
									"physicalType": "nvarchar"
								},
								"sink": {
									"name": "PromoterID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "LeadCount",
									"type": "Int32",
									"physicalType": "int"
								},
								"sink": {
									"name": "LeadCount",
									"type": "Int32",
									"physicalType": "Int32"
								}
							},
							{
								"source": {
									"name": "EarliestLeadEntryDate",
									"type": "DateTime",
									"physicalType": "datetime2"
								},
								"sink": {
									"name": "EarliestLeadEntryDate",
									"type": "DateTime",
									"physicalType": "DateTime"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{

					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "With A As\r\n(\r\nSelect j.JobID,j.ContractID,j.GrossAmount,concat(LastName,',',FirstName) as Customer,c.Phone,c.City,c.State,c.Zip,p.ProductName as Product,js.JobStatus as Job_Status,\r\nmg.ShortName as MarketName,mg.District,j.ContractDate,j.CancelDate,\r\nCASE WHEN md.MilestoneDateTypeID IN ('SWR-C','HSI-C','PBC-C','RTW-C','FHI-C','MAC-S','MXH-C','PHI-C','CTA-C') THEN md.ActualDate END AS CompleteDate\r\nfrom EDW.FACT_JOB j left join EDW.DIM_CUSTOMER c on j.CustomerID=c.CustomerID\r\nleft join EDW.DIM_PRODUCT p on j.ProductID=p.ProductID\r\nleft join EDW.DIM_JOB_STATUS js on j.JobStatusID=js.JobStatusID\r\nLeft join RDM.REF_MKTNG_MARKET_GROUP mg on j.ProductionBranchID=mg.BranchID\r\nleft join EDW.FACT_MILESTONE_DETAIL md on j.JobID=md.JobID and md.MilestoneDateTypeID IN ('SWR-C','HSI-C','PBC-C','RTW-C','FHI-C','MAC-S','MXH-C','PHI-C','CTA-C')\r\n),\r\nB AS\r\n(\r\n    Select p.JobID,SUM(p.PaymentAmount) as AmountPaid from EDW.FACT_JOB_PAYMENT p left join EDW.DIM_PAYMENT_TYPE pt on p.PaymentTypeID=pt.PaymentTypeID where pt.PaymentType Not in ('Cancelled')\r\n    group by p.JobID\r\n)\r\n\r\nSelect A.ContractID,(A.GrossAmount-ISNULL(B.AMountPaid,0)) as AmountDue,ISNULL(B.AmountPaid,0) as AmountPaid,A.Customer,A.Phone,A.City,A.[State],A.Zip,A.Product,A.GrossAmount,A.Job_Status as JobStatus,A.MarketName,\r\nA.District,A.ContractDate,A.CancelDate,A.CompleteDate\r\nfrom A left join B on A.JobID=B.JobID\r\nwhere ContractID is not null",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",
						"preCopyScript": "Truncate Table OUT.REPORT_LP_BALANCES_DUE",

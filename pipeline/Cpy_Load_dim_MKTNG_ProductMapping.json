				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "Update EDW.DIM_MKTNG_Product_MAPPING\r\nSET EntryDate=T2.EntryDate\r\nFrom\r\nEDW.DIM_MKTNG_Product_MAPPING T1 Join \r\n(\r\n\tselect \r\n\tP.Division,\r\n\tP.ProductID,\r\n\tP.EntryDate\r\n\tfrom \r\n\t\t( select \r\n\t\t  a.division,\r\n\t\t  a.ProductID,\r\n\t\t  max(b.entrydate) as entrydate\r\n\t\t  from EDW.DIM_Product a\r\n\t\t  join edw.fact_lead b on a.ProductID = b.ProductID\r\n\t\t  group by  a.division,\r\n\t\t\t\t  a.ProductID\r\n\t\t) P\r\n\twhere entrydate>='2022-01-01' and Year(EntryDate)<=Year(Getdate())\r\n) T2 \r\n On T1.division=T2.division and T1.ProductID=T2.ProductID\r\n Where  T1.division is NOT NULL and T1.ProductID is NOT NULL ;\r\n "
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			}

							"type": "Query",
							"text": "WITH M1 AS \n(\nSELECT \nAGENT_NAME,\nDIVISION\nFROM \n(\n\tSELECT \n\tAGENT_NAME,\n\tDIVISION,\n\tROW_NUMBER() OVER (PARTITION BY AGENT_NAME ORDER BY CNT DESC) AS RW\n\tFROM\n\t(\n\t\t\tSELECT AGENT_NAME,DIVISION,COUNT(1) as CNT\n\t\t\tFROM EDW.FACT_FIVE9_CALL_LOG_ALL \n\t\t\tWHERE AGENT_NAME IS NOT NULL\n\t\t\tAND DIVISION!='NA'\n\t\t\tGROUP BY AGENT_NAME,DIvision\n\t\n\t\t\t) A1\n\t\t) A2\n\tWHERE RW=1\n\t)\n\n\nUPDATE TGT \nSET TGT.DIVISION = M1.DIVISION,\nTGT.DIVISION_ORIG = M1.DIVISION\nFROM M1\nJOIN  [EDW].[FACT_FIVE9_AGENT_STATE_SUMMARY] TGT\nON M1.AGENT_NAME = TGT.AGENT_NAME\nWHERE TGT.DATA_IDENTIFIER='ALL_DIVISION';\n\n\nUPDATE [EDW].[FACT_FIVE9_AGENT_STATE_SUMMARY] SET DIVISION='CTA' WHERE DIVISION='PHI';\nUPDATE [EDW].[FACT_FIVE9_AGENT_STATE_SUMMARY] SET DIVISION='RTW' WHERE DIVISION='HSI';\nUPDATE [EDW].[FACT_FIVE9_AGENT_STATE_SUMMARY] SET DIVISION='MAC' WHERE DATA_IDENTIFIER!='ALL_DIVISION';"

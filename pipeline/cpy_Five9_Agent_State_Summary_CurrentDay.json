			{
				"name": "cpy_FACT_Agent_State_Summary",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "cpy_Agent_State_Summary_MAC",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.6:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "WITH M1 AS \n(\n\t\tSELECT \n\t\t\tCASE WHEN DIVISION='NA' THEN \n\t\t\t\t( CASE \n\t\t\t\t\tWHEN Email_Extn='madcitywindows.com' THEN 'MAC'\n\t\t\t\t\tWHEN Email_Extn='fhiaremodeling.com' THEN 'FHI'\n\t\t\t\t\tWHEN Email_Extn='pacificbath.com' THEN 'PBC'\n\t\t\t\t\tWHEN Email_Extn='closetamerica.com' THEN 'CTA'\n\t\t\t\t\tELSE 'NA' END\n\t\t\t\t\t)\n\t\t\t\tELSE DIVISION END AS DIVISION,\n\t\t\t\tCONCAT(CONCAT(AGENT_FIRST_NAME,' '),AGENT_LAST_NAME) AS AGENT_NAME,\n\t\t\t\tAGENT,\n\t\t\t\tDATE,\n\t\t\t\tAFTER_CALL_WORK ,\n\t\t\t\tLOGIN\t\t\t,\n\t\t\t\tNOT_READY\t\t,\n\t\t\t\tON_CALL\t\t\t,\n\t\t\t\tON_PREVIEW\t\t,\n\t\t\t\tON_VOICEMAIL\t,\n\t\t\t\tREADY\t\t\t,\n\t\t\t\tRINGING\t\t\t,\n\t\t\t\tFILE_IDENTIFIER AS DATA_IDENTIFIER,\n\t\t\t\t[UTILIZATION],\n\t\t\t\t[OCCUPANCY],\n\t\t\t\tCAST(GETDATE() AS DATE) AS LAST_UPDATED_TS\n\t\t\t\t\n\t\t\t\t\tFROM\n\t\t\t\t\t(\n\t\t\t\t\t\tSELECT \n\t\t\t\t\t\tCASE \n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'RIT GROUP' THEN 'RTW'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'FHI GROUP' THEN 'FHI'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'MCW GROUP' THEN 'MAC'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'PHI GROUP' THEN 'PHI'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'PBC GROUP' THEN 'PBC'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'SWR GROUP' THEN 'SWR'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'HSI GROUP' THEN 'HSI'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'MAX GROUP' THEN 'MXH'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='ALL_DIVISION' AND UPPER(AGENT_GROUP) = 'HOME ORG'  THEN 'CTA'\n\t\t\t\t\t\t\tWHEN FILE_IDENTIFIER='MAC' THEN 'MAC'\n\t\t\t\t\t\t\tELSE 'NA' END AS DIVISION,\n\t\t\t\t\t\t\tSUBSTRING(Agent, CHARINDEX('@', Agent) + 1, LEN(Agent) - CHARINDEX('@', Agent)) AS Email_Extn,\n\t\t\t\t\t\t\t*\n\t\t\t\t\t\tFROM [ODS].[FIVE9_AGENT_STATE_SUMMARY]\n\t\t\n\t\t\t) A\n\t\t\t\n\t)\n\t\n\t\nSELECT DISTINCT\nCASE \nWHEN DIVISION='PHI' THEN 'CTA' \nWHEN DIVISION='HSI' THEN 'RTW' \nELSE DIVISION END AS DIVISION,\nAGENT_NAME,\nAGENT,\nDATE,\nAFTER_CALL_WORK ,\nLOGIN\t\t\t,\nNOT_READY\t\t,\t\nON_CALL\t\t\t,\t\nON_PREVIEW\t\t,\t\nON_VOICEMAIL\t,\t\nREADY\t\t\t,\t\nRINGING\t\t\t,\t\nDATA_IDENTIFIER ,\nDIVISION AS DIVISION_ORIG,\nUTILIZATION,\nOCCUPANCY,\nLAST_UPDATED_TS\n\nFROM M1\t",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlPoolSink",
						"preCopyScript": "DELETE FROM [EDW].[FACT_FIVE9_AGENT_STATE_SUMMARY]\nWHERE CAST(DATE AS DATE) IN ( SELECT DISTINCT CAST((CASE WHEN ISDate(date)=1 THEN DATE ELSE '2099-01-01' END ) AS DATE) FROM [ODS].[FIVE9_AGENT_STATE_SUMMARY] WHERE FILE_IDENTIFIER='ALL_DIVISION' )\nAND DATA_IDENTIFIER ='ALL_DIVISION';\n\nDELETE FROM [EDW].[FACT_FIVE9_AGENT_STATE_SUMMARY]\nWHERE CAST(DATE AS DATE) IN ( SELECT DISTINCT CAST((CASE WHEN ISDate(date)=1 THEN DATE ELSE '2099-01-01' END ) AS DATE) FROM [ODS].[FIVE9_AGENT_STATE_SUMMARY] WHERE FILE_IDENTIFIER='MAC' )\nAND DATA_IDENTIFIER ='MAC';",
						"writeBehavior": "Insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,

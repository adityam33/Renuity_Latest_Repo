				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "INSERT INTO [EDW].[DIM_MKTNG_SUB_SOURCE_MAPPING_TX_XLSX]\n(Division\t,\nLeadSourceGroupID\t,\nLeadSourceID\t,\nLeadSubSourceID\t,\nSourceGroup\t,\nSourceCode\t,\nLeadSubSource\t,\nActive\t,\nEntryDate\t,\nTX_Channel\t,\nTX_SourceGroup\t,\nTX_SourceCode\t,\nMappingInd\t,\nCreatedTS\t,\nLastUpdatedTS\t,\nACU_AccountCode\t,\nACU_MarketingAccountID\t,\nACU_MarketingAccount\t,\nVendor\t\n)\n\nSELECT \nA.Division\t,\nA.LeadSourceGroupID\t,\nA.LeadSourceID\t,\nA.LeadSubSourceID\t,\nA.SourceGroup\t,\nA.SourceCode\t,\nA.LeadSubSource\t,\nA.Active\t,\nA.EntryDate\t,\nA.TX_Channel\t,\nA.TX_SourceGroup\t,\nA.TX_SourceCode\t,\nA.MappingInd\t,\nA.CreatedTS\t,\nA.LastUpdatedTS\t,\nA.ACU_AccountCode\t,\nA.ACU_MarketingAccountID\t,\nA.ACU_MarketingAccount\t,\nA.Vendor\t\nFROM EDW.DIM_MKTNG_SUB_SOURCE_MAPPING A\nLEFT JOIN [EDW].[DIM_MKTNG_SUB_SOURCE_MAPPING_TX_XLSX] B \nON A.LeadSubSourceID = B.LeadSubSourceID\nWHERE A.MappingInd NOT IN ('UNMAP')\nAND B.LeadSubSourceID IS NULL;\n\n\n\n--*************************************\n--*************************************\n\n\n\nWITH A AS \n(\nSELECT \nLeadID,\nHomeBaseManaged,\nCostType,\nCAST(REPLACE(TRIM(CPL_Dollar), '$', '') AS DECIMAL(10,2)) AS CPL_Dollar,\nRevShareAmt,\nInstallSaleFee,\nCostPerDemo,\nVendor,\nMC_ModelPct,\nApprover,\nPayment,\nVendorID,\nMarketDetail,\nBudgetSetRate,\nAgencyFee\nFROM [ODS].[STG_TH_TAXONOMY_XLSX_MC_PAY]\n)\n\nUPDATE M1\nSET \nM1.XL_HomeBaseManaged        =  A.HomeBaseManaged\n,M1.XL_CostType               =  A.CostType\n,M1.XL_CPL_AMT                =  A.CPL_Dollar\n,M1.XL_RevShare_AMT           =  A.RevShareAmt\n,M1.XL_InstallSaleFee         =  A.InstallSaleFee\n,M1.XL_CostPerDemo            =  A.CostPerDemo\n,M1.XL_Vendor                 =  A.Vendor\n,M1.XL_MC_Model               =  A.MC_ModelPct\n,M1.XL_Approver_MktgLead      =  A.Approver\n,M1.XL_Payment                =  A.Payment\n,M1.XL_VendorID               =  A.VendorID\n,M1.XL_MarketDetail           =  A.MarketDetail\n,M1.XL_BudgetSetRate          =  A.BudgetSetRate\n,M1.XL_AgencyFeePctSpend      =  A.AgencyFee\nFROM  [EDW].[DIM_MKTNG_SUB_SOURCE_MAPPING_TX_XLSX] M1\nJOIN A \nON M1.LeadSubSourceID = A.LeadID;"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}

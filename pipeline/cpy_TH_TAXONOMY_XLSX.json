				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "UPDATE tgt\r\nSET \r\n    tgt.Division = SUBSTRING(src.Srs_ID,1,3),\r\n    tgt.SourceGroup = src.SourceGroup,\r\n    tgt.CostType = src.Srs_Id_CostType,\r\n    tgt.Vendor = src.Vendor,\r\n    tgt.UnitProd_CPL = src.UnitProd_CPL,\r\n    tgt.UnitProd_RevShare = src.UnitProd_RevShare,\r\n    tgt.EntryDate_To_ApptDateCutOff = src.EntryDate_To_ApptDateCutOff,\r\n    tgt.Unit_Affil_CPI_AMT = src.Unit_Affil_CPL_AMT,\r\n    tgt.Unit_CPD_AMT = src.Unit_CPD_AMT,\r\n    tgt.Unit_CPL_AMT = src.Unit_CPL_AMT,\r\n    tgt.Mrkt_Cost = src.Mrkt_Cost,\r\n    tgt.LastUpdatedTS = GETDATE()\r\nFROM [EDW].[DIM_MKTNG_COST_MATRIX] tgt\r\nJOIN ODS.[STG_TH_TAXONOMY_XLSX_COST_MATRIX] src\r\n    ON tgt.LeadSubSourceID = src.Srs_ID\r\n   AND tgt.ProductForOpCo_Reporting = src.ProductForOpCo_Reporting;\r\n\r\n\r\nINSERT INTO [EDW].[DIM_MKTNG_COST_MATRIX] (\r\n    Division,\r\n    LeadSubSourceID,\r\n    SourceGroup,\r\n    ProductForOpCo_Reporting,\r\n    CostType,\r\n    Vendor,\r\n    UnitProd_CPL,\r\n    UnitProd_RevShare,\r\n    EntryDate_To_ApptDateCutOff,\r\n    Unit_Affil_CPI_AMT,\r\n    Unit_CPD_AMT,\r\n    Unit_CPL_AMT,\r\n    Mrkt_Cost,\r\n    LastUpdatedTS\r\n)\r\nSELECT \r\n    SUBSTRING(src.Srs_ID,1,3) AS Division,\r\n    src.Srs_ID,\r\n    src.SourceGroup,\r\n    src.ProductForOpCo_Reporting,\r\n    src.Srs_Id_CostType,\r\n    src.Vendor,\r\n    src.UnitProd_CPL,\r\n    src.UnitProd_RevShare,\r\n    src.EntryDate_To_ApptDateCutOff,\r\n    src.Unit_Affil_CPL_AMT,\r\n    src.Unit_CPD_AMT,\r\n    src.Unit_CPL_AMT,\r\n    src.Mrkt_Cost,\r\n    GETDATE()\r\nFROM ODS.[STG_TH_TAXONOMY_XLSX_COST_MATRIX] src\r\nLEFT JOIN [EDW].[DIM_MKTNG_COST_MATRIX] tgt\r\n    ON tgt.LeadSubSourceID = src.Srs_ID\r\n   AND tgt.ProductForOpCo_Reporting = src.ProductForOpCo_Reporting\r\nWHERE tgt.LeadSubSourceID IS NULL;\r\n"
						}

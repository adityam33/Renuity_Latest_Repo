						"type": "SqlDWSink",
						"writeBehavior": "Upsert",
						"upsertSettings": {
							"keys": [
								"Division_Name",
								"Week",
								"FICO_Band"
							],
							"interimSchemaName": ""
						},
						"sqlWriterUseTableLock": false
					},

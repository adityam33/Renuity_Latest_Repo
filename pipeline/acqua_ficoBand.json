					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT  CASE \n            WHEN [Division_Name] LIKE '%Pacific Bath%' THEN 'West Division'\n            WHEN [Division_Name] LIKE '%Florida Home%' THEN 'East Florida'\n            WHEN [Division_Name] LIKE '%Max Home%'     THEN 'East Gulf'\n            ELSE [Division_Name] END AS [Division_Name]\n      ,[Week]\n      ,[FICO_Band]\n      ,[Aprvd]\n      ,[Denied]\n      ,[Total]\n      ,[Approval%]\n      ,[Contracted]\n      ,[Contracted_Approved]\n      ,[Apvd_Amount]\n      ,[Denied_Amount]\n      ,[Total_Amount]\n      ,[Approval_%]\n     ,[Lender]\n\t  ,getdate() as insertedDate\n  FROM [ODS].[acqua_ficoBand]\n",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},

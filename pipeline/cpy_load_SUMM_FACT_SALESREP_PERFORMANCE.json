{
	"name": "cpy_load_SUMM_FACT_SALESREP_PERFORMANCE",
	"properties": {
		"activities": [
			{
				"name": "Load Sales Rep Level Performance into Summary Fact",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.06:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT \n[Division]\n,[SalesRep1_EmployeeID] as SalesRep_EmployeeID\n,1 as SalesRepPosition\n,COUNT([IssuedLeadID]) AS IssuedLeadCount\n,MIN([ApptDate]) as EarliestAppointmentDate\n,sum(case when [NetIssued] = 'True' then 1 else 0 end) as NetIssuedCount\n,sum(case when [Sat] = 'True' then 1 else 0 end) as SatCount\n,sum(case when [Sold] = 'True' then 1 else 0 end) as SoldCount\n,sum([GrossSalesAmount]) as GrossSalesAmount\n FROM [EDW].[FACT_ISSUED_LEAD]\n group BY\n[Division]\n,[SalesRep1_EmployeeID]\n\nUNION\n\nSELECT \n[Division]\n,[SalesRep2_EmployeeID] as SalesRep_EmployeeID\n,2 as SalesRepPosition\n,COUNT([IssuedLeadID]) AS IssuedLeadCount\n,MIN([ApptDate]) as EarliestAppointmentDate\n,sum(case when [NetIssued] = 'True' then 1 else 0 end) as NetIssuedCount\n,sum(case when [Sat] = 'True' then 1 else 0 end) as SatCount\n,sum(case when [Sold] = 'True' then 1 else 0 end) as SoldCount\n,sum([GrossSalesAmount]) as GrossSalesAmount\n FROM [EDW].[FACT_ISSUED_LEAD]\n group BY\n[Division]\n,[SalesRep2_EmployeeID]",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",
						"preCopyScript": "IF OBJECT_ID('EDW.SUMM_FACT_SALESREP_PERFORMANCE')  IS NOT NULL TRUNCATE TABLE EDW.SUMM_FACT_SALESREP_PERFORMANCE",
						"writeBehavior": "Insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "Division",

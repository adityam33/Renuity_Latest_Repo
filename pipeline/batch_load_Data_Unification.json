				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "UPDATE EDW_DUN.UNI_REF_MAPPING \nSET MatchType='EXACT',\nUnifiedValue='Wind/Doors',\nUnifiedValue_Group='Other',\nMappingInd='MAPPED',\nCreatedByProcess = 'Manual Process Load',\nLastUpdatedTS=GETDATE()\nWHERE TableName='DIM_PRODUCT'\nAND TablePK_EDW IN ('FHI-1','PHI-1','RTW-1');\n\n\n\nUPDATE EDW_DUN.UNI_REF_MAPPING \nSET MatchType='EXACT',\nUnifiedValue='Bath',\nUnifiedValue_Group='Other',\nMappingInd='MAPPED',\nCreatedByProcess = 'Manual Process Load',\nLastUpdatedTS=GETDATE()\nWHERE TableName='DIM_PRODUCT'\nAND TablePK_EDW IN ('HSI-1','MAC-1','MXH-1','PBC-1');\n\n\n\n\nUPDATE EDW_DUN.UNI_REF_MAPPING \nSET MatchType='EXACT',\nUnifiedValue='Closet',\nUnifiedValue_Group='Closet',\nMappingInd='MAPPED',\nCreatedByProcess = 'Manual Process Load',\nLastUpdatedTS=GETDATE()\nWHERE TableName='DIM_PRODUCT'\nAND TablePK_EDW IN ('CTA-2');"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			},
			{
				"name": "Re-process_LatestAppRules",
				"type": "Script",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "UPDATE [EDW_DUN].[UNI_REF_MAPPING] SET MappingInd='UNMAPPED'\nWHERE UNI_RuleID IN \n(\n\tSELECT DISTINCT A.UNI_RuleID FROM [EDW_DUN].[UNI_RULEBOOK_XREF] A\n\tJOIN \n\t(\n\tSELECT * FROM [EDW_DUN].[UNI_RULEBOOK_XREF] \n\tWHERE CreatedTS>=GETDATE()-5\n\t) M1\n\tON \t\n\t A.TableName\t\t\t= M1.TableName\n\tAND A.TableColumnName\t= M1.TableColumnName\t\n\tAND A.MatchType\t\t\t= M1.MatchType\n\tAND A.RuleValue\t\t\t= M1.RuleValue\n\t\t);"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			}

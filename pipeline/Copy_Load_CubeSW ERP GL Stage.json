{
	"name": "Copy_Load_CubeSW ERP GL Stage",
	"properties": {
		"activities": [
			{
				"name": "Cpy CubeSW ERP GL Stage load",
				"description": "Loads last 2 months of GL data into stage table",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.06:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "select \nGL.GL_LINE_KEY\n,GL.AccountCode\n,ACC.AccountClass \n,ACC.AccountDescription\t\n,GL.BalanceAmount \n,GL.BatchNumber \n,GL.BranchCode\n,BRANCH.CompanyID \n--,ORG.CompanyName\n,GL.ReferenceNumber \n--,GL.Posted\t\n,GL.FinPeriodID \n,GL.LedgerID \n,GL.CustomerVendor\t\n,C.CustomerClass \n--,C.CustomerClassDescription \n,C.CustomerID \n,C.CustomerName\n,VEN.VendorName\n,VEN.VendorID\n--,VEN.VendorClassDescription\n,VEN.VendorClass \n,GL.DepartmentID \n,DEPT.Department\n,GL.MarketingAccountID\n,MACC.MarketingAccount\n,GL.ProductID \n,PRO.Product\n,GL.ProjectID \n--,GL.SourceID \n--,SRC.Source\n--,GL.SourceVendorID\t\n--,SRCV.SourceVendor\n,GL.TransactionDescription\n,GL.Createdby\n,GL.CreatedDateTime\n,GL.LastModifiedDateTime\n,BAT.BatchDescription\nfrom  EDW.FACT_ERP_GL_TRANSACTION GL\nLeft Outer Join EDW.DIM_ERP_ACCOUNT ACC on GL.AccountCode = ACC.AccountCode\nLeft Outer Join EDW.DIM_ERP_BRANCH BRANCH on GL.BranchCode = BRANCH.BranchCode\nLeft Outer Join EDW.DIM_ERP_CUSTOMER C on GL.CustomerVendor = C.CustomerID\nLeft Outer Join EDW.DIM_ERP_DEPARTMENT DEPT on GL.DepartmentID = DEPT.DepartmentID\nLeft Outer Join EDW.DIM_ERP_MARKETING_ACCOUNT MACC on GL.MarketingAccountID = MACC.MarketingAccountID\nLeft Outer Join EDW.DIM_ERP_ORGANIZATION ORG on BRANCH.CompanyID=ORG.CompanyId\nLeft Outer Join EDW.DIM_ERP_PRODUCT PRO on PRO.ProductID = GL.ProductID\nLeft Outer Join EDW.DIM_ERP_SOURCE SRC on SRC.SourceID = GL.SourceID\nLeft Outer Join EDW.DIM_ERP_SOURCE_VENDOR SRCV  on SRCV.SourceVendorID = GL.SourceVendorID\nLeft Outer Join EDW.DIM_ERP_VENDOR VEN on GL.CustomerVendor = VEN.VendorID\nLeft Outer JOin EDW.DIM_ERP_BATCH BAT on GL.BatchNUmber=BAT.BatchNumber\nwhere Posted='1' and --GL.AccountCode in (\n--'60000',\n--'60002',\n--'62000',\n--'62002',\n--'63000',\n--'64000',\n--'65000',\n--'66000',\n--'67000',\n--'67002',\n--'67003',\n--'67004',\n--'67005',\n--'67006',\n--'67007',\n--'67008',\n--'67009',\n--'67010',\n--'67011',\n--'67050',\n--'67055',\n--'67060',\n--'67061',\n--'67062',\n--'68000'\n--) and RIGHT(FinPeriodID,4) IN ('2022','2023')-- and FinPeriodID<='12-2024'\nEomonth(concat(substring(finperiodid,1,charindex('-',finperiodid)),'01-',substring(finperiodid,charindex('-',finperiodid)+1,len(finperiodid))))>=dateadd(M,-6,getdate())",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},

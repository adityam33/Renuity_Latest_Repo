						"sqlReaderQuery": "SELECT \nM1.type \t\t\t\tAS DocumentType\n,M1.referencenbr \t\tAS ReferenceNumber\t\n,M1.ARAccount\t\t\tAS AccountID\n,M1.customer\t\t\tAS CustomerID\n,M1.branch\t\t\t\tAS BranchCode\n,M1.customerordernbr \tAS CustomerOrderNumber\n,M1.date\t\t\t\tAS DocumentDate\n,M1.closeddate\t\t\tAS ClosedDate\n,M1.duedate\t\t\t\tAS\tDueDate\n,M1.paymentdate\t\t\tAS\tPaymentDate\n,M1.postperiod\t\t\tAS\tPostPeriod\n,M1.InvoiceDate\t\t\tAS\tInvoiceDate\n,M1.arregister_tranperiodid\tAS\tRegister_TranPeriodID\n,M1.paymentperiod\t\t\tAS\tPaymentPeriod\n,M1.arregister_approved\t\tAS\tRegister_Approved\n,M1.arregister_rejected\t\tAS\tRegister_Rejected\n,M1.arregister_released\t\tAS\tRegister_Released\n,M1.status\t\t\t\t\tAS\tStatus\n,M1.arregister_voided\t\tAS\tRegister_Voided\n,M1.arregister_docbal\t\tAS\tRegister_DocumentBalance\n,M1.arregister_origDocamt\tAS\tRegister_OriginalDocumentAmount\n,M1.paymentmethod\t\t\tAS\tPaymentMethod\n,M1.reasonforcredit\t\t\tAS\tReasonForCredit\n,M1.description\t\t\t\tAS\tInvoice_Description\n,M1.description_2\t\t\tAS\tPayment_Description\n,M1.payment_currency\t\tAS\tPayment_Currency\n,M1.Invoice_currency\t\tAS\tInvoice_Currency\n,M1.origrefnbr\t\t\t\tAS\tOriginalReferenceNumbber\n,M1.Invoice_ProjectiD\t\tAS\tInvoice_ProjectID\n,M1.Payment_projectID\t\tAS\tPayment_ProjectID\n,M1.Invoice_batchNbr\t\tAS\tInvoice_BatchNumber\n,M1.Payment_BatchNbr\t\tAS\tPayment_BatchNumber\n,M1.cashdiscount\t\t\tAS\tCashDiscount\n,M1.taxtotal\t\t\t\tAS\tTaxTotal\n,M1.retainageDocument\t\tAS\tRetainageDocument\n,M1.paymentref\t\t\t\tAS\tPaymentReference\n,M1.cashaccount\t\t\t\tAS\tCashAccount\n,M1.selected\t\t\t\tAS\tselected\n,M1.lpjob\t\t\t\t\tAS\tLplob\n,M1.lppmttype\t\t\t\tAS\tLpPmtType\n,M1.ARPayment_origDocAmt\tAS\tARPayment_OrigDocAmt\n,M1.Balance\t\t\t\t\tAS\tBalance\n,M1.AdjAmount\t\t\t\tAS\tAdjAmount\n,M1.Application_ReferenceNumber\tAS\tApplication_ReferenceNumber\n,M1.Application_Type\t\t\tAS\tApplication_Type\n,M1.Invoice_createdby\t\t\tAS\tInvoice_CreatedBy\n,M1.Invoice_Createdon\t\t\tAS\tInvoice_Createdon\n,M1.Invoice_lastModifiedby\t\tAS\tInvoice_LastModifiedBy\n,M1.Invoice_lastmodfiedOn\t\tAS\tInvoice_lastmodifiedOn\n,M1.Payment_createdby\t\t\tAS\tPayment_Createdby\n,M1.Payment_createdon\t\t\tAS\tPayment_Createdon\n,M1.Payment_Lastmodifiedby\t\tAS\tPayment_Lastmodifiedby\n,M1.Payment_lastModifiedon\t\tAS\tPayment_lastModifiedon\n,M1.Source\t\t\t\t\t\tAS\tSource\n,M1.ARInvoice_released\t\t\tAS\tARInvoice_released\n,COALESCE(M1.Payment_Currency,M1.Invoice_Currency)\tAS Currency\n,COALESCE(M1.Payment_BatchNbr,M1.Invoice_batchNbr) AS BatchNumber\n,BM.BranchCode\n,BM.BranchID\n,BM.Active\n,BM.BranchAccountID\n,BM.BranchName\n,BM.CompanyID\n\nFROM \n(\t\t\n\t\tselect \n\t\tr.type,r.referencenbr,r.ARAccount,r.customer,r.branch,i.customerordernbr,r.date,r.closeddate,r.duedate,p.paymentdate,\n\t\tr.postperiod,i.date  as InvoiceDate,r.arregister_tranperiodid,p.paymentperiod,r.arregister_approved,r.arregister_rejected,r.arregister_released,r.status,r.arregister_voided,\n\t\tr.arregister_docbal,r.arregister_origDocamt,p.paymentmethod,i.reasonforcredit,i.description, p.description_2,\n\t\tp.currency as payment_currency,i.currency as Invoice_currency,i.origrefnbr,i.projectid as Invoice_ProjectID,p.project as Payment_projectID,i.batchnbr as Invoice_batchNbr,p.batchnbr as Payment_BatchNbr,\n\t\ti.cashdiscount,i.taxtotal,i.retainageDocument,p.paymentref,p.cashaccount,p.selected,p.lpjob,p.lppmttype,\n\t\tp.ARPayment_origDocAmt, p.Balance,a.AdjAmount,\n\t\ta.Payment_SOAdjust_ReferenceNbr as Application_ReferenceNumber,a.Payment_SOAdjust_type as Application_Type,\n\t\ti.createdby as Invoice_createdby,i.createdon as Invoice_Createdon,i.lastmodifiedby as Invoice_lastModifiedby,i.lastmodifiedon as Invoice_lastmodfiedOn,\n\t\tp.createdby as Payment_createdby,p.createdon as Payment_createdon,p.lastmodifiedby as Payment_Lastmodifiedby,p.lastmodifiedon as Payment_lastModifiedon,\n\t\ti.Source,i.ARInvoice_released\n\t\tfrom ods.erp_ar_register r \n\t\tjoin ods.erp_ar_adjust a on  r.referencenbr=a.Invoice_Tran_ReferenceNbr and r.type=a.Invoice_Tran_type\n\t\tleft join ods.erp_ar_invoice i on i.referencenbr=r.referencenbr and i.type=r.Type\n\t\tleft join ods.erp_Ar_payment p on p.referencenbr=a.Payment_SOAdjust_ReferenceNbr and p.type=a.Payment_SOAdjust_type\n\t\t\n\t\t\n\t\t\n\t\tUnion all\n\t\t\n\t\tselect \n\t\tr.type,r.referencenbr,r.ARAccount,r.customer,r.branch,i.customerordernbr,r.date,r.closeddate,r.duedate,p.paymentdate,\n\t\tr.postperiod,i.date as InvoiceDate,r.arregister_tranperiodid,p.paymentperiod,r.arregister_approved,r.arregister_rejected,r.arregister_released,r.status,r.arregister_voided,\n\t\tr.arregister_docbal,r.arregister_origDocamt,p.paymentmethod,i.reasonforcredit,i.description, \n\t\tp.description_2,p.currency as payment_currency,\n\t\ti.currency as Invoice_currency,i.origrefnbr,\n\t\ti.projectid as Invoice_ProjectID,p.project as Payment_projectID,i.batchnbr as Invoice_batchNbr,p.batchnbr as Payment_BatchNbr,\n\t\ti.cashdiscount,i.taxtotal,i.retainageDocument,p.paymentref,p.cashaccount,p.selected,p.lpjob,p.lppmttype,\n\t\ti.ARInvoice_origDocamt,i.ARInvoice_Docbal,a1.AdjAmount,\n\t\ta1.Invoice_Tran_ReferenceNbr as Application_ReferenceNumber,a1.Invoice_Tran_type as Application_Type,\n\t\ti.createdby as Invoice_createdby,i.createdon as Invoice_Createdon,i.lastmodifiedby as Invoice_lastModifiedby,i.lastmodifiedon as Invoice_lastmodfiedOn,\n\t\tp.createdby as Payment_createdby,p.createdon as Payment_createdon,p.lastmodifiedby as Payment_Lastmodifiedby,p.lastmodifiedon as Payment_lastModifiedon,\n\t\ti.Source,i.ARInvoice_released\n\t\tfrom ods.erp_ar_register r \n\t\tjoin ods.erp_ar_adjust a1 on  r.referencenbr = a1.Payment_SOAdjust_ReferenceNbr and r.type = a1.Payment_SOAdjust_type \n\t\tleft join ods.erp_Ar_payment p on r.referencenbr=p.referencenbr and r.type=p.type\n\t\tleft join ods.erp_ar_invoice i on i.referencenbr=a1.Invoice_Tran_ReferenceNbr and i.type=a1.Invoice_Tran_Type\n\t\t\n\t\tUnion all\n\t\t\n\t\tselect r.type,r.referencenbr,r.ARAccount,r.customer,r.branch,i.customerordernbr,r.date,r.closeddate,r.duedate,p.paymentdate,\n\t\tr.postperiod,i.date as InvoiceDate,r.arregister_tranperiodid,p.paymentperiod,r.arregister_approved,r.arregister_rejected,r.arregister_released,r.status,r.arregister_voided,\n\t\tr.arregister_docbal,r.arregister_origDocamt,p.paymentmethod,i.reasonforcredit,i.description, \n\t\tp.description_2,p.currency as payment_currency,\n\t\ti.currency as Invoice_currency,i.origrefnbr,\n\t\ti.projectid as Invoice_ProjectID,p.project as Payment_projectID,i.batchnbr as Invoice_batchNbr,p.batchnbr as Payment_BatchNbr,\n\t\ti.cashdiscount,i.taxtotal,i.retainageDocument,p.paymentref,p.cashaccount,p.selected,p.lpjob,p.lppmttype,\n\t\tNULL as ARInvoice_origDocamt,NULL as ARInvoice_Docbal,Null as AdjAmount,\n\t\tNULL as Application_ReferenceNumber,NULL as Application_Type,\n\t\ti.createdby as Invoice_createdby,i.createdon as Invoice_Createdon,i.lastmodifiedby as Invoice_lastModifiedby,i.lastmodifiedon as Invoice_lastmodfiedOn,\n\t\tp.createdby as Payment_createdby,p.createdon as Payment_createdon,p.lastmodifiedby as Payment_Lastmodifiedby,p.lastmodifiedon as Payment_lastModifiedon,\n\t\ti.Source,i.ARInvoice_released\n\t\tfrom ods.erp_ar_register r \n\t\tleft join ods.erp_ar_adjust a on  r.referencenbr=a.Invoice_Tran_ReferenceNbr and r.type=a.Invoice_Tran_type\n\t\tleft join ods.erp_ar_adjust a1 on  r.referencenbr = a1.Payment_SOAdjust_ReferenceNbr and r.type = a1.Payment_SOAdjust_type \n\t\tleft join ods.erp_ar_invoice i on r.referencenbr=i.referencenbr and r.type=i.type\n\t\tleft join ods.erp_ar_payment p on r.referencenbr=p.referencenbr and r.type=p.type\n\t\twhere   a.Invoice_Tran_ReferenceNbr is  null and  a1.Payment_SOAdjust_ReferenceNbr is  null\n\t\t\n\t\t\n\t\t\n\t\t) M1\n\t\t\n\t\tLEFT JOIN ODS.ERP_BRANCH_MASTER BM \n\t\tON M1.branch  = BM.BranchCode",

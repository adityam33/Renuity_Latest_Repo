				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "select \r\nCASE \r\nWHEN CompanyName='Max Home' THEN 'FHIA, LLC' ELSE CompanyName END AS CompanyName,\r\nBranchCode,\r\nVendorID,VendorName,VendorClass,PaymentTerm,PostingPeriod,DocumentType,ReferenceNbr,VendorRef,Status,--PaymentDate,\r\nDueDate,DocumentDate,Balance,CAST(GETDATE() as DATE) as AgedOnDate,CreatedDate,\r\ncase when datediff(d,Duedate,getdate()) <=0 then Balance else 0 end as 'current',\r\ncase when datediff(d,Duedate,getdate()) between 1 and 30 then Balance else 0 end as '1to30Days',\r\ncase when datediff(d,Duedate,getdate()) between 31 and 60 then Balance else 0 end as '31to60Days',\r\ncase when datediff(d,Duedate,getdate()) between 61 and 90  then Balance else 0 end as '61to90Days',\r\ncase when datediff(d,Duedate,getdate()) >= 91   then Balance else 0 end as 'Over90Days',\r\nPaymentMethod\r\nfrom (\r\nselect o.CompanyName,b.BranchCode,v.VendorID,v.VendorName,v.VendorClass,i.PostingPeriod,i.Type as DocumentType,i.ReferenceNbr,i.VendorRef,i.Status,--p.PaymentDate,\r\nCase when i.Type='Debit Adj.' and i.DueDate is NULL then CAST(GETDATE() as DATE) ELSE i.DueDate END as DueDate,i.Date as DocumentDate,i.Balance as DocumentBalance,CONCAT(i.TermsID,'-',i.TermsID_Description) as PaymentTerm,\r\ncase when i.type in ('Debit Adj.','Prepayment') then (-1 *i.Balance) else i.Balance end Balance,i.CreatedOn as CreatedDate,i.PayTypeID as PaymentMethod\r\nfrom EDW.DIM_ERP_VENDOR v \r\nleft join ods.erp_ap_invoice i on i.Vendor=v.VendorID\r\nleft join ods.erp_branch_master b on i.branch=b.branchcode\r\nleft join EDW.DIM_ERP_ORGANIZATION o on b.CompanyID=o.CompanyID \r\nwhere i.status in ('Open') and CAST(i.Date as Date)<=CAST(GETDATE() as Date)\r\n) a\r\n\r\n\r\nUNION\r\n\r\nselect \r\nCASE\r\nWHEN CompanyName='Max Home' THEN 'FHIA, LLC' ELSE CompanyName END AS CompanyName,\r\nBranchCode,VendorID,VendorName,VendorClass,PaymentTerm,PostingPeriod,DocumentType,ReferenceNbr,VendorRef,Status,--PaymentDate,\r\nDueDate,DocumentDate,Balance,CAST(GETDATE() as DATE) as AgedOnDate,CreatedDate,\r\ncase when datediff(d,Duedate,getdate()) <=0 then Balance else 0 end as 'current',\r\ncase when datediff(d,Duedate,getdate()) between 1 and 30 then Balance else 0 end as '1to30Days',\r\ncase when datediff(d,Duedate,getdate()) between 31 and 60 then Balance else 0 end as '31to60Days',\r\ncase when datediff(d,Duedate,getdate()) between 61 and 90  then Balance else 0 end as '61to90Days',\r\ncase when datediff(d,Duedate,getdate()) >= 91   then Balance else 0 end as 'Over90Days',\r\nPaymentMethod\r\nfrom (\r\nselect o.CompanyName,b.BranchCode,v.VendorID,v.VendorName,v.VendorClass,i.FinPeriod as PostingPeriod,i.Type as DocumentType,i.ReferenceNbr,NULL as VendorRef,i.Status,--p.PaymentDate,\r\nCAST(GETDATE() as DATE) as DueDate,i.PaymentDate as DocumentDate,i.Balance as DocumentBalance,NULL as PaymentTerm,\r\ncase when i.type in ('Prepayment','Payment','Voided Payment') then (-1 *i.Balance) else i.Balance end Balance,i.CreatedOn as CreatedDate,i.PaymentMethod\r\nfrom EDW.DIM_ERP_VENDOR v \r\nleft join ods.erp_ap_payment i on i.Vendor=v.VendorID\r\nleft join ods.erp_branch_master b on i.branch=b.branchcode\r\nleft join EDW.DIM_ERP_ORGANIZATION o on b.CompanyID=o.CompanyID \r\nwhere i.status in ('Open') and i.type in ('Prepayment','Payment','Voided Payment') and CAST(i.PaymentDate as Date)<=CAST(GETDATE() as DATE)\r\n) a",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},

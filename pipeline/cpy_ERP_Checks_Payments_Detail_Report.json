						]
					}
				],
				"policy": {
					"timeout": "0.00:40:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "Select i.Type as InvoiceType,i.ReferenceNbr as InvoiceRefNbr,i.Status as InvoiceStatus,p.PaymentDate as ApplicationDate,p.FinPeriod as ApplicationPeriod,p.PaymentRef,CONCAT(v.VendorID,'-',v.VendorName) as Vendor,\r\np.PaymentMethod,i.PayTypeID as InvoicePayID,p.CashAccount,p.Description,p.PaymentAmount,i.Branch as InvoiceBranch,p.Branch,CASE WHEN p.Status='Closed' then pl.CurrentAdjustAmt\r\nELSE i.Amount END as PayAmount,p.Status,pl.CashDiscountDate,CONCAT(i.TermsID,'-',i.TermsID_Description) as PaymentTerm,\r\nCASE WHEN p.Status='Closed' and i.DueDate is not null then pl.CurrentAdjustAmt\r\nWHEN p.Status='Closed' and i.DueDate is null then pl.CurrentAdjustAmt*(-1)\r\nWHEN i.Type='Debit Adj.' then i.Amount*(-1)\r\nELSE 0 END as AmountPaid,i.Balance,i.Description as InvoiceDescription,i.PostingPeriod as InvoicePostingPeriod,i.VendorRef as VendorReference,\r\nv.VendorClass,v.VendorClassDescription,v.VendorID as Vendor_ID,v.VendorName,i.DueDate,o.CompanyName,i.CashDiscount,p.ReferenceNbr,p.Type,\r\nCASE WHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,pl.CashDiscountDate)<0 and i.CashDiscount>0 then 'Y'\r\nWHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,pl.CashDiscountDate)>=0 and i.CashDiscount>0 then 'N' \r\nelse 'NA' END as MissedDiscountFlag,i.Date as InvoiceDate,i.createdOn as InvoiceCreatedDate,\r\nCASE WHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,i.DueDate)>0 THEN 'Paid Before Due Date'\r\nWHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,i.DueDate)=0 THEN 'Paid on Due Date'\r\nWHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,i.DueDate)<0  THEN 'Late Payment'\r\nELSE 'NA' END as PaymentOnTimeStatus\r\n from ODS.ERP_AP_INVOICE i left join ODS.ERP_VENDOR_MASTER v on i.Vendor=v.VendorID\r\n left join ODS.ERP_BILLS_PAYMENTS_LINK pl on i.Type=pl.InvoiceDocType and i.ReferenceNbr=pl.InvoiceRefNbr\r\n left join ODS.ERP_AP_PAYMENT p on pl.PaymentDocType=p.Type and pl.PaymentRefNbr=p.ReferenceNbr\r\n left join EDW.DIM_ERP_BRANCH b on i.Branch=b.BranchCode\r\n left join EDW.DIM_ERP_ORGANIZATION o on b.CompanyID=o.CompanyID\r\n Where CAST(RIGHT(i.PostingPeriod,4) as INT)>=2024 and (pl.PaymentDocType Not IN ('Refund','VQC','Voided Payment','Vendor Refund','Voided Check','Voided Refund') or pl.PaymentDocType is NULL)\r\n and i.Type!='QCK'",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},

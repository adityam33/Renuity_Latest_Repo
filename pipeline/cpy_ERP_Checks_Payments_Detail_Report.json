							"text": "TRUNCATE TABLE EDW.ERP_CHECKS_PAYMENTS_DETAIL;\n\nINSERT INTO EDW.ERP_CHECKS_PAYMENTS_DETAIL\n(InvoiceDocType\t,\nInvoiceRefNbr\t,\nInvoiceStatus\t,\nApplicationDate\t,\nApplicationPeriod\t,\nPaymentReferenceNumber\t,\nVendor\t,\nPaymentMethod\t,\nInvoicePayID\t,\nCashAccount\t,\nPaymentDescription\t,\nPaymentAmount\t,\nInvoiceBranch\t,\nBranch\t,\nPayAmount\t,\nPaymentStatus\t,\nCashDiscountDate\t,\nPaymentTerms\t,\nAmountPaid\t,\nBalance\t,\nInvoiceDescription\t,\nInvoicePostingPeriod\t,\nVendorReference\t,\nVendorClass\t,\nVendorClassDescription\t,\nVendor_ID\t,\nVendorName\t,\nDueDate\t,\nCompanyName\t,\nCashDiscount\t,\nReferenceNumber\t,\nDocumentType\t,\nMissedDiscountFlag\t,\nInvoiceDate\t,\nInvoiceCreatedDate\t,\nPaymentOnTimeStatus\t\n\n)\n\n\n\nSELECT \nInvoiceType\t,\nInvoiceRefNbr\t,\nInvoiceStatus\t,\nApplicationDate\t,\nApplicationPeriod\t,\nPaymentRef\t,\nVendor\t,\nPaymentMethod\t,\nInvoicePayID\t,\nCashAccount\t,\nDescription\t,\nPaymentAmount\t,\nInvoiceBranch\t,\nBranch\t,\nPayAmount\t,\nStatus\t,\nCashDiscountDate\t,\nPaymentTerm\t,\nAmountPaid\t,\nBalance\t,\nInvoiceDescription\t,\nInvoicePostingPeriod\t,\nVendorReference\t,\nVendorClass\t,\nVendorClassDescription\t,\nVendor_ID\t,\nVendorName\t,\nDueDate\t,\nCompanyName\t,\nCashDiscount\t,\nReferenceNbr\t,\nType\t,\nMissedDiscountFlag\t,\nInvoiceDate\t,\nInvoiceCreatedDate\t,\nPaymentOnTimeStatus\t\nFROM \n(\n\t\tSelect \n\t\ti.Type as InvoiceType,\n\t\ti.ReferenceNbr as InvoiceRefNbr,\n\t\ti.Status as InvoiceStatus,\n\t\tp.PaymentDate as ApplicationDate,\n\t\tp.FinPeriod as ApplicationPeriod,\n\t\tp.PaymentRef,\n\t\tCONCAT(v.VendorID,'-',v.VendorName) as Vendor,\n\t\tp.PaymentMethod,\n\t\ti.PayTypeID as InvoicePayID,\n\t\tp.CashAccount,\n\t\tp.Description,\n\t\tp.PaymentAmount,\n\t\ti.Branch as InvoiceBranch,\n\t\tp.Branch,\n\t\tCASE WHEN p.Status='Closed' then pl.CurrentAdjustAmt\n\t\tELSE i.Amount END as PayAmount,\n\t\tp.Status,\n\t\tpl.CashDiscountDate,\n\t\tCONCAT(i.TermsID,'-',i.TermsID_Description) as PaymentTerm,\n\t\tCASE \n\t\tWHEN p.Status='Closed' and i.DueDate is not null then pl.CurrentAdjustAmt\n\t\tWHEN p.Status='Closed' and i.DueDate is null then pl.CurrentAdjustAmt*(-1)\n\t\tWHEN i.Type='Debit Adj.' then i.Amount*(-1)\n\t\tELSE 0 END as AmountPaid,\n\t\t\n\t\ti.Balance,\n\t\ti.Description as InvoiceDescription,\n\t\ti.PostingPeriod as InvoicePostingPeriod,\n\t\ti.VendorRef as VendorReference,\n\t\tv.VendorClass,\n\t\tv.VendorClassDescription,\n\t\tv.VendorID as Vendor_ID,\n\t\tv.VendorName,\n\t\ti.DueDate,\n\t\to.CompanyName,\n\t\ti.CashDiscount,\n\t\tp.ReferenceNbr,\n\t\tp.Type,\n\t\tCASE \n\t\tWHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,pl.CashDiscountDate)<0 and i.CashDiscount>0 then 'Y'\n\t\tWHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,pl.CashDiscountDate)>=0 and i.CashDiscount>0 then 'N' \n\t\telse 'NA' END as MissedDiscountFlag,\n\t\t\n\t\ti.Date as InvoiceDate,\n\t\ti.createdOn as InvoiceCreatedDate,\n\t\t\n\t\tCASE \n\t\tWHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,i.DueDate)>0 THEN 'Paid Before Due Date'\n\t\tWHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,i.DueDate)=0 THEN 'Paid on Due Date'\n\t\tWHEN p.Status='Closed' and DATEDIFF(dd,p.PaymentDate,i.DueDate)<0  THEN 'Late Payment'\n\t\tELSE 'NA' END as PaymentOnTimeStatus\n\t\t\n\t\tfrom ODS.ERP_AP_INVOICE i left join ODS.ERP_VENDOR_MASTER v on i.Vendor=v.VendorID\n\t\tleft join ODS.ERP_BILLS_PAYMENTS_LINK pl on i.Type=pl.InvoiceDocType and i.ReferenceNbr=pl.InvoiceRefNbr\n\t\tleft join ODS.ERP_AP_PAYMENT p on pl.PaymentDocType=p.Type and pl.PaymentRefNbr=p.ReferenceNbr\n\t\tleft join EDW.DIM_ERP_BRANCH b on i.Branch=b.BranchCode\n\t\tleft join EDW.DIM_ERP_ORGANIZATION o on b.CompanyID=o.CompanyID\n\t\tWhere CAST(RIGHT(i.PostingPeriod,4) as INT)>=2024 and (pl.PaymentDocType Not IN ('Refund','VQC','Voided Payment','Vendor Refund','Voided Check','Voided Refund') or pl.PaymentDocType is NULL)\n\t\tand i.Type!='QCK'\n\t\t\n\t\t) M1"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			}

	"name": "cpy_ERP_Checks_Payments_Detail_Report",
	"properties": {
		"activities": [
			{
				"name": "cp_Checks_Payments_Detail",
				"type": "Copy",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [
					{
						"activity": "Cpy_Bills_Payment_Link",

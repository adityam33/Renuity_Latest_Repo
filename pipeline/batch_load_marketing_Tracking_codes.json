	"name": "batch_load_marketing_Tracking_codes",
	"properties": {
		"activities": [
			{
				"name": "ODS Tracking codes",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "PostgreSqlV2Source",
						"query": "SELECT *\nFROM tracking_codes\nWHERE ( created_at >= (CURRENT_TIMESTAMP - INTERVAL '7 days')\n   OR updated_at >= (CURRENT_TIMESTAMP - INTERVAL '7 days')) \n   and Hash_code is not null"
					},
					"sink": {
						"type": "SqlDWSink",
						"preCopyScript": "Truncate table ODS.AP_TRACKING_CODES",
						"writeBehavior": "Insert",
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "Postgres_Division_mappings",
						"type": "DatasetReference"
					}
				],
				"outputs": [

					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT ID,\nHash_Code, \nCase when Hash_code like '%ca' or Hash_code like '%gc' then 'CTA'\n\twhen Hash_code like '%mh' then 'FHI'\n\twhen Hash_code like '%pb' then 'PBC'\n\twhen Hash_code like '%rw' or Hash_code like '%hs' then 'RTW'\n\twhen Hash_code like '%fhi' then 'FHI'\n\twhen Hash_code like '%mac' then 'MAC'\n\twhen Hash_code like '%swr' then 'SWR' end as Division, \n\tDivision as Division_SRC,\n\tParent_Channel, Channel_Category,Channel, Channel_Provider,\nSub_Channel_1 ,Sub_Channel_2, Sub_Channel_3, Sub_Channel_4, Sub_Channel_5, Sub_Channel_6, Sub_Channel_7, \nSub_Channel_8, Sub_Channel_9, Sub_Channel_10, Sub_Channel_11, Sub_Channel_12,\nLanding_page, Destination_Number,Content, Description,Active, Status, Created_At, Updated_at, Getdate() as LastUpdatedTS\n\nfrom ODS.AP_TRacking_codes\n-- where Parent_Channel like '%Life%'",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",
						"writeBehavior": "Upsert",
						"upsertSettings": {
							"keys": [
								"Hash_Code"
							],
							"interimSchemaName": ""
						},
						"disableMetricsCollection": false
					},

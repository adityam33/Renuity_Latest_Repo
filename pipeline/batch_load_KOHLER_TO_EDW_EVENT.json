				"typeProperties": {
					"source": {
						"type": "SqlPoolSource",
						"sqlReaderQuery": "SELECT \nTimestamp\t\t\n,Company\t\t\t\n,Division\t\t\n,LeadID\t\t\t\n,BusinessGroup \n,UNI_ProductName\n,LeadCreatedDate \n,ChargeBackPrice \n,CostPerSale \t \n,MarketingCostTotal\t\n,LPExternalID \t\t\n,Phone \t\t\t\t\n,LeadSource \t\t\t\n,GETDATE() AS LastUpdatedTS\nFROM\n(\n\tSELECT *\n\t,ROW_NUMBER() OVER (PARTITION BY LPExternalID,DIVISION ORDER BY Timestamp DESC) AS RW\n\tFROM EDW.FACT_KOHLER_LEAD_COST_MTD\n\tWHERE LPExternalID IS NOT NULL\n\t\n\t) M1\nWHERE RW=1\n\n\nUNION ALL \n\n\nSELECT \nTimestamp\t\t\n,Company\t\t\t\n,Division\t\t\n,LeadID\t\t\t\n,BusinessGroup \n,UNI_ProductName\n,LeadCreatedDate \n,ChargeBackPrice \n,CostPerSale \t \n,MarketingCostTotal\t\n,LPExternalID \t\t\n,Phone \t\t\t\t\n,LeadSource \t\t\t\n,GETDATE() AS LastUpdatedTS\nFROM\n(\n\tSELECT *\n\t,ROW_NUMBER() OVER (PARTITION BY Company,Division,LeadID,BusinessGroup,UNI_ProductName,LeadCreatedDate ,\n\t\t\t\t\t\t\t\t\tChargeBackPrice ,CostPerSale ,MarketingCostTotal,LPExternalID ,Phone,LeadSource \t \n\t\t\t\t\t\tORDER BY Timestamp DESC) AS RW\n\tFROM EDW.FACT_KOHLER_LEAD_COST_MTD\n\tWHERE LPExternalID IS NULL\n\t\n\t) M1\nWHERE RW=1;",
						"queryTimeout": "02:00:00"
					},

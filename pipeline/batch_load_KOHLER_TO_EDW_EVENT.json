				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT\nGETDATE() AS Timestamp\n,CASE \n\tWHEN A.Division='HSI' THEN 'Home Smart'\n\tWHEN A.Division='RTW' THEN 'Rite Window'\n\tWHEN A.Division='PBC' THEN 'Pacific Bath'\n\tWHEN A.Division='SWR' THEN 'Statewide' End AS Company\n,A.Division\n,B.LeadID\n,A.BusinessGroup \t\t\n,A.DealerName \t\t\t\n,CAST( SUBSTRING(A.LeadCreatedDate, 1, CHARINDEX(',',A.LeadCreatedDate) - 1) AS DATE) AS LeadCreatedDate\n,A.LeadStatus \t\t\t\n,A.UnqualifiedReason \t\n,A.Stage \t\t\t\t\n,A.AppointmentStatus \t\n,A.JobStatus \t\t\t\n,A.LossReason \t\t\t\n,A.AppointmentDate \t\n,A.OpportunityAmount \t\n,A.GrossSale \t\t\t\n,A.NetSale \t\t\t\n,A.Source \t\t\t\t\n,A.CampaignName \t\t\n,A.ChargeBackPrice \t\n,A.CostPerSale \n,(COALESCE(A.ChargeBackPrice,0.00) + COALESCE(A.CostPerSale,0.00)) AS MarketingCostTotal\n,A.LPExternalID \t\t\n,A.Phone \t\t\t\t\n,A.LeadSource \t\t\t\n,P.UNI_ProductName\n,CAST(GETDATE() AS DATE) AS LastUpdatedTS\nFROM ODS.KOHLER_LEAD_COST_INQUIRIES A\nLEFT JOIN [EDW].[FACT_INBOUND_QUEUE_LOG] B\nON A.LPExternalID = SUBSTRING(B.User11, 1, CHARINDEX('.', B.User11) - 1) \nAND A.Division = B.Division\nLEFT JOIN EDW.DIM_PRODUCT P \nON B.ProductID = P.PRODUCTNAME\nAND B.Division = P.Division;",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlPoolSink",
						"preCopyScript": "DELETE FROM EDW.FACT_KOHLER_LEAD_COST_MTD WHERE CAST(LastUpdatedTS AS DATE) = CAST(GETDATE() AS DATE);",
						"allowCopyCommand": true
					},

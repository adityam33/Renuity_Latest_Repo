							"text": "\nDELETE FROM  EDW.FACT_UTM_PARAMETERS_VALUE_Managed_Instance_Test\nWHERE InboundQueueID IN \n(\nSELECT \n    InboundQueueID\n    FROM \n    (\n\tSELECT InboundQueueID,Count(1) AS CT FROM EDW.FACT_UTM_PARAMETERS_VALUE_Managed_Instance_Test\n\tGROUP  BY InboundQueueID\n\tHAVING Count(1)>1\n        ) A1\n\t\n    ) ;\n\n\nDELETE FROM EDW.FACT_UTM_PARAMETERS_VALUE_Managed_Instance_Test WHERE InboundQueueID IS NULL OR InboundQueueID=''"

			{
				"name": "Backup to Blob",
				"type": "Copy",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [
					{
						"activity": "Raw response Load",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.03:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "WITH CleanResponse AS (\n    SELECT \n        REPLACE(\n            REPLACE(ApplicationResponse, CHAR(13), CHAR(10)),\n        CHAR(10)+CHAR(10), CHAR(10)) AS CleanText\n    FROM ODS.FINANCE_API_RESPONSE_RAW where ExportType='applications' and ID = (Select max(Id) from ODS.FINANCE_API_Response_RAw where ExportType='applications')\n),\nRows AS (\n    -- Split the entire blob into proper rows\n    SELECT \n        ROW_NUMBER() OVER(ORDER BY (SELECT NULL)) AS rn,\n        value AS line\n    FROM CleanResponse\n    CROSS APPLY STRING_SPLIT(CleanText, CHAR(10))\n    WHERE value <> ''\n),\nData AS (\n    SELECT line FROM Rows WHERE rn > 1\n),\nFixed AS (\n    -- Replace commas *inside JSON arrays* with a placeholder\n    SELECT \n        line,\n        REPLACE(\n            REPLACE(\n                line,\n                '\",\"', '\"~\"'          -- inside array\n            ),\n        ', ', '~ ') AS FixedLine\n    FROM Data\n),\nSplitColumns AS (\n    -- Split using comma that is NOT inside an array\n    SELECT\n        f.line,\n        ROW_NUMBER() OVER(PARTITION BY f.line ORDER BY (SELECT NULL)) AS ColIndex,\n        REPLACE(REPLACE(value, '~\"', '\",\"'), '~ ', ', ') AS ColValue\n    FROM Fixed f\n    CROSS APPLY STRING_SPLIT(FixedLine, ',')\n)\nSELECT\n    MAX(CASE WHEN ColIndex = 1 THEN ColValue END) AS ApplicationId,\n    MAX(CASE WHEN ColIndex = 2 THEN ColValue END) AS ApplicationFriendlyId,\n    MAX(CASE WHEN ColIndex = 3 THEN ColValue END) AS SourcePlatformId,\n    MAX(CASE WHEN ColIndex = 4 THEN ColValue END) AS ProjectNumbers,\n    MAX(CASE WHEN ColIndex = 5 THEN ColValue END) AS TransUnionCreditRange,\n    MAX(CASE WHEN ColIndex = 6 THEN ColValue END) AS ExperianCreditRange,\n    MAX(CASE WHEN ColIndex = 7 THEN ColValue END) AS AppetiteEngineStatus,\n    MAX(CASE WHEN ColIndex = 8 THEN ColValue END) AS PostalCode,\n    MAX(CASE WHEN ColIndex = 9 THEN ColValue END) AS HasCoApplicant,\n    MAX(CASE WHEN ColIndex = 10 THEN ColValue END) AS CoApplicantTransUnionCreditRange,\n    MAX(CASE WHEN ColIndex = 11 THEN ColValue END) AS CoApplicantExperianCreditRange,\n    MAX(CASE WHEN ColIndex = 12 THEN ColValue END) AS SalesRepresentativeEmail,\n    MAX(CASE WHEN ColIndex = 13 THEN ColValue END) AS ProjectAmount,\n    MAX(CASE WHEN ColIndex = 14 THEN ColValue END) AS DeclinedLenders,\n    MAX(CASE WHEN ColIndex = 15 THEN ColValue END) AS EligibleLender,\n    MAX(CASE WHEN ColIndex = 16 THEN ColValue END) AS Lender,\n    MAX(CASE WHEN ColIndex = 17 THEN ColValue END) AS LenderStatus,\n    MAX(CASE WHEN ColIndex = 18 THEN ColValue END) AS CreditLimit,\n    MAX(CASE WHEN ColIndex = 19 THEN ColValue END) AS PlanSelected,\n    MAX(CASE WHEN ColIndex = 20 THEN ColValue END) AS TermLength,\n    MAX(CASE WHEN ColIndex = 21 THEN ColValue END) AS InterestRate,\n    MAX(CASE WHEN ColIndex = 22 THEN ColValue END) AS APR,\n    MAX(CASE WHEN ColIndex = 23 THEN ColValue END) AS MonthlyPayment,\n    MAX(CASE WHEN ColIndex = 24 THEN ColValue END) AS PaymentFactor,\n    MAX(CASE WHEN ColIndex = 25 THEN ColValue END) AS FinancedAmount,\n    MAX(CASE WHEN ColIndex = 26 THEN ColValue END) AS DownPayment,\n    MAX(CASE WHEN ColIndex = 27 THEN ColValue END) AS ExpiresAt,\n    MAX(CASE WHEN ColIndex = 28 THEN ColValue END) AS SubmittedAt,\n    MAX(CASE WHEN ColIndex = 29 THEN ColValue END) AS LenderLastUpdatedAt\nFROM SplitColumns\nGROUP BY line;\n",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},

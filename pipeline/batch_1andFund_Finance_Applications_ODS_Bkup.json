					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"parameters": [
								{
									"name": "ApplicationResponse",
									"type": "String",
									"value": {
										"value": "@activity('GetJobResults').output.Response",
										"type": "Expression"
									},
									"direction": "Input"
								},
								{
									"name": "JobId",
									"type": "String",
									"value": {
										"value": "@activity('Get JobId').output.resultSets[0].rows[0].JobId",
										"type": "Expression"
									},
									"direction": "Input"
								},
								{
									"name": "UpdatedTS",
									"type": "Datetime",
									"value": {
										"value": "@formatDateTime(convertTimeZone(utcNow(), 'UTC', 'Eastern Standard Time'), 'yyyy-MM-dd HH:mm:ss')",
										"type": "Expression"
									},
									"direction": "Input"
								}
							],
							"type": "Query",
							"text": {
								"value": "DECLARE @JobIdParam VARCHAR(50) = @JobId;\nDECLARE @UpdatedTSParam DATETIME = @UpdatedTS;\nDECLARE @ApplicationResponseParam Varchar(Max) = @ApplicationResponse;\n\nUpdate ODS.FINANCE_API_RESPONSE_RAW\nSet ApplicationResponse= @ApplicationResponseParam ,\n     UpdatedTs= @UpdatedTSParam\nWhere JobId = @JobIdParam and ExportType='applications';\n",
								"type": "Expression"
							}
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			},

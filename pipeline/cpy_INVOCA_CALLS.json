									"path": "$['keypresses']"
								},
								"sink": {
									"name": "keypresses",
									"type": "String"
								}
							}
						]
					}
				},
				"inputs": [
					{
						"referenceName": "SRC_INVOCA_CALL_DETAIL_RECORDS",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ODS_INVOCA_CALL_DETAIL_RECORD",
						"type": "DatasetReference"
					}
				]
			}
		],
		"folder": {
			"name": "SRC_to_ODS/INVOCA"
		},
		"annotations": [],
		"lastPublishTime": "2024-12-26T10:42:02Z"
	},
	"type": "Microsoft.Synapse/workspaces/pipelines"
}
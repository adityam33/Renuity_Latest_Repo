				},
				"inputs": [
					{
						"referenceName": "AD_API_linkedservice",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "AD_UserProfileTbl",
						"type": "DatasetReference"
					}
				]
			}
		],
		"variables": {
			"RecCount": {
				"type": "Integer"
			}
		},
		"folder": {
			"name": "Active_Directory_API"
		},
		"annotations": [],

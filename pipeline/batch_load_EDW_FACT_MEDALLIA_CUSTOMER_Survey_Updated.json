							"type": "Query",
							"text": "Update EDW.FACT_Medallia_Customer_survey\nSet ActiveInd='1'\nWhere Survey_ID in (Select Survey_ID from EDW.FACT_Medallia_Customer_survey where  \nCAST(Response_Date as Date) between DATEADD(dd,-14,CAST(GETDATE() as DATE)) and DATEADD(dd,-0,CAST(GETDATE() as DATE))  \nand Survey_ID not in (Select Survey_ID from EDW.FACT_Medallia_Customer_survey_Invitations where Survey_Status in ('EXPIRED','NOT_SAMPLED','EXCLUDED','DELIVERY_FAILED','DELIVERY_BOUNCED') \n))"

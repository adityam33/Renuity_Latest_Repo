				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "Select A.MonthYear,\r\nA.Division,\r\nA.YTD_Recordable,\r\nA.YTD_LostTime,\r\nA.YTD_EmployeeHours,\r\nCAST((A.YTD_Recordable * 200000.0) / NULLIF(A.YTD_EmployeeHours, 0) AS DECIMAL(10, 2)) AS TRIR,\r\nCAST((A.YTD_LostTime * 200000.0) / NULLIF(A.YTD_EmployeeHours, 0) AS DECIMAL(10, 2)) AS LTIR,\r\n'2.00' as Target_TRIR,\r\n'0.75' as Target_LTIR\r\nfrom\r\n(Select TRY_CONVERT(DATE, i.MonthYear, 105) as MonthYear,\r\nCASE WHEN i.Division='FHIA' THEN 'FHI'\r\nWHEN i.Division='Home Org (CA/RC)' THEN 'CTA'\r\nWHEN i.Division='Mad City' THEN 'MAC'\r\nWHEN i.Division='Max Home' THEN 'MXH'\r\nWHEN i.Division='Pacific Bath' THEN 'PBC'\r\nWHEN i.Division='Rite Window (North/South)' THEN 'RTW'\r\nWHEN i.Division='Statewide' THEN'SWR'\r\nWHEN i.Division='Renuity Home Base' THEN 'HomeBase' END as Division,\r\nSUM(i.Recordable) OVER (PARTITION BY i.Division ORDER BY TRY_CONVERT(DATE, i.MonthYear, 105)\r\n        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS YTD_Recordable,\r\nSUM(i.LostTime) OVER (PARTITION BY i.Division ORDER BY TRY_CONVERT(DATE, i.MonthYear, 105)\r\n        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS YTD_LostTime,\r\ne.EmployeeHours as YTD_EmployeeHours\r\nfrom ODS.SAFETY_METRICS_INJURY_COUNT i left join ODS.SAFETY_METRICS_EMPLOYEE_HOURS e on TRY_CONVERT(DATE, i.MonthYear, 105)=TRY_CONVERT(DATE, e.MonthYear, 105) \r\nand (CASE WHEN i.Division='FHIA' THEN 'FHI'\r\nWHEN i.Division='Home Org (CA/RC)' THEN 'CTA'\r\nWHEN i.Division='Mad City' THEN 'MAC'\r\nWHEN i.Division='Max Home' THEN 'MXH'\r\nWHEN i.Division='Pacific Bath' THEN 'PBC'\r\nWHEN i.Division='Rite Window (North/South)' THEN 'RTW'\r\nWHEN i.Division='Statewide' THEN'SWR'\r\nWHEN i.Division='Renuity Home Base' THEN 'HomeBase' END)=(CASE WHEN e.Division='FHIA' THEN 'FHI'\r\nWHEN e.Division='Home Org (CA/RC)' THEN 'CTA'\r\nWHEN e.Division='Mad City' THEN 'MAC'\r\nWHEN e.Division='Max Home' THEN 'MXH'\r\nWHEN e.Division='Pacific Bath' THEN 'PBC'\r\nWHEN e.Division='Rite Window (North/South)' THEN 'RTW'\r\nWHEN e.Division='Statewide' THEN'SWR'\r\nWHEN e.Division='Renuity HB' THEN 'HomeBase' END)\r\nwhere TRY_CONVERT(DATE, i.MonthYear, 105)>='2025-01-31' --and i.Division='Statewide'\r\n--Order by TRY_CONVERT(DATE, i.MonthYear, 105),Division\r\n\r\nUNION ALL\r\n\r\nSELECT CAST('2024-12-31' AS DATE) AS MonthDate,\r\nCASE WHEN i.Division='FHIA' THEN 'FHI'\r\nWHEN i.Division='Home Org (CA/RC)' THEN 'CTA'\r\nWHEN i.Division='Mad City' THEN 'MAC'\r\nWHEN i.Division='Max Home' THEN 'MXH'\r\nWHEN i.Division='Pacific Bath' THEN 'PBC'\r\nWHEN i.Division='Rite Window (North/South)' THEN 'RTW'\r\nWHEN i.Division='Statewide' THEN'SWR'\r\nWHEN i.Division='Renuity Home Base' THEN 'HomeBase' END as Division,\r\nSUM(i.Recordable) AS YTD_Recordable,\r\nSUM(i.LostTime) AS YTD_LostTime,\r\nMAX(e.EmployeeHours) AS YTD_EmployeeHours\r\nFROM ODS.SAFETY_METRICS_INJURY_COUNT i left join ODS.SAFETY_METRICS_EMPLOYEE_HOURS e on TRY_CONVERT(DATE, i.MonthYear, 105)=TRY_CONVERT(DATE, e.MonthYear, 105) \r\nand (CASE WHEN i.Division='FHIA' THEN 'FHI'\r\nWHEN i.Division='Home Org (CA/RC)' THEN 'CTA'\r\nWHEN i.Division='Mad City' THEN 'MAC'\r\nWHEN i.Division='Max Home' THEN 'MXH'\r\nWHEN i.Division='Pacific Bath' THEN 'PBC'\r\nWHEN i.Division='Rite Window (North/South)' THEN 'RTW'\r\nWHEN i.Division='Statewide' THEN'SWR'\r\nWHEN i.Division='Renuity Home Base' THEN 'HomeBase' END)=(CASE WHEN e.Division='FHIA' THEN 'FHI'\r\nWHEN e.Division='Home Org (CA/RC)' THEN 'CTA'\r\nWHEN e.Division='Mad City' THEN 'MAC'\r\nWHEN e.Division='Max Home' THEN 'MXH'\r\nWHEN e.Division='Pacific Bath' THEN 'PBC'\r\nWHEN e.Division='Rite Window (North/South)' THEN 'RTW'\r\nWHEN e.Division='Statewide' THEN'SWR'\r\nWHEN e.Division='Renuity HB' THEN 'HomeBase' END)\r\n    WHERE YEAR(TRY_CONVERT(DATE, i.MonthYear, 105)) = 2024\r\n    GROUP BY i.Division) A\r\n",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},

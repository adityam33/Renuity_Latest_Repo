						"sqlReaderQuery": "SELECT\r\n    t.sid,\r\n    c.mid,\r\n    c.conv_id,\r\n    c.user_ns,\r\n    c.flow_ns,\r\n    c.user_id,\r\n    t.from_number,\r\n    t.to_number,\r\n    c.team_id,\r\n    t.body AS sms_body,\r\n    c.content AS chat_content,\r\n    c.payload,\r\n    c.postback,\r\n    c.msg_type,\r\n    c.type AS chat_type,\r\n    c.node_ns,\r\n    t.status AS sms_status,\r\n    c.is_delivered,\r\n    c.is_read,\r\n    t.error_code,\r\n    t.date_sent,\r\n    c.created_ts,\r\n    c.created_ts_date,\r\n    t.date_created,\r\n    t.date_updated,\r\n    t.price,\r\n    t.num_segments,\r\n    t.num_media,\r\n    t.account_sid,\r\n    t.messaging_service_sid,\r\n    CASE \r\n        WHEN t.sid IS NOT NULL AND c.mid IS NOT NULL THEN 'Both'\r\n        WHEN t.sid IS NOT NULL THEN 'Twilio'\r\n        WHEN c.mid IS NOT NULL THEN 'Chat'\r\n        ELSE 'Unknown'\r\n    END AS source_system\r\nFROM ODS.CHANNEL_TWILIO_SMS_LOGS t\r\nFULL OUTER JOIN ODS.CHANNEL_CHAT_MSGS c\r\n    ON t.sid = c.mid\r\n",

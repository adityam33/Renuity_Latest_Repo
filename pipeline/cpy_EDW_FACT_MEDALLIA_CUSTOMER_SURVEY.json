{
	"name": "cpy_EDW_FACT_MEDALLIA_CUSTOMER_SURVEY",
	"properties": {
		"activities": [
			{
				"name": "Copy data Load Medallia EDW",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false

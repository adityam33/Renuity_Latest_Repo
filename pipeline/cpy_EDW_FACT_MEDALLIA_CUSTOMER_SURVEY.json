				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlPoolSource",
						"sqlReaderQuery": "Select B.* from (\nSELECT\nM1.Survey_ID,\nM1.Response_Date,\nM1.Program,\nM1.CustomerID,\nM1.LeadID,\nCASE WHEN M1.Sales_Rep_ID_1 IS NOT NULL THEN CONCAT(M1.Division,'-',M1.Sales_Rep_ID_1) ELSE LD_M.SalesRep1_EmployeeID END AS SalesRep1_EmployeeID,\nLD_M.SalesRep2_EmployeeID,\nLD_M.BranchID,\nLD_M.ApptDate,\nM1.ContractID,\nM1.Division,\nCASE WHEN M1.Service_Technician_ID IS NOT NULL THEN CONCAT(M1.Division,'-',M1.Service_Technician_ID) ELSE M1.InstallerID_1 END AS InstallerID_1,\nM1.InstallerID_2,\nM1.InstallerID_3,\nM1.InstallerID_4,\nM1.Product_Line_InstallationExperience,\nM1.Date_To_Survey,\nM1.Country,\nM1.Language,\nM1.Unit,\nM1.Sold,\nM1.DevelopmentCycle,\nM1.SalesOrganization,\nM1.Record_Type_Medallia_Conversations,\nM1.Main_Metric,\nM1.Service_Datetime,\nM1.Channel,\nM1.Product_Line_InHomeConsultationExperience,\nM1.Social_Unit_ID,\nCASE WHEN M1.On_Site_Quote_Satisfaction_Team_Score in ('NA','N/A') THEN '' ELSE CAST(M1.On_Site_Quote_Satisfaction_Team_Score as INT) END as On_Site_Quote_Satisfaction_Team_Score,\n--M1.Reason_for_Score,\nCAST(M1.Reason_for_Score as VARCHAR(8000)) as Reason_for_Score,\nCASE WHEN M1.Sales_Understanding in ('NA','N/A') THEN '' ELSE CAST(M1.Sales_Understanding as INT) END as Sales_Understanding,\nCASE WHEN M1.Sales_Communication in ('NA','N/A') THEN '' ELSE CAST(M1.Sales_Communication as INT) END as Sales_Communication,\nCASE WHEN M1.Sales_Punctuality in ('NA','N/A') THEN '' ELSE CAST(M1.Sales_Punctuality as INT) END AS Sales_Punctuality,\nCASE WHEN M1.Sales_Professionalism in ('NA','N/A') THEN '' ELSE CAST(M1.Sales_Professionalism as INT) END AS Sales_Professionalism,\nCASE WHEN M1.Sales_Product_Knowledge in ('NA','N/A') THEN '' ELSE CAST(M1.Sales_Product_Knowledge as INT) END AS Sales_Product_Knowledge,\nCASE WHEN M1.Completeness_Of_Information in ('NA','N/A') THEN '' ELSE CAST(M1.Completeness_Of_Information AS INT) END AS Completeness_Of_Information,\nM1.Received_Quote,\nCASE WHEN M1.Satisfaction_With_Quote in ('NA','N/A') THEN '' ELSE CAST(M1.Satisfaction_With_Quote as INT) END AS Satisfaction_With_Quote,\nM1.Quote_Project_Start_Date,\nM1.Product_Demo,\nCASE WHEN M1.Product_Demo_Benefits in ('NA','N/A') THEN '' ELSE CAST(M1.Product_Demo_Benefits as INT) END AS Product_Demo_Benefits,\nM1.Reason_For_Not_Moving_Forward,\nM1.Decided_Against_Other,\n--M1.Final_Comment,\nCAST(M1.Final_Comment as VARCHAR(8000)) as Final_Comment,\nCASE WHEN M1.Service_NPS in ('NA','N/A') THEN '' ELSE CAST(M1.Service_NPS as INT) END AS Service_NPS,\nM1.Reasons_For_Your_Score,\nM1.Give_More_Feedback,\nCASE WHEN M1.In_Home_Sales in ('NA','N/A') THEN '' ELSE CAST(M1.In_Home_Sales as INT) END as In_Home_Sales,\nCASE WHEN M1.Install_Team in ('NA','N/A') THEN '' ELSE CAST(M1.Install_Team as INT) END as Install_Team,\nCASE WHEN M1.Installation in ('NA','N/A') THEN '' ELSE Cast(M1.Installation as INT) END AS Installation,\nCASE WHEN M1.Product_Walkthrough in ('NA','N/A') THEN '' ELSE CAST(M1.Product_Walkthrough as INT) END as Product_Walkthrough,\nCASE WHEN M1.Experience in ('NA','N/A') THEN '' ELSE  CAST(M1.Experience as INT) END as Experience,\nCASE WHEN M1.Satisfaction in ('NA','N/A') THEN '' ELSE CAST(M1.Satisfaction as INT) END as Satisfaction,\nM1.Area_For_Improvement,\nM1.Area_Of_Satisfaction,\nM1.Testimonial,\nM1.Additional_Comments,\nM1.LP_CustomerID,\nM1.LP_LeadID,\nCASE WHEN M1.Sales_Rep_ID_1 is not null then M1.Sales_Rep_ID_1 ELSE LD_M.LP_SalesRep1_EmployeeID END as LP_SalesRepEmployeeID_1,\nLD_M.LP_SalesRep2_EmployeeID as LP_SalesRepEmployeeID_2,\nLD_M.LP_BranchID,\nCASE WHEN M1.Service_Technician_ID is not null then M1.Service_Technician_ID ELSE M1.LP_InstallerID_1 END as LP_InstallerID_1,\nM1.LP_InstallerID_2,\nM1.LP_InstallerID_3,\nM1.LP_InstallerID_4,\nM1.LastUpdatedTs,\nM1.ReportingMarketID,\nM1.LP_ReportingMarketID,\nM1.LP_ReportingMarketTypeID,\nM1.ReportingMarketTypeID,\nLD_M.ProductID,\nLD_M.LP_ProductID,\nM1.Account_ID as Medallia_AccountID,\nM1.Sales_Rep_ID_1 as Medallia_SalesRepID1,\nM1.Service_Technician_ID as Medallia_ServiceTechID1,\nCOALESCE(M1.Active,DE.Active) AS SalesRepActiveFlag,\nROW_NUMBER() OVER (PARTITION BY M1.Survey_ID ORDER BY LD_M.EntryDate DESC) as rownum\nFROM \n(\n\n\t\tSELECT \n\t\t\t\tA.Survey_ID,\n\t\t\t\tA.Response_Date,\n\t\t\t\tA.Program,\n\t\t\t\tCase when A.Lead_ID is not null then LD.CustomerID ELSE COALESCE(LJ_1.CustomerID,LJ_2.CustomerID) END as CustomerID,\n\t\t\t\tCase when A.Lead_ID is not NUll then LD.LeadID ELSE COALESCE(LJ_1.LeadID,LJ_2.LeadID) END as LeadID,\n\t\t\t\tCOALESCE(LJ_1.ContractID,LJ_2.ContractID) AS ContractID,\n\t\t\t\tA.Division,\n\t\t\t\tCOALESCE(LJ_1.InstallerID_1,LJ_2.InstallerID_1) AS InstallerID_1,\n\t\t\t\tCOALESCE(LJ_1.InstallerID_2,LJ_2.InstallerID_2) AS InstallerID_2,\n\t\t\t\tCOALESCE(LJ_1.InstallerID_3,LJ_2.InstallerID_3) AS InstallerID_3,\n\t\t\t\tCOALESCE(LJ_1.InstallerID_4,LJ_2.InstallerID_4) AS InstallerID_4,\n\t\t\t\tA.Product_Line_InstallationExperience,\n\t\t\t\tA.Date_To_Survey,\n\t\t\t\tA.Country,\n\t\t\t\tA.[Language],\n\t\t\t\tA.Unit,\n\t\t\t\tCase when A.Sold='Not Sold' then '0' Else '1' END as Sold,\n\t\t\t\tA.Development_Cycle as DevelopmentCycle,\n\t\t\t\tA.Sales_Organization as SalesOrganization,\n\t\t\t\tA.Record_Type_Medallia_Conversations,\n\t\t\t\tA.Main_Metric,\n\t\t\t\tA.Service_Datetime,\n\t\t\t\tA.Channel,\n\t\t\t\tA.Product_Line_InHomeConsultationExperience,\n                A.Sales_Rep_ID_1,\n                A.Service_Technician_ID,\n\t\t\t\tA.Social_Unit_ID,\n\t\t\t\tA.On_Site_Quote_Satisfaction_Team_Score,\n\t\t\t\tA.Reason_for_Score,\n\t\t\t\tA.Sales_Understanding,\n\t\t\t\ta.Sales_Communication,\n\t\t\t\tA.Sales_Punctuality,\n\t\t\t\tA.Sales_Professionalism,\n\t\t\t\tA.Sales_Product_Knowledge,\n\t\t\t\tA.Completeness_Of_Information,\n\t\t\t\tA.Received_Quote,\n\t\t\t\tA.Satisfaction_With_Quote,\n\t\t\t\tA.Quote_Project_Start_Date,\n\t\t\t\tA.Product_Demo,\n\t\t\t\tA.Product_Demo_Benefits,\n\t\t\t\tA.Reason_For_Not_Moving_Forward,\n\t\t\t\tA.Decided_Against_Other,\n\t\t\t\tA.Final_Comment,\n\t\t\t\tA.Service_NPS,\n\t\t\t\tA.Reasons_For_Your_Score,\n\t\t\t\tA.Give_More_Feedback,\n\t\t\t\tA.In_Home_Sales,\n\t\t\t\tA.Install_Team,\n\t\t\t\tA.Installation,\n\t\t\t\ta.Product_Walkthrough,\n\t\t\t\tA.Experience,\n\t\t\t\tA.Satisfaction,\n\t\t\t\tA.Area_For_Improvement,\n\t\t\t\tA.Area_Of_Satisfaction,\n\t\t\t\tA.Testimonial,\n\t\t\t\tA.Additional_Comments,\n\t\t\t\tCASE WHEN A.Lead_ID is not null then LD.LP_CustomerID ELSE COALESCE(LJ_1.LP_CustomerID,LJ_2.LP_CustomerID) END as LP_CustomerID,\n\t\t\t\tCASE WHEN A.Lead_ID is not NUll then LD.LP_LeadID ELSE COALESCE(LJ_1.LP_LeadID,LJ_2.LP_LeadID) END as LP_LeadID,\n\t\t\t\tCOALESCE(LJ_1.LP_InstallerID_1,LJ_2.LP_InstallerID_1) AS LP_InstallerID_1,\n\t\t\t\tCOALESCE(LJ_1.LP_InstallerID_2,LJ_2.LP_InstallerID_2) AS LP_InstallerID_2,\n\t\t\t\tCOALESCE(LJ_1.LP_InstallerID_3,LJ_2.LP_InstallerID_3) AS LP_InstallerID_3,\n\t\t\t\tCOALESCE(LJ_1.LP_InstallerID_4,LJ_2.LP_InstallerID_4) AS LP_InstallerID_4,\n\t\t\t\tGETDATE() AS LastUpdatedTs,\n\t\t\t\tB.ReportingMarketID,\n\t\t\t\tB.LP_ReportingMarketID,\n\t\t\t\tB.LP_ReportingMarketTypeID,\n\t\t\t\tB.ReportingMarketTypeID,\n                E.Active,\n                A.ACCOUNT_ID\n\t\t\t\t\n\t\t\t\t\n\t\t\tFROM (\t\n\t\t\t\t\tSELECT *,\n\t\t\t\t\t\tCASE \n\t\t\t\t\t\t\tWHEN Brand_name='Mad City Windows & Baths'\tTHEN 'MAC'\n\t\t\t\t\t\t\tWHEN Brand_name='Pacific Bath'\t\t\t\tTHEN 'PBC'\n\t\t\t\t\t\t\tWHEN Brand_name='Statewide Remodeling'\t\tTHEN 'SWR'\n\t\t\t\t\t\t\tWHEN Brand_name='FHIA Remodeling'\t\t\tTHEN 'FHI'\n\t\t\t\t\t\t\tWHEN Brand_name='Max Home'\t\t\t\t\tTHEN 'MXH'\n\t\t\t\t\t\t\tWHEN Brand_name='Rite Window & Door'\t\tTHEN 'RTW'\n\t\t\t\t\t\t\tWHEN Brand_name='Paradise Home Improvement' THEN 'PHI'\n\t\t\t\t\t\t\tWhen Brand_name='Home Smart'\t\t\t\tTHEN 'HSI'\n\t\t\t\t\t\t\tWHEN Brand_name='Renuity'\t\t\t\t\tTHEN 'PHI' \n\t\t\t\t\t\tEND AS Division\n\t\t\t\t\t\tFROM ODS.MEDALLIA_CUSTOMER_SURVEY\n\t\t\t\t\t\t) A\n\t\t\t\n\t\t\tLEFT JOIN EDW.FACT_LEAD LD \tON (A.Lead_ID = LD.LP_LeadID AND A.Division = LD.Division) \n\t\t\t\n\t\t\tLEFT JOIN EDW.FACT_JOB LJ_1 ON (A.Lead_ID = LJ_1.LP_LeadID AND A.Division = LJ_1.Division) \n\t\t\t\n\t\t\tLEFT JOIN EDW.FACT_JOB LJ_2 ON  A.Contract_ID = LJ_2.ContractID AND A.Division = LJ_2.Division\n\t\t\t\n\t\t\t\n\t\t\tLEFT JOIN EDW.DIM_BRANCH B \n\t\t\tON A.Production_branch_name=B.LongName AND A.Division = B.Division\n\t\t\t\n            LEFT JOIN EDW.DIM_EMPLOYEE E\n            ON A.Sales_REP_ID_1=E.LP_EmployeeID and A.Division=E.Division\n\n\t\t\t\n\t\t) M1\n\t\n\tLEFT JOIN  EDW.FACT_LEAD LD_M ON M1.LeadID = LD_M.LeadID\n    LEFT JOIN EDW.DIM_EMPLOYEE DE ON LD_M.SalesRep1_EmployeeID=DE.EmployeeID) B\n    where B.rownum=1",
						"queryTimeout": "02:00:00"
					},

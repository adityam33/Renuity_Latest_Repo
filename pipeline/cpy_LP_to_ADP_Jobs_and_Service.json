							}
						}
					}
				]
			},
			{
				"name": "Jobs_and_Service_ALL_DIV",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT * FROM \n(\nSELECT \n'SERVICE ID' AS ServiceID,\nJSV.LP_JobServiceID AS TicketNumber,\nTRIM(CASE \n        WHEN RIGHT(REPLACE(JOB.ContractID, '-', ''), 1) = '.' \n        THEN LEFT(REPLACE(JOB.ContractID, '-', ''), LEN(REPLACE(JOB.ContractID, '-', '')) - 1) \n        ELSE REPLACE(JOB.ContractID, '-', '') \n\t\tEND) AS JobNumber\t\n\nFROM EDW.FACT_JOB_SERVICE JSV \nJOIN EDW.DIM_CUSTOMER CST ON JSV.CustomerID = CST.CustomerID \nLEFT JOIN EDW.FACT_JOB JOB ON JOB.JobID = JSV.JobID\nWHERE JSV.ScheduledServiceDate >=CAST(GETDATE()-7 AS DATE)\nAND JSV.ScheduledServiceDate <= CAST(DATEADD(DAY,7,GETDATE()) AS DATE)\nAND Job.ContractID!='NEW'\nAND JOB.ContractID NOT LIKE'VACA%'\n) M1\nWHERE JobNumber IS NOT NULL",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "ServiceID",
									"type": "String",
									"physicalType": "varchar"
								},
								"sink": {
									"name": "ServiceID",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "TicketNumber",
									"type": "Int32",
									"physicalType": "int"
								},
								"sink": {
									"name": "TicketNumber",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "JobNumber",
									"type": "String",
									"physicalType": "nvarchar"
								},
								"sink": {
									"name": "JobNumber",
									"type": "String",
									"physicalType": "String"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "EDW_FACT_JOB",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "Jobs_and_Service_ALL_DIV",
						"type": "DatasetReference"
					}
				]
			}

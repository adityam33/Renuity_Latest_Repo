			{
				"name": "Update Leadsourcegroupsourceid",
				"description": "Updates Leadsourceid, sourcegroupid,active fields from LP",
				"type": "Script",
				"dependsOn": [
					{
						"activity": "Taxonomy onetime load",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.06:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "Update [EDW].[DIM_MKTNG_SUB_SOURCE_MAPPING]  set \nLeadSourceGroupID=a.LeadSourceGroupID\n, LeadSourceID=a.LeadSourceID\n, Active=a.active\n,EntryDate=A.EntryDate\nFrom [EDW].[DIM_MKTNG_SUB_SOURCE_MAPPING] t left join (\nselect \nss.Division,\nsg.LeadSourceGroupID,\ns.LeadSourceID,\nss.leadsubsourceid,\nsg.sourcegroup,\nss.sourcecode,\nss.leadsubsource,\nss.active,\nMax(F.EntryDate) As EntryDate\nfrom edw.dim_lead_sub_source ss\nJoin EDW.Fact_Lead F on SS.LeadSubSourceId=F.LeadSubSourceID\nleft join edw.dim_lead_source s on s.leadsourceid=ss.leadsourceid\nleft join edw.dim_lead_source_group sg on s.sourcegroupid=sg.leadsourcegroupid\nGroup By ss.Division,\nsg.LeadSourceGroupID,\ns.LeadSourceID,\nss.leadsubsourceid,\nsg.sourcegroup,\nss.sourcecode,\nss.leadsubsource,\nss.active\n)a\non  t.Division=a.Division and t.leadsubsourceid=a.leadsubsourceid \n"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			}

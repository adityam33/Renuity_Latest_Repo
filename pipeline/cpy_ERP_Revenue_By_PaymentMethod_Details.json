{
	"name": "cpy_ERP_Revenue_By_PaymentMethod_Details",
	"properties": {
		"activities": [
			{
				"name": "ODS to EDW - Rveneue by PaymentMethod Details",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "WITH BaseQuery AS (\r\n    -- This CTE holds the original query's logic plus the line-level calculation\r\n    SELECT \r\n        d.TranType,\r\n        d.ReferenceNbr,\r\n        Concat(d.CashAccount,' - ',d.Description) as CashAccount,\r\n        d.Currency,\r\n        d.Status,\r\n        d.Description_2 as Description,\r\n        d.DepositDate,\r\n        d.FinPeriod,\r\n        d.DocumentRef,\r\n        d.CashDropAccount,\r\n        d.CashDropAmount,\r\n        dd.DocModule,\r\n        dd.DocType as Type,\r\n        p.ReferenceNbr as PaymentReference,\r\n        dd.CashAccount as PaymentCashAccount,\r\n        p.Customer,\r\n        c.CustomerName as AccountName,\r\n        dd.DepositAmount AS DepositAmount,\r\n        p.PaymentMethod,\r\n        p.Status as PaymentStatus,\r\n        p.PaymentRef,\r\n        p.PaymentDate,\r\n        p.Branch,\r\n        p.BranchName,\r\n        -- Calculate ChargeSharePerLine\r\n        ISNULL(\r\n            CAST(d.chargeTotal AS DECIMAL(18, 4)) / \r\n            NULLIF(COUNT(dd.ReferenceNbr) OVER (PARTITION BY d.ReferenceNbr,d.TranType), 0), \r\n            0\r\n        ) AS ChargeSharePerLine,\r\n        -- Calculate the Division field (kept as-is)\r\n        CASE \r\n            WHEN BranchName LIKE '9%' THEN 'BYLT'\r\n            WHEN BranchName LIKE '8%' THEN 'PBC'\r\n            WHEN BranchName LIKE '7%' THEN 'FHIA'\r\n            WHEN BranchName LIKE '03%' THEN 'CTA'\r\n            WHEN BranchName LIKE '6%' AND BranchName != '6008' THEN 'RTW'\r\n            WHEN BranchName LIKE '5%' AND BranchName NOT IN ('5009','5010','5011','5012','5013','5014') THEN 'CTA'\r\n            WHEN BranchName LIKE '4%' AND BranchName != '4014' THEN 'MAC'\r\n            WHEN BranchName LIKE '3%' THEN 'SWR'\r\n            WHEN BranchName LIKE '2%' THEN 'FHIA'\r\n            WHEN BranchName LIKE '1%' THEN 'RTW'\r\n            WHEN BranchName IN ('6008','5009','5010','5011','5012','5013','5014','4014') OR BranchName like 'Renuity%' THEN 'Ren'\r\n        END AS Division\r\n    FROM \r\n        ODS.ERP_CA_DEPOSIT d \r\n        LEFT JOIN ODS.ERP_CA_DEPOSIT_DETAIL dd ON d.ReferenceNbr=dd.ReferenceNbr AND d.TranType=dd.TranType\r\n        LEFT JOIN ODS.ERP_AR_PAYMENT p ON p.ReferenceNbr=dd.ReferenceNbr_2 AND p.Type=dd.DocType\r\n        LEFT JOIN EDW.DIM_ERP_CUSTOMER c ON p.Customer=c.CustomerID\r\n    WHERE \r\n        d.LastModifiedOn>=DATEADD(mm,-12,GETDATE()) --and d.FinPeriod='082025'\r\n)\r\n-- Select from the CTE and apply the final logic\r\nSELECT \r\n    *,\r\n    -- Calculate the Total Amount by grouping\r\n    SUM(DepositAmount - ChargeSharePerLine) OVER (\r\n        PARTITION BY TranType, ReferenceNbr, Status\r\n    ) AS TotalAmount,\r\n    -- Determine Debit/Credit based on the grouped Total Amount\r\n    CASE \r\n        WHEN SUM(DepositAmount - ChargeSharePerLine) OVER (\r\n            PARTITION BY TranType, ReferenceNbr, Status\r\n        ) >= 0 THEN 'Credit'\r\n        ELSE 'Debit'\r\n    END AS Debit_Credit_Indicator\r\nFROM \r\n    BaseQuery;",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},

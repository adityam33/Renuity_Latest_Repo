			{
				"name": "cpy_load_Fact_Five9_Agent_Login_Logout",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "cpy_Agent_Login_Logs_MAC",
						"dependencyConditions": [
							"Succeeded"
						]
					},
					{
						"activity": "cpy_FIVE9_AGENT_TIMEOUT_LOGS_MAC",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.6:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT \n\tCASE WHEN DATA_IDENTIFIER='MAC_NEW_SERVER' THEN 'MAC' ELSE DIVISION END AS DIVISION,\n\tAGENT_NAME,\n\tDATE,\n\tREASON_CODE,\n\tLOGIN_LOGOUT,\n\tTIME,\n\tLASTUPDATEDTS,\n\tCASE WHEN DATA_IDENTIFIER='MAC_NEW_SERVER' THEN 'MAC' ELSE DIVISION END AS DIVISION_ORIG,\n\tDATA_IDENTIFIER\n\tFROM\n\t\t(\n\t\t\tSELECT \n\t\t\tDIVISION,\n\t\t\tCASE \n\t\t\t\tWHEN AGENT_NAME IN ('Michael McKenzie','Micheal Mckenzie') THEN 'Michael McKenzie' \n\t\t\t\tWHEN AGENT_NAME IN ('Schedule Mason') and DIVISION='SWR' THEN 'Mason Schedule'\n\t\t\tELSE AGENT_NAME END AS AGENT_NAME,\n\t\t\tcast(DATE as date) DATE,\n\t\t\tREASON_CODE, \n\t\t\tCAST('NON_PRODUCTIVE' AS VARCHAR(100)) AS LOGIN_LOGOUT,\n\t\t\tcast(CAST (\n\t\t\tRIGHT('00' + CAST( (TOTAL_SECS / 3600) AS VARCHAR(2)), 2) + ':' +\n\t\t\tRIGHT('00' + CAST( ((TOTAL_SECS % 3600) / 60) AS VARCHAR(2)), 2) + ':' +\n\t\t\tRIGHT('00' + CAST( (TOTAL_SECS % 60) AS VARCHAR(2)), 2)\n\t\t\tAS TIME) AS VARCHAR(8)) AS TIME, \n\t\t\tCURRENT_TIMESTAMP AS LASTUPDATEDTS,\n\t\t\tDATA_IDENTIFIER\n\t\t\tFROM (\n\t\t\t\t\tSELECT \n\t\t\t\t\t\t'NA' AS DIVISION,\n\t\t\t\t\t\tAGENT_NAME,\n\t\t\t\t\t\tDATE,\n\t\t\t\t\t\tREASON_CODE,\n\t\t\t\t\t\tAGENT,\n\t\t\t\t\t\tDATA_IDENTIFIER,\n\t\t\t\t\t\tSUM(DATEPART(SS,AGENT_STATE_TIME)+ (DATEPART(MI,AGENT_STATE_TIME)  *60) + (DATEPART(HH,AGENT_STATE_TIME) *3600)) AS TOTAL_SECS \n\t\t\t\t\tFROM  \n\t\t\t\t\t\t(\n\t\t\t\t\t\t\tSELECT \n\t\t\t\t\t\t\tAGENT_NAME,\n\t\t\t\t\t\t\tDATE,\n\t\t\t\t\t\t\tREASON_CODE,\n\t\t\t\t\t\t\tCASE WHEN AGENT_STATE_TIME LIKE '24:%' THEN '23:59:00' ELSE AGENT_STATE_TIME END AS AGENT_STATE_TIME,\n\t\t\t\t\t\t\tAGENT,\n\t\t\t\t\t\t\tDATA_IDENTIFIER\n\t\t\t\t\t\t\tFROM ODS.FIVE9_AGENT_TIMEOUT_LOGS \n\t\t\t\t\t\t\t\t) M1\n\t\t\t\t\tGROUP BY \n\t\t\t\t\tAGENT_NAME,\n\t\t\t\t\tDATE,\n\t\t\t\t\tREASON_CODE,\n\t\t\t\t\tAGENT,\n\t\t\t\t\tDATA_IDENTIFIER\n\t\t\t\t\t\n\t\t\t\t\t)A\n\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t\n\n\t\tUNION ALL\n\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\t\t\t\t\n\t\t\tSELECT \n\t\t\t\tDIVISION,\n\t\t\t\tAGENT_NAME,\n\t\t\t\tDATE,\n\t\t\t\tREASON_CODE,\n\t\t\t\tLOGIN_LOGOUT,\n\t\t\t\tCASE WHEN TIME LIKE '24:%' THEN '23:59:00' ELSE TIME END AS TIME,\n\t\t\t\tLASTUPDATEDTS,\n\t\t\t\tDATA_IDENTIFIER\n\t\t\t\tFROM\n\t\t\t\t(\n\t\t\t\t\tSELECT \n\t\t\t\t\t'NA' AS DIVISION,\n\t\t\t\t\tAGENT_NAME,\n\t\t\t\t\tCAST(DATE as date) DATE, \n\t\t\t\t\t'NA' AS REASON_CODE, \n\t\t\t\t\tCAST('LOGGED_IN' AS VARCHAR(100)) AS LOGIN_LOGOUT, \n\t\t\t\t\tCAST(LOGIN_TIME AS VARCHAR(8)) AS TIME, \n\t\t\t\t\tCURRENT_TIMESTAMP AS LASTUPDATEDTS,\n\t\t\t\t\tAGENT,\n\t\t\t\t\tDATA_IDENTIFIER\t\t\t\t\t\t\n\t\t\t\t\tFROM ODS.FIVE9_AGENT_LOGIN_LOGS\n\t\t\t\t\t\n\t\t\t\t\t) M2\n\t\t\t\t\n\t) A\n\t\t\t\t",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlPoolSink",
						"preCopyScript": {
							"value": "DELETE FROM [EDW].[FACT_FIVE9_AGENT_LOGIN_LOGOUT] WHERE LOGIN_LOGOUT='LOGGED_IN'AND DATA_IDENTIFIER='ALL_DIVISION'\n\tAND DATE IN (SELECT DISTINCT(DATE) FROM [ODS].[FIVE9_AGENT_LOGIN_LOGS] WHERE DATA_IDENTIFIER='ALL_DIVISION');\n\t\nDELETE FROM [EDW].[FACT_FIVE9_AGENT_LOGIN_LOGOUT] WHERE LOGIN_LOGOUT='LOGGED_IN'AND DATA_IDENTIFIER='MAC_NEW_SERVER'\n\tAND DATE IN (SELECT DISTINCT(DATE) FROM [ODS].[FIVE9_AGENT_LOGIN_LOGS] WHERE DATA_IDENTIFIER='MAC_NEW_SERVER');\n\t\nDELETE FROM [EDW].[FACT_FIVE9_AGENT_LOGIN_LOGOUT] WHERE LOGIN_LOGOUT='NON_PRODUCTIVE'AND DATA_IDENTIFIER='ALL_DIVISION'\n\tAND DATE IN (SELECT DISTINCT(DATE) FROM [ODS].[FIVE9_AGENT_TIMEOUT_LOGS] WHERE DATA_IDENTIFIER='ALL_DIVISION');\n\t\nDELETE FROM [EDW].[FACT_FIVE9_AGENT_LOGIN_LOGOUT] WHERE LOGIN_LOGOUT='NON_PRODUCTIVE'AND DATA_IDENTIFIER='MAC_NEW_SERVER'\n\tAND DATE IN (SELECT DISTINCT(DATE) FROM [ODS].[FIVE9_AGENT_TIMEOUT_LOGS] WHERE DATA_IDENTIFIER='MAC_NEW_SERVER');",
							"type": "Expression"
						},
						"writeBehavior": "Insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [

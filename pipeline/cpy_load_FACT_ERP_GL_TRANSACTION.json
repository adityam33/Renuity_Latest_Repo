				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "WITH CTE as\n(\n    SELECT *, row_num = ROW_NUMBER() OVER (\n                PARTITION BY GL_LINE_KEY\n                ORDER BY (SELECT NULL)\n                )\n    FROM [EDW].[FACT_ERP_GL_TRANSACTION]\n    where GL_LINE_KEY in \n    (\n        SELECT [GL_LINE_KEY]\n        FROM [EDW].[FACT_ERP_GL_TRANSACTION]\n        group by \n        [GL_LINE_KEY]\n        having count(1) > 1\n    )\n)\nDELETE FROM cte\nWHERE row_num > 1;"
						}
					]
				}
			}

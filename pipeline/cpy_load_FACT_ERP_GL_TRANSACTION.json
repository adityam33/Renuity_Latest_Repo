				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "delete\nFROM [EDW].[FACT_ERP_GL_TRANSACTION]\nwhere GL_LINE_KEY in \n(\nSELECT [GL_LINE_KEY]\n FROM [EDW].[FACT_ERP_GL_TRANSACTION]\n group by \n [GL_LINE_KEY]\n having count(1) > 1\n )\n and Selected IS NULL\n "
						}
					]
				}

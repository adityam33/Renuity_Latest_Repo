	"name": "cp_instal_revenue_payment_details",
	"properties": {
		"activities": [
			{
				"name": "cp_instal_revenue_detail",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT \n    g.Module,\n    g.BatchNumber,\n    g.ReferenceNumber,\n    g.TransactionDate,\n    g.ProjectID,\n    g.CustomerVendor AS BusinessAccountName,\n    g.TransactionDescription,\n    g.AccountCode,\n    g.SubAccount,\n    g.BranchCode,\n    g.FinPeriodID,\n    g.SourceVendorID,\n    g.MarketingAccountID,\n    g.CreditAmount,\n    g.DebitAmount,\n    g.BalanceAmount,\n    g.Posted,\n    g.Released,\n    g.ServicePeriod,\n    (-1) * (g.DebitAmount - g.CreditAmount) AS Amount,\n\n    CASE \n        WHEN g.BranchCode LIKE '00%' THEN 'Ren'\n        WHEN g.BranchCode LIKE '03%' THEN 'CTA'\n        WHEN g.BranchCode LIKE '1%' THEN 'RTW-N'\n        WHEN g.BranchCode LIKE '2%' THEN 'FHIA'\n        WHEN g.BranchCode LIKE '3%' THEN 'SWR'\n        WHEN g.BranchCode LIKE '4%' THEN 'MAC'\n        WHEN g.BranchCode LIKE '5%' THEN 'CTA'\n        WHEN g.BranchCode LIKE '6%' THEN 'RTW-S'\n        WHEN g.BranchCode LIKE '7%' THEN 'MXH'\n        WHEN g.BranchCode LIKE '8%' THEN 'PBC'\n        WHEN g.BranchCode LIKE '9%' THEN 'Bylte'\n    END AS Division,\n    cs.Description AS Product,\n    CASE WHEN p.PaymentMethod is not null then p.PaymentMethod ELSE 'Not Paid' END as PaymentMethod,\n    EOMONTH(DATEADD(m,-1,CAST(GETDATE() AS DATE))) AS SnapshotDate\nFROM \n    EDW.FACT_ERP_GL_TRANSACTION g\nLEFT JOIN \n    ODS.ERP_SUBACCOUNT_SEGMENT_MASTER cs \n    ON g.ProductID = cs.Value AND cs.SegmentID = 1\nLEFT JOIN \n    (Select Project,PaymentMethod,PaymentDate,ROW_NUMBER() OVER (PARTITION BY Project ORDER BY PaymentDate DESC) AS rn from ODS.ERP_AR_PAYMENT where Type not in ('Refund') AND (PaymentDate is NULL or CAST(PaymentDate AS DATE) >= '2024-01-01')) p \n    ON p.Project = g.ProjectID and rn=1 \n\nWHERE \n    g.AccountCode = '60000'\n    AND CAST(CONCAT(RIGHT(g.FinPeriodID,4),'-',LEFT(g.FinPeriodID,2),'-01') as DATE) >= '2024-09-01'\n    AND CAST(CONCAT(RIGHT(g.FinPeriodID,4),'-',LEFT(g.FinPeriodID,2),'-01') as DATE) < CAST(DATEADD(month, DATEDIFF(month, 0, GETDATE()), 0) as DATE)\n    --AND (p.PaymentDate is NULL or CAST(p.PaymentDate AS DATE) >= '2024-09-01')\n   -- AND CAST(p.PaymentDate AS DATE) <= CAST(GETDATE() AS DATE)\nORDER BY \n    g.FinPeriodID;\n",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",

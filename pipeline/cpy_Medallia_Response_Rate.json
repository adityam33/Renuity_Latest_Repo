				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "With Response_Data AS\r\n(\r\nSELECT \r\n    CAST(B.CreationDate AS DATE) AS ResponseDate, \r\n    COUNT(B.Survey_ID) AS ResponseCount\r\nFROM \r\n    EDW.FACT_Medallia_Customer_survey B\r\nWHERE \r\n    B.Response_Date is not null\r\n    AND \r\n    (    B.Survey_Status IN ('COMPLETED','DELIVERED_AND_REMINDED') or B.Survey_Status is NULL\r\n    )\r\nGROUP BY \r\n    CAST(B.CreationDate AS DATE)\r\n--ORDER BY \r\n    --EOMONTH(CAST(B.CreationDate AS DATE))\r\n),\r\nInvite_Data AS\r\n(\r\nSelect A.CreationDate as ResponseDate,Count(A.Survey_ID) as InvitationsCount \r\nfrom (\r\nSelect CAST(Creation_Date as Date) as CreationDate,Survey_ID from EDW.FACT_Medallia_Customer_survey_Invitations where Survey_Status in ('SURVEY_ENGINE_ONLY','EXCLUDED','DELIVERED','DELIVERED_NO_REMINDER','EXPIRED','DELIVERY_FAILED','DELIVERED_AND_REMINDED')\r\n--and CAST(Creation_Date as DATE) BETWEEN '2024-05-01' and '2024-05-31' \r\nand Survey_ID not in (Select Survey_ID from EDW.FACT_Medallia_Customer_survey)\r\n\r\nUNION\r\n\r\nSelect CAST(CreationDate as Date) as ResponseDate,Survey_ID from EDW.FACT_Medallia_Customer_survey --where CAST(CreationDate as DATE) BETWEEN '2024-05-01' and '2024-05-31'\r\n) A\r\ngroup by A.CreationDate\r\n--order by EOMONTH(A.CreationDate)\r\n\r\n)\r\nSelect A.ResponseDate as Survey_Month,A.ResponseCount as Total_Response_Count,B.InvitationsCount as Total_Survey_Sent_Count,\r\n0 as Survey_Sent_Count_Medallia,\r\n0 as Surevy_Sent_Count_Guild,\r\n0 as Response_Count_Medallia,\r\n0 as Response_Count_Guild,\r\nCAST((A.ResponseCount*100.0/B.InvitationsCount) as Decimal(8,2)) as Response_Rate from\r\nInvite_Data B inner join Response_Data A on B.ResponseDate=A.ResponseDate\r\nOrder by B.ResponseDate",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",
						"preCopyScript": "Truncate table OUT.MEDALLIA_INSTALL_INVITE_RESPONSE_SUMMARY",
						"writeBehavior": "Insert",
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [

			{
				"name": "Applications with LP ids",
				"type": "Script",
				"dependsOn": [
					{
						"activity": "FACT Transactions",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "Truncate table EDW.FACT_FINANCE_APPLICATION;\r\n\r\nWith Applications_Mulitples as \r\n(\r\n\r\nSelect  ProspectId as  ProspectId_Derived, s1.Value as  ProjectNumber_Derived,  A.* from [EDW].[DIM_FINANCE_APPLICATIONS] A \r\nCROSS APPLY STRING_SPLIT(A.ProjectNumbers, '/', 1) s1\r\nWHERE A.ProjectNumbers like '%/%' and  A.ProspectId not like '%/%' \r\n\r\nUnion All \r\n\r\nSelect  s.Value as ProspectId_Derived, ProjectNumbers as  ProjectNumber_Derived,  A.* from [EDW].[DIM_FINANCE_APPLICATIONS] A \r\nCROSS APPLY STRING_SPLIT(A.ProspectId, '/', 1)  s\r\nWHERE A.ProspectId like '%/%' and A.ProjectNumbers not like '%/%'\r\n\r\nUnion All\r\n\r\nSelect  s.Value as ProspectId_Derived, s1.Value as  ProjectNumber_Derived, A.* from [EDW].[DIM_FINANCE_APPLICATIONS] A \r\nCROSS APPLY STRING_SPLIT(A.ProspectId, '/', 1)  s\r\nCROSS APPLY STRING_SPLIT(A.ProjectNumbers, '/', 1) s1\r\nWHERE A.ProjectNumbers like '%/%' and A.ProspectId like '%/%' and s.ordinal = s1.ordinal\r\n\r\n),\r\n\r\nApplications as  (\r\n--Select * from (\r\nSelect * from Applications_Mulitples \r\nUnion All \r\nSelect ProspectId as ProspectId_Derived, ProjectNumbers as  ProjectNumber_Derived, *\r\nfrom [EDW].[DIM_FINANCE_APPLICATIONS] A \r\nwhere applicationId not in ( Select Distinct ApplicationId from Applications_Mulitples ) \r\n--) a where applicationId in ( Select ApplicationId from EDW.FACT_FInance_Application Group by ApplicationId having count(*)>1)\r\n),\r\n\r\nApplications_withLP as (\r\nSelect  \r\nA.ApplicationId, A.ProjectNumbers, A.ProspectId, \r\nA.ProjectAmount, A.Lender, A.LenderStatus, A.SubmittedAt, A.LenderlastupdatedAt,\r\nL.LeadId, L.CustomerId, L.Entrydate, L.ProductId, L.BranchId, L.LeadsubsourceId, L.SalesRep1_EmployeeId,\r\nL.EverSet, L.EverNetIssued, L.EverSat,\r\nJ.JobId, J.ContractId, J.ContractDate, J.GrossAmount, J.productId as J_productId, J.ProductionBranchId, J.SalesRep1_EmployeeId as J_SalesRep1_EmployeeId,\r\nJ.FinanceSourceId, J.FinanceCompanyId,\r\nJ.FundedAmount, J.FinanceAmount, J.FinanceFee,\r\nJ.JobStatusId, JS.JobStatusCategoryId, JS.JobStatus, UNI_jobStatus, Uni_jobstatuscategory, Uni_JobstatusSubCategory,\r\ncase when \r\n\t ( Case when A.ProjectNumber_Derived='' then 'NA' else A.ProjectNumber_Derived end = J.ContractID\t\r\n   --Or  Cast(A.SubmittedAt as date) between cast(J.contractDate as date) and cast(dateadd(Day, 1,J.contractDate) as date)  \r\n   --Or  Cast(A.SubmittedAt as date) between cast(L.Entrydate as date) and cast(dateadd(Month, 1,L.Entrydate) as date)  \r\n\t)\r\n\t then 1 else 0 end as flag\r\n,ProjectNumber_Derived as ContractID_1look, ProspectId_Derived as LPCustomerID_1look\r\n\r\nfrom Applications A \r\nleft join EDW.FACT_lead L on L.division='MAC' and Coalesce(Nullif(A.ProspectId_Derived,''),'NA')=cast(L.LP_CustomerId as varchar(32))\r\nLeft join EDW.FACT_Job J on L.LeadId=J.LeadId\r\nLeft join EDW.DIM_Job_Status JS on J.JobStatusId=JS.JobStatusId\r\nwhere  ( A.ProspectId  like '%/%'  or TRY_CAST(A.ProspectId AS FLOAT) IS not NULL )\r\n)\r\n\r\nInsert into EDW.FACT_FINANCE_APPLICATION\r\nselect *\r\nfrom (\r\nSelect *  from Applications_withLP where Flag=1\r\nUnion \r\nSelect * from Applications_withLP where  Flag=0 and ApplicationId not in (Select distinct ApplicationId from Applications_withLP where Flag=1) \r\n)a ;\r\n\r\n\r\n "
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			},
			{
				"name": "Update Isduplicate Flag",
				"type": "Script",
				"dependsOn": [
					{
						"activity": "Applications with LP ids",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "with A As (\nselect  Row_number() over(partition by ProspectId Order by submittedAt desc) as RN, *  from EDW.DIM_FINANCE_Applications where\nProspectId<>'' and \nprospectId in (Select ProspectId  from EDW.DIM_FINANCE_Applications group by prospectId having count(*)>1)\n)\n--Select T1.*, Rn\nUpdate T1 set IsDuplicate =1 \nfrom EDW.DIM_FINANCE_Applications T1 join A on T1.ApplicationId=A.ApplicationId and A.RN>1\n"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			}

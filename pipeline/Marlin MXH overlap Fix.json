			{
				"name": "Fact_Summ_AD_Performance_Metrics",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "Campaign Taxonomy mapping",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.2:30:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"additionalColumns": [
							{
								"name": "LastUpdateTS",
								"value": {
									"value": "@utcNow()",
									"type": "Expression"
								}
							}
						],
						"sqlReaderQuery": "With AD_Performance As (\n\tSelect \n\tConcat(TrafficSource,Replace(DataSourceName,'Statewide Bath - Swish ','Statewide Bath - Swish'), Campaign,LP_market) as CampaignKey,\n\tCast(PerformanceDate as Date) as PerformanceDate, TrafficSource, Account, DatasourceName, Campaign, Adgroup, Ad, \n\tCampaignId, AdgroupId, AdId,\n\tMarket, LP_Market, Division,\n\tSum(cost) As Cost, \n\tSum(Clicks) as Clicks,\n\tSum(Impressions) as Impressions, \n\tSum(Conversions) as Conversions\n\tfrom EDW.FACT_AD_Performance_Metrics\n\t\n\twhere cast(LastUpdateTS as date) >= cast(Dateadd(D, -7, Getdate()) as date) -- refreshing the data which has updated in last 7 days\n\n\tGroup by \n\tConcat(TrafficSource,DataSourceName, Campaign,LP_market) ,\n\tCast(PerformanceDate as Date), TrafficSource, Account, DatasourceName, Campaign, Adgroup, Ad, \n\tCampaignId, AdgroupId, AdId,\n\tMarket, LP_Market, Division\n)\n\n--Select Eomonth(PerformanceDate), DataSourceName,Campaign, Sum(Cost), sum(Adjusted_Cost) from (\nSelect F.*,\nCM.Reporting_Division, CM.LeadSubsourceId, CM.BranchId, CM.ProductId as ProductId, \n\nCoalesce(CM.StaticPercentage,100) as StaticPercentage, CM.MappingInd,\n\nF.Cost * Cast((Coalesce(CM.StaticPercentage,100)/100.0) as float) As Adjusted_Cost,\nF.Clicks * Cast((Coalesce(CM.StaticPercentage,100)/100.0) as float) As Adjusted_Clicks,\nF.Impressions * Cast((Coalesce(CM.StaticPercentage,100)/100.0) as float) As Adjusted_Impressions,\nF.Conversions * Cast((Coalesce(CM.StaticPercentage,100)/100.0) as float) As Adjusted_Conversions\n\nfrom AD_Performance F \n\nLeft join EDW.[DIM_MKTNG_CAMPAIGN_MAPPING_NoProductSpend] CM on F.CampaignKey=CM.CampaignKey\n--where Cast(PerformanceDate as date)='2025-11-04' --and F.Campaign='Brand | Google Structure | All Markets' \n\n--)a Group by Eomonth(PerformanceDate), DataSourceName,Campaign\n--Order by 3\n\n\n--Order by  F.Campaign, F.Market",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",
						"preCopyScript": "Delete  T1\n--Select Distinct T1.TrafficSource, Eomonth(T1.PerformanceDate) \nfrom EDW.FACT_SUMM_AD_PERFORMANCE_METRICS T1\n join \n(\n\tSelect S.TrafficSource,S.PerformanceDate from \n\t(Select Distinct  TrafficSource,PerformanceDate, CampaignKey from EDW.FACT_SUMM_AD_PERFORMANCE_METRICS \n\t  ) S\n\tLeft join \n\t(Select Distinct  TrafficSource,cast(PERFORMANCEDATE as date) as PerformanceDate, Concat(TrafficSource,DatasourceName,Campaign,LP_Market)as CampaignKey\n\tfrom EDW.FACT_AD_PERFORMANCE_METRICS \n\tWhere cast(LastUpdateTs as date)>= Dateadd(D,-7,Getdate())  \n         ) F \n\tOn S.PerformanceDate=F.PerformanceDate and S.CampaignKey =F.CampaignKey\n\tWhere F.TrafficSource is not null and F.PerformanceDate is not null --Order by 1,2\n\t\n)T2  on T1.TrafficSource=T2.Trafficsource and T1.PerformanceDate =T2.PerformanceDate",
						"writeBehavior": "Insert",
						"disableMetricsCollection": false
					},

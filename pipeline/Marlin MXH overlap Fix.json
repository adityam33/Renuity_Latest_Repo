				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "With FACT_AD_Performance_Metrics As ( \n\tSelect Distinct 'Funnel' as Source,\n\tConcat(F.TrafficSource,Trim(F.DataSourceName),F.Campaign,F.LP_Market) as CampaignKey,\n\tF.TrafficSource, F.Account, F.DatasourceName, F.Campaign,F.LP_Market as Market, F.Division,\n\t\n\tCase \n\t\tWhen F.Division='SWR' then 'B.Statewide' \n\t\tWhen F.Division='RTW' then 'H.Rite Window' \n\t\tWhen F.Division='PBC' then 'G.West Division' \n\t\tWhen F.Division='FHI' then 'A.East Division' \n\t\tWhen F.Division='MAC' then 'C.Mad City' \n\t\tWhen F.Division='CTA' then 'I.Home Org' \n\t\tWhen F.Division='REN' then '0.Renuity'\n\tEND  As Reporting_Division,\n\t\n\tF.LP_LeadsubsourceID  as LeadSubsourceId,\n\tF.LP_BranchID as BranchId,\n\tCoalesce(SP.ProductId, F.LP_ProductID) as ProductId,\n\t\n\tCase when (F.Division is not null and F.LP_LeadsubsourceID is not null and F.LP_BranchID is not null and F.LP_ProductID is not null ) then 'MAP' else 'UNMAP' end  AS MappingInd,\n\t\n\tGetdate() as CreatedTs,\n\tgetdate() as LastUpdatedTs,\n\t'DataTeam' as CreatedBy,\n\t\n\tcase when F.TrafficSource='Google' and ( F.Division in ('MAC','SWR','RTW') or F.DataSourceName like '%Max%' or F.Campaign like '%MXH%' or F.Campaign like '%MAX%')  and F.Campaign like '%Brand%' and Replace(F.Campaign,' ','') not like '%NonBrand%' then \n\t\tCONVERT(VARCHAR(64), HashBytes('SHA2_256',TRIM(Upper(Concat(F.TrafficSource,Trim(F.DataSourceName),F.Campaign,F.LP_Market,SP.ProductId)))), 2)\n\telse CONVERT(VARCHAR(64), HashBytes('SHA2_256',TRIM(Upper(Concat(F.TrafficSource,Trim(F.DataSourceName),F.Campaign,F.LP_Market)))), 2) end as Hashed_CampaignKey,\n\t\n\tCoalesce(SP.StaticPercentage,100) as StaticPercentage\n\t\n\t--CM.CampaignKey,\n\t--SP.Hashed_CampaignKey,\n\t--SP.StaticPercentage,\n\t--SP.ProductId\n\n\tFROM EDW.FACT_ad_performance_Metrics  F\n\t\n\tLeft join EDW.DIM_MKTNG_CAMPAIGN_SPEND_SPLIT SP\n\ton F.TrafficSource=SP.TrafficSource and F.DatasourceName=SP.DatasourceName and F.campaign=SP.campaign and F.LP_Market=SP.Market\n\t-- For brand campaigns to get the % and productIds\n\t\n\twhere F.Account<>'LSA - Mad City Windows - Madison Local Services'\n)\n\nSelect F.*\nFrom FACT_AD_Performance_Metrics F\nLeft join EDW.DIM_MKTNG_CAMPAIGN_MAPPING_NoProductSpend CM  On F.Hashed_CampaignKey  = CM.Hashed_CampaignKey\n --For Incremental load\n\nwhere CM.CampaignKey is NULL\n\n\n--Order by 3,4,6,7\n",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},

				"typeProperties": {
					"source": {
						"type": "SqlDWSource",
						"sqlReaderQuery": "select t1.* from \n (select FinPeriod,customer as customerid, branch as branchcode, companyid,\ncase when type in ('Credit Memo','Invoice','Credit WO','Debit Memo') then Invoice_projectID else Payment_projectid end as ProjectID,\ntype as DocumentType,Referencenbr as ReferenceNumber,Date as Documentdate, Duedate,status, DocumentBalance,\ncase when datediff(d,date,getdate()) =0 then DocumentBalance else 0 end as 'current',\ncase when datediff(d,date,getdate()) between 1 and 30 then DocumentBalance else 0 end as '1to30Days',\ncase when datediff(d,date,getdate()) between 31 and 60 then DocumentBalance else 0 end as '31to60Days',\ncase when datediff(d,date,getdate()) between 61 and 90  then DocumentBalance else 0 end as '61to90Days',\ncase when datediff(d,date,getdate()) >= 91   then DocumentBalance else 0 end as 'Over90Days'\nfrom (\nselect  format(r.date, 'MM-yyyy') as FinPeriod,r.customer,r.branch,b.companyid,\ni.projectid as Invoice_ProjectID,p.project as Payment_projectID,\nr.type,r.referencenbr,r.date,r.duedate,r.status,\ncase when r.type in('Credit Memo','Payment','Prepayment') then (-1 *ARRegister_docBal) else ARRegister_docBal end DocumentBalance, r.closeddate\nfrom ods.erp_Ar_register r \nleft join ods.erp_ar_invoice i on r.referencenbr=i.referencenbr and r.type=i.type\nleft join ods.erp_ar_payment p on r.referencenbr=p.referencenbr and r.type=p.type\nleft join ods.erp_branch_master b on r.branch=b.branchcode\nwhere r.date>='2023-01-01' and \n((Eomonth(i.createdon) >= Eomonth(dateadd(m,-2,getdate()))  or  Eomonth(i.Lastmodifiedon) >= Eomonth(dateadd(m,-2,getdate())) ) \n or (Eomonth(p.createdon) >= Eomonth(dateadd(m,-2,getdate())) or   Eomonth(p.Lastmodifiedon) >= Eomonth(dateadd(m,-2,getdate()))  ) \n ) and  r.status in ('Open','Reserved','Closed','Voided') \n and format(r.date, 'MM-yyyy') not in ('01-8023','05-2032','06-2222','08-3022','11-7021')\n) a )t1 \nLeft join edw.fact_ar_aged_period ar on \nt1.finperiod=ar.finperiod and \nt1.documentdate=ar.documentdate and \nt1.documenttype=ar.documenttype and \nt1.referencenumber=ar.referencenumber\nwhere ar.documentdate is null and ar.documenttype is null and ar.referencenumber is null ",
						"queryTimeout": "00:15:00",
						"partitionOption": "None"

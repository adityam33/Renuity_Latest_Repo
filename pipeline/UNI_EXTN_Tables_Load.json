						"sqlReaderQuery": "SELECT \nBR.BranchID,\nBR.Division,\nBR.LongName AS BranchName,\nBR.ShortName,\nBR.MediumName,\nNULL AS UNI_Market,\nNULL AS UNI_MarketGroup,\nNULL AS UNI_MarketRegion,\nNULL AS ACU_ID,\nNULL AS ACU_Market,\nNULL AS OrganicVsNonOrganic,\nNULL AS TypeOfMarket,\nNULL AS District,\nNULL AS State,\nNULL AS Region,\n'NEW' AS MappingInd,\nGETDATE() AS CreatedTS,\nGETDATE() AS LastUpdatedTS,\nCASE \nWHEN BR.Division='FHI' \t\t\t\t\t\t\t\t\t\t\t\t\tTHEN 'A.FHIA'\nWHEN BR.Division='SWR' \t\t\t\t\t\t\t\t\t\t\t\t\tTHEN 'B.Statewide'\nWHEN BR.Division='RTW' \t\t\t\t\t\t\t\t\t\t\t\t\tTHEN 'H.Rite Window'\nWHEN BR.Division='MXH' \t\t\t\t\t\t\t\t\t\t\t\t\tTHEN 'F.Max Home'\nWHEN BR.Division='HSI' \t\t\t\t\t\t\t\t\t\t\t\t\tTHEN 'E.Home Smart'\nWHEN BR.Division='PBC' AND BR.LongName \t\tLIKE '%Gtr%' \t\t\t\tTHEN 'G.Pacific Gutter'\nWHEN BR.Division='PBC' AND BR.LongName NOT \tLIKE '%Gtr%'  \t\t\t\tTHEN 'G.West Division'\nWHEN BR.Division IN ('CTA','PHI','MAC') AND BR.LongName LIKE '%Garage%' THEN 'I.Garage Coating'\nWHEN BR.Division='CTA' AND BR.LongName NOT LIKE '%Garage%'  \t\t\tTHEN 'J.Closet America'\nWHEN BR.Division='PHI' AND BR.LongName NOT LIKE '%Garage%'  \t\t\tTHEN 'D.Paradise'\nWHEN BR.Division='MAC' AND BR.LongName NOT LIKE '%Garage%'  \t\t\tTHEN 'C.Mad City'\nEND  AS Division_MKTG\n\nFROM EDW.DIM_BRANCH BR \nLEFT JOIN EDW_DUN.DIM_BRANCH_EXTN BEX \nON BR.BranchID = BEX.BranchID\nWHERE BEX.BranchID IS NULL",

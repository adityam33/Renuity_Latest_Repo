				"userProperties": [],
				"linkedServiceName": {
					"referenceName": "RDC",
					"type": "LinkedServiceReference"
				},
				"typeProperties": {
					"scripts": [
						{
							"type": "Query",
							"text": "INSERT INTO EDW_DUN.DIM_BRANCH_EXTN\n(BranchID\t,Division\t,Division_MKTG\t,BranchName\t,ShortName\t,MediumName\t,\nUNI_Market\t,UNI_MarketGroup\t,UNI_MarketRegion\t,ACU_ID\t,ACU_Market\t,OrganicVsNonOrganic\t,\nTypeOfMarket\t,District\t,State\t,Region\t,MappingInd\t,CreatedTS\t,LastUpdatedTS\t,Division_MKTG_Old\t\n)\n\nSELECT \nA.BranchID,A.Market,A.Division AS Division_MKTG,A.BranchName,A.ShortName,\nA.MediumName,A.Market_OpCo_Reporting,A.MarketGroup,A.MarketRegion,A.ACU_ID,\nA.ACU_Market,A.Organic_vs_New,A.TypeOfMarket,A.District,A.State,A.Region,\n'MAPPED',GETDATE() AS CreatedTS,GETDATE() AS LastUpadtedTS,A.Division\nFROM  [RDM].[REF_MKTNG_MARKET_GROUP]  A\nLEFT JOIN EDW_DUN.DIM_BRANCH_EXTN B\nON A.BranchID = B.BranchID\nWHERE B.BranchID IS NULL;\n\n\n\n\nUPDATE A\nSET \nA.ShortName=B.ShortName,\nA.UNI_Market =B.Market_OpCo_Reporting ,\nA.UNI_MarketGroup = B.MarketGroup,\nA.UNI_MarketRegion = B.MarketRegion,\nA.ACU_ID = B.ACU_ID,\nA.ACU_Market = B.ACU_Market,\nA.OrganicVsNonOrganic = B.Organic_vs_New,\nA.TypeOfMarket = B.TypeOfMarket,\nA.District = B.District,\nA.State = B.State,\nA.Region = B.Region\n--A.DIvision_MKTG = B.Division\nFROM [EDW_DUN].[DIM_BRANCH_EXTN] A \nJOIN [RDM].[REF_MKTNG_MARKET_GROUP] B\nON A.BranchID = B.BranchID;\n\n\nUPDATE [EDW_DUN].[DIM_BRANCH_EXTN]\nSET Division_MKTG = 'I.Home Org'\nWHERE (Division_MKTG like '%Closet%' OR  Division_MKTG like '%Garage%') ;"
						}
					],
					"scriptBlockExecutionTimeout": "02:00:00"
				}
			},
			{
				"name": "DIM_BRANCH_EXTN_Load",
				"type": "Copy",
				"dependsOn": [],
				"policy": {

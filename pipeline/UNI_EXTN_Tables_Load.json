						"sqlReaderQuery": "SELECT \nREF.TablePK_EDW AS ProductID,\nPR.ProductGroupID,\nPR.Division,\nPR.ProductName,\nPR.LongDescription AS ProductDescription,\nPG.ProductGroup,\nREF.UnifiedValue AS UNI_ProductName,\nREF.UnifiedValue_Group AS UNI_ProductGroup,\nPEX.ACU_ProductID,\nPEX.ACU_Product,\nCOALESCE(PEX.MappingInd,'NEW') AS MappingInd,\nGETDATE() AS CreatedTS,\nGETDATE() AS LastUpdatedTS\nFROM [EDW_DUN].[UNI_REF_MAPPING] REF\nJOIN EDW.DIM_PRODUCT PR ON REF.TablePK_EDW = PR.ProductID\nLEFT JOIN EDW.DIM_PRODUCT_GROUP PG ON PR.ProductGroupID = PG.ProductGroupID\nLEFT JOIN EDW_DUN.[DIM_PRODUCT_EXTN] PEX ON REF.TablePK_EDW = PEX.ProductID\nWHERE REF.TableName='DIM_PRODUCT'\nAND REF.MappingInd !='UNMAPPED'\nAND (CAST(REF.CreatedTs AS DATE)>=CAST(GETDATE()-5 AS DATE) OR CAST(REF.LastUpdatedTS AS DATE)>=CAST(GETDATE()-5 AS DATE))",

						"sqlReaderQuery": "SELECT REF.TablePK_EDW AS BranchID,\nBR.Division,\nBR.LongName AS BranchName,\nBR.ShortName,\nBR.MediumName,\nREF.UnifiedValue AS UNI_Market,\nREF.UnifiedValue_Group AS UNI_MarketGroup,\nREF.UnifiedValue_Category AS UNI_MarketRegion,\nBEX.ACU_ID,\nBEX.ACU_Market,\nBEX.OrganicVsNonOrganic,\nBEX.TypeOfMarket,\nBEX.District,\nBEX.State,\nBEX.Region,\nCOALESCE(BEX.MappingInd,'NEW') AS MappingInd,\nGETDATE() AS CreatedTS,\nGETDATE() AS LastUpdatedTS,\nCASE \n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='FHI' THEN 'A.FHIA'\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='SWR' THEN 'B.Statewide'\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='RTW' THEN 'H.Rite Window'\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='MXH' THEN 'F.Max Home'\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='HSI' THEN 'E.Home Smart'\n\t\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='PBC' AND BR.LongName like '%Gtr%'  \t \t\tTHEN 'G.Pacific Gutter'\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='PBC' AND BR.LongName NOT like '%Gtr%'  \t  \tTHEN 'G.Pacific Bath'\n\t\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division IN ('CTA','PHI','MAC') AND BR.LongName like '%Garage%' THEN 'I.Garage Coating'\n\t\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='CTA' AND BR.LongName NOT like '%Garage%'  THEN 'J.Closet America'\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='PHI' AND BR.LongName NOT like '%Garage%'  THEN 'D.Paradise'\n\tWHEN BEX.Division_MKTG IS NULL AND BR.Division='MAC' AND BR.LongName NOT like '%Garage%'  THEN 'C.Mad City'\n\t\n\tELSE BEX.Division_MKTG END AS Division_MKTG\n\t\n\nFROM [EDW_DUN].[UNI_REF_MAPPING] REF\nJOIN EDW.DIM_BRANCH BR ON REF.TablePK_EDW = BR.BranchID\nLEFT JOIN EDW_DUN.DIM_BRANCH_EXTN BEX ON REF.TablePK_EDW = BEX.BranchID\nWHERE REF.TableName='DIM_BRANCH'\nAND REF.MappingInd !='UNMAPPED'\nAND (CAST(REF.CreatedTs AS DATE)>=CAST(GETDATE()-10 AS DATE) OR CAST(REF.LastUpdatedTS AS DATE)>=CAST(GETDATE()-10 AS DATE))",

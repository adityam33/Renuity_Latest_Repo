{
	"name": "cpy_load_SUMM_FACT_PROMOTER_PERFORMANCE",
	"properties": {
		"activities": [
			{
				"name": "Load Sales Rep Level Performance into Summary Fact",
				"type": "Copy",
				"dependsOn": [],
				"policy": {

						"partitionOption": "None"
					},
					"sink": {
						"type": "SqlDWSink",
						"preCopyScript": "IF OBJECT_ID('EDW.SUMM_FACT_PROMOTER_PERFORMANCE')  IS NOT NULL TRUNCATE TABLE EDW.SUMM_FACT_PROMOTER_PERFORMANCE",
						"writeBehavior": "Insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "Division",
									"type": "String",
									"physicalType": "nvarchar"
								},

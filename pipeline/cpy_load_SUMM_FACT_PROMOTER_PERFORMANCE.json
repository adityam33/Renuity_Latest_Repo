						"type": "SqlDWSource",
						"sqlReaderQuery": "SELECT\n[Division]\n,[PromoterID]\n,count([LeadID]) as LeadCount\n,min([EntryDate]) as EarliestLeadEntryDate\n FROM [EDW].[FACT_LEAD]\n where \n LP_PromoterID is not null\n group by \n[Division]\n,[PromoterID]",
